; fourth-walker-emit.fk — m4c of fourth-kernel.form: the emitter walks the
; program tree and emits the WALKER's native source, probe included.
;
; M1's emitter (fourth-kernel-emit.fk) hand-shaped its program text; this one
; READS the program — a fourth-walker.fk cell tree, through the observe door —
; and serializes it into a C node table beside a generic walk function. The
; program stays data even in C: the walker text is program-independent, only
; the table and the root index vary. That is the fourth sibling's shape — a
; walker, not a per-program compiler.
;
; The probe is emitted WITH the walker (the sibling-gate of the measurement
; protocol: a carrier without a probe door is not yet a sibling): fk_arms[]
; counts every dispatch by tag, and main prints the result followed by the
; seven arm counts — the binary is born observable, line 1 the value,
; lines 2..8 the trace.
;
; Flattening: post-order over the cells; a node's row is (tag, a, b, c) with
; child indices into the table; the root is the last row. cons builds the
; row list newest-first; emission walks tail-first so index 0 prints first.

(defn fkc-flat (n acc)
    (if (eq (fk-tag n) 1) (cons (list 1 (ms-value (fk-body n)) 0 0) acc)
    (if (eq (fk-tag n) 2) (cons (list 2 0 0 0) acc)
    (if (eq (fk-tag n) 7) (fkc-un2 7 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 9) (fkc-un2 9 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 14) (fkc-un2 14 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 17) (fkc-un2 17 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 15) (cons (list 15 0 0 0) acc)
    (if (eq (fk-tag n) 16) (cons (list 16 0 0 0) acc)
    (if (eq (fk-tag n) 18) (cons (list 18 0 0 0) acc)
    (if (eq (fk-tag n) 20) (fkc-un2 20 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 21) (fkc-un2 21 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 22) (fkc-un2 22 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 12) (fkc-call2 (ms-value (ms-child (fk-body n) 0)) (fkc-flat (ms-child (fk-body n) 1) acc))
    (if (eq (fk-tag n) 6) (fkc-if2 (fkc-flat (ms-child (fk-body n) 0) acc) n)
        (fkc-bin2 (fk-tag n) (fkc-flat (ms-child (fk-body n) 0) acc) n))))))))))))))))

(defn fkc-call2 (fidx acc1) (cons (list 12 fidx (sub (len acc1) 1) 0) acc1))

(defn fkc-un2 (tag acc1) (cons (list tag (sub (len acc1) 1) 0 0) acc1))

(defn fkc-bin2 (tag acc1 n) (fkc-bin3 tag (sub (len acc1) 1) (fkc-flat (ms-child (fk-body n) 1) acc1)))
(defn fkc-bin3 (tag ia acc2) (cons (list tag ia (sub (len acc2) 1) 0) acc2))

(defn fkc-if2 (acc1 n) (fkc-if3 acc1 (sub (len acc1) 1) n))
(defn fkc-if3 (acc1 ic n) (fkc-if4 (fkc-flat (ms-child (ms-child (fk-body n) 1) 0) acc1) ic n))
(defn fkc-if4 (acc2 ic n) (fkc-if5 acc2 (sub (len acc2) 1) ic n))
(defn fkc-if5 (acc2 it ic n) (fkc-if6 (fkc-flat (ms-child (ms-child (fk-body n) 1) 1) acc2) it ic))
(defn fkc-if6 (acc3 it ic) (cons (list 6 ic it (sub (len acc3) 1)) acc3))

(defn fkc-flatten (prog) (fkc-flat prog (empty)))

(defn fkc-row-text (r)
    (str_concat "{"
    (str_concat (int_to_str (nth r 0))
    (str_concat ","
    (str_concat (int_to_str (nth r 1))
    (str_concat ","
    (str_concat (int_to_str (nth r 2))
    (str_concat ","
    (str_concat (int_to_str (nth r 3)) "},")))))))))

(defn fkc-rows-text (rows)
    (if (eq (len rows) 1) (fkc-row-text (head rows))
        (str_concat (fkc-rows-text (tail rows)) (fkc-row-text (head rows)))))

(defn fkc-pr-text ()
    "extern int putchar(int); static void fk_pr(long long v) { char b[32]; int n = 0; if (v < 0) { putchar(45); v = 0 - v; } if (v == 0) { putchar(48); } while (v > 0) { b[n] = 48 + v % 10; v = v / 10; n = n + 1; } while (n > 0) { n = n - 1; putchar(b[n]); } putchar(10); } static void fk_pv(long long v) { if ((v & 1) == 0) { fk_pr(v >> 1); } else { fk_pr(v); } } ")

(defn fkc-decl-text (rows)
    (str_concat "static long long fk_arms[12]; static const long long fk_node["
    (str_concat (int_to_str (len rows))
    (str_concat "][4] = { "
    (str_concat (fkc-rows-text rows) " }; ")))))

(defn fkc-walk-text (root)
    (str_concat "static long long fk_walk(long long i, long long a) { long long t = fk_node[i][0]; fk_arms[t] = fk_arms[t] + 1; if (t == 1) { return fk_node[i][1]; } if (t == 2) { return a; } if (t == 3) { return fk_walk(fk_node[i][1], a) + fk_walk(fk_node[i][2], a); } if (t == 4) { return fk_walk(fk_node[i][1], a) - fk_walk(fk_node[i][2], a); } if (t == 5) { if (fk_walk(fk_node[i][1], a) <= fk_walk(fk_node[i][2], a)) { return 1; } return 0; } if (t == 6) { if (fk_walk(fk_node[i][1], a) == 0) { return fk_walk(fk_node[i][3], a); } return fk_walk(fk_node[i][2], a); } if (t == 7) { return fk_walk("
    (str_concat (int_to_str root)
                ", fk_walk(fk_node[i][1], a)); } if (t == 8) { return fk_node[fk_walk(fk_node[i][1], a)][fk_walk(fk_node[i][2], a)]; } if (t == 9) { putchar((int)fk_walk(fk_node[i][1], a)); return 0; } if (t == 10) { return fk_walk(fk_node[i][1], a) / fk_walk(fk_node[i][2], a); } if (t == 11) { return fk_walk(fk_node[i][1], a) % fk_walk(fk_node[i][2], a); } return 0; } ")))

(defn fkc-main-text (root)
    (str_concat "extern int atoi(const char *); int main(int argc, char **argv) { long long a = 0; if (argc > 1) { a = atoi(argv[1]); } fk_pr(fk_walk("
    (str_concat (int_to_str root)
                ", a)); long long t = 1; while (t <= 11) { fk_pr(fk_arms[t]); t = t + 1; } return 0; }")))

(defn fkc-emit2 (rows)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-text rows)
    (str_concat (fkc-walk-text (sub (len rows) 1))
                (fkc-main-text (sub (len rows) 1))))))

(defn fkc-emit (prog) (fkc-emit2 (fkc-flatten prog)))

; ── m4d first move — the quine seed ──────────────────────────────────────
; Four new ops, each a named axiom-face in the emitted sibling:
;   8 NODE a b   read fk_node[a][b] — the binary OBSERVES ITSELF (axiom 4 inward)
;   9 PUTC e     emit one char, return 0 — the efferent PORT (axiom 4 outward)
;   10 DIV, 11 MOD — figure leaves the digit printer needs
; PUTC returning 0 makes ADD a sequencing door (values stay 0). The
; self-printer walks its OWN node table row by row (ARG is the row index,
; SELF advances it) and emits exactly the text fkc-rows-text computes from
; the same flatten — the data half of self-emission. The quine knot — the
; program containing its own true length — closes by fixpoint authoring:
; the row COUNT of fkd-printer-with is independent of the literal inside,
; so one rebuild with the measured length lands exactly.

(defn fkd-node (a b) (fk-node 8 (ms-intern a b)))
(defn fkd-putc (e)   (fk-node 9 e))
(defn fkd-div (a b)  (fk-node 10 (ms-intern a b)))
(defn fkd-mod (a b)  (fk-node 11 (ms-intern a b)))
(defn fkd-seq (a b)  (fk-add a b))
(defn fkd-ch (c)     (fkd-putc (fk-lit c)))
(defn fkd-d1 (v)     (fkd-putc (fk-add (fk-lit 48) v)))

(defn fkd-num (v)
    (fk-if (fk-le v (fk-lit 9))
           (fkd-d1 v)
           (fk-if (fk-le v (fk-lit 99))
                  (fkd-seq (fkd-d1 (fkd-div v (fk-lit 10)))
                           (fkd-d1 (fkd-mod v (fk-lit 10))))
                  (fkd-seq (fkd-d1 (fkd-div v (fk-lit 100)))
                  (fkd-seq (fkd-d1 (fkd-mod (fkd-div v (fk-lit 10)) (fk-lit 10)))
                           (fkd-d1 (fkd-mod v (fk-lit 10))))))))

(defn fkd-cell (j) (fkd-num (fkd-node (fk-arg) (fk-lit j))))

(defn fkd-row ()
    (fkd-seq (fkd-ch 123)
    (fkd-seq (fkd-cell 0)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 1)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 2)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 3)
    (fkd-seq (fkd-ch 125) (fkd-ch 44)))))))))))

(defn fkd-printer-with (nminus1)
    (fk-if (fk-le (fk-arg) (fk-lit nminus1))
           (fkd-seq (fkd-row) (fk-self (fk-add (fk-arg) (fk-lit 1))))
           (fkd-putc (fk-lit 10))))

(defn fkd-self-printer ()
    (fkd-printer-with (sub (len (fkc-flatten (fkd-printer-with 0))) 1)))

; ── m4e1 — CALL + the function table, emitted ────────────────────────────
; A program is a LIST of one-param functions flattened into ONE table; the
; emitted C gains fk_fn[] (each function's root index), CALL dispatches
; through it, and SELF re-enters fk_fn[0] — the single-program emission is
; the one-function special case. This is the stone that unblocks the
; emitter-as-program (the full m4d fixpoint's named blocker): the emitter
; wants several functions, and now programs may have them.

(defn fkc-fm (fns acc roots)
    (if (eq (len fns) 0) (list acc roots)
        (fkc-fm2 (fkc-flat (head fns) acc) (tail fns) roots)))
(defn fkc-fm2 (acc1 rest roots)
    (fkc-fm rest acc1 (cons (sub (len acc1) 1) roots)))
(defn fkc-flatten-many (fns) (fkc-fm fns (empty) (empty)))

(defn fkc-fn-text (roots)
    (if (eq (len roots) 1) (int_to_str (head roots))
        (str_concat (fkc-fn-text (tail roots)) (str_concat "," (int_to_str (head roots))))))

(defn fkc-decl-many-text (rows roots)
    (str_concat "static long long fk_arms[24]; static long long fk_mem[256]; static char fk_src[262144]; static long long fk_heap_head[4096]; static long long fk_heap_tail[4096]; static long long fk_hp; extern long long time(long long *); extern unsigned int arc4random(void); static const long long fk_fn["
    (str_concat (int_to_str (len roots))
    (str_concat "] = { "
    (str_concat (fkc-fn-text roots)
    (str_concat " }; static const long long fk_node["
    (str_concat (int_to_str (len rows))
    (str_concat "][4] = { "
    (str_concat (fkc-rows-text rows) " }; ")))))))))

(defn fkc-arms-many-text ()
    " if (t == 8) { return fk_node[fk_walk(fk_node[i][1], a) >> 1][fk_walk(fk_node[i][2], a) >> 1] << 1; } if (t == 9) { putchar((int)(fk_walk(fk_node[i][1], a) >> 1)); return 0; } if (t == 10) { return ((fk_walk(fk_node[i][1], a) >> 1) / (fk_walk(fk_node[i][2], a) >> 1)) << 1; } if (t == 11) { return ((fk_walk(fk_node[i][1], a) >> 1) % (fk_walk(fk_node[i][2], a) >> 1)) << 1; } if (t == 12) { return fk_walk(fk_fn[fk_node[i][1]], fk_walk(fk_node[i][2], a)); } if (t == 13) { long long mi = fk_walk(fk_node[i][1], a) >> 1; long long mv = fk_walk(fk_node[i][2], a); fk_mem[mi & 255] = mv; return mv; } if (t == 14) { return fk_mem[(fk_walk(fk_node[i][1], a) >> 1) & 255]; } if (t == 15) { return time(0) << 1; } if (t == 16) { return ((long long)arc4random()) << 1; } if (t == 17) { return ((long long)fk_src[(fk_walk(fk_node[i][1], a) >> 1) & 262143]) << 1; } if (t == 18) { return 1; } if (t == 19) { long long hh = fk_walk(fk_node[i][1], a); long long ht = fk_walk(fk_node[i][2], a); fk_hp = fk_hp + 1; fk_heap_head[fk_hp & 4095] = hh; fk_heap_tail[fk_hp & 4095] = ht; return ((fk_hp & 4095) << 1) | 1; } if (t == 20) { long long p = (fk_walk(fk_node[i][1], a) >> 1) & 4095; if (p == 0) { return 1; } return fk_heap_head[p]; } if (t == 21) { long long p = (fk_walk(fk_node[i][1], a) >> 1) & 4095; if (p == 0) { return 1; } return fk_heap_tail[p]; } if (t == 22) { long long p = (fk_walk(fk_node[i][1], a) >> 1) & 4095; long long n = 0; while (p != 0) { n = n + 1; p = (fk_heap_tail[p] >> 1) & 4095; } return n << 1; } if (t == 23) { long long p = (fk_walk(fk_node[i][1], a) >> 1) & 4095; long long k = fk_walk(fk_node[i][2], a) >> 1; while (p != 0 && k > 0) { p = (fk_heap_tail[p] >> 1) & 4095; k = k - 1; } if (p == 0) { return 1; } return fk_heap_head[p]; } return 0; } ")

(defn fkc-walk-many-text ()
    (str_concat "static long long fk_walk(long long i, long long a) { long long t = fk_node[i][0]; fk_arms[t] = fk_arms[t] + 1; if (t == 1) { return fk_node[i][1] << 1; } if (t == 2) { return a; } if (t == 3) { return fk_walk(fk_node[i][1], a) + fk_walk(fk_node[i][2], a); } if (t == 4) { return fk_walk(fk_node[i][1], a) - fk_walk(fk_node[i][2], a); } if (t == 5) { if (fk_walk(fk_node[i][1], a) <= fk_walk(fk_node[i][2], a)) { return 2; } return 0; } if (t == 6) { if (fk_walk(fk_node[i][1], a) == 0) { return fk_walk(fk_node[i][3], a); } return fk_walk(fk_node[i][2], a); } if (t == 7) { return fk_walk(fk_fn[0], fk_walk(fk_node[i][1], a)); }"
                (fkc-arms-many-text)))

(defn fkc-main-many-text ()
    "extern int atoi(const char *); int main(int argc, char **argv) { long long a = 0; if (argc > 1) { a = atoi(argv[1]) << 1; } fk_pv(fk_walk(fk_fn[0], a)); long long t = 1; while (t <= 23) { fk_pr(fk_arms[t]); t = t + 1; } return 0; }")

(defn fkc-emit-many2 (flat)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-many-text (nth flat 0) (nth flat 1))
    (str_concat (fkc-walk-many-text)
                (fkc-main-many-text)))))

(defn fkc-emit-many (fns) (fkc-emit-many2 (fkc-flatten-many fns)))

; ── n1/n2 — the NET organ + the api-on-a-4th-kernel-binary ──────────────
; A server-variant main owns the net organ through quoteless externs:
; socket/bind/listen/accept, then dup2(fd, 1) repoints stdout to the
; accepted connection so the PROGRAM's PUTC bytes ARE the response. The
; program is a pure responder (fn 0 PUTCs a full HTTP/1.0 response, the
; connection closed after — HTTP/1.0 connection-close, which curl honors).
; The kernel-resource lifecycle is the constant main (the organ); the body
; the program serves is Form. Port is argv[1] (default 8080).
(defn fkc-server-main-text ()
    "extern int socket(int,int,int); extern int bind(int,const void*,unsigned int); extern int listen(int,int); extern long accept(int,void*,void*); extern int close(int); extern int dup2(int,int); extern int fflush(void*); extern int fork(void); extern void _exit(int); extern int setsockopt(int,int,int,const void*,unsigned int); extern long read(int,void*,unsigned long); extern int shutdown(int,int); extern int atoi(const char *); static char fk_rq[8192]; struct fk_sa { unsigned char len; unsigned char fam; unsigned char p[2]; unsigned int addr; unsigned char z[8]; }; int main(int argc, char **argv) { long long port = 8080; if (argc > 1) { port = atoi(argv[1]); } int sfd = socket(2, 1, 0); int yes = 1; setsockopt(sfd, 65535, 4, &yes, 4); struct fk_sa a; a.len = 16; a.fam = 2; a.p[0] = (port >> 8) & 255; a.p[1] = port & 255; a.addr = 0; for (int z = 0; z < 8; z = z + 1) { a.z[z] = 0; } if (bind(sfd, &a, 16) < 0) { return 1; } listen(sfd, 16); while (1) { long cfd = accept(sfd, 0, 0); if (cfd < 0) { continue; } if (fork() == 0) { read((int)cfd, fk_rq, 8192); dup2((int)cfd, 1); fk_walk(fk_fn[0], 0); fflush(0); shutdown((int)cfd, 2); _exit(0); } close((int)cfd); } return 0; }")

(defn fkc-emit-server2 (flat)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-many-text (nth flat 0) (nth flat 1))
    (str_concat (fkc-walk-many-text)
                (fkc-server-main-text)))))

(defn fkc-emit-server (fns) (fkc-emit-server2 (fkc-flatten-many fns)))

; fkresp — a responder PROGRAM (cells) that PUTCs the bytes of a Form string,
; one PUTC per byte (ord off char_at), sequenced by fkd-seq (ADD over PUTC=0).
; The string IS the whole HTTP/1.0 response; fold it once, get a program-as-
; cells the net main serves. Authoring-time recursion over the string; the
; emitted program is a flat PUTC chain — a static response, no input read yet.
(defn fkresp-from (s i)
    (if (eq i (str_len s)) (fk-lit 0)
        (fkd-seq (fkd-ch (ord (char_at s i))) (fkresp-from s (add i 1)))))
(defn fkresp (s) (fkresp-from s 0))

; ── n3 — the DRIVER organ: fork/exec/pipe a host command, its stdout into ──
; fk_src, then the PROGRAM parses that stream with the BMF cursor. This is
; the keystone the model stones ride: the sibling does not reimplement TTS,
; STT, or an LLM — it DRIVES the host's own (say, whisper-cpp, ollama)
; through this organ and parses/measures the result (host-resource-access:
; allow-presence + measure-health). argv[1..] is the command + args; the
; captured bytes land in fk_src (the same buffer the universal loader fills),
; so op 17 BUF and the streaming cursor read a LIVE subprocess.
(defn fkc-driver-main-text ()
    "extern int pipe(int *); extern int fork(void); extern int dup2(int,int); extern int close(int); extern long read(int,void*,unsigned long); extern int execvp(const char*, char* const*); extern void _exit(int); extern int atoi(const char *); int main(int argc, char **argv) { if (argc < 2) { return 1; } int fds[2]; if (pipe(fds) < 0) { return 2; } int pid = fork(); if (pid == 0) { dup2(fds[1], 1); close(fds[0]); close(fds[1]); execvp(argv[1], &argv[1]); _exit(127); } close(fds[1]); long total = 0; long g; while ((g = read(fds[0], fk_src + total, 262143 - total)) > 0) { total = total + g; } fk_src[total] = 0; close(fds[0]); long long a = 0; fk_pv(fk_walk(fk_fn[0], a)); return 0; }")

(defn fkc-emit-driver2 (flat)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-many-text (nth flat 0) (nth flat 1))
    (str_concat (fkc-walk-many-text)
                (fkc-driver-main-text)))))

(defn fkc-emit-driver (fns) (fkc-emit-driver2 (fkc-flatten-many fns)))

; fkcount — a two-function parser PROGRAM that counts the bytes of the captured
; stream (fk_src) until NUL, via the cursor. The witness that the driver
; captured a real host-model stream: fn 0 calls fn 1 from position 0; fn 1
; recurses 1 + count(pos+1) while BUF(pos) is non-zero. Drive say/whisper/ollama
; through fkc-emit-driver with this as the program — the count is the proof the
; sibling drove the host organ and received its output.
(defn fkcount-fns ()
    (list (fk-call 1 (fk-lit 0))
          (fk-if (fk-buf (fk-arg))
                 (fk-add (fk-lit 1) (fk-call 1 (fk-add (fk-arg) (fk-lit 1))))
                 (fk-lit 0))))

; ── the UNIVERSAL walker — no baked program: load a table FILE and run it ──
; One binary, many programs. The table file (fkc-table-file) is plain ints —
; function count, roots, row count, rows — read through the fs afferent port
; (open/read: the loader IS the filesystem organ's physical proof). Any
; program any grammar compiles to cells becomes a file this one binary runs.

(defn fkc-table-file2 (rows roots)
    (str_concat (int_to_str (len roots))
    (str_concat " "
    (str_concat (fkc-fn-sp roots)
    (str_concat " "
    (str_concat (int_to_str (len rows))
    (str_concat " " (fkc-rows-sp rows))))))))
(defn fkc-table-file (fns) (fkc-table-file2 (nth (fkc-flatten-many fns) 0) (nth (fkc-flatten-many fns) 1)))

(defn fkc-fn-sp (roots)
    (if (eq (len roots) 1) (int_to_str (head roots))
        (str_concat (fkc-fn-sp (tail roots)) (str_concat " " (int_to_str (head roots))))))
(defn fkc-row-sp (r)
    (str_concat (int_to_str (nth r 0))
    (str_concat " "
    (str_concat (int_to_str (nth r 1))
    (str_concat " "
    (str_concat (int_to_str (nth r 2))
    (str_concat " " (int_to_str (nth r 3)))))))))
(defn fkc-rows-sp (rows)
    (if (eq (len rows) 1) (fkc-row-sp (head rows))
        (str_concat (fkc-rows-sp (tail rows)) (str_concat " " (fkc-row-sp (head rows))))))

(defn fkc-decl-universal-text ()
    "static long long fk_arms[24]; static long long fk_mem[256]; static char fk_src[262144]; static long long fk_heap_head[4096]; static long long fk_heap_tail[4096]; static long long fk_hp; extern long long time(long long *); extern unsigned int arc4random(void); static long long fk_fn[64]; static long long fk_node[4096][4]; static char fk_buf[262144]; static long long fk_pos; extern int open(const char *, int); extern long long read(int, char *, unsigned long); static long long fk_next() { while (fk_buf[fk_pos] != 0) { if (fk_buf[fk_pos] >= 48) { if (fk_buf[fk_pos] <= 57) { break; } } fk_pos = fk_pos + 1; } long long v = 0; while (fk_buf[fk_pos] >= 48 && fk_buf[fk_pos] <= 57) { v = v * 10 + (fk_buf[fk_pos] - 48); fk_pos = fk_pos + 1; } return v; } ")

(defn fkc-main-universal-text ()
    "extern int atoi(const char *); int main(int argc, char **argv) { if (argc < 2) { return 1; } int fd = open(argv[1], 0); if (fd < 0) { return 2; } long long got = read(fd, fk_buf, 262143); if (got < 0) { return 3; } fk_buf[got] = 0; long long nf = fk_next(); long long k = 0; while (k < nf) { fk_fn[k] = fk_next(); k = k + 1; } long long nr = fk_next(); long long r = 0; while (r < nr) { fk_node[r][0] = fk_next(); fk_node[r][1] = fk_next(); fk_node[r][2] = fk_next(); fk_node[r][3] = fk_next(); r = r + 1; } long long a = 0; if (argc > 2) { a = atoi(argv[2]) << 1; } if (argc > 3) { int sfd = open(argv[3], 0); if (sfd >= 0) { long long sg = read(sfd, fk_src, 262143); if (sg >= 0) { fk_src[sg] = 0; } } } fk_pv(fk_walk(fk_fn[0], a)); long long t = 1; while (t <= 23) { fk_pr(fk_arms[t]); t = t + 1; } return 0; }")

(defn fkc-emit-universal ()
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-universal-text)
    (str_concat (fkc-walk-many-text)
                (fkc-main-universal-text)))))

; ── self-JIT on heat — learned-primitive's crystallize, in the emitted sibling ──
; The emitter lowers each pure function FROM ITS CELLS to a native C
; alternative (fkc-nat-expr: straight C expressions; tags 1-7 and 12 — the
; pure-compute family; a function using ports/organs is honestly not lowered).
; At runtime the walker counts heat per function (CALL and SELF); when heat
; crosses the threshold (argv), dispatch flips to the native alternative —
; gas cooled to ice on measured heat, the flip visible in the probe (fk_njit).

(defn fkc-nat-expr (n)
    (if (eq (fk-tag n) 1) (int_to_str (add (ms-value (fk-body n)) (ms-value (fk-body n))))
    (if (eq (fk-tag n) 2) "a"
    (if (eq (fk-tag n) 3) (str_concat "(" (str_concat (fkc-nat-expr (ms-child (fk-body n) 0)) (str_concat " + " (str_concat (fkc-nat-expr (ms-child (fk-body n) 1)) ")"))))
    (if (eq (fk-tag n) 4) (str_concat "(" (str_concat (fkc-nat-expr (ms-child (fk-body n) 0)) (str_concat " - " (str_concat (fkc-nat-expr (ms-child (fk-body n) 1)) ")"))))
    (if (eq (fk-tag n) 5) (str_concat "(" (str_concat (fkc-nat-expr (ms-child (fk-body n) 0)) (str_concat " <= " (str_concat (fkc-nat-expr (ms-child (fk-body n) 1)) " ? 2 : 0)"))))
    (if (eq (fk-tag n) 6) (str_concat "(" (str_concat (fkc-nat-expr (ms-child (fk-body n) 0)) (str_concat " == 0 ? " (str_concat (fkc-nat-expr (ms-child (ms-child (fk-body n) 1) 1)) (str_concat " : " (str_concat (fkc-nat-expr (ms-child (ms-child (fk-body n) 1) 0)) ")"))))))
    (if (eq (fk-tag n) 7) (str_concat "fk_nat0(" (str_concat (fkc-nat-expr (fk-body n)) ")"))
    (if (eq (fk-tag n) 12) (str_concat "fk_nat" (str_concat (int_to_str (ms-value (ms-child (fk-body n) 0))) (str_concat "(" (str_concat (fkc-nat-expr (ms-child (fk-body n) 1)) ")"))))
        "0")))))))))

(defn fkc-jit-protos (k nf)
    (if (eq k nf) " "
        (str_concat "static long long fk_nat" (str_concat (int_to_str k) (str_concat "(long long); " (fkc-jit-protos (add k 1) nf))))))
(defn fkc-jit-bodies (fns k)
    (if (eq (len fns) 0) " "
        (str_concat "static long long fk_nat" (str_concat (int_to_str k) (str_concat "(long long a) { return " (str_concat (fkc-nat-expr (head fns)) (str_concat "; } " (fkc-jit-bodies (tail fns) (add k 1)))))))))
(defn fkc-jit-fills (k nf)
    (if (eq k nf) " "
        (str_concat "fk_nat_tab[" (str_concat (int_to_str k) (str_concat "] = fk_nat" (str_concat (int_to_str k) (str_concat "; " (fkc-jit-fills (add k 1) nf))))))))

(defn fkc-walk-jit-text ()
    (str_concat "static long long fk_walk(long long i, long long a) { long long t = fk_node[i][0]; fk_arms[t] = fk_arms[t] + 1; if (t == 1) { return fk_node[i][1] << 1; } if (t == 2) { return a; } if (t == 3) { return fk_walk(fk_node[i][1], a) + fk_walk(fk_node[i][2], a); } if (t == 4) { return fk_walk(fk_node[i][1], a) - fk_walk(fk_node[i][2], a); } if (t == 5) { if (fk_walk(fk_node[i][1], a) <= fk_walk(fk_node[i][2], a)) { return 2; } return 0; } if (t == 6) { if (fk_walk(fk_node[i][1], a) == 0) { return fk_walk(fk_node[i][3], a); } return fk_walk(fk_node[i][2], a); } if (t == 7) { long long v7 = fk_walk(fk_node[i][1], a); fk_heat[0] = fk_heat[0] + 1; if (fk_heat[0] > fk_hot) { fk_njit = fk_njit + 1; return fk_nat_tab[0](v7); } return fk_walk(fk_fn[0], v7); } if (t == 12) { long long f12 = fk_node[i][1]; long long v12 = fk_walk(fk_node[i][2], a); fk_heat[f12] = fk_heat[f12] + 1; if (fk_heat[f12] > fk_hot) { fk_njit = fk_njit + 1; return fk_nat_tab[f12](v12); } return fk_walk(fk_fn[f12], v12); }"
                (fkc-arms-many-text)))

(defn fkc-main-jit-text (nf)
    (str_concat "extern int atoi(const char *); int main(int argc, char **argv) { long long a = 0; if (argc > 1) { a = atoi(argv[1]) << 1; } fk_hot = 1000000000000; if (argc > 2) { fk_hot = atoi(argv[2]); } "
    (str_concat (fkc-jit-fills 0 nf)
                "fk_pv(fk_walk(fk_fn[0], a)); long long t = 1; while (t <= 23) { fk_pr(fk_arms[t]); t = t + 1; } fk_pr(fk_njit); return 0; }")))

(defn fkc-emit-jit2 (fns flat)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-many-text (nth flat 0) (nth flat 1))
    (str_concat "static long long fk_heat[64]; static long long fk_hot; static long long fk_njit; static long long (*fk_nat_tab[64])(long long); "
    (str_concat (fkc-jit-protos 0 (len fns))
    (str_concat (fkc-jit-bodies fns 0)
    (str_concat (fkc-walk-jit-text)
                (fkc-main-jit-text (len fns)))))))))

(defn fkc-emit-jit (fns) (fkc-emit-jit2 fns (fkc-flatten-many fns)))

; band helper — does any row carry the given tag? (organ ops in the table)
(defn fkd-has-tag (rows t)
    (if (eq (len rows) 0) 0
        (if (eq (nth (head rows) 0) t) 1 (fkd-has-tag (tail rows) t))))

; band helper — does any row carry (1, v, 0, 0)? (the knot's LIT, scanned)
(defn fkd-has-lit (rows v)
    (if (eq (len rows) 0) 0
        (if (eq (nth (head rows) 0) 1)
            (if (eq (nth (head rows) 1) v) 1 (fkd-has-lit (tail rows) v))
            (fkd-has-lit (tail rows) v))))
