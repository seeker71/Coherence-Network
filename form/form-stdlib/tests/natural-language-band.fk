; natural-language-band.fk — natural language parses into universal Form recipe
; nodes through the SAME four-way grammar engine as the arithmetic grammar.
;
; A sentence is a grammar like any other: rules of seq / alt / cap / ref / lit /
; run, actions emitting UNIVERSAL shapes — fact / property / isa / relation /
; question / meaning — never language-prefixed blueprints. The kernel never
; learns a language; English is one row of grammar DATA over the proven engine,
; so the parse crosses four-way (Go / Rust / TS / fkwu) where the section-DSL
; front end (source-compiler + file IO) reaches only three.
;
; The witness is a bitmask: each sentence class owns one bit, so the total names
; exactly which classes parse. All eight here → 255.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    ;; universal node constructors — the expected recipe shapes
    (defn s (x) (intern_trivial_string x))
    (defn fact2 (a b)  (intern_node (bp "fact")     (list (s a) (s b))))
    (defn prop2 (a b)  (intern_node (bp "property") (list (s a) (s b))))
    (defn isa2  (a b)  (intern_node (bp "isa")      (list (s a) (s b))))
    (defn rel3  (a v b)(intern_node (bp "relation") (list (s a) (s v) (s b))))
    (defn ques1 (a)    (intern_node (bp "question") (list (s a))))
    (defn mean2 (a b)  (intern_node (bp "meaning")  (list (s a) (s b))))

    ;; the natural-language grammar — pure data over the one engine
    (let nl (grammar "sentence" (list
        (rule3 "sentence"
            (p-cap "v" (list "alt"
                (p-ref "fact-the") (p-ref "fact-bare") (p-ref "property")
                (p-ref "isa") (p-ref "question") (p-ref "meaning")
                (p-ref "rel-relates") (p-ref "rel-svo")))
            (t-splice "v"))
        (rule3 "fact-the"
            (list "seq" (p-lit "the") (p-cap "s" (p-run "alpha")) (p-lit "is") (p-cap "n" (p-run "digit")))
            (t-emit "fact" (list (t-splice "s") (t-splice "n"))))
        (rule3 "fact-bare"
            (list "seq" (p-cap "s" (p-run "alpha")) (p-lit "is") (p-cap "n" (p-run "digit")))
            (t-emit "fact" (list (t-splice "s") (t-splice "n"))))
        (rule3 "property"
            (list "seq" (p-lit "the") (p-cap "s" (p-run "alpha")) (p-lit "is") (p-cap "a" (p-run "alpha")))
            (t-emit "property" (list (t-splice "s") (t-splice "a"))))
        (rule3 "isa"
            (list "seq" (p-lit "a") (p-cap "s" (p-run "alpha")) (p-lit "is") (p-lit "a") (p-cap "t" (p-run "alpha")))
            (t-emit "isa" (list (t-splice "s") (t-splice "t"))))
        ;; one generic subject-verb-object rule replaces every fixed-verb rule:
        ;; the verb is captured, not hard-coded. "source supports binary",
        ;; "kernel has source", "agent reads spec" all flow through this one cell.
        ;; Ordered LAST in the alt so the specific forms (fact / question / …) win.
        (rule3 "rel-svo"
            (list "seq" (p-cap "s" (p-run "alpha")) (p-cap "v" (p-run "alpha")) (p-cap "o" (p-run "alpha")))
            (t-emit "relation" (list (t-splice "s") (t-splice "v") (t-splice "o"))))
        (rule3 "rel-relates"
            (list "seq" (p-cap "s" (p-run "alpha")) (p-lit "relates") (p-lit "to") (p-cap "o" (p-run "alpha")))
            (t-emit "relation" (list (t-splice "s") (t-const "relates-to") (t-splice "o"))))
        (rule3 "question"
            (list "seq" (p-lit "what") (p-lit "is") (p-cap "s" (p-run "alpha")))
            (t-emit "question" (list (t-splice "s"))))
        (rule3 "meaning"
            (list "seq" (p-cap "s" (p-run "alpha")) (p-lit "means") (p-cap "m" (p-run "alpha")))
            (t-emit "meaning" (list (t-splice "s") (t-splice "m")))))))

    (defn chk (got exp bit) (if (node_eq got exp) bit 0))
    (defn total (xs) (if (nil? xs) 0 (add (head xs) (total (tail xs)))))

    ;; one witness — a flat bitmask fold (each class owns one bit; all ten → 1023)
    (total (list
        (chk (g-parse nl "the count is 13")            (fact2 "count" "13")                       1)
        (chk (g-parse nl "count is 13")                (fact2 "count" "13")                       2)
        (chk (g-parse nl "the kernel is native")       (prop2 "kernel" "native")                  4)
        (chk (g-parse nl "a cell is a organism")       (isa2 "cell" "organism")                   8)
        (chk (g-parse nl "source supports binary")     (rel3 "source" "supports" "binary")       16)
        (chk (g-parse nl "grammar relates to meaning") (rel3 "grammar" "relates-to" "meaning")   32)
        (chk (g-parse nl "what is count")              (ques1 "count")                           64)
        (chk (g-parse nl "form means object")          (mean2 "form" "object")                  128)
        (chk (g-parse nl "kernel has source")          (rel3 "kernel" "has" "source")           256)
        (chk (g-parse nl "agent reads spec")           (rel3 "agent" "reads" "spec")            512))))
