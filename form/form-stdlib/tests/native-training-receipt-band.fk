; preludes: form-stdlib/core.fk form-stdlib/nearest-shape.fk form-stdlib/classifier-eval.fk form-stdlib/native-training-receipt.fk
;
; native-training-receipt-band - one tiny native trained artifact with weights,
; data, eval, and receipt proof.
;
; Verdict 2047 when the prototype weights classify a 3-cycle / 12-row heldout
; window, the eval counts close, and the receipt is an active native artifact
; that beats the oracle bar named in the receipt.

(do
    (let speech-present (list 5 0 0))
    (let scene-present (list 0 5 0))
    (let aligned (list 5 5 5))
    (let readback-ok (list 0 0 5))
    (let weights
        (list
            (list "speech-present" speech-present)
            (list "scene-present" scene-present)
            (list "aligned" aligned)
            (list "readback-ok" readback-ok)))
    (let evals
        (list
            (list (ns-label (list 5 0 0) weights) "speech-present")
            (list (ns-label (list 0 5 0) weights) "scene-present")
            (list (ns-label (list 5 5 5) weights) "aligned")
            (list (ns-label (list 0 0 5) weights) "readback-ok")
            (list (ns-label (list 5 0 0) weights) "speech-present")
            (list (ns-label (list 0 5 0) weights) "scene-present")
            (list (ns-label (list 5 5 5) weights) "aligned")
            (list (ns-label (list 0 0 5) weights) "readback-ok")
            (list (ns-label (list 5 0 0) weights) "speech-present")
            (list (ns-label (list 0 5 0) weights) "scene-present")
            (list (ns-label (list 5 5 5) weights) "aligned")
            (list (ns-label (list 0 0 5) weights) "readback-ok")))
    (let receipt
        (ntr-row
            "form-native-nearest-shape-v0"
            "nearest-shape-prototype"
            "form/form-stdlib/native-training-receipt.fk"
            "sha256:11c30e257616249f1b887050e816e7128be7f9a1783efb1a63887929e850228a"
            "sha256:bdaa8aaa572502cf926e9165fa2f17c52ba0848c11120830256af38b178de1df"
            "sha256:c2906980a00a66efe59a5a3c982e365652db12761f14232bb9a8ca969a6213d1"
            3 12 12
            (ce-correct evals)
            (ce-wrong evals)
            1000000
            750000
            "active"))
    (let c0 (if (ntr-row? receipt) 1 0))
    (let c1 (if (str_eq (ns-label (list 5 0 0) weights) "speech-present") 2 0))
    (let c2 (if (str_eq (ns-label (list 0 5 0) weights) "scene-present") 4 0))
    (let c3 (if (str_eq (ns-label (list 0 0 5) weights) "readback-ok") 8 0))
    (let c4 (if (eq (ce-correct evals) 12) 16 0))
    (let c5 (if (eq (ce-wrong evals) 0) 32 0))
    (let c6 (if (ce-passes? evals 12 0) 64 0))
    (let c7 (if (ntr-trained? receipt) 128 0))
    (let c8 (if (ntr-beats-oracle? receipt) 256 0))
    (let c9 (if (ntr-larger-heldout-window? receipt 12 3) 512 0))
    (let c10 (if (eq (len (ntr-floor)) 4) 1024 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 c10)))))))))))
