; sh-parse-debug.fk — print the shell AST for a handful of scripts (dev only).
(do
    (defn sh-show-kids (xs)
        (if (nil? xs) ""
            (if (nil? (tail xs)) (sh-show (head xs))
                (str_concat (sh-show (head xs)) (str_concat " " (sh-show-kids (tail xs)))))))
    (defn sh-show (n)
        (if (nil? (node_children n))
            (str_concat "'" (str_concat (node_value n) "'"))
            (str_concat "(" (str_concat (sh-show-kids (node_children n)) ")"))))

    (print (str_concat "echo hello                 => " (sh-show (sh-parse "echo hello"))))
    (print (str_concat "echo hello | grep hello    => " (sh-show (sh-parse "echo hello | grep hello"))))
    (print (str_concat "echo a ; echo b            => " (sh-show (sh-parse "echo a ; echo b"))))
    (print (str_concat "cat in.txt | grep foo >o   => " (sh-show (sh-parse "cat in.txt | grep foo > out.txt"))))
    (print (str_concat "echo $HOME                 => " (sh-show (sh-parse "echo $HOME"))))
    (print (str_concat "x=1                        => " (sh-show (sh-parse "x=1"))))
    (print (str_concat "echo \"hello world\"         => " (sh-show (sh-parse "echo \"hello world\""))))
    (print (str_concat "ls -la /usr/bin            => " (sh-show (sh-parse "ls -la /usr/bin"))))
    0)
