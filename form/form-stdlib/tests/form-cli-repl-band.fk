; preludes: form-stdlib/core.fk form-stdlib/form-cli-repl.fk
;
; form-cli-repl-band — the interactive / non-interactive control logic, proven four-way.
; The two truth tables (launch mode, per-line kind) that govern form-cli's REPL — the same
; two-mode shape every agent CLI has — decided by recipe, so the carrier just obeys.
;
; Verdict 255:
;   1    -p forces one-shot, whatever the terminal           (mode 1 0 0 = 1)
;   2    a given question is one-shot (arg or pipe)           (mode 0 1 1 = 1)
;   4    bare at a terminal is interactive                    (mode 0 1 0 = 0)
;   8    bare with no terminal falls to help                  (mode 0 0 0 = 2)
;   16   a blank REPL line is empty                           (classify 1 0 0 = 3)
;   32   a /line is a meta-command                            (classify 0 0 1 = 1)
;   64   a (line is a Form expression                         (classify 0 1 0 = 0)
;   128  anything else is a question                          (classify 0 0 0 = 2)
(do
    (let c0 (if (eq (frepl-mode 1 0 0) 1) 1 0))
    (let c1 (if (eq (frepl-mode 0 1 1) 1) 2 0))
    (let c2 (if (eq (frepl-mode 0 1 0) 0) 4 0))
    (let c3 (if (eq (frepl-mode 0 0 0) 2) 8 0))
    (let c4 (if (eq (frepl-classify 1 0 0) 3) 16 0))
    (let c5 (if (eq (frepl-classify 0 0 1) 1) 32 0))
    (let c6 (if (eq (frepl-classify 0 1 0) 0) 64 0))
    (let c7 (if (eq (frepl-classify 0 0 0) 2) 128 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
