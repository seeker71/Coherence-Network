; tests/bmf-native-apply-band.fk — Path C: native + interpreted agree
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/source-compiler.fk form-stdlib/engine.fk
;
; The kernel's bmf_apply_rule_native is an additive fast path for
; engine.fk's apply-object-rule. This band asserts byte-identity of the
; emitted result Recipe — same kind, same value (under node_eq), same
; source-span — across both paths for the simplest rule shape (flat
; sequence of object-literal matchers, no captures).
;
; Scoring: 1 when the native path produces a result-object whose value
; NodeID matches the interpreted path's result-object value NodeID
; AND both consumed the same prefix length; 0 otherwise. Run under Go
; only this breath — Rust and TS carry a panic stub for the native
; until the next breath mirrors the implementation.

;; core.fk shims — engine.fk's BMF object surface (cell, cell-kind, …)
;; lives in core.fk along with nil?/take/nth/foldl/reverse-list. validate.sh
;; auto-prepends core.fk when running tests; the explicit Go invocation
;; named in the design doc verification line doesn't, so we inline the
;; specific names this test exercises. These are exact copies — the same
;; shape engine.fk closes over either way.
(defn nil? (xs) (eq (len xs) 0))
(defn cell (kind value origin inverse)
    (list "cell" kind value origin inverse))
(defn cell? (c) (and (gt (len c) 0) (str_eq (head c) "cell")))
(defn cell-kind (c) (head (tail c)))
(defn cell-value (c) (head (tail (tail c))))
(defn cell-origin (c) (head (tail (tail (tail c)))))
(defn cell-inverse (c) (head (tail (tail (tail (tail c))))))
(defn cell-undo (c) (do (let inv (cell-inverse c)) (inv c)))
(defn take (n xs)
    (if (or (le n 0) (nil? xs)) (empty)
        (cons (head xs) (take (sub n 1) (tail xs)))))
(defn nth (xs n)
    (if (eq n 0) (head xs) (nth (tail xs) (sub n 1))))
(defn cons-flip (acc x) (cons x acc))
(defn foldl (f init xs)
    (if (nil? xs) init (foldl f (f init (head xs)) (tail xs))))
(defn reverse (xs) (foldl cons-flip (empty) xs))

(do
    ;; Rule action: emit a tagged "pair" recipe from the consumed run.
    ;; Captures collection is empty in the POC scope (no named captures
    ;; yet), so the action returns a constant Recipe whose NodeID is
    ;; identical across both paths.
    (defn emit-pair (_captures)
        (intern_trivial_int 42))

    (defn undo-pair (obj)
        (bmf-object-source obj))

    ;; Pattern: ("sequence" ("object" "int" "") ("object" "ws" "")) —
    ;; two object-literal matchers, the second kind-only (empty value
    ;; means "any value of this kind"). Both engine.fk's
    ;; match-object-sequence and the kernel's bmf_apply_rule_native
    ;; consume this shape.
    (let rule
        (list "pair"
              (list "sequence"
                    (object-lit "int" "")
                    (object-lit "ws" ""))
              emit-pair
              undo-pair))

    (let object-stream
        (list (bmf-atom "int" "7")
              (bmf-atom "ws" " ")
              (bmf-atom "trailing" "x")))

    ;; --- Interpreted path (engine.fk) ---------------------------------
    (let interp-match (apply-object-rule rule object-stream))
    (let interp-result (cap-get (match-caps interp-match) "result"))
    (let interp-recipe (bmf-object-value interp-result))
    (let interp-rest (match-rest interp-match))

    ;; --- Native path (kernel) -----------------------------------------
    (let native-match (bmf_apply_rule_native rule object-stream))
    (let native-result (cap-get (match-caps native-match) "result"))
    (let native-recipe (bmf-object-value native-result))
    (let native-rest (match-rest native-match))

    ;; Score 1 when the two recipes are node_eq AND the rest streams
    ;; have the same length (both consumed two tokens, leaving one).
    (if (and (node_eq interp-recipe native-recipe)
             (eq (len interp-rest) (len native-rest)))
        1
        0))
