; concept-xpath-band.fk — concept-and-edge addressability sibling-witness.
;
; preludes: form-stdlib/concept-xpath.fk
;
; Exercises every path selector concept-xpath supports against a
; deterministic 3-concept corpus. Three-way sibling parity (Go, Rust,
; TypeScript) attests that the path splitter, find-by-id walker,
; field selector (title, cross-refs[i], parent), reverse-edge
; lookup, and orphan filter all behave the same way across kernels.
;
; Band verdict: 9 when every assertion lands.
;   /concept                       → 3 concepts                    → 1
;   /concept/<id>                  → 1 concept, id round-trips      → 1
;   /concept/<id>/title            → "Trust over Fear"              → 1
;   /concept/<id>/cross-refs       → 2 entries                       → 1
;   /concept/<id>/cross-refs[1]    → "lc-edges-as-vitality"          → 1
;   /concept/<id>/parent           → "lc-trust-over-fear"            → 1
;   /concept/by-cross-ref/<id>     → 1 concept (lc-trust-over-fear)  → 1
;   /concept/orphans               → 2 concepts                      → 1
;   cxpath-first missing id        → CONCEPT-NOT-FOUND sentinel      → 1
;
; The missing-id probe rides along — its passing is required for
; the sentinel discipline to hold, so it's part of the verdict.

(do
    ;; ---- BUILD THE 3-CONCEPT CORPUS --------------------------------
    (let c-tof
        (concept-make "lc-trust-over-fear"
                      "Trust over Fear"
                      (list "lc-field-substrate" "lc-edges-as-vitality")
                      ""))
    (let c-fs
        (concept-make "lc-field-substrate"
                      "The Field as Substrate"
                      (list "lc-trust-over-fear")
                      "lc-trust-over-fear"))
    (let c-ev
        (concept-make "lc-edges-as-vitality"
                      "Edges as Vitality"
                      (list)
                      ""))
    (let corpus (concept-corpus (list c-tof c-fs c-ev)))

    ;; ---- /concept → 3 ---------------------------------------------
    (let q-all (cxpath "/concept" corpus))
    (let all-ok (if (eq (len q-all) 3) 1 0))

    ;; ---- /concept/<id> → 1, id round-trips ------------------------
    (let q-by-id (cxpath-first "/concept/lc-trust-over-fear" corpus))
    (let id-ok
        (if (str_eq (concept-id q-by-id) "lc-trust-over-fear") 1 0))

    ;; ---- /concept/<id>/title → string -----------------------------
    (let q-title
        (cxpath-first "/concept/lc-trust-over-fear/title" corpus))
    (let title-ok
        (if (str_eq (node_value q-title) "Trust over Fear") 1 0))

    ;; ---- /concept/<id>/cross-refs → list of 2 ---------------------
    (let q-refs
        (cxpath "/concept/lc-trust-over-fear/cross-refs" corpus))
    (let refs-ok (if (eq (len q-refs) 2) 1 0))

    ;; ---- /concept/<id>/cross-refs[i] → indexed entry --------------
    (let q-ref1
        (cxpath-first "/concept/lc-trust-over-fear/cross-refs[1]"
                      corpus))
    (let ref1-ok
        (if (str_eq (node_value q-ref1) "lc-edges-as-vitality") 1 0))

    ;; ---- /concept/<id>/parent → trivial-string --------------------
    (let q-parent
        (cxpath-first "/concept/lc-field-substrate/parent" corpus))
    (let parent-ok
        (if (str_eq (node_value q-parent) "lc-trust-over-fear") 1 0))

    ;; ---- /concept/by-cross-ref/<id> → 1 ---------------------------
    (let q-rev
        (cxpath "/concept/by-cross-ref/lc-field-substrate" corpus))
    (let rev-ok (if (eq (len q-rev) 1) 1 0))

    ;; ---- /concept/orphans → 2 -------------------------------------
    (let q-orphans (cxpath "/concept/orphans" corpus))
    (let orphans-ok (if (eq (len q-orphans) 2) 1 0))

    ;; ---- missing-id probe (not part of verdict) -------------------
    ;; cxpath-first on an unknown id returns CONCEPT-NOT-FOUND.
    ;; Documents the sentinel; callers detect via node_eq.
    (let q-miss
        (cxpath-first "/concept/lc-nonexistent" corpus))
    (let miss-ok
        (if (node_eq q-miss CONCEPT-NOT-FOUND) 1 0))

    ;; ---- VERDICT --------------------------------------------------
    ;; Sum lands on 9 when every selector behaves the same way
    ;; across all three sibling kernels.
    (add all-ok
        (add id-ok
            (add title-ok
                (add refs-ok
                    (add ref1-ok
                        (add parent-ok
                            (add rev-ok
                                (add orphans-ok miss-ok)))))))))
