; tests/bml-thesis-companion-shell-source-proof.fk - large companion files
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves that larger original companion .bml files can be scanned by the
; native sibling kernels and accepted as whole source files. container-Rule.bml
; now carries parsed class body components; BMF-grammar.bml remains an explicit
; class shell until its grammar body lowering lands.

(do
    (defn bool-score (b bit)
        (if b bit 0))

    (defn int-score (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn str-score (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let container-path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/container-Rule.bml")
    (let bmf-path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/BMF-grammar.bml")

    (let container-source (bml-source-scan-file container-path))
    (let container-parsed (bml-source-file-parse-declarations container-path))
    (let container-nodes (bml-source-exec-parse-nodes container-parsed))
    (let container-model (bml-source-declaration-model container-parsed))
    (let rule-process-class (bml-model-find-class container-model "RuleProcess"))
    (let rule-class (bml-model-find-class container-model "Rule"))

    (let bmf-source (bml-source-scan-file bmf-path))
    (let bmf-parsed (bml-source-file-parse-declarations bmf-path))
    (let bmf-nodes (bml-source-exec-parse-nodes bmf-parsed))
    (let bmf-model (bml-source-declaration-model bmf-parsed))
    (let bmf-package (head bmf-nodes))
    (let bmf-import (nth bmf-nodes 1))
    (let bmf-class (bml-model-find-class bmf-model "BMF"))

    (sum
        (list
            (bool-score (gt (len container-source) 0) 1)
            (bool-score (bml-source-exec-parse-ok? container-parsed) 2)
            (int-score (len (bml-source-exec-parse-rest container-parsed)) 0 4)
            (int-score (len (bml-source-exec-parse-rules container-parsed)) 4 8)
            (int-score (len (bml-model-classes container-model)) 2 16)
            (str-score (bml-class-structural-base-name rule-process-class) "Process" 32)
            (bool-score (bml-properties-has? (bml-class-properties rule-class) "public") 64)
            (int-score (len (bml-class-own-methods rule-process-class)) 1 128)
            (int-score (len (bml-class-body rule-class)) 4 256)
            (bool-score (gt (len bmf-source) 0) 512)
            (bool-score (bml-source-exec-parse-ok? bmf-parsed) 1024)
            (int-score (len (bml-source-exec-parse-rest bmf-parsed)) 0 2048)
            (int-score (len (bml-source-exec-parse-rules bmf-parsed)) 3 4096)
            (str-score (head (comp-bml-fields bmf-package)) "BMF" 8192)
            (str-score (head (comp-bml-fields bmf-import)) "BMF.primitive.*" 16384)
            (str-score (bml-class-name bmf-class) "BMF" 32768)
            (bool-score (bml-properties-has? (bml-class-properties bmf-class) "public") 65536)
            (str-score (bml-class-structural-base-name bmf-class) "Application" 131072)
            (int-score (len (bml-class-body bmf-class)) 0 262144)
            (str-score (nth (bml-source-exec-parse-rules bmf-parsed) 2) "file-class-eof-shell" 524288))))
