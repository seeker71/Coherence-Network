; preludes: form-stdlib/core.fk form-stdlib/minimal-surface.fk form-stdlib/fourth-walker.fk form-stdlib/fourth-walker-emit.fk
;
; fourth-walker-emit-band — m4c's emitter proven three-way: the emitter READS
; a program-as-cells through the observe door and serializes it byte-identically
; on every kernel — the node table, the 3-child IF flatten order, and the whole
; emitted C walker with the root index spliced. The probe (fk_arms) is in the
; emitted text by construction.
;
; Verdict 15 when the emission lands:
;   1   the tiny program ADD(LIT 40, LIT 2) flattens to the canonical table
;       (post-order, children before parent, root last)
;   2   the branch program IF(LE(ARG,1),111,222) flattens with the 3-child IF
;       row carrying (cond, then, else) indices
;   4   two emissions of the same program are str_eq (deterministic text)
;   8   the FULL emitted C for the tiny program equals the canonical text —
;       printer, arms declaration, node table, generic walker with root
;       spliced into SELF, and the probe-printing main, byte for byte
(do
    (let tiny (fk-add (fk-lit 40) (fk-lit 2)))
    (let c0 (if (str_eq (fkc-rows-text (fkc-flatten tiny)) "{1,40,0,0},{1,2,0,0},{3,0,1,0},") 1 0))

    (let branch (fk-if (fk-le (fk-arg) (fk-lit 1)) (fk-lit 111) (fk-lit 222)))
    (let c1 (if (str_eq (fkc-rows-text (fkc-flatten branch)) "{2,0,0,0},{1,1,0,0},{5,0,1,0},{1,111,0,0},{1,222,0,0},{6,2,3,4},") 2 0))

    (let c2 (if (str_eq (fkc-emit (fk-fib-program)) (fkc-emit (fk-fib-program))) 4 0))

    (let want (str_concat "extern int putchar(int); static void fk_pr(long long v) { char b[32]; int n = 0; if (v < 0) { putchar(45); v = 0 - v; } if (v == 0) { putchar(48); } while (v > 0) { b[n] = 48 + v % 10; v = v / 10; n = n + 1; } while (n > 0) { n = n - 1; putchar(b[n]); } putchar(10); } static long long fk_arms[8]; static const long long fk_node[3][4] = { {1,40,0,0},{1,2,0,0},{3,0,1,0}, }; "
              (str_concat "static long long fk_walk(long long i, long long a) { long long t = fk_node[i][0]; fk_arms[t] = fk_arms[t] + 1; if (t == 1) { return fk_node[i][1]; } if (t == 2) { return a; } if (t == 3) { return fk_walk(fk_node[i][1], a) + fk_walk(fk_node[i][2], a); } if (t == 4) { return fk_walk(fk_node[i][1], a) - fk_walk(fk_node[i][2], a); } if (t == 5) { if (fk_walk(fk_node[i][1], a) <= fk_walk(fk_node[i][2], a)) { return 1; } return 0; } if (t == 6) { if (fk_walk(fk_node[i][1], a) == 0) { return fk_walk(fk_node[i][3], a); } return fk_walk(fk_node[i][2], a); } if (t == 7) { return fk_walk(2, fk_walk(fk_node[i][1], a)); } return 0; } "
                          "extern int atoi(const char *); int main(int argc, char **argv) { long long a = 0; if (argc > 1) { a = atoi(argv[1]); } fk_pr(fk_walk(2, a)); long long t = 1; while (t <= 7) { fk_pr(fk_arms[t]); t = t + 1; } return 0; }")))
    (let c3 (if (str_eq (fkc-emit tiny) want) 8 0))

    (add c0 (add c1 (add c2 c3))))
