; shell-awk-staged.fk — the roadmap verb's manifest reconciliation, run END-TO-END
; ON FKWU over STAGED input. fkwu carries no read_file (host file reads are a
; standing wall for the universal walker), so the sovereign pattern is the body's
; own (fkwu_run.sh / fsh-main): a thin host carrier stages the bytes into input_byte
; (tag 17, the staged-input door fkwu DOES carry), and fkwu runs native awk over
; them — no read_file, no host awk, no bash in the compute loop. fkwu-only
; (input_byte is not in the Go/Rust/TS walkers); the awk COMPUTE is the four-way
; shell-awk band. Scale note: saw-read materializes the whole input by per-byte
; recursion (O(n^2), deep) — fine for a staged slice; a full 38KB manifest needs a
; streaming cursor reader (the named follow-on), so the carrier stages the relevant
; rows, not the whole file.
;
; Run:  scripts/fkwu_run.sh <staged-rows-file> <s-expr shell preludes> \
;         form-stdlib/tests/shell-awk-staged.fk     -> verdict 127 (first stdout line)
;
; preludes: form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk
(do
    (defn saw-read (i acc)
        (do (let b (input_byte i))
            (if (eq b 0) acc (saw-read (add i 1) (str_concat acc (byte_to_str b))))))
    (let manifest (saw-read 0 ""))
    ; awk '$1=="shell-awk"{print $3}' over the staged rows -> "127\n"; trim the
    ; newline (str_to_int stops at non-digits) -> the band's own verdict, 127.
    (let out (sh-bi-awk (list "$1==\"shell-awk\"{print $3}") manifest))
    (str_to_int (sh-awk-trim (head out))))
