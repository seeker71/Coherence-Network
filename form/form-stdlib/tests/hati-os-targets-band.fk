; preludes: form-stdlib/core.fk form-stdlib/hati-os-targets.fk
;
; hati-os-targets-band - host OS implementation and distribution catalog proof.
; Verdict 16383 when macOS and Android target rows, clang oracle surfaces,
; Form-native object/executable emitters, Form-native JIT runtime rows,
; implementation rows, and hati.earth download coordinates are discoverable.

(do
    (let c0 (if (eq (len (hos-targets)) 2)
                (if (eq (len (hos-artifacts)) 2) 1 0)
                0))

    (let mac (hos-target-by-name "macos-arm64"))
    (let android (hos-target-by-name "android-arm64"))
    (let c1 (if (str_eq (hos-target-os mac) "macos")
                (if (str_eq (hos-target-binary-format mac) "mach-o") 2 0)
                0))
    (let c2 (if (str_eq (hos-target-os android) "android")
                (if (str_eq (hos-target-binary-format android) "elf") 4 0)
                0))

    (let mac-process (hos-impl-for "macos-arm64" "host:process"))
    (let mac-usage (hos-impl-for "macos-arm64" "host:usage"))
    (let mac-mlx (hos-impl-for "macos-arm64" "mlx:array"))
    (let c3 (if (str_eq (hos-impl-capability mac-process) "cap.host.process")
                (if (str_eq (hos-impl-capability mac-usage) "cap.host.usage")
                    (if (str_eq (hos-impl-capability mac-mlx) "cap.compute.mlx") 8 0)
                    0)
                0))

    (let android-sensor (hos-impl-for "android-arm64" "sensor:signal"))
    (let android-dsp (hos-impl-for "android-arm64" "dsp:signal"))
    (let android-mlx (hos-impl-for "android-arm64" "mlx:array"))
    (let c4 (if (str_eq (hos-impl-implementation android-sensor) "SensorManager+LocationManager+GNSS-permission-gated")
                (if (str_eq (hos-impl-capability android-dsp) "cap.compute.dsp")
                    (if (str_eq (hos-impl-implementation android-mlx) "unsupported-on-android") 16 0)
                    0)
                0))

    (let mac-artifact (hos-artifact-for "macos-arm64"))
    (let android-artifact (hos-artifact-for "android-arm64"))
    (let c5 (if (str_eq (hos-artifact-url mac-artifact) "https://hati.earth/downloads/hati-os/macos/arm64/hati-os-macos-arm64.tar.zst") 32 0))
    (let c6 (if (str_eq (hos-artifact-url android-artifact) "https://hati.earth/downloads/hati-os/android/arm64/hati-os-android-arm64.tar.zst") 64 0))
    (let c7 (if (str_eq (hos-artifact-status mac-artifact) "public-asset-door")
                (if (str_eq (hos-download-url "android-arm64") (hos-artifact-url android-artifact)) 128 0)
                0))
    (let c8 (if (str_eq (hos-target-clang-triple mac) "arm64-apple-macosx")
                (if (str_eq (hos-target-assembly-surface mac) "mach-o-relocatable+arm64-asm") 256 0)
                0))
    (let c9 (if (str_eq (hos-target-clang-triple android) "aarch64-linux-android")
                (if (str_eq (hos-target-assembly-surface android) "elf-relocatable+aarch64-asm") 512 0)
                0))
    (let c10 (if (str_eq (hos-target-jit-oracle mac) "clang")
                (if (str_eq (hos-target-jit-runtime mac) "form-native-arm64-assembler")
                    (if (str_eq (hos-target-jit-model mac) "clang-oracle-sampled-form-native-recipe") 1024 0)
                    0)
                0))
    (let c11 (if (str_eq (hos-target-jit-oracle android) "clang")
                (if (str_eq (hos-target-jit-runtime android) "form-native-arm64-assembler")
                    (if (str_eq (hos-target-jit-model android) "clang-oracle-sampled-form-native-recipe") 2048 0)
                    0)
                0))
    (let c12 (if (str_eq (hos-target-form-native-object mac) "form-macho")
                (if (str_eq (hos-target-form-native-object android) "form-elf") 4096 0)
                0))
    (let c13 (if (str_eq (hos-target-form-native-executable mac) "form-macho+ld")
                (if (str_eq (hos-target-form-native-executable android) "form-elf-exec") 8192 0)
                0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 (add c10 (add c11 (add c12 c13))))))))))))))
