; sh-exec-debug.fk — run scripts through the form-native executor (dev only).
(do
    (defn show (label src)
        (print (str_concat label (str_concat " => |" (str_concat (sh-out src) "|")))))

    ; native builtins, pipelines, sequences, variables
    (show "echo hello              " "echo hello")
    (show "seq 3 | wc -l           " "seq 3 | wc -l")
    (show "seq 5 | grep 3          " "seq 5 | grep 3")
    (show "echo abc | rev          " "echo abc | rev")
    (show "x=hi ; echo $x          " "x=hi ; echo $x")
    (show "echo a ; echo b         " "echo a ; echo b")
    (show "seq 5 | head 2          " "seq 5 | head 2")
    (show "echo one two | wc -l    " "echo one two | wc -l")
    (show "passthrough git status  " "git status")
    (show "pipe native->passthru   " "seq 3 | git log")

    ; the native/passthrough PLAN (dispatch proof surface)
    (defn show-plan (s)
        (print (str_concat "PLAN " (str_concat s ":"))))
    (defn dump-steps (steps)
        (if (nil? steps) 0
            (do (let st (head steps))
                (print (str_concat "  [" (str_concat (sh-step-kind st)
                        (str_concat "] " (str_concat (sh-step-name st)
                        (str_concat " " (sh-join (sh-step-args st) ",")))))))
                (dump-steps (tail steps)))))
    (show-plan "seq 5 | grep 3 | git commit")
    (dump-steps (sh-plan (sh-parse "seq 5 | grep 3 | git commit")))
    0)
