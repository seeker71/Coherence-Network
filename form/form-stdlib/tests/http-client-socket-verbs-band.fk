; http-client-socket-verbs-band.fk - HTTP verbs over real socket calls.
;
; preludes: form-stdlib/http-client.fk
;
; Proves the client method lane is not built on http_get or sock_request:
; source grammar renders a non-GET request, sends it over socket_send, receives
; the request with socket_recv, and closes both sides. Verdict: 127.

section [form.action] {
    def hcsv-contains(s, needle) = ge(str_find(s, needle, 0), 0);
    def hcsv-starts(s, prefix) = if gt(str_len(prefix), str_len(s)) then false else str_eq(substring(s, 0, str_len(prefix)), prefix);

    let body = "{\"title\":\"native\"}";
    let srv = socket_listen(0);
    let listen-ok = if ge(srv, 0) then 1 else 0;
    let port = socket_port(srv);
    let port-ok = if gt(port, 0) then 2 else 0;

    let cli = socket_connect("127.0.0.1", port);
    let conn = if ge(cli, 0) then socket_accept(srv) else -1;
    let pair-ok = if ge(cli, 0) then if ge(conn, 0) then 4 else 0 else 0;

    let rendered = kh-render-request("PATCH", "/api/ideas", "127.0.0.1", body);
    let sent = socket_send(cli, rendered);
    let request = if gt(sent, 0) then socket_recv(conn, 65536) else "";
    let sent-ok = if gt(sent, 0) then 8 else 0;
    let method-ok = if hcsv-starts(request, "PATCH /api/ideas HTTP/1.0\r\n") then 16 else 0;
    let host-ok = if hcsv-contains(request, "Host: 127.0.0.1\r\n") then 32 else 0;
    let body-ok = if hcsv-contains(request, "Content-Length: 18\r\n\r\n{\"title\":\"native\"}") then 64 else 0;

    socket_close(conn);
    socket_close(cli);
    socket_close(srv);

    add(listen-ok, add(port-ok, add(pair-ok, add(sent-ok, add(method-ok, add(host-ok, body-ok))))));
}
