; jit-lower-band.fk — portable JIT lowering as Form recipe, proven on the fourth lane.
;
; Runs the lowerer from jit-lower.fk on expressions built with the fourth-walker
; cell model, then executes the (lowered) program and checks answers match the
; direct (un-lowered) version. This is the body-owned version of the logic feature
; (gap #3 reference semantics from the Go typed hardcode).
;
; When the fourth-walker-emit (or a generalized lower-then-emit) is used on the
; lowered tree, the emitted native binary gets the benefit with no host-specific
; JIT code in the kernel — exactly the intent of host-kernel.form ("JIT ... composite of a recipe")
; and fourth-kernel.form (emitter / lowerer as Form, m4e-jit self-JIT on heat, m4e3
; real-recipe flattener).

(do
  ;; Build a guard that would have been RBasicLogic in the full system.
  ;; (and (le x 5) (ge x 0)) — truthy 0/1 convention.
  (let x (fk-lit 3))
  (let guard-direct (fk-if (fk-le x (fk-lit 5))
                           (fk-if (fk-le (fk-lit 0) x) (fk-lit 1) (fk-lit 0))
                           (fk-lit 0)))

  ;; The portable lower (from jit-lower.fk) applied to an and shape.
  ;; We construct the and explicitly using the helper the lowerer exports.
  (let and-shape (jit-lower-and (fk-le x (fk-lit 5)) (fk-le (fk-lit 0) x)))
  (let lowered (jit-lower and-shape))   ; the recipe does the work

  ;; Run both on the fourth walker (or the emitted binary when this band is
  ;; loaded as a table).
  (let r-direct (fk-run (fk-lit 0) guard-direct))   ; dummy arg, not used
  (let r-lowered (fk-run (fk-lit 0) lowered))

  ;; For a real tree the lowerer would be applied to a whole program cell.
  ;; Here we just prove the logic lowering rule itself produces a tree that
  ;; walks to the same 0/1 as the direct IF expansion.
  ;; Verdict piece: 1 if they agree on this case.
  (if (eq r-direct r-lowered) 1 0)

  ;; Extend with or/not cases in follow-up slices exactly as the Go reference
  ;; and the ledger sketches. The same pattern applies to folding and unboxing
  ;; rules once those helpers are filled in jit-lower.fk.

  ;; When this band (and its cousins for the other JIT features) passes on the
  ;; emitted fourth binary (via the audit or validate.sh fourth arm), we have
  ;; a proven binary that carries the full JIT-as-portable-Form-recipe surface.
)