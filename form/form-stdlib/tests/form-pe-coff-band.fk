; preludes: form-stdlib/core.fk form-stdlib/form-pe-coff.fk
;
; form-pe-coff-band - Windows x86_64 native recipe object floor.
; Verdict 255 when Form emits a minimal x64 COFF object for a loadable recipe
; DLL: AMD64 machine header, .text section, Windows-x64 machine-code bytes,
; external recipe symbol, empty string table, and a second swappable recipe body
; behind the same symbol.

(do
    (let code (pe-x64-recipe-mul3-add7-code))
    (let obj (pe-recipe-object code))
    (let code2 (pe-x64-recipe-mul5-add1-code))
    (let obj2 (pe-recipe-object code2))

    (let c0 (if (eq (len obj) 88) 1 0))
    (let c1 (if (eq (nth obj 0) 100)
                (if (eq (nth obj 1) 134)
                    (if (eq (nth obj 2) 1) 2 0)
                    0)
                0))
    (let c2 (if (eq (nth obj 8) 66)
                (if (eq (nth obj 12) 1) 4 0)
                0))
    (let c3 (if (eq (nth obj 20) 46)
                (if (eq (nth obj 21) 116)
                    (if (eq (nth obj 36) 6)
                        (if (eq (nth obj 40) 60) 8 0)
                        0)
                    0)
                0))
    (let c4 (if (eq (nth obj 60) 72)
                (if (eq (nth obj 61) 141)
                    (if (eq (nth obj 64) 7)
                        (if (eq (nth obj 65) 195) 16 0)
                        0)
                    0)
                0))
    (let c5 (if (eq (nth obj 66) 114)
                (if (eq (nth obj 67) 101)
                    (if (eq (nth obj 70) 112) 32 0)
                    0)
                0))
    (let c6 (if (eq (nth obj 78) 1)
                (if (eq (nth obj 80) 32)
                    (if (eq (nth obj 82) 2) 64 0)
                    0)
                0))
    (let c7 (if (eq (nth obj 84) 4)
                (if (eq (len obj2) 88)
                    (if (eq (nth obj2 63) 137)
                        (if (eq (nth obj2 64) 1) 128 0)
                        0)
                    0)
                0))

    (sum (list c0 c1 c2 c3 c4 c5 c6 c7)))
