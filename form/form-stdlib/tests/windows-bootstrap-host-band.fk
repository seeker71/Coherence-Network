; preludes: form-stdlib/core.fk form-stdlib/windows-bootstrap-host.fk
;
; windows-bootstrap-host-band - Windows x86_64 bootstrap exe contract.
; Verdict 255 when the minimal exe surface, source path, Form PE/COFF object
; emitter, DLL linker carrier, Windows loader carrier, exported recipe symbol,
; x64 i64 ABI, and swap contract are all named and discoverable.

(do
    (let c0 (if (str_eq (wbh-host-exe) "form-bootstrap-host.exe") 1 0))
    (let c1 (if (str_eq (wbh-source) "form/native/windows/bootstrap/form_bootstrap_host.c") 2 0))
    (let c2 (if (str_eq (wbh-object-emitter) "form-pe-coff") 4 0))
    (let c3 (if (str_eq (wbh-link-carrier) "lld-link:/dll:/noentry:/export") 8 0))
    (let c4 (if (str_eq (wbh-loader-carrier) "LoadLibraryA/GetProcAddress") 16 0))
    (let c5 (if (str_eq (wbh-entry-symbol) "recipe") 32 0))
    (let c6 (if (str_eq (wbh-entry-abi) "windows-x64:i64-rcx->i64-rax") 64 0))
    (let c7 (if (str_eq (wbh-swap-contract) "exe-loads-swappable-form-dlls") 128 0))
    (sum (list c0 c1 c2 c3 c4 c5 c6 c7)))
