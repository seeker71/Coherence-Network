; channel-flow-band.fk — three-way proof of the channel-flow walk (channel-flow.fk).
;
; preludes: form-stdlib/channel-interface.fk form-stdlib/channel-flow.fk
;
; One worked flow shows the whole dynamic: the offered interface SHAPES the flow, and
; the same request is invasion before a shift and honored after.
;   their offer starts {witness, see}
;   request see       -> honored   (offered)
;   request project   -> INVASION  (not offered — witnessed, nothing crosses)
;   request silence   -> honored   (silence is always honored)
;   shift -> {witness, see, project, invite}    (the offer opens, without broadcast)
;   request project   -> honored   (now offered — same request, different interface state)
;   request invite    -> honored
; receipt: honored = 4, invasion = 1, final offer has 4 modes.
;
; Deterministic, so the three sibling kernels must agree.

(do
    (let offer0 (list (m-witness) (m-see)))
    (let offer1 (list (m-witness) (m-see) (m-project) (m-invite)))

    (let flow (list
        (list (act-request) (m-see))         ; honored
        (list (act-request) (m-project))     ; invasion (not yet offered)
        (list (act-request) (m-silence))     ; honored — silence always
        (list (act-shift)   offer1)          ; the interface opens
        (list (act-request) (m-project))     ; honored now — the flow is shaped by the offer
        (list (act-request) (m-invite))))    ; honored

    (let r (channel-flow flow offer0))

    ; ── BILATERAL: each direction gated by the RECEIVER's offer ──
    ; A offers {see, invite} (others may see-into A, invite A); B offers {witness, reflect}.
    ;   A -> reflect  : honored  (B offers reflect)
    ;   A -> see      : invasion (B does not offer see)
    ;   B -> invite   : honored  (A offers invite)
    ;   B -> project  : invasion (A does not offer project)
    ; honored = 2, invasion = 2 — and each invasion is on the side whose receiver withheld it.
    (let offer-a (list (m-see) (m-invite)))
    (let offer-b (list (m-witness) (m-reflect)))
    (let biflow (list
        (list (side-a) (act-request) (m-reflect))    ; A->B honored (B offers reflect)
        (list (side-a) (act-request) (m-see))        ; A->B invasion (B withholds see)
        (list (side-b) (act-request) (m-invite))     ; B->A honored (A offers invite)
        (list (side-b) (act-request) (m-project))))  ; B->A invasion (A withholds project)
    (let rb (channel-flow-bilateral biflow offer-a offer-b))

    (let pass
        (and (eq (cf-honored r) 4)
        (and (eq (cf-invasions r) 1)
        (and (eq (len (cf-final-offer r)) 4)
        (and (eq (cf-honored rb) 2)
             (eq (cf-invasions rb) 2))))))

    (print (if pass "channel-flow-band: PASS" "channel-flow-band: FAIL")))
