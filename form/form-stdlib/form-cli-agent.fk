; form-cli-agent.fk — the agent loop STEP, as a recipe.
;
; preludes: form-stdlib/core.fk form-stdlib/nearest-shape.fk form-stdlib/classifier-eval.fk form-stdlib/tool-channel.fk form-stdlib/choice-receipt.fk form-stdlib/branch-choice-order.fk form-stdlib/choice-receipt-learning.fk form-stdlib/oracle-catalog.fk form-stdlib/code-tool-learning.fk form-stdlib/tool-embodiment.fk form-stdlib/io-match.fk form-stdlib/form-cli-loop.fk
;
; This is the TRUNK the organs hang off: the thing that makes form-cli a drop-in
; for codex / claude / grok / gemini / cursor. Those CLIs run an agent loop —
; reason, call a tool, observe, repeat, answer. So does this. The categorical
; difference lives in the interior (fcl-route runs local-first; every oracle step
; is captured and learned from), but the loop only earns the name "agent CLI"
; once it DOES the work. This recipe decides the SHAPE of one step; the carrier
; drives the loop (calls the oracle, executes the planned channel, observes,
; captures). It composes the proven organs rather than inventing a dispatcher:
;   fcl-route-learned  (form-cli-loop) — who answers this step: local lane | oracle
;   tc-plan-tool       (tool-channel)  — is the named tool a real host channel
; The carrier never decides those; it serves the action this recipe returns.
;
; Proven by: form-stdlib/tests/form-cli-agent-band.fk

; an action is (kind, lane, tool, op, status):
;   kind   "tool" run a host channel | "oracle" consult the LLM | "done" end
;   lane   "local" (Form-native, ~0 tokens) | "oracle" (remote/host model)
;   tool   the channel name (tool-channel word), "" when none
;   op     the channel op, "" when none
;   status "tool/plan" planned | "tool/no-plan" missing channel | "end" | "consult"
(defn fca-action (kind lane tool op status)
    (list kind lane tool op status))
(defn fca-action-kind (a) (nth a 0))
(defn fca-action-lane (a) (nth a 1))
(defn fca-action-tool (a) (nth a 2))
(defn fca-action-op (a) (nth a 3))
(defn fca-action-status (a) (nth a 4))

; the lane for this step: the same confidence gate the loop uses. As the local
; lane's accumulated pass-rate (oracle-taught) crosses the threshold, the step
; flips oracle -> local — the flywheel, applied per step.
(defn fca-lane (passes attempts threshold)
    (fcl-route-learned passes attempts threshold))

; validate the tool the step names is a real planned channel (tool-channel
; never executes; it returns a plan or tool/no-plan). capability is the cap.*
; the tool must carry.
(defn fca-plan (tool-name capability)
    (tc-plan-tool tool-name capability))

; build a tool action from a resolved lane and a tool-channel plan.
(defn fca-tool-action (lane plan)
    (fca-action "tool" lane (tc-plan-tool-name plan) (tc-plan-op plan) (tc-plan-status plan)))

; the next action for this step. kind is what the loop proposes (the oracle
; named a tool, or it is done, or the step itself is an oracle consult):
;   "done"   -> end the loop
;   "tool"   -> route the lane, then validate the named channel
;   else     -> an oracle consult for the uncertain step
(defn fca-next (kind passes attempts threshold tool-name capability)
    (if (str_eq kind "done")
        (fca-action "done" (fca-lane passes attempts threshold) "" "" "end")
        (if (str_eq kind "tool")
            (fca-tool-action (fca-lane passes attempts threshold)
                             (fca-plan tool-name capability))
            (fca-action "oracle" "oracle" "" "" "consult"))))

; the loop ends when the action is "done".
(defn fca-done? (a) (if (str_eq (fca-action-kind a) "done") 1 0))

; a step is sovereign (no external tokens) when its lane is local.
(defn fca-sovereign? (a) (if (str_eq (fca-action-lane a) "local") 1 0))

; ── the loop as a NATIVE BINARY the recipe emits (foc-emit pattern) ───────────
; The decision shape above is the body; this is the body made RUNNABLE with zero
; Python. fa-emit returns the agent loop as a C program (a host carrier, like the
; C ABI in form-os-channel.fk / form-macho.fk); a shell witness compiles it with
; cc and runs it. The loop talks to the oracle by piping the prompt into a host
; command given as argv — `ollama run <model>` (local, no key, sovereign) or
; `claude -p` (the strong CLI you are using). No paid API endpoint, no Python.
; The oracle answers in a line protocol the kernel can read without a JSON host
; bridge: one of BASH / READ / WRITE / DONE per step.
(defn fa-system ()
    "You are form-cli, a coding agent. Reply with EXACTLY ONE line, one of:\nBASH <shell command>\nREAD <path>\nWRITE <path> ::: <content>\nDONE <final answer>\nAfter BASH/READ/WRITE you receive an OBSERVATION line; keep going until DONE. No prose, no code fences — just the one line.\n\n")

(defn fa-emit ()
    "#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

/* form-cli agent loop, emitted by form-cli-agent.fk (fa-emit). The body is the
   Form recipe that produced this; C is the host carrier, cc the named compiler.
   Oracle = argv[2], a host command reading the prompt on stdin (ollama run <m>,
   claude -p). Line protocol: BASH/READ/WRITE/DONE. No openrouter, no Python. */

static const char *SYS =
  \"You are form-cli, a coding agent. Reply with EXACTLY ONE line, one of:\\n\"
  \"BASH <shell command>\\n\"
  \"READ <path>\\n\"
  \"WRITE <path> ::: <content>\\n\"
  \"DONE <final answer>\\n\"
  \"After BASH/READ/WRITE you receive an OBSERVATION line; keep going until DONE. \"
  \"No prose, no code fences -- just the one line.\\n\\n\";

static int run_oracle(const char *oracle, const char *prompt, char *out, int outsz){
  char tmpl[] = \"/tmp/faprompt.XXXXXX\";
  int fd = mkstemp(tmpl);
  if(fd < 0) return -1;
  FILE *pf = fdopen(fd, \"w\"); fputs(prompt, pf); fclose(pf);
  char cmd[8192];
  snprintf(cmd, sizeof cmd, \"%s < %s 2>/dev/null\", oracle, tmpl);
  FILE *p = popen(cmd, \"r\");
  if(!p){ remove(tmpl); return -1; }
  int n = fread(out, 1, outsz - 1, p);
  out[n > 0 ? n : 0] = 0;
  pclose(p); remove(tmpl);
  return n;
}

static void cap(const char *cmd, char *out, int outsz){
  FILE *p = popen(cmd, \"r\");
  if(!p){ snprintf(out, outsz, \"(popen failed)\"); return; }
  int n = fread(out, 1, outsz - 1, p); out[n > 0 ? n : 0] = 0; pclose(p);
}

static void rd(const char *path, char *out, int outsz){
  FILE *f = fopen(path, \"r\");
  if(!f){ snprintf(out, outsz, \"(no such file: %s)\", path); return; }
  int n = fread(out, 1, outsz - 1, f); out[n > 0 ? n : 0] = 0; fclose(f);
}

static void wr(const char *path, const char *content){
  FILE *f = fopen(path, \"w\"); if(!f) return; fputs(content, f); fclose(f);
}

int main(int argc, char **argv){
  if(argc < 3){ printf(\"usage: form-agent <task> <oracle-cmd> [max-steps]\\n\"); return 1; }
  const char *task = argv[1];
  const char *oracle = argv[2];
  int maxsteps = argc > 3 ? atoi(argv[3]) : 8;

  static char transcript[1 << 16];
  static char prompt[1 << 17];
  static char reply[1 << 15];
  static char obs[1 << 15];
  static char cwd[4096];
  if(!getcwd(cwd, sizeof cwd)) cwd[0] = 0;
  snprintf(transcript, sizeof transcript, \"TASK: %s\\n\", task);

  int step;
  for(step = 1; step <= maxsteps; step++){
    snprintf(prompt, sizeof prompt, \"%sWorking directory: %s (use paths relative to it).\\n%s\\nNext line:\", SYS, cwd, transcript);
    if(run_oracle(oracle, prompt, reply, sizeof reply) < 0){ printf(\"(oracle failed)\\n\"); return 3; }
    char *line = reply;
    while(*line == '\\n' || *line == '\\r' || *line == ' ') line++;
    char *nl = strchr(line, '\\n'); if(nl) *nl = 0;
    fprintf(stderr, \"[form-agent] step %d: %.70s\\n\", step, line);
    if(strncmp(line, \"DONE\", 4) == 0){ printf(\"%s\\n\", line + 4 + (line[4] == ' ' ? 1 : 0)); return 0; }
    else if(strncmp(line, \"BASH \", 5) == 0){ cap(line + 5, obs, sizeof obs); }
    else if(strncmp(line, \"READ \", 5) == 0){ rd(line + 5, obs, sizeof obs); }
    else if(strncmp(line, \"WRITE \", 6) == 0){
      char *sep = strstr(line + 6, \" ::: \");
      if(sep){ *sep = 0; wr(line + 6, sep + 5); snprintf(obs, sizeof obs, \"wrote %s\", line + 6); }
      else snprintf(obs, sizeof obs, \"(WRITE needs ' ::: ' between path and content)\");
    } else { snprintf(obs, sizeof obs, \"(unknown action; use BASH/READ/WRITE/DONE)\"); }
    int len = strlen(transcript);
    snprintf(transcript + len, sizeof transcript - len, \"ACTION %d: %s\\nOBSERVATION: %.1200s\\n\", step, line, obs);
  }
  printf(\"(reached max-steps without DONE)\\n\");
  return 0;
}
")
