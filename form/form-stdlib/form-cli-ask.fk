; form-cli-ask.fk - the form-cli ASK verb, native on the fkwu walker.
;
; preludes: form-stdlib/core.fk form-stdlib/http-client.fk
;
; The question goes to the local LLM at localhost:11434 through http-fetch.
; Plain HTTP lowers through the BML http-client socket recipes carried by fkwu:
; socket_connect/socket_send/socket_recv/socket_close. The generic
; HttpExchange class wrapper is proven separately and does not widen this
; minimal runtime path. No host shell, subprocess, Go, clang, LLVM, http_get, or
; sock_request is in the runtime ask path.

section [form.bml] {
    def fca-esc-char(c) {
        let cp = ord(c);
        if eq(cp, 34) then "\\\"" else
        if eq(cp, 92) then "\\\\" else
        if eq(cp, 10) then "\\n" else
        if eq(cp, 13) then "\\r" else
        if eq(cp, 9) then "\\t" else
        c;
    }

    def fca-esc-loop(s, i, acc) {
        if ge(i, str_len(s)) then acc else
            fca-esc-loop(s, add(i, 1), str_concat(acc, fca-esc-char(char_at(s, i))));
    }

    def fca-json-string(s) {
        fca-esc-loop(s, 0, "");
    }

    def fca-gen-body(model, question) {
        str_concat(
            "{\"model\":\"",
            str_concat(
                fca-json-string(model),
                str_concat(
                    "\",\"prompt\":\"",
                    str_concat(fca-json-string(question), "\",\"stream\":false}"))));
    }

    def fca-unesc-char(c) {
        let cp = ord(c);
        if eq(cp, 110) then "\n" else
        if eq(cp, 114) then "\r" else
        if eq(cp, 116) then "\t" else
        if eq(cp, 34) then "\"" else
        if eq(cp, 92) then "\\" else
        if eq(cp, 47) then "/" else
        c;
    }

    def fca-read-string(s, i, acc) {
        if ge(i, str_len(s)) then acc else
            fca-read-string-step(s, i, acc, char_at(s, i));
    }

    def fca-read-string-step(s, i, acc, c) {
        if str_eq(c, "\"") then acc else
        if str_eq(c, "\\") then
            if ge(add(i, 1), str_len(s)) then acc else
                fca-read-string(
                    s,
                    add(i, 2),
                    str_concat(acc, fca-unesc-char(char_at(s, add(i, 1)))))
        else
            fca-read-string(s, add(i, 1), str_concat(acc, c));
    }

    def fca-field(reply, key) {
        let marker = str_concat("\"", str_concat(key, "\":\""));
        let at = str_find(reply, marker, 0);
        if lt(at, 0) then "" else
            fca-read-string(reply, add(at, str_len(marker)), "");
    }

    def fca-ask-model(model, question) {
        let body = fca-gen-body(model, question);
        let reply = http-fetch("POST", "http://localhost:11434/api/generate", body);
        let answer = fca-field(reply, "response");
        if gt(str_len(answer), 0) then str_concat("", answer) else
            str_concat("[ask: no answer from local oracle - is ollama running at localhost:11434?]\n", reply);
    }

    def fca-ask(question) {
        if eq(str_len(question), 0) then
            "ask: usage - ask <question>   (answered by the local oracle, native on fkwu)"
        else
            fca-ask-model("form-llama", question);
    }
}

0
