; grammars/bml.fk - BML object compiler and runtime support
;
; Reference shape: the 2000 BML/JBML compiler lowers BMF matches into
; component objects, then into an instruction stream for a backtracking VM.
; This file keeps that shape in Form data so Python, Go, Rust, TypeScript,
; and future languages can reuse the same compiler bands.

; Per-dialect BML-AST-* category constants are declared as data in
; form-stdlib/form-ontology.json and emitted into
; form-stdlib/dialect-categories.fk by scripts/generate_ontology.py. This
; file references them as free identifiers; load dialect-categories.fk as
; a prelude before this file.

(do
    ;; --- source objects ---------------------------------------------

    (defn bml-src-keyword (value) (bmf-atom "bml-keyword" value))
    (defn bml-src-name (value) (bmf-atom "bml-name" value))
    (defn bml-src-op (value) (bmf-atom "bml-op" value))
    (defn bml-src-int (value) (bmf-atom "bml-int" value))
    (defn bml-src-string (value) (bmf-atom "bml-string" value))
    (defn bml-src-prop (value) (bmf-atom "bml-property" value))
    (defn bml-src-list (value) (bmf-atom "bml-list" value))
    (defn bml-src-code (value) (bmf-atom "bml-code" value))

    ;; --- file source scanner ----------------------------------------
    ;; This is the real file boundary for BML proof: bytes on disk become
    ;; BML source objects before any BMF rule or BMA lowering can run.

    (defn bml-source-keywords (_x)
        (list "package" "import" "class" "interface" "template" "section"
              "syntax" "const" "enum" "operator" "for" "while" "loop"
              "switch" "select" "case" "default" "if" "else" "if_fail"
              "while_success" "return" "break" "continue" "try" "catch"
              "throw" "fail" "cut" "mark" "save" "restore" "discard"
              "choice" "choose" "asm" "instanceof" "library" "naming"
              "conventions" "DefaultMethods" "Nil" "Fail" "EndOfFile"
              "EndOfLine" "Cut" "MultiMatch" "Primitive"))

    (defn bml-source-properties (_x)
        (list "public" "private" "protected" "abstract" "static" "final"
              "default" "delegate" "shared" "get" "put" "strict" "relaxed"
              "deferred" "native" "exception" "explicit" "extern" "library"
              "name" "guid" "operator" "coercion" "reassign" "array"
              "exclusive" "in" "out" "inout" "assign" "inline" "hidden"
              "singleton" "unique" "struct" "noobject" "dynamic" "alias"
              "outer" "nostate"))

    (defn bml-source-name-kind (value)
        (if (fsc-string-list-contains? (bml-source-keywords 0) value)
            "bml-keyword"
            (if (fsc-string-list-contains? (bml-source-properties 0) value)
                "bml-property"
                "bml-name")))

    (defn bml-source-scan-name-token (start)
        (do
            (let read (fsc-source-scan-name-loop start start))
            (let value (nth read 0))
            (let end (nth read 1))
            (fsc-scan-result
                (fsc-source-object
                    (bml-source-name-kind value)
                    value
                    start
                    end)
                end)))

    (defn bml-source-ops (_x)
        (list "<<prim" ".*" "::=" "=>" "<=" ">>>=" ">>=" "<<=" ">>>"
              ">>" "<<" "++" "--" "==" "!=" ">=" "<=" ":=" "*=" "/="
              "%=" "+=" "-=" "&=" "|=" "^=" "&&" "||" ".." "#("
              "{" "}" "(" ")" "[" "]" ";" "," ":" "." "+" "-" "*" "/"
              "%" "=" "'" "<" ">" "!" "~" "?" "|" "&" "^" "$"))

    (defn bml-source-dialect (_x)
        (fsc-source-dialect
            (bml-source-keywords 0)
            "bml-keyword"
            "bml-name"
            "bml-int"
            "bml-string"
            "bml-op"
            "bml-eof"
            (bml-source-ops 0)))

    (defn bml-line-comment-prefix (_x) (str_concat "/" "/"))
    (defn bml-block-comment-open (_x) (str_concat "/" "*"))
    (defn bml-block-comment-close (_x) (str_concat "*" "/"))

    (defn bml-source-skip-line-comment (cursor)
        (if (fsc-source-cursor-end? cursor) cursor
            (if (str_eq (fsc-source-cursor-char cursor) "\n") cursor
                (bml-source-skip-line-comment
                    (fsc-source-cursor-advance cursor)))))

    (defn bml-source-skip-block-comment (cursor)
        (if (fsc-source-cursor-end? cursor) cursor
            (if (fsc-source-cursor-prefix? cursor (bml-block-comment-close 0))
                (fsc-source-advance-n cursor 2)
                (bml-source-skip-block-comment
                    (fsc-source-cursor-advance cursor)))))

    (defn bml-source-scan-skip (cursor)
        (do
            (let start (fsc-source-scan-skip cursor))
            (if (fsc-source-cursor-prefix? start (bml-line-comment-prefix 0))
                (bml-source-scan-skip
                    (bml-source-skip-line-comment
                        (fsc-source-advance-n start 2)))
            (if (fsc-source-cursor-prefix? start (bml-block-comment-open 0))
                (bml-source-scan-skip
                    (bml-source-skip-block-comment
                        (fsc-source-advance-n start 2)))
                start))))

    (defn bml-source-scan-next (cursor)
        (do
            (let start (bml-source-scan-skip cursor))
            (let ch (fsc-source-cursor-char start))
            (if (fsc-source-cursor-end? start)
                (fsc-scan-result
                    (fsc-source-object "bml-eof" "" start start)
                    start)
            (if (str_eq ch "\"")
                (fsc-source-scan-string start "bml-string")
            (if (fsc-digit? ch)
                (fsc-source-scan-int start "bml-int")
            (if (fsc-source-name-start-char? ch)
                (bml-source-scan-name-token start)
                (fsc-source-scan-op
                    start
                    "bml-op"
                    (bml-source-ops 0))))))))

    (defn bml-source-scan-text-loop (cursor acc)
        (do
            (let result (bml-source-scan-next cursor))
            (let object (fsc-scan-result-object result))
            (if (str_eq (bmf-object-kind object) "bml-eof")
                (reverse-list acc)
                (bml-source-scan-text-loop
                    (fsc-scan-result-cursor result)
                    (cons object acc)))))

    (defn bml-source-scan-text (source)
        (bml-source-scan-text-loop
            (fsc-source-cursor source 0 1 0)
            (empty)))

    (defn bml-source-scan-file-form (path)
        (bml-source-scan-text-loop
            (fsc-file-source-cursor path 0 1 0 (file_size path))
            (empty)))

    (defn bml-source-scan-file (path)
        (bml_scan_file path))

    (defn bml-kw (value) (object-lit "bml-keyword" value))
    (defn bml-op (value) (object-lit "bml-op" value))
    (defn bml-ref (name) (object-lit "bml-ref" name))
    (defn bml-name (capture-name) (list "capture" capture-name (object-lit "bml-name" "")))
    (defn bml-int-lit (capture-name) (list "capture" capture-name (object-lit "bml-int" "")))
    (defn bml-string-lit (capture-name) (list "capture" capture-name (object-lit "bml-string" "")))
    (defn bml-prop (capture-name) (list "capture" capture-name (object-lit "bml-property" "")))

    ;; --- AST helpers --------------------------------------------------

    (defn bml-cap-str (objects capture-name)
        (intern_trivial_string (bmf-collection-value objects capture-name)))

    (defn bml-cap-int (objects capture-name)
        (intern_trivial_int (str_to_int (bmf-collection-value objects capture-name))))

    (defn bml-ast-int (n)
        (intern_node BML-AST-INT (list (intern_trivial_int n))))

    (defn bml-ast-string (s)
        (intern_node BML-AST-STRING (list (intern_trivial_string s))))

    (defn bml-ast-name (s)
        (intern_node BML-AST-NAME (list (intern_trivial_string s))))

    (defn bml-ast-add (left right)
        (intern_node BML-AST-ADD (list left right)))

    (defn bml-ast-package (name)
        (intern_node BML-AST-PACKAGE (list (intern_trivial_string name))))

    (defn bml-ast-import (name star)
        (intern_node BML-AST-IMPORT
                     (list (intern_trivial_string name)
                           (intern_trivial_string star))))

    (defn bml-ast-interface (name parent body)
        (intern_node BML-AST-INTERFACE
                     (list (intern_trivial_string name)
                           (intern_trivial_string parent)
                           body)))

    (defn bml-ast-return (expr)
        (intern_node BML-AST-RETURN (list expr)))

    (defn bml-ast-block (items)
        (intern_node BML-AST-BLOCK items))

    (defn bml-ast-method (name body)
        (intern_node BML-AST-METHOD (list (intern_trivial_string name) body)))

    (defn bml-ast-class (name base sections)
        (intern_node BML-AST-CLASS
                     (list (intern_trivial_string name)
                           (intern_trivial_string base)
                           sections)))

    (defn bml-ast-section (properties body)
        (intern_node BML-AST-SECTION (list properties body)))

    (defn bml-ast-field (field-type name)
        (intern_node BML-AST-FIELD
                     (list (intern_trivial_string field-type)
                           (intern_trivial_string name))))

    (defn bml-ast-const (const-type name value)
        (intern_node BML-AST-CONST
                     (list (intern_trivial_string const-type)
                           (intern_trivial_string name)
                           value)))

    (defn bml-ast-choose (branches)
        (intern_node BML-AST-CHOOSE branches))

    (defn bml-ast-fail (_x) (intern_node BML-AST-FAIL (empty)))
    (defn bml-ast-cut (_x) (intern_node BML-AST-CUT (empty)))
    (defn bml-ast-save (_x) (intern_node BML-AST-SAVE (empty)))
    (defn bml-ast-restore (_x) (intern_node BML-AST-RESTORE (empty)))
    (defn bml-ast-discard (_x) (intern_node BML-AST-DISCARD (empty)))
    (defn bml-ast-break (label)
        (intern_node BML-AST-BREAK (list (intern_trivial_string label))))
    (defn bml-ast-continue (label)
        (intern_node BML-AST-CONTINUE (list (intern_trivial_string label))))
    (defn bml-ast-throw (expr)
        (intern_node BML-AST-THROW (list expr)))
    (defn bml-ast-try (body handler)
        (intern_node BML-AST-TRY (list body handler)))
    (defn bml-ast-char (value)
        (intern_node BML-AST-CHAR (list (intern_trivial_string value))))
    (defn bml-ast-array (items)
        (intern_node BML-AST-ARRAY items))

    ;; --- BML compiler component objects -----------------------------
    ;; BML support is a compiler band above the kernel. Source sections
    ;; reduce into reversible BMF object cells whose values are these
    ;; generic BML component objects. Later runtime passes can lower the
    ;; component values into BMA ops or into a denser authoring dialect.

    (defn comp-bml-component (kind fields)
        (list "comp-bml-component" kind fields))

    (defn comp-bml-kind (component)
        (nth component 1))

    (defn comp-bml-fields (component)
        (nth component 2))

    (defn bml-component-kind? (component kind)
        (str_eq (comp-bml-kind component) kind))

    (defn bml-model (classes interfaces)
        (list "bml-model" classes interfaces))

    (defn bml-model-classes (model) (nth model 1))
    (defn bml-model-interfaces (model) (nth model 2))

    (defn bml-interface-ref-component (name)
        (comp-bml-component "InterfaceRef" (list name)))

    (defn bml-components-of-kind (items kind)
        (if (nil? items) (empty)
            (do
                (let item (head items))
                (let rest (bml-components-of-kind (tail items) kind))
                (if (bml-component-kind? item kind)
                    (cons item rest)
                    rest))))

    (defn bml-class-name (class-component)
        (nth (comp-bml-fields class-component) 0))

    (defn bml-class-properties (class-component)
        (nth (comp-bml-fields class-component) 1))

    (defn bml-class-supers (class-component)
        (nth (comp-bml-fields class-component) 2))

    (defn bml-class-body (class-component)
        (nth (comp-bml-fields class-component) 3))

    (defn bml-class-structural-base-name (class-component)
        (if (nil? (bml-class-supers class-component)) ""
            (head (bml-class-supers class-component))))

    (defn bml-class-delegation-base-names (class-component)
        (if (nil? (bml-class-supers class-component)) (empty)
            (tail (bml-class-supers class-component))))

    (defn bml-interface-name (interface-component)
        (nth (comp-bml-fields interface-component) 0))

    (defn bml-interface-properties (interface-component)
        (nth (comp-bml-fields interface-component) 1))

    (defn bml-interface-parent-name (interface-component)
        (nth (comp-bml-fields interface-component) 2))

    (defn bml-interface-body (interface-component)
        (nth (comp-bml-fields interface-component) 3))

    (defn bml-section-body (section-component)
        (nth (comp-bml-fields section-component) 2))

    (defn bml-field-type (field-component)
        (nth (comp-bml-fields field-component) 0))

    (defn bml-field-name (field-component)
        (nth (comp-bml-fields field-component) 1))

    (defn bml-method-return (method-component)
        (nth (comp-bml-fields method-component) 0))

    (defn bml-method-name (method-component)
        (nth (comp-bml-fields method-component) 1))

    (defn bml-method-body (method-component)
        (nth (comp-bml-fields method-component) 3))

    (defn bml-method-parameters (method-component)
        (if (gt (len (comp-bml-fields method-component)) 4)
            (nth (comp-bml-fields method-component) 4)
            (empty)))

    (defn bml-parameter-type (parameter-component)
        (nth (comp-bml-fields parameter-component) 0))

    (defn bml-parameter-name (parameter-component)
        (nth (comp-bml-fields parameter-component) 1))

    (defn bml-interface-ref-name (interface-ref)
        (head (comp-bml-fields interface-ref)))

    (defn bml-include-path (include-component)
        (head (comp-bml-fields include-component)))

    (defn bml-property-component (name value)
        (comp-bml-component "Property" (list name value)))

    (defn bml-property-name (property)
        (nth (comp-bml-fields property) 0))

    (defn bml-property-value (property)
        (nth (comp-bml-fields property) 1))

    (defn bml-properties-find (properties name)
        (if (nil? properties) (empty)
            (if (str_eq (bml-property-name (head properties)) name)
                (head properties)
                (bml-properties-find (tail properties) name))))

    (defn bml-properties-has? (properties name)
        (if (nil? (bml-properties-find properties name)) false true))

    (defn bml-properties-value (properties name default-value)
        (do
            (let property (bml-properties-find properties name))
            (if (nil? property) default-value
                (bml-property-value property))))

    (defn bml-access-level (properties)
        (if (bml-properties-has? properties "private") "private"
            (if (bml-properties-has? properties "protected") "protected"
                (if (bml-properties-has? properties "public") "public"
                    (bml-properties-value properties "access" "public")))))

    (defn bml-section-name (section-component)
        (nth (comp-bml-fields section-component) 0))

    (defn bml-section-properties (section-component)
        (nth (comp-bml-fields section-component) 1))

    (defn bml-field-properties (field-component)
        (nth (comp-bml-fields field-component) 2))

    (defn bml-field-init (field-component)
        (if (gt (len (comp-bml-fields field-component)) 3)
            (nth (comp-bml-fields field-component) 3)
            (empty)))

    (defn bml-const-type (const-component)
        (nth (comp-bml-fields const-component) 0))

    (defn bml-const-name (const-component)
        (nth (comp-bml-fields const-component) 1))

    (defn bml-const-properties (const-component)
        (nth (comp-bml-fields const-component) 2))

    (defn bml-const-value (const-component)
        (nth (comp-bml-fields const-component) 3))

    (defn bml-method-properties (method-component)
        (nth (comp-bml-fields method-component) 2))

    (defn bml-constructor-name (constructor-component)
        (nth (comp-bml-fields constructor-component) 0))

    (defn bml-constructor-properties (constructor-component)
        (nth (comp-bml-fields constructor-component) 1))

    (defn bml-constructor-body (constructor-component)
        (nth (comp-bml-fields constructor-component) 2))

    (defn bml-constructor-parameters (constructor-component)
        (if (gt (len (comp-bml-fields constructor-component)) 3)
            (nth (comp-bml-fields constructor-component) 3)
            (empty)))

    (defn bml-body-source (token-values)
        (comp-bml-component "BodySource" (list token-values)))

    (defn bml-body-source-values (body-component)
        (head (comp-bml-fields body-component)))

    (defn bml-string-list-contains? (items value)
        (if (nil? items) false
            (if (str_eq (head items) value) true
                (bml-string-list-contains? (tail items) value))))

    (defn bml-body-source-contains? (body-component value)
        (bml-string-list-contains?
            (bml-body-source-values body-component)
            value))

    (defn bml-body-source-assignment-at? (values)
        (if (gt (len values) 3)
            (if (str_eq (nth values 1) "=")
                (str_eq (nth values 3) ";")
                false)
            false))

    (defn bml-body-source-assignment-count-loop (values count)
        (if (nil? values) count
            (if (bml-body-source-assignment-at? values)
                (bml-body-source-assignment-count-loop
                    (drop 4 values)
                    (add count 1))
                (bml-body-source-assignment-count-loop
                    (tail values)
                    count))))

    (defn bml-body-source-assignment-count (body-component)
        (bml-body-source-assignment-count-loop
            (bml-body-source-values body-component)
            0))

    (defn bml-body-source-exec-assignments-loop (values self env)
        (if (nil? values) self
            (if (bml-body-source-assignment-at? values)
                (do
                    (record_set
                        self
                        (head values)
                        (record_get env (nth values 2)))
                    (bml-body-source-exec-assignments-loop
                        (drop 4 values)
                        self
                        env))
                (bml-body-source-exec-assignments-loop
                    (tail values)
                    self
                    env))))

    (defn bml-body-source-exec-assignments (body-component self env)
        (bml-body-source-exec-assignments-loop
            (bml-body-source-values body-component)
            self
            env))

    (defn bml-template-parameters (template-component)
        (nth (comp-bml-fields template-component) 0))

    (defn bml-template-kind (template-component)
        (nth (comp-bml-fields template-component) 1))

    (defn bml-template-body (template-component)
        (nth (comp-bml-fields template-component) 2))

    (defn bml-template-valid-kind? (template-component)
        (if (str_eq (bml-template-kind template-component) "class") true
            (str_eq (bml-template-kind template-component) "interface")))

    (defn bml-class-abstract? (class-component)
        (bml-properties-has? (bml-class-properties class-component) "abstract"))

    (defn bml-class-final? (class-component)
        (bml-properties-has? (bml-class-properties class-component) "final"))

    (defn bml-method-abstract? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "abstract"))

    (defn bml-method-final? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "final"))

    (defn bml-method-default? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "default"))

    (defn bml-method-deferred? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "deferred"))

    (defn bml-method-class? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "class"))

    (defn bml-field-delegate? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "delegate"))

    (defn bml-field-class? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "class"))

    (defn bml-field-shared? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "shared"))

    (defn bml-field-get? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "get"))

    (defn bml-field-put? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "put"))

    (defn bml-field-strict? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "strict"))

    (defn bml-field-relaxed? (field-component)
        (bml-properties-has? (bml-field-properties field-component) "relaxed"))

    (defn bml-const-class? (const-component)
        (bml-properties-has? (bml-const-properties const-component) "class"))

    (defn bml-member-name (component)
        (if (bml-component-kind? component "Field")
            (bml-field-name component)
            (if (bml-component-kind? component "Method")
                (bml-method-name component)
                (if (bml-component-kind? component "Const")
                    (bml-const-name component)
                    (if (bml-component-kind? component "Class")
                        (bml-class-name component)
                        (if (bml-component-kind? component "Constructor")
                            (bml-constructor-name component)
                            ""))))))

    (defn bml-member-properties (component)
        (if (bml-component-kind? component "Field")
            (bml-field-properties component)
            (if (bml-component-kind? component "Method")
                (bml-method-properties component)
                (if (bml-component-kind? component "Const")
                    (bml-const-properties component)
                    (if (bml-component-kind? component "Class")
                        (bml-class-properties component)
                        (if (bml-component-kind? component "Constructor")
                            (bml-constructor-properties component)
                            (empty)))))))

    (defn bml-model-find-class-loop (classes name)
        (if (nil? classes) (empty)
            (if (str_eq (bml-class-name (head classes)) name)
                (head classes)
                (bml-model-find-class-loop (tail classes) name))))

    (defn bml-model-find-class (model name)
        (bml-model-find-class-loop (bml-model-classes model) name))

    (defn bml-model-find-interface-loop (interfaces name)
        (if (nil? interfaces) (empty)
            (if (str_eq (bml-interface-name (head interfaces)) name)
                (head interfaces)
                (bml-model-find-interface-loop (tail interfaces) name))))

    (defn bml-model-find-interface (model name)
        (bml-model-find-interface-loop (bml-model-interfaces model) name))

    (defn bml-body-members-of-kind (items kind)
        (if (nil? items) (empty)
            (do
                (let item (head items))
                (let rest (bml-body-members-of-kind (tail items) kind))
                (if (bml-component-kind? item kind)
                    (cons item rest)
                    (if (bml-component-kind? item "Section")
                        (append (bml-body-members-of-kind (bml-section-body item) kind) rest)
                        rest)))))

    (defn bml-body-member-effective-properties (items kind name inherited-properties)
        (if (nil? items) (empty)
            (do
                (let item (head items))
                (if (bml-component-kind? item kind)
                    (if (str_eq (bml-member-name item) name)
                        (append inherited-properties (bml-member-properties item))
                        (bml-body-member-effective-properties (tail items) kind name inherited-properties))
                    (if (bml-component-kind? item "Section")
                        (do
                            (let section-found
                                (bml-body-member-effective-properties
                                    (bml-section-body item)
                                    kind
                                    name
                                    (append inherited-properties (bml-section-properties item))))
                            (if (nil? section-found)
                                (bml-body-member-effective-properties (tail items) kind name inherited-properties)
                                section-found))
                        (bml-body-member-effective-properties (tail items) kind name inherited-properties))))))

    (defn bml-class-member-effective-properties (class-component kind name)
        (bml-body-member-effective-properties (bml-class-body class-component) kind name (empty)))

    (defn bml-class-own-fields (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "Field"))

    (defn bml-class-own-methods (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "Method"))

    (defn bml-class-own-constructors (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "Constructor"))

    (defn bml-class-interface-refs (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "InterfaceRef"))

    (defn bml-interface-own-methods (interface-component)
        (bml-body-members-of-kind (bml-interface-body interface-component) "Method"))

    (defn bml-class-own-constants (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "Const"))

    (defn bml-class-own-inner-classes (class-component)
        (bml-body-members-of-kind (bml-class-body class-component) "Class"))

    (defn bml-find-field (fields name)
        (if (nil? fields) (empty)
            (if (str_eq (bml-field-name (head fields)) name)
                (head fields)
                (bml-find-field (tail fields) name))))

    (defn bml-find-method (methods name)
        (if (nil? methods) (empty)
            (if (str_eq (bml-method-name (head methods)) name)
                (head methods)
                (bml-find-method (tail methods) name))))

    (defn bml-find-const (constants name)
        (if (nil? constants) (empty)
            (if (str_eq (bml-const-name (head constants)) name)
                (head constants)
                (bml-find-const (tail constants) name))))

    (defn bml-find-inner-class (classes name)
        (if (nil? classes) (empty)
            (if (str_eq (bml-class-name (head classes)) name)
                (head classes)
                (bml-find-inner-class (tail classes) name))))

    (defn bml-class-structural-fields (model class-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let base (bml-class-structural-base-name class-component))
                    (append
                        (if (str_eq base "") (empty)
                            (bml-class-structural-fields model base))
                        (bml-class-own-fields class-component))))))

    (defn bml-class-field-lookup-structural (model class-name field-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let own (bml-find-field (bml-class-own-fields class-component) field-name))
                    (if (nil? own)
                        (do
                            (let base (bml-class-structural-base-name class-component))
                            (if (str_eq base "") (empty)
                                (bml-class-field-lookup-structural model base field-name)))
                        own)))))

    (defn bml-class-const-lookup-structural (model class-name const-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let own (bml-find-const (bml-class-own-constants class-component) const-name))
                    (if (nil? own)
                        (do
                            (let base (bml-class-structural-base-name class-component))
                            (if (str_eq base "") (empty)
                                (bml-class-const-lookup-structural model base const-name)))
                        own)))))

    (defn bml-class-inner-class-lookup-structural (model class-name inner-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let own (bml-find-inner-class (bml-class-own-inner-classes class-component) inner-name))
                    (if (nil? own)
                        (do
                            (let base (bml-class-structural-base-name class-component))
                            (if (str_eq base "") (empty)
                                (bml-class-inner-class-lookup-structural model base inner-name)))
                        own)))))

    (defn bml-class-extends-structural? (model actual-name expected-name)
        (if (str_eq actual-name expected-name) true
            (do
                (let class-component (bml-model-find-class model actual-name))
                (if (nil? class-component) false
                    (do
                        (let base (bml-class-structural-base-name class-component))
                        (if (str_eq base "") false
                            (bml-class-extends-structural? model base expected-name)))))))

    (defn bml-class-can-extend? (model base-name)
        (do
            (let base-component (bml-model-find-class model base-name))
            (if (nil? base-component) false
                (if (bml-class-final? base-component) false true))))

    (defn bml-member-accessible? (model owner-class from-class properties)
        (do
            (let access (bml-access-level properties))
            (if (str_eq access "private")
                (str_eq owner-class from-class)
                (if (str_eq access "protected")
                    (bml-class-extends-structural? model from-class owner-class)
                    true))))

    (defn bml-class-all-delegation-bases (model class-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let base (bml-class-structural-base-name class-component))
                    (append
                        (bml-class-delegation-base-names class-component)
                        (if (str_eq base "") (empty)
                            (bml-class-all-delegation-bases model base)))))))

    (defn bml-method-binding (self-class this-class method-component)
        (list "bml-method-binding" self-class this-class method-component))

    (defn bml-method-binding-self (binding) (nth binding 1))
    (defn bml-method-binding-this (binding) (nth binding 2))
    (defn bml-method-binding-method (binding) (nth binding 3))

    (defn bml-class-method-lookup-bases (model bases self-class method-name)
        (if (nil? bases) (empty)
            (do
                (let found (bml-class-method-lookup-in-class model (head bases) self-class method-name))
                (if (nil? found)
                    (bml-class-method-lookup-bases model (tail bases) self-class method-name)
                    found))))

    (defn bml-class-method-lookup-in-class (model class-name self-class method-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let own (bml-find-method (bml-class-own-methods class-component) method-name))
                    (if (nil? own)
                        (bml-class-method-lookup-bases
                            model
                            (bml-class-supers class-component)
                            self-class
                            method-name)
                        (bml-method-binding self-class class-name own))))))

    (defn bml-class-method-lookup (model class-name method-name)
        (bml-class-method-lookup-in-class model class-name class-name method-name))

    (defn bml-invoke-from-context (model self-class _this-class method-name)
        (bml-class-method-lookup-in-class model self-class self-class method-name))

    (defn bml-super-invoke (model self-class this-class method-name)
        (do
            (let class-component (bml-model-find-class model this-class))
            (if (nil? class-component) (empty)
                (bml-class-method-lookup-bases
                    model
                    (bml-class-supers class-component)
                    self-class
                    method-name))))

    (defn bml-class-method-override-allowed? (model class-name method-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) false
                (do
                    (let own (bml-find-method (bml-class-own-methods class-component) method-name))
                    (if (nil? own) true
                        (do
                            (let inherited
                                (bml-class-method-lookup-bases
                                    model
                                    (bml-class-supers class-component)
                                    class-name
                                    method-name))
                            (if (nil? inherited) true
                                (if (bml-method-final? (bml-method-binding-method inherited))
                                    false
                                    true))))))))

    (defn bml-interface-method-lookup (model interface-name method-name)
        (do
            (let interface-component (bml-model-find-interface model interface-name))
            (if (nil? interface-component) (empty)
                (do
                    (let own (bml-find-method (bml-interface-own-methods interface-component) method-name))
                    (if (nil? own)
                        (do
                            (let parent (bml-interface-parent-name interface-component))
                            (if (str_eq parent "") (empty)
                                (bml-interface-method-lookup model parent method-name)))
                        own)))))

    (defn bml-interface-default-method-lookup (model interface-name method-name)
        (do
            (let method (bml-interface-method-lookup model interface-name method-name))
            (if (nil? method) (empty)
                (if (bml-method-default? method) method
                    (empty)))))

    (defn bml-interface-refs-default-method-lookup (model refs method-name)
        (if (nil? refs) (empty)
            (do
                (let found
                    (bml-interface-default-method-lookup
                        model
                        (bml-interface-ref-name (head refs))
                        method-name))
                (if (nil? found)
                    (bml-interface-refs-default-method-lookup model (tail refs) method-name)
                    found))))

    (defn bml-class-bases-interface-default-method-lookup (model bases method-name)
        (if (nil? bases) (empty)
            (do
                (let found
                    (bml-class-interface-default-method-lookup model (head bases) method-name))
                (if (nil? found)
                    (bml-class-bases-interface-default-method-lookup model (tail bases) method-name)
                    found))))

    (defn bml-class-interface-default-method-lookup (model class-name method-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) (empty)
                (do
                    (let own (bml-find-method (bml-class-own-methods class-component) method-name))
                    (if (nil? own)
                        (do
                            (let own-interface
                                (bml-interface-refs-default-method-lookup
                                    model
                                    (bml-class-interface-refs class-component)
                                    method-name))
                            (if (nil? own-interface)
                                (bml-class-bases-interface-default-method-lookup
                                    model
                                    (bml-class-supers class-component)
                                    method-name)
                                own-interface))
                        (empty))))))

    (defn bml-interface-extends? (model actual-name expected-name)
        (if (str_eq actual-name expected-name) true
            (do
                (let interface-component (bml-model-find-interface model actual-name))
                (if (nil? interface-component) false
                    (do
                        (let parent (bml-interface-parent-name interface-component))
                        (if (str_eq parent "") false
                            (bml-interface-extends? model parent expected-name)))))))

    (defn bml-interface-refs-support? (model refs interface-name)
        (if (nil? refs) false
            (if (bml-interface-extends? model (bml-interface-ref-name (head refs)) interface-name)
                true
                (bml-interface-refs-support? model (tail refs) interface-name))))

    (defn bml-class-bases-support-interface? (model bases interface-name)
        (if (nil? bases) false
            (if (bml-class-supports-interface? model (head bases) interface-name)
                true
                (bml-class-bases-support-interface? model (tail bases) interface-name))))

    (defn bml-class-supports-interface? (model class-name interface-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) false
                (if (bml-interface-refs-support?
                        model
                        (bml-class-interface-refs class-component)
                        interface-name)
                    true
                    (bml-class-bases-support-interface?
                        model
                        (bml-class-supers class-component)
                        interface-name)))))

    (defn bml-class-own-concrete-method? (class-component method-name)
        (do
            (let method (bml-find-method (bml-class-own-methods class-component) method-name))
            (if (nil? method) false
                (if (bml-method-abstract? method) false
                    (if (bml-method-deferred? method) false true)))))

    (defn bml-class-concrete? (class-component)
        (if (bml-class-abstract? class-component) false true))

    (defn bml-application-main-entry? (model class-name)
        (do
            (let class-component (bml-model-find-class model class-name))
            (if (nil? class-component) false
                (if (if (bml-class-extends-structural? model class-name "BML.lang.Application")
                        true
                        (bml-class-extends-structural? model class-name "Application"))
                    (bml-class-own-concrete-method? class-component "Main")
                    false))))

    (defn bml-comp-one (kind objects field)
        (comp-bml-component kind (list (bmf-collection-value objects field))))

    (defn bml-comp-two (kind objects a b)
        (comp-bml-component kind
            (list
                (bmf-collection-value objects a)
                (bmf-collection-value objects b))))

    (defn bml-comp-three (kind objects a b c)
        (comp-bml-component kind
            (list
                (bmf-collection-value objects a)
                (bmf-collection-value objects b)
                (bmf-collection-value objects c))))

    (defn bml-comp-four (kind objects a b c d)
        (comp-bml-component kind
            (list
                (bmf-collection-value objects a)
                (bmf-collection-value objects b)
                (bmf-collection-value objects c)
                (bmf-collection-value objects d))))

    (defn bml-compile-package (objects)
        (bml-comp-one "Package" objects "name"))

    (defn bml-compile-import (objects)
        (bml-comp-two "Import" objects "name" "star"))

    (defn bml-compile-binary-type (objects)
        (bml-comp-two "BinaryType" objects "name" "fields"))

    (defn bml-compile-class (objects)
        (bml-comp-four "Class" objects "name" "properties" "supers" "body"))

    (defn bml-compile-interface (objects)
        (bml-comp-four "Interface" objects "name" "properties" "parent" "body"))

    (defn bml-compile-template (objects)
        (bml-comp-three "Template" objects "parameters" "kind" "body"))

    (defn bml-compile-section (objects)
        (bml-comp-three "Section" objects "name" "properties" "body"))

    (defn bml-compile-syntax (objects)
        (bml-comp-three "Syntax" objects "name" "rules" "attributes"))

    (defn bml-compile-field (objects)
        (bml-comp-three "Field" objects "type" "name" "properties"))

    (defn bml-compile-const (objects)
        (bml-comp-four "Const" objects "type" "name" "properties" "value"))

    (defn bml-compile-enum (objects)
        (bml-comp-four "Enum" objects "name" "properties" "base" "values"))

    (defn bml-compile-method (objects)
        (bml-comp-four "Method" objects "return" "name" "properties" "body"))

    (defn bml-compile-parameter (objects)
        (bml-comp-three "Parameter" objects "type" "name" "properties"))

    (defn bml-compile-property (objects)
        (bml-comp-two "Property" objects "name" "value"))

    (defn bml-compile-statement (objects)
        (bml-comp-three "Statement" objects "kind" "value" "body"))

    (defn bml-compile-expression (objects)
        (bml-comp-three "Expression" objects "kind" "left" "right"))

    (defn bml-compile-asm (objects)
        (bml-comp-three "Asm" objects "locals" "statements" "blocks"))

    (defn bml-compile-main-rule (objects)
        (bml-comp-one "MainRule" objects "item"))

    (defn bml-compile-file (objects)
        (bml-comp-one "File" objects "items"))

    (defn bml-true-property (name)
        (bml-property-component name "true"))

    (defn bml-parameter-component (param-type name)
        (comp-bml-component "Parameter" (list param-type name (empty))))

    (defn bml-join-two-name (first second)
        (str_concat (str_concat first ".") second))

    (defn bml-join-star-name (name)
        (str_concat name ".*"))

    (defn bml-emit-file-package-two (objects)
        (comp-bml-component
            "Package"
            (list
                (bml-join-two-name
                    (bmf-collection-value objects "first")
                    (bmf-collection-value objects "second")))))

    (defn bml-emit-file-package-one (objects)
        (comp-bml-component
            "Package"
            (list (bmf-collection-value objects "name"))))

    (defn bml-emit-file-import-one-star (objects)
        (comp-bml-component
            "Import"
            (list
                (bml-join-star-name (bmf-collection-value objects "name"))
                ".*")))

    (defn bml-emit-file-import-two-star (objects)
        (comp-bml-component
            "Import"
            (list
                (bml-join-star-name
                    (bml-join-two-name
                        (bmf-collection-value objects "first")
                        (bmf-collection-value objects "second")))
                ".*")))

    (defn bml-emit-file-include (objects)
        (comp-bml-component
            "Include"
            (list (bmf-collection-value objects "path"))))

    (defn bml-emit-file-interface-empty (objects)
        (comp-bml-component
            "Interface"
            (list
                (bmf-collection-value objects "name")
                (empty)
                (bmf-collection-value objects "parent")
                (empty))))

    (defn bml-emit-file-class-empty-two-base (objects)
        (comp-bml-component
            "Class"
            (list
                (bmf-collection-value objects "name")
                (list (bml-true-property (bmf-collection-value objects "property")))
                (list (bmf-collection-value objects "first")
                      (bmf-collection-value objects "second"))
                (empty))))

    (defn bml-file-section-field-class (objects base-name)
        (do
            (let field
                (comp-bml-component
                    "Field"
                    (list
                        (bmf-collection-value objects "field-type")
                        (bmf-collection-value objects "field-name")
                        (empty))))
            (let section
                (comp-bml-component
                    "Section"
                    (list
                        ""
                        (list (bml-true-property
                                (bmf-collection-value objects "section-property")))
                        (list field))))
            (comp-bml-component
                "Class"
                (list
                    (bmf-collection-value objects "name")
                    (list (bml-true-property (bmf-collection-value objects "property")))
                    (list base-name)
                    (list section)))))

    (defn bml-emit-file-class-section-field (objects)
        (bml-file-section-field-class
            objects
            (bmf-collection-value objects "base")))

    (defn bml-emit-file-class-section-field-primitive (objects)
        (bml-file-section-field-class objects "Primitive"))

    (defn bml-emit-file-class-section-const-string (objects)
        (do
            (let const
                (comp-bml-component
                    "Const"
                    (list
                        (bmf-collection-value objects "const-type")
                        (bmf-collection-value objects "const-name")
                        (empty)
                        (bmf-collection-value objects "const-value"))))
            (let section
                (comp-bml-component
                    "Section"
                    (list
                        ""
                        (list (bml-true-property "class")
                              (bml-true-property
                                (bmf-collection-value objects "section-property")))
                        (list const))))
            (comp-bml-component
                "Class"
                (list
                    (bmf-collection-value objects "name")
                    (list (bml-true-property (bmf-collection-value objects "property")))
                    (list (bmf-collection-value objects "base"))
                    (list section)))))

    (defn bml-emit-file-class-section-return-method (objects)
        (do
            (let method
                (comp-bml-component
                    "Method"
                    (list
                        (bmf-collection-value objects "return-type")
                        (bmf-collection-value objects "method-name")
                        (empty)
                        (bml-ast-return
                            (bml-ast-int
                                (str_to_int
                                    (bmf-collection-value objects "return-value")))))))
            (let section
                (comp-bml-component
                    "Section"
                    (list
                        ""
                        (list (bml-true-property
                                (bmf-collection-value objects "section-property")))
                        (list method))))
            (comp-bml-component
                "Class"
                (list
                    (bmf-collection-value objects "name")
                    (list (bml-true-property (bmf-collection-value objects "property")))
                    (list (bmf-collection-value objects "base"))
                    (list section)))))

    (defn bml-emit-file-class-primitive-cut (objects)
        (do
            (let section-properties
                (list (bml-true-property
                        (bmf-collection-value objects "section-property"))))
            (let match-method
                (comp-bml-component
                        "Method"
                        (list
                        (bmf-collection-value objects "match-return")
                        (bmf-collection-value objects "match-name")
                        (empty)
                        (bml-ast-cut 0)
                        (list
                            (bml-parameter-component (bmf-collection-value objects "context-type") (bmf-collection-value objects "context-name"))
                            (bml-parameter-component (bmf-collection-value objects "env-type") (bmf-collection-value objects "env-name"))
                            (bml-parameter-component (bmf-collection-value objects "tag-type") (bmf-collection-value objects "tag-name"))))))
            (let as-string-method
                (comp-bml-component
                        "Method"
                        (list
                        (bmf-collection-value objects "as-string-return")
                        (bmf-collection-value objects "as-string-name")
                        (empty)
                        (bml-ast-return
                            (bml-ast-string
                                (bmf-collection-value objects "as-string-value")))
                        (empty))))
            (let as-create-method
                (comp-bml-component
                        "Method"
                        (list
                        (bmf-collection-value objects "as-create-return")
                        (bmf-collection-value objects "as-create-name")
                        (empty)
                        (bml-ast-return
                            (bml-ast-string
                                (bmf-collection-value objects "as-create-value")))
                        (empty))))
            (let section
                (comp-bml-component
                    "Section"
                    (list
                        ""
                        section-properties
                        (list match-method as-string-method as-create-method))))
            (comp-bml-component
                "Class"
                (list
                    "Cut"
                    (list (bml-true-property (bmf-collection-value objects "property")))
                    (list "Primitive")
                    (list section)))))

    (let bml-reference-rule-names
        (list
            "bmlCommentLine" "bmlCommentNest" "File" "MainRule" "Package" "Import"
            "BinaryType" "NamingConventions" "TypeNamingDecl" "TypeNamingConventions"
            "OperatorNamingConventions" "OpNamingDecl" "OperatorGroupNameDecl"
            "DefaultMethods" "ClassUse" "BMLClassUse" "ClassDecl" "Class" "SuperClass"
            "ClassSection" "Syntax" "ClassBlock" "Interface" "ParentInterface"
            "MemberField" "FieldDefinition" "InterfaceRef" "ArrayDefinition" "Field"
            "Method" "Parameter" "InterfaceSection" "InterfaceBlock" "ClassInterface"
            "Template" "TemplateParameter" "Range" "PackageName" "ClassName" "FieldName"
            "LabelName" "OpSym" "OpName" "MethodName" "TemplateArgument" "FullClassName"
            "Label" "Constant" "Const" "EnumConst" "Enum" "Guid" "Property"
            "TemplateProperty" "ClassDefProperty" "ClassDefSingletonProperty"
            "ClassDefUniqueProperty" "ClassDefStructProperty" "ClassDefNoObjectProperty"
            "ClassDefDynamicProperty" "ClassDefAliasProperty" "ClassDefOuterProperty"
            "LibraryProperty" "ForwardInterfaceProperty" "ForwardNameProperty"
            "AbstractProperty" "StaticProperty" "ClassProperty" "HiddenProperty"
            "DefaultProperty" "NameProperty" "GuidProperty" "MethodProperty"
            "OperatorProperty" "OperatorCostProperty" "CoercionOperatorProperty"
            "FinalMethodProperty" "ReassignMethodProperty" "NativeMethodProperty"
            "ExceptionMethodProperty" "ExplicitMethodProperty" "ExternMethodProperty"
            "ArrayProperty" "StrictArrayProperty" "RelaxedArrayProperty"
            "ExclusiveArrayProperty" "SharedArrayProperty" "ParameterProperty"
            "InParameterProperty" "OutParameterProperty" "InOutParameterProperty"
            "AssignParameterProperty" "MemberProperty" "GetMemberProperty"
            "PutMemberProperty" "DelegateMemberProperty" "InlineMemberProperty"
            "ConstMemberProperty" "AccessProperty" "PublicAccessProperty"
            "PrivateAccessProperty" "ProtectedAccessProperty" "Properties" "spc"
            "Statement" "CodeBlock" "ExpressionStatement" "BMLLabel" "For" "While"
            "Loop" "CaseExpr" "Case" "Switch" "SwitchBlock" "Select" "Fail" "With"
            "Choose" "If" "Return" "Break" "Continue" "Try" "Throw" "asmId"
            "asmClassUse" "Asm" "asmBlock" "asmLocalDecl" "asmStatement" "asmArgument"
            "asmConst" "asmLabelDecl" "asmMethodRef" "asmMethodSignature" "asmReg"
            "op" "Expression" "BaseExpr" "Identifier" "LocalField" "ConstExpression"
            "float" "Char" "Array" "Block" "Anonymous" "Arguments"
            "TypeCastOp" "SelectOp" "ItemAtOp" "IfOp" "BMFRule" "BMFLit" "BMFRange"
            "BMFChar" "BMFBasis" "BMFLiteral" "BMFCall" "BMFCallBase" "BMFPrim"
            "BMFInline" "BMFTag" "BMFExpr" "BMFTerm" "BMFFactor" "BMFItemMethod"
            "BMFItem" "BMFOpt" "BMFMust" "BMFAttribute"))

    (let bml-thesis-bmf-primitives
        (list "Nil" "Fail" "EndOfFile" "EndOfLine" "Cut" "MultiMatch" "Primitive"))

    (let bml-thesis-bmf-primitive-rule-names
        (list "bmf-nil" "bmf-fail" "bmf-end-of-file" "bmf-end-of-line"
              "bmf-cut-primitive" "bmf-multi-match" "bmf-primitive-base"))

    (let bml-compiler-rules
        (list
            (list "bml-package"
                  (list "sequence" (bml-kw "package") (list "capture" "name" (object-lit "bml-name" "")) (bml-op ";"))
                  bml-compile-package
                  bmf-identity-inverse)
            (list "bml-import"
                  (list "sequence" (bml-kw "import") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "star" (object-lit "bml-op" "")) (bml-op ";"))
                  bml-compile-import
                  bmf-identity-inverse)
            (list "bml-binary-type"
                  (list "sequence" (bml-kw "binary") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "fields" (object-lit "bml-list" "")))
                  bml-compile-binary-type
                  bmf-identity-inverse)
            (list "bml-class"
                  (list "sequence" (bml-kw "class") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (list "capture" "supers" (object-lit "bml-list" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-class
                  bmf-identity-inverse)
            (list "bml-interface"
                  (list "sequence" (bml-kw "interface") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (list "capture" "parent" (object-lit "bml-name" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-interface
                  bmf-identity-inverse)
            (list "bml-template"
                  (list "sequence" (bml-kw "template") (list "capture" "parameters" (object-lit "bml-list" "")) (list "capture" "kind" (object-lit "bml-name" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-template
                  bmf-identity-inverse)
            (list "bml-section"
                  (list "sequence" (bml-kw "section") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-section
                  bmf-identity-inverse)
            (list "bml-syntax"
                  (list "sequence" (bml-kw "syntax") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "rules" (object-lit "bml-list" "")) (list "capture" "attributes" (object-lit "bml-list" "")))
                  bml-compile-syntax
                  bmf-identity-inverse)
            (list "bml-field"
                  (list "sequence" (list "capture" "type" (object-lit "bml-name" "")) (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (bml-op ";"))
                  bml-compile-field
                  bmf-identity-inverse)
            (list "bml-const"
                  (list "sequence" (bml-kw "const") (list "capture" "type" (object-lit "bml-name" "")) (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (bml-op "=") (list "capture" "value" (object-lit "bml-int" "")))
                  bml-compile-const
                  bmf-identity-inverse)
            (list "bml-enum"
                  (list "sequence" (bml-kw "enum") (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (list "capture" "base" (object-lit "bml-name" "")) (list "capture" "values" (object-lit "bml-list" "")))
                  bml-compile-enum
                  bmf-identity-inverse)
            (list "bml-method"
                  (list "sequence" (list "capture" "return" (object-lit "bml-name" "")) (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-method
                  bmf-identity-inverse)
            (list "bml-parameter"
                  (list "sequence" (list "capture" "type" (object-lit "bml-name" "")) (list "capture" "name" (object-lit "bml-name" "")) (list "capture" "properties" (object-lit "bml-list" "")))
                  bml-compile-parameter
                  bmf-identity-inverse)
            (list "bml-property"
                  (list "sequence" (list "capture" "name" (object-lit "bml-property" "")) (list "capture" "value" (object-lit "bml-name" "")))
                  bml-compile-property
                  bmf-identity-inverse)
            (list "bml-statement"
                  (list "sequence" (list "capture" "kind" (object-lit "bml-keyword" "")) (list "capture" "value" (object-lit "bml-name" "")) (list "capture" "body" (object-lit "bml-list" "")))
                  bml-compile-statement
                  bmf-identity-inverse)
            (list "bml-expression"
                  (list "sequence" (list "capture" "kind" (object-lit "bml-name" "")) (list "capture" "left" (object-lit "bml-name" "")) (list "capture" "right" (object-lit "bml-name" "")))
                  bml-compile-expression
                  bmf-identity-inverse)
            (list "bml-asm"
                  (list "sequence" (bml-kw "asm") (list "capture" "locals" (object-lit "bml-list" "")) (list "capture" "statements" (object-lit "bml-list" "")) (list "capture" "blocks" (object-lit "bml-list" "")))
                  bml-compile-asm
                  bmf-identity-inverse)
            (list "bml-main-rule"
                  (list "capture" "item" (object-lit "bml-list" ""))
                  bml-compile-main-rule
                  bmf-identity-inverse)
            (list "bml-file"
                  (list "capture" "items" (object-lit "bml-list" ""))
                  bml-compile-file
                  bmf-identity-inverse)))

    (defn bml-compiler-rule-name (r) (head r))

    (defn bml-compiler-find-rule (rule-name rules)
        (if (nil? rules) (empty)
            (if (str_eq (bml-compiler-rule-name (head rules)) rule-name)
                (head rules)
                (bml-compiler-find-rule rule-name (tail rules)))))

    (defn bml-compiler-has-rule? (rule-name)
        (if (nil? (bml-compiler-find-rule rule-name bml-compiler-rules)) false true))

    (defn bml-compiler-rule-count-loop (rules)
        (if (nil? rules) 0
            (add 1 (bml-compiler-rule-count-loop (tail rules)))))

    (defn bml-compiler-rule-count (_x)
        (bml-compiler-rule-count-loop bml-compiler-rules))

    (defn bml-reference-rule-count (_x)
        (len bml-reference-rule-names))

    (defn bml-thesis-bmf-primitive-count (_x)
        (len bml-thesis-bmf-primitives))

    (defn apply-bml-compiler-rule (rule-name objects)
        (apply-object-rule (bml-compiler-find-rule rule-name bml-compiler-rules) objects))

    ;; --- BMF rule emitters ------------------------------------------

    (defn bml-emit-class-header (objects)
        (bml-ast-class
            (bmf-collection-value objects "name")
            (bmf-collection-value objects "base")
            (intern_node BML-AST-BLOCK (empty))))

    (defn bml-emit-class-two-base-header (objects)
        (comp-bml-component
            "Class"
            (list
                (bmf-collection-value objects "name")
                (empty)
                (list (bmf-collection-value objects "first")
                      (bmf-collection-value objects "second"))
                (empty))))

    (defn bml-source-class-header (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "class")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ":")
                  (bml-src-name (node_value (head (tail kids)))))))

    (defn bml-emit-interface-header (objects)
        (bml-ast-interface
            (bmf-collection-value objects "name")
            (bmf-collection-value objects "parent")
            (intern_node BML-AST-BLOCK (empty))))

    (defn bml-source-interface-header (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "interface")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ":")
                  (bml-src-name (node_value (head (tail kids)))))))

    (defn bml-emit-package-simple (objects)
        (bml-ast-package (bmf-collection-value objects "name")))

    (defn bml-source-package-simple (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "package")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ";"))))

    (defn bml-emit-import-simple (objects)
        (bml-ast-import (bmf-collection-value objects "name") ""))

    (defn bml-source-import-simple (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "import")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ";"))))

    (defn bml-emit-import-star-simple (objects)
        (bml-ast-import (bmf-collection-value objects "name") ".*"))

    (defn bml-source-import-star-simple (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "import")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ".*")
                  (bml-src-op ";"))))

    (defn bml-emit-section-header (objects)
        (bml-ast-section
            (intern_node BML-AST-NAME
                         (list (bml-cap-str objects "property")))
            (intern_node BML-AST-BLOCK (empty))))

    (defn bml-emit-field (objects)
        (bml-ast-field
            (bmf-collection-value objects "type")
            (bmf-collection-value objects "name")))

    (defn bml-source-field (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-name (node_value (head kids)))
                  (bml-src-name (node_value (head (tail kids))))
                  (bml-src-op ";"))))

    (defn bml-emit-const-int (objects)
        (bml-ast-const
            (bmf-collection-value objects "type")
            (bmf-collection-value objects "name")
            (intern_node BML-AST-INT (list (bml-cap-int objects "value")))))

    (defn bml-source-const-int (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (let value-node (head (tail (tail kids))))
            (list (bml-src-keyword "const")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-name (node_value (head (tail kids))))
                  (bml-src-op "=")
                  (bml-src-int (int_to_str (node_value (head (node_children value-node)))))
                  (bml-src-op ";"))))

    (defn bml-emit-return-int (objects)
        (bml-ast-return
            (intern_node BML-AST-INT (list (bml-cap-int objects "value")))))

    (defn bml-source-return-int (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (let value-node (head kids))
            (list (bml-src-keyword "return")
                  (bml-src-int (int_to_str (node_value (head (node_children value-node)))))
                  (bml-src-op ";"))))

    (defn bml-emit-break-simple (objects)
        (bml-ast-break (bmf-collection-value objects "label")))

    (defn bml-source-break-simple (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "break")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ";"))))

    (defn bml-emit-continue-simple (objects)
        (bml-ast-continue (bmf-collection-value objects "label")))

    (defn bml-source-continue-simple (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-keyword "continue")
                  (bml-src-name (node_value (head kids)))
                  (bml-src-op ";"))))

    (defn bml-emit-throw-int (objects)
        (bml-ast-throw
            (intern_node BML-AST-INT (list (bml-cap-int objects "value")))))

    (defn bml-source-throw-int (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (let value-node (head kids))
            (list (bml-src-keyword "throw")
                  (bml-src-int (int_to_str (node_value (head (node_children value-node)))))
                  (bml-src-op ";"))))

    (defn bml-emit-try-throw-return (objects)
        (bml-ast-try
            (bml-ast-block
                (list (bml-ast-throw
                        (intern_node BML-AST-INT
                                     (list (bml-cap-int objects "throw-value"))))))
            (bml-ast-block
                (list (bml-ast-return
                        (intern_node BML-AST-INT
                                     (list (bml-cap-int objects "return-value"))))))))

    (defn bml-source-try-throw-return (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (let body (head kids))
            (let handler (head (tail kids)))
            (let throw-node (head (node_children body)))
            (let return-node (head (node_children handler)))
            (let throw-value-node (head (node_children throw-node)))
            (let return-value-node (head (node_children return-node)))
            (list (bml-src-keyword "try") (bml-src-op "{")
                  (bml-src-keyword "throw")
                  (bml-src-int (int_to_str (node_value (head (node_children throw-value-node)))))
                  (bml-src-op ";") (bml-src-op "}")
                  (bml-src-keyword "catch") (bml-src-op "{")
                  (bml-src-keyword "return")
                  (bml-src-int (int_to_str (node_value (head (node_children return-value-node)))))
                  (bml-src-op ";") (bml-src-op "}"))))

    (defn bml-emit-char-lit (objects)
        (bml-ast-char (bmf-collection-value objects "value")))

    (defn bml-source-char-lit (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (list (bml-src-op "'")
                  (bml-src-string (node_value (head kids)))
                  (bml-src-op "'"))))

    (defn bml-emit-array-int (objects)
        (bml-ast-array
            (list (intern_node BML-AST-INT (list (bml-cap-int objects "value"))))))

    (defn bml-source-array-int (object)
        (do
            (let kids (node_children (bmf-object-value object)))
            (let value-node (head kids))
            (list (bml-src-op "#(")
                  (bml-src-int (int_to_str (node_value (head (node_children value-node)))))
                  (bml-src-op ")"))))

    (defn bml-emit-method-return-add (objects)
        (bml-ast-method
            (bmf-collection-value objects "name")
            (bml-ast-return
                (bml-ast-add
                    (intern_node BML-AST-INT (list (bml-cap-int objects "left")))
                    (intern_node BML-AST-INT (list (bml-cap-int objects "right")))))))

    (defn bml-emit-choose-fail-int (objects)
        (bml-ast-choose
            (list
                (bml-ast-block (list (bml-ast-fail 0)))
                (bml-ast-block
                    (list (bml-ast-return
                            (intern_node BML-AST-INT
                                         (list (bml-cap-int objects "value")))))))))

    (defn bml-emit-fail-simple (_objects)
        (bml-ast-fail 0))

    (defn bml-source-fail-simple (_object)
        (list (bml-src-keyword "fail") (bml-src-op ";")))

    (defn bml-emit-cut-simple (_objects)
        (bml-ast-cut 0))

    (defn bml-source-cut-simple (_object)
        (list (bml-src-keyword "cut") (bml-src-op ";")))

    (defn bml-emit-mark-simple (_objects)
        (bml-ast-save 0))

    (defn bml-source-mark-simple (_object)
        (list (bml-src-keyword "mark") (bml-src-op ";")))

    (defn bml-emit-state-int (objects)
        (bml-ast-block
            (list (bml-ast-save 0)
                  (intern_node BML-AST-INT (list (bml-cap-int objects "value")))
                  (bml-ast-discard 0))))

    (defn bml-emit-node-source (objects)
        (compiler-object "bml-source-node" objects objects compiler-identity-inverse))

    ;; --- BML rulebook ------------------------------------------------

    (let bml-bmf-reference-model
        (comp-bmf-syntax
            "BML"
            "bml"
            "file"
            (list
                (comp-bmf-rule "Rule" (empty) (comp-bmf-sequence (empty)) (comp-bmf-process "Invoke" "Object"))
                (comp-bmf-rule "Sequence" (empty) (comp-bmf-sequence (empty)) (empty))
                (comp-bmf-rule "Branch" (empty) (comp-bmf-branch (empty)) (empty))
                (comp-bmf-rule "Repeat" (empty) (comp-bmf-repeat (empty) 0 2147483647) (empty))
                (comp-bmf-rule "Tag" (empty) (comp-bmf-tag "" (empty)) (empty))
                (comp-bmf-rule "RuleCall" (empty) (comp-bmf-rule-call "name" (empty)) (empty))
                (comp-bmf-rule "MethodCall" (empty) (comp-bmf-method-call "name" (empty)) (empty))
                (comp-bmf-rule "Primitive" (empty) (comp-bmf-primitive "Cut" (empty)) (empty))
                (comp-bmf-rule "CharRange" (empty) (comp-bmf-char-range "a" "z") (empty))
                (comp-bmf-rule "CharChain" (empty) (comp-bmf-char-chain "literal") (empty)))
            (empty)
            (empty)))

    section [bml.bmf] {
      bml-comment-line ::= "/" "/" char-not-eol eol => bml-emit-node-source;
      bml-comment-nest ::= "/" "*" bml-comment-body "*" "/" => bml-emit-node-source;
      file ::= init main-rule eof => bml-emit-node-source;
      main-rule ::= include binary-type naming-conventions default-methods package import class interface template asm statement => bml-emit-node-source;
      package ::= "package" spc cut package-name ";" => bml-emit-node-source;
      import ::= "import" spc cut full-class-name import-star ";" => bml-emit-node-source;
      binary-type ::= "binary" cut $name:name "[" binary-field-list "]" => bml-emit-node-source;
      naming-conventions ::= "naming" cut "conventions" "{" type-naming-conventions operator-naming-conventions "}" => bml-emit-node-source;
      type-naming-decl ::= full-class-name cut "=" $name:name eol => bml-emit-node-source;
      operator-naming-decl ::= "'" op-name "'" cut "=" $name:name eol => bml-emit-node-source;
      default-methods ::= "DefaultMethods" cut "{" method "}" => bml-emit-node-source;
      package-simple ::= "package" $name:name ";" => bml-emit-package-simple <= bml-source-package-simple;
      file-package-one ::= "package" $name:name ";" => bml-emit-file-package-one;
      file-package-two ::= "package" $first:name "." $second:name ";" => bml-emit-file-package-two;
      import-simple ::= "import" $name:name ";" => bml-emit-import-simple <= bml-source-import-simple;
      import-star-simple ::= "import" $name:name ".*" ";" => bml-emit-import-star-simple <= bml-source-import-star-simple;
      file-import-one-star ::= "import" $name:name ".*" ";" => bml-emit-file-import-one-star;
      file-import-two-star ::= "import" $first:name "." $second:name ".*" ";" => bml-emit-file-import-two-star;
      file-include ::= "#" $directive:name $path:string => bml-emit-file-include;
      class-header ::= "class" $name:name ":" $base:name => bml-emit-class-header <= bml-source-class-header;
      class-two-base-header ::= "class" $name:name ":" $first:name "," $second:name => bml-emit-class-two-base-header;
      file-class-empty-two-base ::= "class" $name:name "[" $property:property "]" ":" $first:name "," $second:name "{" "}" => bml-emit-file-class-empty-two-base;
      file-class-section-field ::= "class" $name:name "[" $property:property "]" ":" $base:name "{" "section" "[" $section-property:property "]" "{" $field-type:name $field-name:name ";" "}" "}" => bml-emit-file-class-section-field;
      file-class-section-field-primitive ::= "class" $name:name "[" $property:property "]" ":" "Primitive" "{" "section" "[" $section-property:property "]" "{" $field-type:name $field-name:name ";" "}" "}" => bml-emit-file-class-section-field-primitive;
      file-class-section-const-string ::= "class" $name:name "[" $property:property "]" ":" $base:name "{" "section" "[" "class" "," $section-property:property "]" "{" "const" $const-type:name $const-name:name "=" $const-value:string ";" "}" "}" => bml-emit-file-class-section-const-string;
      file-class-section-return-method ::= "class" $name:name "[" $property:property "]" ":" $base:name "{" "section" "[" $section-property:property "]" "{" $return-type:name $method-name:name "(" ")" "{" "return" $return-value:int ";" "}" "}" "}" => bml-emit-file-class-section-return-method;
      file-class-primitive-cut ::= "class" "Cut" "[" $property:property "]" ":" "Primitive" "{" "section" "[" $section-property:property "]" "{" $match-return:name $match-name:name "(" $context-type:name $context-name:name "," $env-type:name $env-name:name "," $tag-type:name $tag-name:name ")" "{" $system-name:name "." "Cut" "(" $arg-object:name "." $argument-name:name "(" $arg-index:int ")" ")" ";" "}" $as-string-return:name $as-string-name:name "(" ")" "{" "return" $as-string-value:string ";" "}" $as-create-return:name $as-create-name:name "(" ")" "{" "return" $as-create-value:string ";" "}" "}" "}" => bml-emit-file-class-primitive-cut;
      class ::= "class" spc cut class-name properties super-class-list class-block => bml-emit-node-source;
      interface-header ::= "interface" $name:name ":" $parent:name => bml-emit-interface-header <= bml-source-interface-header;
      file-interface-empty ::= "interface" $name:name ":" $parent:name "{" "}" => bml-emit-file-interface-empty;
      interface ::= "interface" cut class-name properties parent-interface interface-block => bml-emit-node-source;
      template ::= "template" "<" cut template-parameter-list ">" class-or-interface => bml-emit-node-source;
      section-header ::= "section" "[" $property:property "]" => bml-emit-section-header;
      section-comma-header ::= "section" "[" $first:property "," $second:property "]" => bml-emit-node-source;
      section-named-header ::= "section" $name:name "[" $property:property "]" => bml-emit-node-source;
      section-named-comma-header ::= "section" $name:name "[" $first:property "," $second:property "]" => bml-emit-node-source;
      section-library-header ::= "section" "[" "library" "=" $value:string "]" => bml-emit-node-source;
      class-section ::= "section" spc cut properties class-block => bml-emit-node-source;
      syntax-section ::= "syntax" spc cut "[" $name:name "]" "{" bmf-rule-list bmf-attribute-list "}" => bml-emit-node-source;
      class-block ::= "{" template class-section syntax-section class-interface code-block class const method field "}" => bml-emit-node-source;
      interface-block ::= "{" interface-section constant method "}" => bml-emit-node-source;
      interface-ref ::= bml-class-use method-params array-definition-list => bml-emit-node-source;
      array-definition ::= "[" range "]" => bml-emit-node-source;
      field ::= $type:name $name:name ";" => bml-emit-field <= bml-source-field;
      field-definition ::= interface-ref field-list => bml-emit-node-source;
      member-field ::= field-name properties field-init => bml-emit-node-source;
      const-int ::= "const" $type:name $name:name "=" $value:int ";" => bml-emit-const-int <= bml-source-const-int;
      const ::= "const" spc cut interface-ref field-name properties "=" expression => bml-emit-node-source;
      enum ::= "enum" spc cut class-name properties enum-base "{" enum-const-list "}" => bml-emit-node-source;
      property ::= member-property "|" parameter-property "|" method-property "|" array-property "|" access-property "|" class-def-property "|" library-property "|" name-property "|" guid-property => bml-emit-node-source;
      properties ::= "[" property-list "]" => bml-emit-node-source;
      method-return-add ::= $type:name $name:name "(" ")" "{" "return" $left:int "+" $right:int ";" "}" => bml-emit-method-return-add;
      method ::= method-head properties code-block => bml-emit-node-source;
      method-head ::= "operator" spc cut full-class-name "|" interface-ref method-name => bml-emit-node-source;
      parameter ::= field-definition => bml-emit-node-source;
      statement ::= for while loop switch select if if-fail while-success return break continue try throw fail mark-simple cut-simple with choice choose asm expression-statement code-block => bml-emit-node-source;
      code-block ::= "{" cut statement-list "}" => bml-emit-node-source;
      expression-statement ::= expression ";" => bml-emit-node-source;
      for ::= label "for" "(" cut for-init expression ";" expression ")" statement => bml-emit-node-source;
      while ::= label "while" "(" cut expression ")" statement => bml-emit-node-source;
      if-fail ::= "if_fail" code-block => bml-emit-node-source;
      while-success ::= "while_success" code-block => bml-emit-node-source;
      loop ::= label "loop" spc cut statement => bml-emit-node-source;
      switch ::= "switch" "(" cut expression ")" switch-block => bml-emit-node-source;
      select ::= "select" "(" cut expression ")" switch-block => bml-emit-node-source;
      case ::= "case" spc cut case-expr ":" statement-list => bml-emit-node-source;
      default-case ::= "default" ":" cut statement-list => bml-emit-node-source;
      if ::= "if" "(" cut expression ")" statement "else" spc cut statement => bml-emit-node-source;
      return-int ::= "return" $value:int ";" => bml-emit-return-int <= bml-source-return-int;
      return ::= "return" expression ";" => bml-emit-node-source;
      break-simple ::= "break" $label:name ";" => bml-emit-break-simple <= bml-source-break-simple;
      break ::= "break" label-name ";" cut => bml-emit-node-source;
      continue-simple ::= "continue" $label:name ";" => bml-emit-continue-simple <= bml-source-continue-simple;
      continue ::= "continue" label-name ";" cut => bml-emit-node-source;
      try-throw-return ::= "try" "{" "throw" $throw-value:int ";" "}" "catch" "{" "return" $return-value:int ";" "}" => bml-emit-try-throw-return <= bml-source-try-throw-return;
      try ::= "try" spc cut statement "catch" "(" interface-ref field-name properties ")" statement => bml-emit-node-source;
      throw-int ::= "throw" $value:int ";" => bml-emit-throw-int <= bml-source-throw-int;
      throw ::= "throw" spc cut expression ";" cut => bml-emit-node-source;
      fail-simple ::= "fail" ";" => bml-emit-fail-simple <= bml-source-fail-simple;
      fail ::= fail-simple => bml-emit-node-source;
      cut-simple ::= "cut" ";" => bml-emit-cut-simple <= bml-source-cut-simple;
      mark-simple ::= "mark" ";" => bml-emit-mark-simple <= bml-source-mark-simple;
      nostate-property ::= "nostate" => bml-emit-node-source;
      choice-fail-int ::= "choice" "{" "fail" ";" "}" "," "{" "return" $value:int ";" "}" => bml-emit-choose-fail-int;
      choice ::= "choice" code-block choose-tail => bml-emit-node-source;
      choose-fail-int ::= "choose" "{" "fail" ";" "}" "," "{" "return" $value:int ";" "}" => bml-emit-choose-fail-int;
      choose ::= "choose" code-block choose-tail => bml-emit-node-source;
      asm ::= "asm" cut "{" asm-local-decl-list asm-statement-list "}" => bml-emit-node-source;
      asm-block ::= ".begin" cut asm-local-decl-list asm-statement-list ".end" => bml-emit-node-source;
      expression ::= op base-expr => bml-emit-node-source;
      base-expr ::= "(" expression ")" "|" identifier "|" const-expression => bml-emit-node-source;
      identifier ::= interface-ref local-field-list => bml-emit-node-source;
      const-expression ::= float "|" int "|" string "|" char "|" array "|" block "|" anonymous => bml-emit-node-source;
      float ::= signed-digits "." digits exponent => bml-emit-node-source;
      char-lit ::= "'" $value:string "'" => bml-emit-char-lit <= bml-source-char-lit;
      char ::= "'" cut char-body "'" => bml-emit-node-source;
      array-int ::= "#(" $value:int ")" => bml-emit-array-int <= bml-source-array-int;
      array ::= "#(" expression-list ")" => bml-emit-node-source;
      block ::= interface-ref "(" parameter-list ")" properties code-block => bml-emit-node-source;
      anonymous ::= "class" spc cut bml-class-use "(" parameter-list ")" properties class-block => bml-emit-node-source;
      arguments ::= expression-list => bml-emit-node-source;
      op-select ::= "." select-op => bml-emit-node-source;
      op-item-at ::= "[" item-at-op "]" => bml-emit-node-source;
      op-call ::= "(" arguments ")" => bml-emit-node-source;
      op-instanceof ::= "instanceof" => bml-emit-node-source;
      op-type-cast ::= "(" type-cast-op ")" => bml-emit-node-source;
      op-prefix-inc ::= "++" => bml-emit-node-source;
      op-prefix-dec ::= "--" => bml-emit-node-source;
      op-not ::= "!" => bml-emit-node-source;
      op-bit-not ::= "~" => bml-emit-node-source;
      op-neg ::= "-" => bml-emit-node-source;
      op-pos ::= "+" => bml-emit-node-source;
      op-post-inc ::= "++" => bml-emit-node-source;
      op-post-dec ::= "--" => bml-emit-node-source;
      op-mul ::= "*" => bml-emit-node-source;
      op-div ::= "/" => bml-emit-node-source;
      op-mod ::= "%" => bml-emit-node-source;
      op-add ::= "+" => bml-emit-node-source;
      op-sub ::= "-" => bml-emit-node-source;
      op-shl ::= "<<" => bml-emit-node-source;
      op-shr-unsigned ::= ">>>" => bml-emit-node-source;
      op-shr ::= ">>" => bml-emit-node-source;
      op-lt ::= "<" => bml-emit-node-source;
      op-le ::= "<=" => bml-emit-node-source;
      op-gt ::= ">" => bml-emit-node-source;
      op-ge ::= ">=" => bml-emit-node-source;
      op-eq ::= "==" => bml-emit-node-source;
      op-ne ::= "!=" => bml-emit-node-source;
      op-bit-and ::= "&" => bml-emit-node-source;
      op-bit-xor ::= "^" => bml-emit-node-source;
      op-bit-or ::= "|" => bml-emit-node-source;
      op-and ::= "&&" => bml-emit-node-source;
      op-or ::= "||" => bml-emit-node-source;
      op-if ::= "?" if-op ":" => bml-emit-node-source;
      op-assign-ref ::= ":=" => bml-emit-node-source;
      op-assign ::= "=" => bml-emit-node-source;
      op-mul-assign ::= "*=" => bml-emit-node-source;
      op-div-assign ::= "/=" => bml-emit-node-source;
      op-mod-assign ::= "%=" => bml-emit-node-source;
      op-add-assign ::= "+=" => bml-emit-node-source;
      op-sub-assign ::= "-=" => bml-emit-node-source;
      op-shl-assign ::= "<<=" => bml-emit-node-source;
      op-shr-assign ::= ">>=" => bml-emit-node-source;
      op-and-assign ::= "&=" => bml-emit-node-source;
      op-or-assign ::= "|=" => bml-emit-node-source;
      op-xor-assign ::= "^=" => bml-emit-node-source;
      bmf-rule ::= bmf-call "::=" bmf-rule-body ";" cut => bml-emit-node-source;
      bmf-lit ::= bmf-bang-prefix string bmf-bang-suffix => bml-emit-node-source;
      bmf-range ::= bmf-char ".." bmf-char => bml-emit-node-source;
      bmf-char ::= "\\" cut int "|" "'" cut bmf-char-body "'" => bml-emit-node-source;
      bmf-basis ::= bmf-range "|" bmf-lit "|" bmf-call-base "|" bmf-primitive => bml-emit-node-source;
      bmf-literal ::= float "|" int "|" string "|" "#" cut field-name => bml-emit-node-source;
      bmf-call ::= $base:name bmf-call-args => bml-emit-node-source;
      bmf-call-base ::= bmf-call => bml-emit-node-source;
      bmf-primitive ::= bmf-nil "|" bmf-fail "|" bmf-end-of-file "|" bmf-end-of-line "|" bmf-cut-primitive "|" bmf-multi-match "|" bmf-primitive-base => bml-emit-node-source;
      bmf-nil ::= "Nil" => bml-emit-node-source;
      bmf-fail ::= "Fail" => bml-emit-node-source;
      bmf-end-of-file ::= "EndOfFile" => bml-emit-node-source;
      bmf-end-of-line ::= "EndOfLine" => bml-emit-node-source;
      bmf-cut-primitive ::= "Cut" => bml-emit-node-source;
      bmf-multi-match ::= "MultiMatch" => bml-emit-node-source;
      bmf-multi-match-count ::= "MultiMatch" "(" bmf-expr "," int ")" => bml-emit-node-source;
      bmf-primitive-base ::= "Primitive" => bml-emit-node-source;
      bmf-prim ::= "<<prim" spc id ">>" => bml-emit-node-source;
      bmf-inline ::= "<<" bmf-expr ">>" => bml-emit-node-source;
      bmf-tag ::= "$" $tag:name cut ":" => bml-emit-node-source;
      bmf-expr ::= bmf-term bmf-expr-tail => bml-emit-node-source;
      bmf-term ::= bmf-factor bmf-term-tail => bml-emit-node-source;
      bmf-factor ::= bmf-tag bmf-factor-body => bml-emit-node-source;
      bmf-item-method ::= bmf-item "." cut bmf-call-base => bml-emit-node-source;
      bmf-item ::= bmf-opt "|" bmf-basis "|" bmf-must => bml-emit-node-source;
      bmf-opt ::= "[" cut bmf-expr "]" => bml-emit-node-source;
      bmf-must ::= int "(" bmf-expr ")" int => bml-emit-node-source;
      bmf-attribute ::= id-list code-block => bml-emit-node-source;
      state-int ::= "save" ";" $value:int ";" "discard" ";" => bml-emit-state-int;
    }

    (defn bml-bmf-rule-name (r) (head r))

    (defn bml-bmf-find-rule (rule-name rules)
        (if (nil? rules) (empty)
            (if (str_eq (bml-bmf-rule-name (head rules)) rule-name)
                (head rules)
                (bml-bmf-find-rule rule-name (tail rules)))))

    (defn apply-bml-bmf-rule (rule-name objects)
        (apply-object-rule (bml-bmf-find-rule rule-name bml-bmf-rules) objects))

    (defn bml-bmf-match-node (match)
        (bmf-object-value (cap-get (match-caps match) "result")))

    (defn bml-source-executable-rules (_x)
        (list "try-throw-return"
              "choice-fail-int"
              "choose-fail-int"
              "state-int"
              "return-int"
              "fail-simple"
              "cut-simple"
              "mark-simple"
              "throw-int"))

    (defn bml-source-declaration-rules (_x)
        (list "file-include"
              "file-class-primitive-cut"
              "file-class-section-return-method"
              "file-class-section-const-string"
              "file-class-section-field-primitive"
              "file-class-section-field"
              "file-class-empty-two-base"
              "file-interface-empty"
              "file-package-two"
              "file-package-one"
              "file-import-two-star"
              "file-import-one-star"))

    (defn bml-source-parse-step (ok rule node rest)
        (list "bml-source-parse-step" ok rule node rest))

    (defn bml-source-parse-step-ok? (step) (nth step 1))
    (defn bml-source-parse-step-rule (step) (nth step 2))
    (defn bml-source-parse-step-node (step) (nth step 3))
    (defn bml-source-parse-step-rest (step) (nth step 4))

    (defn bml-source-parse-executable-step-loop (objects rule-names)
        (if (nil? rule-names)
            (bml-source-parse-step false "" (empty) objects)
            (do
                (let rule-name (head rule-names))
                (let m (apply-bml-bmf-rule rule-name objects))
                (if (match? m)
                    (bml-source-parse-step
                        true
                        rule-name
                        (bml-bmf-match-node m)
                        (match-rest m))
                    (bml-source-parse-executable-step-loop
                        objects
                        (tail rule-names))))))

    (defn bml-source-token-value? (object value)
        (if (nil? object) false
            (str_eq (bmf-object-value object) value)))

    (defn bml-source-name-token? (object)
        (if (nil? object) false
            (if (str_eq (bmf-object-kind object) "bml-name") true
                (str_eq (bmf-object-kind object) "bml-keyword"))))

    (defn bml-source-property-token? (object)
        (if (nil? object) false
            (str_eq (bmf-object-kind object) "bml-property")))

    (defn bml-source-property-name-token? (object)
        (if (bml-source-name-token? object) true
            (bml-source-property-token? object)))

    (defn bml-source-token-values (objects)
        (if (nil? objects) (empty)
            (cons
                (bmf-object-value (head objects))
                (bml-source-token-values (tail objects)))))

    (defn bml-source-property-value-parse (objects)
        (if (bml-source-token-value? (head objects) "=")
            (list (bmf-object-value (nth objects 1)) (drop 2 objects))
            (list "true" objects)))

    (defn bml-source-properties-loop (objects acc)
        (if (nil? objects)
            (list (reverse-list acc) objects)
            (do
                (let object (head objects))
                (if (bml-source-token-value? object "]")
                    (list (reverse-list acc) (tail objects))
                (if (bml-source-token-value? object ",")
                    (bml-source-properties-loop (tail objects) acc)
                (if (bml-source-property-name-token? object)
                    (do
                        (let value-parse
                            (bml-source-property-value-parse (tail objects)))
                        (bml-source-properties-loop
                            (nth value-parse 1)
                            (cons
                                (bml-property-component
                                    (bmf-object-value object)
                                    (nth value-parse 0))
                                acc)))
                    (bml-source-properties-loop (tail objects) acc)))))))

    (defn bml-source-properties-parse (objects)
        (if (bml-source-token-value? (head objects) "[")
            (bml-source-properties-loop (tail objects) (empty))
            (list (empty) objects)))

    (defn bml-source-class-property-parse (objects)
        (bml-source-properties-parse objects))

    (defn bml-source-parse-qualified-name-loop (objects current)
        (if (nil? objects)
            (list current objects)
            (if (bml-source-token-value? (head objects) ".")
                (if (bml-source-name-token? (nth objects 1))
                    (bml-source-parse-qualified-name-loop
                        (drop 2 objects)
                        (str_concat
                            (str_concat current ".")
                            (bmf-object-value (nth objects 1))))
                    (list current objects))
                (list current objects))))

    (defn bml-source-parse-qualified-name (objects)
        (if (bml-source-name-token? (head objects))
            (bml-source-parse-qualified-name-loop
                (tail objects)
                (bmf-object-value (head objects)))
            (list "" objects)))

    (defn bml-source-parse-type (objects)
        (do
            (let name-parse (bml-source-parse-qualified-name objects))
            (let type-name (nth name-parse 0))
            (let rest (nth name-parse 1))
            (if (bml-source-token-value? (head rest) "[")
                (if (bml-source-token-value? (nth rest 1) "]")
                    (list (str_concat type-name "[]") (drop 2 rest))
                    name-parse)
                name-parse)))

    (defn bml-source-collect-balanced-brace-loop (objects depth acc)
        (if (nil? objects)
            (list (reverse-list acc) objects)
            (do
                (let object (head objects))
                (let value (bmf-object-value object))
                (if (str_eq value "{")
                    (bml-source-collect-balanced-brace-loop
                        (tail objects)
                        (add depth 1)
                        (cons object acc))
                (if (str_eq value "}")
                    (if (eq depth 1)
                        (list (reverse-list acc) (tail objects))
                        (bml-source-collect-balanced-brace-loop
                            (tail objects)
                            (sub depth 1)
                            (cons object acc)))
                    (bml-source-collect-balanced-brace-loop
                        (tail objects)
                        depth
                        (cons object acc)))))))

    (defn bml-source-collect-balanced-brace (objects)
        (if (bml-source-token-value? (head objects) "{")
            (bml-source-collect-balanced-brace-loop (tail objects) 1 (empty))
            (list (empty) objects)))

    (defn bml-source-collect-balanced-paren-loop (objects depth acc)
        (if (nil? objects)
            (list (reverse-list acc) objects)
            (do
                (let object (head objects))
                (let value (bmf-object-value object))
                (if (str_eq value "(")
                    (bml-source-collect-balanced-paren-loop
                        (tail objects)
                        (add depth 1)
                        (cons object acc))
                (if (str_eq value ")")
                    (if (eq depth 1)
                        (list (reverse-list acc) (tail objects))
                        (bml-source-collect-balanced-paren-loop
                            (tail objects)
                            (sub depth 1)
                            (cons object acc)))
                    (bml-source-collect-balanced-paren-loop
                        (tail objects)
                        depth
                        (cons object acc)))))))

    (defn bml-source-collect-balanced-paren (objects)
        (if (bml-source-token-value? (head objects) "(")
            (bml-source-collect-balanced-paren-loop (tail objects) 1 (empty))
            (list (empty) objects)))

    (defn bml-source-collect-until-semicolon-loop (objects acc)
        (if (nil? objects)
            (list (reverse-list acc) objects)
            (if (bml-source-token-value? (head objects) ";")
                (list (reverse-list acc) (tail objects))
                (bml-source-collect-until-semicolon-loop
                    (tail objects)
                    (cons (head objects) acc)))))

    (defn bml-source-parse-one-parameter (objects)
        (do
            (let type-parse (bml-source-parse-type objects))
            (let param-type (nth type-parse 0))
            (let after-type (nth type-parse 1))
            (let name-object (head after-type))
            (if (bml-source-name-token? name-object)
                (list
                    (bml-parameter-component
                        param-type
                        (bmf-object-value name-object))
                    (tail after-type))
                (list (empty) objects))))

    (defn bml-source-parse-parameters-loop (objects acc)
        (if (nil? objects)
            (reverse-list acc)
            (if (bml-source-token-value? (head objects) ",")
                (bml-source-parse-parameters-loop (tail objects) acc)
                (do
                    (let parsed (bml-source-parse-one-parameter objects))
                    (let parameter (nth parsed 0))
                    (if (nil? parameter)
                        (reverse-list acc)
                        (bml-source-parse-parameters-loop
                            (nth parsed 1)
                            (cons parameter acc)))))))

    (defn bml-source-parse-parameters (objects)
        (bml-source-parse-parameters-loop objects (empty)))

    (defn bml-source-body-source-from-tokens (tokens)
        (bml-body-source (bml-source-token-values tokens)))

    (defn bml-source-super-append-current (current acc)
        (if (str_eq current "") acc
            (cons current acc)))

    (defn bml-source-class-supers-loop (objects acc current)
        (if (nil? objects)
            (list (reverse-list (bml-source-super-append-current current acc)) objects)
            (do
                (let object (head objects))
                (let value (bmf-object-value object))
                (if (str_eq value "{")
                    (list (reverse-list (bml-source-super-append-current current acc)) objects)
                (if (str_eq value ",")
                    (bml-source-class-supers-loop
                        (tail objects)
                        (bml-source-super-append-current current acc)
                        "")
                (if (str_eq value ".")
                    (bml-source-class-supers-loop
                        (tail objects)
                        acc
                        (str_concat current "."))
                (if (bml-source-name-token? object)
                    (bml-source-class-supers-loop
                        (tail objects)
                        acc
                        (str_concat current value))
                    (bml-source-class-supers-loop
                        (tail objects)
                        acc
                        current))))))))

    (defn bml-source-class-supers-parse (objects)
        (if (bml-source-token-value? (head objects) ":")
            (bml-source-class-supers-loop (tail objects) (empty) "")
            (list (empty) objects)))

    (defn bml-source-skip-balanced-brace-loop (objects depth)
        (if (nil? objects) objects
            (do
                (let value (bmf-object-value (head objects)))
                (if (str_eq value "{")
                    (bml-source-skip-balanced-brace-loop (tail objects) (add depth 1))
                (if (str_eq value "}")
                    (if (eq depth 1)
                        (tail objects)
                        (bml-source-skip-balanced-brace-loop (tail objects) (sub depth 1)))
                    (bml-source-skip-balanced-brace-loop (tail objects) depth))))))

    (defn bml-source-skip-class-body (objects)
        (if (bml-source-token-value? (head objects) "{")
            (bml-source-skip-balanced-brace-loop (tail objects) 1)
            objects))

    (defn bml-source-parse-field-after-name (field-type field-name objects)
        (do
            (let properties-parse (bml-source-properties-parse objects))
            (let properties (nth properties-parse 0))
            (let after-properties (nth properties-parse 1))
            (if (bml-source-token-value? (head after-properties) "=")
                (do
                    (let init-parse
                        (bml-source-collect-until-semicolon-loop
                            (tail after-properties)
                            (empty)))
                    (bml-source-parse-step
                        true
                        "file-class-field"
                        (comp-bml-component
                            "Field"
                            (list
                                field-type
                                field-name
                                properties
                                (bml-source-token-values (nth init-parse 0))))
                        (nth init-parse 1)))
            (if (bml-source-token-value? (head after-properties) ";")
                (bml-source-parse-step
                    true
                    "file-class-field"
                    (comp-bml-component
                        "Field"
                        (list field-type field-name properties (empty)))
                    (tail after-properties))
                (bml-source-parse-step false "" (empty) objects)))))

    (defn bml-source-parse-method-after-name (return-type method-name objects)
        (if (bml-source-token-value? (head objects) "(")
            (do
                (let parameter-parse (bml-source-collect-balanced-paren objects))
                (let parameters (bml-source-parse-parameters (nth parameter-parse 0)))
                (let after-parameters (nth parameter-parse 1))
                (let properties-parse
                    (bml-source-properties-parse after-parameters))
                (let properties (nth properties-parse 0))
                (let after-properties (nth properties-parse 1))
                (if (bml-source-token-value? (head after-properties) "{")
                    (do
                        (let body-parse
                            (bml-source-collect-balanced-brace after-properties))
                        (bml-source-parse-step
                            true
                            "file-class-method"
                            (comp-bml-component
                                "Method"
                                (list
                                    return-type
                                    method-name
                                    properties
                                    (bml-source-body-source-from-tokens
                                        (nth body-parse 0))
                                    parameters))
                            (nth body-parse 1)))
                    (bml-source-parse-step false "" (empty) objects)))
            (bml-source-parse-step false "" (empty) objects)))

    (defn bml-source-parse-typed-member (class-name objects)
        (do
            (let type-parse (bml-source-parse-type objects))
            (let member-type (nth type-parse 0))
            (let after-type (nth type-parse 1))
            (let member-object (head after-type))
            (if (bml-source-token-value? member-object "operator")
                (do
                    (let op-token (nth after-type 1))
                    (bml-source-parse-method-after-name
                        member-type
                        (str_concat "operator" (bmf-object-value op-token))
                        (drop 2 after-type)))
            (if (bml-source-name-token? member-object)
                (do
                    (let member-name (bmf-object-value member-object))
                    (let after-name (tail after-type))
                    (if (bml-source-token-value? (head after-name) "(")
                        (bml-source-parse-method-after-name
                            member-type
                            member-name
                            after-name)
                        (bml-source-parse-field-after-name
                            member-type
                            member-name
                            after-name)))
                (bml-source-parse-step false "" (empty) objects)))))

    (defn bml-source-parse-constructor (class-name objects)
        (if (bml-source-token-value? (head objects) class-name)
            (if (bml-source-token-value? (nth objects 1) "(")
                (do
                    (let parameter-parse
                        (bml-source-collect-balanced-paren (tail objects)))
                    (let parameters
                        (bml-source-parse-parameters (nth parameter-parse 0)))
                    (let after-parameters (nth parameter-parse 1))
                    (let properties-parse
                        (bml-source-properties-parse after-parameters))
                    (let properties (nth properties-parse 0))
                    (let after-properties (nth properties-parse 1))
                    (if (bml-source-token-value? (head after-properties) "{")
                        (do
                            (let body-parse
                                (bml-source-collect-balanced-brace
                                    after-properties))
                            (bml-source-parse-step
                                true
                                "file-class-constructor"
                                (comp-bml-component
                                    "Constructor"
                                    (list
                                        class-name
                                        properties
                                        (bml-source-body-source-from-tokens
                                            (nth body-parse 0))
                                        parameters))
                                (nth body-parse 1)))
                        (bml-source-parse-step false "" (empty) objects)))
                (bml-source-parse-step false "" (empty) objects))
            (bml-source-parse-step false "" (empty) objects)))

    (defn bml-source-parse-section (class-name objects)
        (if (bml-source-token-value? (head objects) "section")
            (do
                (let properties-parse
                    (bml-source-properties-parse (tail objects)))
                (let properties (nth properties-parse 0))
                (let after-properties (nth properties-parse 1))
                (if (bml-source-token-value? (head after-properties) "{")
                    (do
                        (let members
                            (bml-source-parse-class-members-until-close
                                class-name
                                (tail after-properties)))
                        (bml-source-parse-step
                            true
                            "file-class-section"
                            (comp-bml-component
                                "Section"
                                (list "" properties (nth members 0)))
                            (nth members 1)))
                    (bml-source-parse-step false "" (empty) objects)))
            (bml-source-parse-step false "" (empty) objects)))

    (defn bml-source-parse-class-member (class-name objects)
        (if (nil? objects)
            (bml-source-parse-step false "" (empty) objects)
            (if (bml-source-token-value? (head objects) "section")
                (bml-source-parse-section class-name objects)
            (do
                (let constructor-step
                    (bml-source-parse-constructor class-name objects))
                (if (bml-source-parse-step-ok? constructor-step)
                    constructor-step
                    (bml-source-parse-typed-member class-name objects))))))

    (defn bml-source-parse-class-members-loop (class-name objects acc)
        (if (nil? objects)
            (reverse-list acc)
            (do
                (let step (bml-source-parse-class-member class-name objects))
                (if (bml-source-parse-step-ok? step)
                    (bml-source-parse-class-members-loop
                        class-name
                        (bml-source-parse-step-rest step)
                        (cons (bml-source-parse-step-node step) acc))
                    (bml-source-parse-class-members-loop
                        class-name
                        (tail objects)
                        acc)))))

    (defn bml-source-parse-class-members (class-name objects)
        (bml-source-parse-class-members-loop class-name objects (empty)))

    (defn bml-source-parse-class-members-until-close-loop (class-name objects acc)
        (if (nil? objects)
            (list (reverse-list acc) objects)
            (if (bml-source-token-value? (head objects) "}")
                (list (reverse-list acc) (tail objects))
                (do
                    (let step (bml-source-parse-class-member class-name objects))
                    (if (bml-source-parse-step-ok? step)
                        (bml-source-parse-class-members-until-close-loop
                            class-name
                            (bml-source-parse-step-rest step)
                            (cons (bml-source-parse-step-node step) acc))
                        (bml-source-parse-class-members-until-close-loop
                            class-name
                            (tail objects)
                            acc))))))

    (defn bml-source-parse-class-members-until-close (class-name objects)
        (bml-source-parse-class-members-until-close-loop
            class-name
            objects
            (empty)))

    (defn bml-source-class-body-enabled? (name)
        (if (str_eq name "RuleProcess") true
            (str_eq name "Rule")))

    (defn bml-source-direct-class-parser? (objects)
        (if (bml-source-token-value? (head objects) "class")
            (do
                (let name (bmf-object-value (nth objects 1)))
                (if (str_eq name "RuleProcess") true
                    (if (str_eq name "Rule") true
                        (str_eq name "BMF"))))
            false))

    (defn bml-source-final-companion-shell-class? (name)
        (str_eq name "BMF"))

    (defn bml-source-class-shell-rest (name body-start)
        (if (bml-source-final-companion-shell-class? name)
            (empty)
            (bml-source-skip-class-body body-start)))

    (defn bml-source-class-shell-rule-name (name)
        (if (bml-source-final-companion-shell-class? name)
            "file-class-eof-shell"
            "file-class-balanced-shell"))

    (defn bml-source-parse-class-body-component (class-name properties supers body-start)
        (do
            (let members
                (bml-source-parse-class-members-until-close
                    class-name
                    (tail body-start)))
            (bml-source-parse-step
                true
                "file-class-body"
                (comp-bml-component
                    "Class"
                    (list
                        class-name
                        properties
                        supers
                        (nth members 0)))
                (nth members 1))))

    (defn bml-source-parse-class-shell-component (class-name properties supers body-start)
        (bml-source-parse-step
            true
            (bml-source-class-shell-rule-name class-name)
            (comp-bml-component
                "Class"
                (list
                    class-name
                    properties
                    supers
                    (empty)))
            (bml-source-class-shell-rest class-name body-start)))

    (defn bml-source-parse-balanced-class-shell (objects)
        (if (bml-source-token-value? (head objects) "class")
            (do
                (let name-object (nth objects 1))
                (if (bml-source-name-token? name-object)
                    (do
                        (let class-name (bmf-object-value name-object))
                        (let property-parse (bml-source-class-property-parse (drop 2 objects)))
                        (let properties (nth property-parse 0))
                        (let after-properties (nth property-parse 1))
                        (let super-parse (bml-source-class-supers-parse after-properties))
                        (let supers (nth super-parse 0))
                        (let body-start (nth super-parse 1))
                        (if (bml-source-token-value? (head body-start) "{")
                            (if (bml-source-class-body-enabled? class-name)
                                (bml-source-parse-class-body-component
                                    class-name
                                    properties
                                    supers
                                    body-start)
                                (bml-source-parse-class-shell-component
                                    class-name
                                    properties
                                    supers
                                    body-start))
                            (bml-source-parse-step false "" (empty) objects)))
                    (bml-source-parse-step false "" (empty) objects)))
            (bml-source-parse-step false "" (empty) objects)))

    (defn bml-source-parse-executable-step (objects)
        (bml-source-parse-executable-step-loop
            objects
            (bml-source-executable-rules 0)))

    (defn bml-source-exec-parse-result (ok nodes rest rules)
        (list "bml-source-exec-parse-result" ok nodes rest rules))

    (defn bml-source-exec-parse-ok? (result) (nth result 1))
    (defn bml-source-exec-parse-nodes (result) (nth result 2))
    (defn bml-source-exec-parse-rest (result) (nth result 3))
    (defn bml-source-exec-parse-rules (result) (nth result 4))
    (defn bml-source-exec-parse-node (result)
        (bml-ast-block (bml-source-exec-parse-nodes result)))

    (defn bml-source-parse-executable-stream-loop (objects nodes rules)
        (if (nil? objects)
            (bml-source-exec-parse-result
                true
                (reverse-list nodes)
                objects
                (reverse-list rules))
            (do
                (let step (bml-source-parse-executable-step objects))
                (if (bml-source-parse-step-ok? step)
                    (bml-source-parse-executable-stream-loop
                        (bml-source-parse-step-rest step)
                        (cons (bml-source-parse-step-node step) nodes)
                        (cons (bml-source-parse-step-rule step) rules))
                    (bml-source-exec-parse-result
                        false
                        (reverse-list nodes)
                        objects
                        (reverse-list rules))))))

    (defn bml-source-parse-executable-stream (objects)
        (bml-source-parse-executable-stream-loop
            objects
            (empty)
            (empty)))

    (defn bml-source-file-parse-executable (path)
        (bml-source-parse-executable-stream (bml-source-scan-file path)))

    (defn bml-source-file-compile-executable (path)
        (bml-compile-program
            (bml-source-exec-parse-node
                (bml-source-file-parse-executable path))))

    (defn bml-source-parse-declaration-step (objects)
        (if (bml-source-direct-class-parser? objects)
            (bml-source-parse-balanced-class-shell objects)
            (do
                (let step
                    (bml-source-parse-executable-step-loop
                        objects
                        (bml-source-declaration-rules 0)))
                (if (bml-source-parse-step-ok? step)
                    step
                    (bml-source-parse-balanced-class-shell objects)))))

    (defn bml-source-parse-declaration-stream-loop (objects nodes rules)
        (if (nil? objects)
            (bml-source-exec-parse-result
                true
                (reverse-list nodes)
                objects
                (reverse-list rules))
            (do
                (let step (bml-source-parse-declaration-step objects))
                (if (bml-source-parse-step-ok? step)
                    (bml-source-parse-declaration-stream-loop
                        (bml-source-parse-step-rest step)
                        (cons (bml-source-parse-step-node step) nodes)
                        (cons (bml-source-parse-step-rule step) rules))
                    (bml-source-exec-parse-result
                        false
                        (reverse-list nodes)
                        objects
                        (reverse-list rules))))))

    (defn bml-source-parse-declaration-stream (objects)
        (bml-source-parse-declaration-stream-loop
            objects
            (empty)
            (empty)))

    (defn bml-source-file-parse-declarations (path)
        (bml-source-parse-declaration-stream (bml-source-scan-file path)))

    (defn bml-source-declaration-model (result)
        (bml-model
            (bml-components-of-kind
                (bml-source-exec-parse-nodes result)
                "Class")
            (bml-components-of-kind
                (bml-source-exec-parse-nodes result)
                "Interface")))

    (defn bml-thesis-bmf-primitive-rule-count-loop (rule-names)
        (if (nil? rule-names) 0
            (add
                (if (nil? (bml-bmf-find-rule (head rule-names) bml-bmf-rules)) 0 1)
                (bml-thesis-bmf-primitive-rule-count-loop (tail rule-names)))))

    (defn bml-thesis-bmf-primitive-rule-count (_x)
        (bml-thesis-bmf-primitive-rule-count-loop bml-thesis-bmf-primitive-rule-names))

    ;; --- native source sections -------------------------------------

    (let bml-bmf-section bml-bmf-second)

    (let bml-bmf-native-section
        (list
            (bmf-native "bml-emit-package-simple" bml-emit-package-simple BML-AST-PACKAGE)
            (bmf-native "bml-emit-import-simple" bml-emit-import-simple BML-AST-IMPORT)
            (bmf-native "bml-emit-import-star-simple" bml-emit-import-star-simple BML-AST-IMPORT)
            (bmf-native "bml-emit-class-header" bml-emit-class-header BML-AST-CLASS)
            (bmf-native "bml-emit-interface-header" bml-emit-interface-header BML-AST-INTERFACE)
            (bmf-native "bml-emit-section-header" bml-emit-section-header BML-AST-SECTION)
            (bmf-native "bml-emit-field" bml-emit-field BML-AST-FIELD)
            (bmf-native "bml-emit-const-int" bml-emit-const-int BML-AST-CONST)
            (bmf-native "bml-emit-return-int" bml-emit-return-int BML-AST-RETURN)
            (bmf-native "bml-emit-break-simple" bml-emit-break-simple BML-AST-BREAK)
            (bmf-native "bml-emit-continue-simple" bml-emit-continue-simple BML-AST-CONTINUE)
            (bmf-native "bml-emit-throw-int" bml-emit-throw-int BML-AST-THROW)
            (bmf-native "bml-emit-try-throw-return" bml-emit-try-throw-return BML-AST-TRY)
            (bmf-native "bml-emit-fail-simple" bml-emit-fail-simple BML-AST-FAIL)
            (bmf-native "bml-emit-cut-simple" bml-emit-cut-simple BML-AST-CUT)
            (bmf-native "bml-emit-mark-simple" bml-emit-mark-simple BML-AST-SAVE)
            (bmf-native "bml-emit-char-lit" bml-emit-char-lit BML-AST-CHAR)
            (bmf-native "bml-emit-array-int" bml-emit-array-int BML-AST-ARRAY)
            (bmf-native "bml-emit-method-return-add" bml-emit-method-return-add BML-AST-METHOD)
            (bmf-native "bml-emit-choose-fail-int" bml-emit-choose-fail-int BML-AST-CHOOSE)
            (bmf-native "bml-emit-state-int" bml-emit-state-int BML-AST-BLOCK)))

    (let bml-recipe-section
        (form-rule-recipe-section "bml"
            (list
                (compiler-rule "bml" "class-header" "BML class source objects" bml-emit-class-header)
                (compiler-rule "bml" "interface-header" "BML interface source objects" bml-emit-interface-header)
                (compiler-rule "bml" "package-simple" "BML package source objects" bml-emit-package-simple)
                (compiler-rule "bml" "import-simple" "BML import source objects" bml-emit-import-simple)
                (compiler-rule "bml" "section-header" "BML section source objects" bml-emit-section-header)
                (compiler-rule "bml" "return-int" "BML return object to BMA ops" bml-emit-return-int)
                (compiler-rule "bml" "break-simple" "BML break object to BMA ops" bml-emit-break-simple)
                (compiler-rule "bml" "continue-simple" "BML continue object to BMA ops" bml-emit-continue-simple)
                (compiler-rule "bml" "throw-int" "BML throw object to BMA ops" bml-emit-throw-int)
                (compiler-rule "bml" "try-throw-return" "BML try object to BMA ops" bml-emit-try-throw-return)
                (compiler-rule "bml" "fail-simple" "BML fail primitive to BMA ops" bml-emit-fail-simple)
                (compiler-rule "bml" "cut-simple" "BML cut primitive to BMA ops" bml-emit-cut-simple)
                (compiler-rule "bml" "mark-simple" "BML mark primitive to BMA save ops" bml-emit-mark-simple)
                (compiler-rule "bml" "char-lit" "BML char literal source objects" bml-emit-char-lit)
                (compiler-rule "bml" "array-int" "BML array literal source objects" bml-emit-array-int)
                (compiler-rule "bml" "method-return-add" "BML method object to BMA ops" bml-emit-method-return-add)
                (compiler-rule "bml" "choice-fail-int" "BML thesis choice object to BMA ops" bml-emit-choose-fail-int)
                (compiler-rule "bml" "choose-fail-int" "BML choice object to BMA ops" bml-emit-choose-fail-int)
                (compiler-rule "bml" "state-int" "BML state object to BMA ops" bml-emit-state-int))))

    (let bml-form-source
        (form-source "bml" (list bml-bmf-section bml-recipe-section)))

    (let bml-bmf-dialect
        (bmf-dialect "bml"
                     (form-section-object bml-bmf-section)
                     bml-bmf-native-section
                     bml-bmf-rules))

    ;; --- BMA-like program lowering ----------------------------------

    (defn bma-op (name value)
        (comp-op name value comp-op-identity-inverse))

    (defn bma-push-int (n) (bma-op "push-int" n))
    (defn bma-push-lit (value) (bma-op "push-lit" value))
    (defn bma-add (_x) (bma-op "add" 0))
    (defn bma-return (_x) (bma-op "return" 0))
    (defn bma-break (label) (bma-op "break" label))
    (defn bma-continue (label) (bma-op "continue" label))
    (defn bma-throw (_x) (bma-op "throw" 0))
    (defn bma-raise (_x) (bma-op "raise" 0))
    (defn bma-resume (_x) (bma-op "resume" 0))
    (defn bma-save (_x) (bma-op "save" 0))
    (defn bma-mark (_x) (bma-op "mark" 0))
    (defn bma-restore (_x) (bma-op "restore" 0))
    (defn bma-discard (_x) (bma-op "discard" 0))
    (defn bma-nostate (_x) (bma-op "nostate" 0))
    (defn bma-fail (_x) (bma-op "fail" 0))
    (defn bma-cut (_x) (bma-op "cut" 0))
    (defn bma-choose (branches) (bma-op "choose" branches))
    (defn bma-try (branches) (bma-op "try" branches))

    (defn bml-node-child (node index)
        (nth (node_children node) index))

    (defn bml-compile-children (children)
        (if (nil? children) (empty)
            (append (bml-compile-node (head children))
                    (bml-compile-children (tail children)))))

    (defn bml-compile-node (node)
        (do
            (let cat (node_category node))
            (if (node_eq cat BML-AST-INT)
                (list (bma-push-int (node_value (bml-node-child node 0))))
            (if (node_eq cat BML-AST-STRING)
                (list (bma-push-lit (node_value (bml-node-child node 0))))
            (if (node_eq cat BML-AST-CHAR)
                (list (bma-push-lit (node_value (bml-node-child node 0))))
            (if (node_eq cat BML-AST-ARRAY)
                (bml-compile-children (node_children node))
            (if (node_eq cat BML-AST-ADD)
                (append (bml-compile-node (bml-node-child node 0))
                        (append (bml-compile-node (bml-node-child node 1))
                                (list (bma-add 0))))
            (if (node_eq cat BML-AST-CONST)
                (bml-compile-node (bml-node-child node 2))
            (if (node_eq cat BML-AST-RETURN)
                (append (bml-compile-node (bml-node-child node 0))
                        (list (bma-return 0)))
            (if (node_eq cat BML-AST-BREAK)
                (list (bma-break (node_value (bml-node-child node 0))))
            (if (node_eq cat BML-AST-CONTINUE)
                (list (bma-continue (node_value (bml-node-child node 0))))
            (if (node_eq cat BML-AST-THROW)
                (append (bml-compile-node (bml-node-child node 0))
                        (list (bma-throw 0)))
            (if (node_eq cat BML-AST-TRY)
                (list (bma-try
                        (list (bml-compile-node (bml-node-child node 0))
                              (bml-compile-node (bml-node-child node 1)))))
            (if (node_eq cat BML-AST-METHOD)
                (bml-compile-node (bml-node-child node 1))
            (if (node_eq cat BML-AST-BLOCK)
                (bml-compile-children (node_children node))
            (if (node_eq cat BML-AST-CHOOSE)
                (list (bma-choose (map bml-compile-node (node_children node))))
            (if (node_eq cat BML-AST-FAIL)
                (list (bma-fail 0))
            (if (node_eq cat BML-AST-CUT)
                (list (bma-cut 0))
            (if (node_eq cat BML-AST-SAVE)
                (list (bma-save 0))
            (if (node_eq cat BML-AST-RESTORE)
                (list (bma-restore 0))
            (if (node_eq cat BML-AST-DISCARD)
                (list (bma-discard 0))
                (empty))))))))))))))))))))))

    (defn bml-compile-program (node)
        (comp-program "bma" (bml-compile-node node)))

    ;; --- BMA-like runtime -------------------------------------------

    (defn bma-bin-add (s)
        (do
            (let right (comp-vm-pop-value s))
            (let s1 (comp-vm-pop-state s))
            (let left (comp-vm-pop-value s1))
            (let s2 (comp-vm-pop-state s1))
            (comp-vm-push s2 (add left right))))

    (defn bma-exec-choose-branches (branches state)
        (if (nil? branches)
            (comp-vm-with-mode state "fail")
            (do
                (let branch-state (bma-exec-ops (head branches) (comp-vm-with-mode state "run")))
                (if (str_eq (comp-vm-mode branch-state) "fail")
                    (bma-exec-choose-branches (tail branches) state)
                    branch-state))))

    (defn bma-exec-try-branches (branches state)
        (do
            (let body-state (bma-exec-ops (head branches) (comp-vm-with-mode state "run")))
            (if (str_eq (comp-vm-mode body-state) "throw")
                (bma-exec-ops (head (tail branches)) (comp-vm-with-mode state "run"))
                body-state)))

    (defn bma-exec-op (op state)
        (do
            (let name (comp-op-name op))
            (if (str_eq name "push-int") (comp-vm-push state (comp-op-value op))
            (if (str_eq name "push-lit") (comp-vm-push state (comp-op-value op))
            (if (str_eq name "add") (bma-bin-add state)
            (if (str_eq name "return") (comp-vm-with-mode state "return")
            (if (str_eq name "break") (comp-vm-with-mode state "break")
            (if (str_eq name "continue") (comp-vm-with-mode state "continue")
            (if (str_eq name "throw") (comp-vm-with-mode state "throw")
            (if (str_eq name "raise") (comp-vm-with-mode state "raise")
            (if (str_eq name "resume") (comp-vm-with-mode state "run")
            (if (str_eq name "save") (comp-vm-save state)
            (if (str_eq name "mark") (comp-vm-save state)
            (if (str_eq name "restore") (comp-vm-restore state)
            (if (str_eq name "discard") (comp-vm-discard state)
            (if (str_eq name "nostate") state
            (if (str_eq name "fail") (comp-vm-with-mode state "fail")
            (if (str_eq name "cut") (comp-vm-with-mode state "cut")
            (if (str_eq name "choose") (bma-exec-choose-branches (comp-op-value op) state)
            (if (str_eq name "try") (bma-exec-try-branches (comp-op-value op) state)
                state))))))))))))))))))))

    (defn bma-exec-ops (ops state)
        (if (nil? ops) state
            (if (str_eq (comp-vm-mode state) "run")
                (bma-exec-ops (tail ops) (bma-exec-op (head ops) state))
                state)))

    (defn bma-run-program (program)
        (bma-exec-ops (comp-program-ops program) (comp-vm-empty 0)))

    (defn bma-run-value (program)
        (comp-vm-pop-value (bma-run-program program)))

    ;; Thesis exit proof: record the executable BMA stream in forward
    ;; DO mode, then replay the trace backward in UNDO mode by restoring
    ;; each op's saved pre-state.
    (defn bma-trace-entry (mode op before after)
        (list "bma-trace-entry" mode (comp-op-name op) before after))

    (defn bma-trace-mode (entry) (nth entry 1))
    (defn bma-trace-op-name (entry) (nth entry 2))
    (defn bma-trace-before (entry) (nth entry 3))
    (defn bma-trace-after (entry) (nth entry 4))

    (defn bma-trace-result (state trace)
        (list "bma-trace-result" state trace))

    (defn bma-trace-result-state (result) (nth result 1))
    (defn bma-trace-result-trace (result) (nth result 2))

    (defn bma-run-program-forward-trace-loop (ops state trace)
        (if (nil? ops)
            (bma-trace-result state (reverse trace))
            (if (str_eq (comp-vm-mode state) "run")
                (do
                    (let op (head ops))
                    (let after (bma-exec-op op state))
                    (bma-run-program-forward-trace-loop
                        (tail ops)
                        after
                        (cons (bma-trace-entry "DO" op state after) trace)))
                (bma-trace-result state (reverse trace)))))

    (defn bma-run-program-forward-trace (program)
        (bma-run-program-forward-trace-loop
            (comp-program-ops program)
            (comp-vm-empty 0)
            (empty)))

    (defn bma-run-program-backward-trace-loop (entries state trace)
        (if (nil? entries)
            (bma-trace-result state (reverse trace))
            (do
                (let entry (head entries))
                (let before (bma-trace-before entry))
                (let op (bma-op (bma-trace-op-name entry) 0))
                (bma-run-program-backward-trace-loop
                    (tail entries)
                    before
                    (cons (bma-trace-entry "UNDO" op state before) trace)))))

    (defn bma-run-program-backward-trace (forward-result)
        (bma-run-program-backward-trace-loop
            (reverse (bma-trace-result-trace forward-result))
            (bma-trace-result-state forward-result)
            (empty)))

    (defn bma-forward-backward-result (forward-state restored-state trace)
        (list "bma-forward-backward" forward-state restored-state trace))

    (defn bma-forward-backward-forward-state (result) (nth result 1))
    (defn bma-forward-backward-restored-state (result) (nth result 2))
    (defn bma-forward-backward-trace (result) (nth result 3))

    (defn bma-run-forward-backward (program)
        (do
            (let forward (bma-run-program-forward-trace program))
            (let backward (bma-run-program-backward-trace forward))
            (bma-forward-backward-result
                (bma-trace-result-state forward)
                (bma-trace-result-state backward)
                (append (bma-trace-result-trace forward)
                        (bma-trace-result-trace backward)))))

    (defn bma-trace-count-mode (trace mode)
        (if (nil? trace) 0
            (add
                (if (str_eq (bma-trace-mode (head trace)) mode) 1 0)
                (bma-trace-count-mode (tail trace) mode))))

    (defn bma-trace-count-op (trace op-name)
        (if (nil? trace) 0
            (add
                (if (str_eq (bma-trace-op-name (head trace)) op-name) 1 0)
                (bma-trace-count-op (tail trace) op-name))))

    0)
