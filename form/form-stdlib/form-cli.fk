; form-cli.fk — the native form-cli DISPATCH library (the verb-routing brain).
;
; The form-cli LOGIC already lives as Form recipes (form-cli-predict/gaps/score/
; review-gap/router/loop, several four-way). This is the missing dispatcher: given a
; command string it splits the verb and routes to a response. It is deterministic
; (str_find/substring/str_eq/str_concat) and crosses four-way (Go/Rust/TS/fkwu) by
; tests/form-cli-band.fk — the brain BOTH surfaces call.
;
; Two input surfaces wrap this one dispatch, both fkwu-native: HEADLESS reads the
; command staged in fk_src (form-cli-main.fk, input_byte = walker tag 17);
; INTERACTIVE TTY runs a read_line loop with an isatty prompt over real fd 0
; (form-cli-repl.fk, tags 114/115/116). One native engine on the emitted kernel,
; not 23 bespoke carriers.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/voice-traits.fk form-stdlib/nearest-shape.fk form-stdlib/co-learning.fk form-stdlib/co-learning-stream.fk form-stdlib/mesh-dispatch.fk form-stdlib/surprise-salience.fk form-stdlib/host-sense-organ.fk form-stdlib/speech-organ.fk form-stdlib/native-host-instance.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-ask.fk

(do
    ; the verb is the command up to the first space (or the whole line).
    (defn fc-verb (cmd)
        (do (let sp (str_find cmd " " 0))
            (if (lt sp 0) cmd (substring cmd 0 sp))))

    ; the argument is everything after the first space (or "" when there is none).
    (defn fc-arg (cmd)
        (do (let sp (str_find cmd " " 0))
            (if (lt sp 0) "" (substring cmd (add sp 1) (str_len cmd)))))

    (defn fc-part (parts i fallback)
        (if (gt (len parts) i) (nth parts i) fallback))

    (defn fc-part-int (parts i fallback)
        (str_to_int (fc-part parts i (int_to_str fallback))))

    (defn fc-native-host-row (r)
        (str_concat (nhi-rec-kind r)
        (str_concat "|"
        (str_concat (nhi-rec-platform r)
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-native? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-listening? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-sharing? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-transcribe? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-surprises r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-learned r))
        (str_concat "|"
        (str_concat (nhi-rec-decision r)
        (str_concat "|"
                    (nhi-rec-share-route r))))))))))))))))))))

    ; native-host <platform> <mic> <camera> <screen> <speech_gate> <freq>
    ;             <surprise_count> <sample_count> [message-token]
    ;
    ; A C-bootstrapped/form-cli carrier can pass host readings as argv/stdin and
    ; receive the lifecycle decision row without linking a Rust evaluator.
    (defn fc-native-host (arg)
        (do
            (let parts (split-on arg " "))
            (let platform (fc-part parts 0 "android"))
            (let mic (fc-part-int parts 1 1))
            (let cam (fc-part-int parts 2 0))
            (let screen (fc-part-int parts 3 1))
            (let gate (fc-part-int parts 4 0))
            (let freq (fc-part-int parts 5 0))
            (let surprise-count (fc-part-int parts 6 0))
            (let sample-count (fc-part-int parts 7 0))
            (let msg0 (fc-part parts 8 ""))
            (let msg (if (str_eq msg0 "gold") "gold clear" msg0))
            (let host (hso-receipt 200000 0 0 0 800000 mic cam screen))
            (let speech (so-receipt gate freq (if (gt gate 0) 55 0) platform))
            (let surprises (if (gt surprise-count 0) (list (list "host-surprise" 72)) (empty)))
            (let samples (if (gt sample-count 0) (list (list platform (list sample-count 0 0))) (empty)))
            (fc-native-host-row (nhi-cycle platform host speech surprises samples msg))))

    ; fnri — local sovereignty knowledge retrieval (no rented mind, no host-exec).
    ;   fnri                    → runtime + no-go flag
    ;   fnri <slug>             → slug:path for fnri-knowledge-cells entry
    ;   fnri resolve <target> <protocol> → interface name for a platform binding
    (defn fc-fnri (arg)
        (if (str_eq arg "")
            (str_concat "runtime=" (str_concat (fnri-runtime)
                (str_concat " no-go=" (int_to_str (fnri-no-go-emission?)))))
            (do
                (let parts (split-on arg " "))
                (if (str_eq (head parts) "resolve")
                    (do
                        (let target (fc-part parts 1 "macos-arm64"))
                        (let protocol (fc-part parts 2 "host:process"))
                        (let resolved (fnri-resolve target protocol))
                        (let iface (fnri-resolve-interface resolved))
                        (bnii-interface-name iface))
                    (do
                        (let k (fnri-knowledge-for arg))
                        (str_concat (fnri-knowledge-slug k)
                            (str_concat ":" (fnri-knowledge-path k))))))))

    ; the four-way dispatch: every verb here returns a pure string the shared
    ; brain produces on Go/Rust/TS/fkwu alike (tests/form-cli-band.fk). The
    ; native-only verbs that read the binary's own baked source (source, verify)
    ; are intercepted by the fkwu runtime wrappers (form-cli-repl.fk /
    ; form-cli-main.fk) before this dispatch, since they use a fkwu-only op.
    (defn fc-respond (cmd)
        (do (let v (fc-verb cmd))
            (if (str_eq v "ping") "pong"
            (if (str_eq v "ask") (fca-ask (fc-arg cmd))
            (if (str_eq v "grounded") (ra-grounded (fc-arg cmd))
            (if (str_eq v "fnri") (fc-fnri (fc-arg cmd))
            (if (str_eq v "native-host") (fc-native-host (fc-arg cmd))
            (if (str_eq v "help")
                "form-cli verbs: ping ask grounded fnri native-host help about kernel source recreate verify diagnose version quit. ask <question>: local oracle (ollama). grounded <question>: lexical retrieve from healed index (re-vec + rag-topk, no Python). fnri [slug|resolve <target> <protocol>]: local sovereignty knowledge from form-native-resource-interfaces.fk (no rented mind). native-host <platform> <mic> <camera> <screen> <speech_gate> <freq> <surprises> <samples> [message]: return the Form host lifecycle row. about: what this is. kernel: what it runs on. source: its own Form source. recreate: how to rebuild. verify: self-coherence. diagnose: the live framebuffer — op-dispatch counts and substrate high-water (fkwu)."
            (if (str_eq v "about")
                "form-cli is one self-contained native binary: a Form program that dispatches verbs and runs an interactive read-eval-print loop, with no separate runtime. Pipe commands on stdin, or run it on a terminal and type. help lists the verbs."
            (if (str_eq v "kernel")
                "form-cli runs on fkwu, a universal walker generated entirely from Form recipes and compiled to native code. The same walker runs any Form program. this binary has the form-cli program built into it."
            (if (str_eq v "recreate")
                "to rebuild: run the source verb to print the Form source this binary carries, then build-form-cli.sh turns those recipes into native code and bakes form-cli into the walker, reproducing this binary. Building needs the bootstrap toolchain. the result runs on its own."
            (if (str_eq v "version")
                "form-cli 0.3"
                (str_concat "form-cli: unknown verb '" (str_concat v "' — type 'help'")))))))))))))
    0)
