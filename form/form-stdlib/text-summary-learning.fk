    (defn tsl-source-read-valid? (read expected-prefix min-bytes)
        (if (and
                (str_eq (tsl-source-read-prefix read) expected-prefix)
                (and
                    (ge (tsl-source-read-file-size read) min-bytes)
                    (eq (tsl-source-read-file-size read) (tsl-source-read-text-len read))))
            1
            0))

    (defn tsl-source-citation (path offset length quote claim line)
        (list path offset length quote claim line))
    (defn tsl-citation-path (citation) (nth citation 0))
