    (defn tsl-citation-file-slice (citation)
        (read_file_slice
            (tsl-citation-path citation)
            (tsl-citation-offset citation)
            (tsl-citation-length citation)))
    (defn tsl-citation-match? (citation)
        (if (str_eq (tsl-citation-file-slice citation) (tsl-citation-quote citation)) 1 0))
    (defn tsl-citations-match? (citations)
        (if (eq (len citations) 0) 1
            (if (eq (tsl-citation-match? (head citations)) 1)
                (tsl-citations-match? (tail citations))
                0)))

