(do (defn visible (akind aval author viewer vrole) (if (str_eq viewer author) 1 (if (str_eq akind "everyone") 1 (if (str_eq akind "person") (if (str_eq viewer aval) 1 0) (if (str_eq akind "group") (if (str_eq aval "friend") 1 (if (str_eq aval vrole) 1 0)) 0))))) (let akind "group") (let aval "resident") (let author "a1") (let viewer "v1") (let vrole "resident") (visible akind aval author viewer vrole))
