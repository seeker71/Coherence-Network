(do (defn lerp (a b t) (_plus a (mul (sub b a) t))) (defn coherence_score (signal vitality weight) (_plus (mul signal weight) (mul vitality (sub 1.0 weight)))) (defn is_above (score threshold) (ge score threshold)) (let mixed (add 2 0.5)) (let midpoint (lerp 0.25 0.75 0.5)) (let score (coherence_score 0.5 1.0 0.25)) (let high (is_above score 0.5)) (let delta (sub score midpoint)) (let ratio (div (_plus score delta) 2.0)) (_plus (_plus (_plus (_plus mixed midpoint) score) delta) ratio))
