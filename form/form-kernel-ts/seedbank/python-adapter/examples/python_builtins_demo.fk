(do (defn stats (values) (do (let total (sum values)) (do (let smallest (min values)) (do (let biggest (max values)) (_plus (_plus total smallest) biggest))))) (defn absolute_distance_from_target (values target) (do (let d 0) (do (do (defn _for_0 (_remaining d) (if (eq (len _remaining) 0) d (do (let v (head _remaining)) (let d (_plus d (abs (sub v target)))) (_for_0 (tail _remaining) d)))) (let d (_for_0 (_iter values) d))) d))) (let values (list 3 17 8 22 5 14)) (let target 10) (let s (stats values)) (let dist (absolute_distance_from_target values target)) (_plus s dist))
