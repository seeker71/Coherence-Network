; form-cli-router.fk — the ONE routing formula, as a recipe.
;
; preludes: form-stdlib/core.fk
;
; Every request the form-cli (or the MCP surface inside another agent) handles is
; routed to exactly one backend. There are only TWO backends, by design — no
; metered LLM REST API exists in this body:
;   form-native    a local Form recipe / trained lane (fully ours; ~0 cost)
;   agent-cli      the subscription agent CLI already running (claude/codex/...);
;                  flat-rate, not per-token — the cost that matters is already paid
;
; The choice is ONE formula over four axes (each 0..100): sovereignty (how much
; this backend is ours), trust (its measured success rate on this shape),
; capability (can it do this category AT ALL — a hard gate), confidence (the
; local lane's accumulated certainty). Sovereignty and trust weigh highest — they
; are the core values; capability and confidence lift. The weights are a DATA
; cell (fcr-weights), tunable without touching the formula.
;
; The flywheel is emergent, not coded: form-native starts with capability 0 for
; the hard categories, so the formula routes to the agent CLI AND every such call
; is captured to train the local lane (training-catalog.fk). As learning raises
; form-native's capability and confidence, its max-sovereignty advantage overtakes
; the agent CLI and the same request flips to local — the more we use the oracle,
; the less we need it.
;
; This composes the same axes tool-embodiment.fk's gate already reads (sovereignty
; local 90 / remote 40, trust = success rate); fcr-fitness names them as one
; explicit, tunable scalar for the per-request route.
;
; ONE confidence primitive. Confidence is a lane's measured pass-rate
; (passes*100/attempts, 0..100) — the certainty it has accumulated from real use,
; including oracle-taught attempts. fcr-confidence-axis is the SINGLE definition of
; confidence in the body: the router's fitness axis (fcr-confidence, fed by it) and
; form-cli-loop.fk's route gate (fcl-confidence, which delegates straight to it)
; both read this one number from the same accumulated learning — so the per-request
; fitness scalar and the route-local-or-oracle gate can never drift into two
; different notions of "confidence".
;
; Proven by: form-stdlib/tests/form-cli-router-band.fk

; THE confidence primitive: a lane's measured pass-rate (0..100) from real use.
; form-cli-loop.fk's fcl-confidence delegates here; the fitness axis below is fed
; by it — one definition, read by both the loop gate and the router fitness.
(defn fcr-confidence-axis (passes attempts)
    (if (eq attempts 0) 0 (div (mul passes 100) attempts)))

; the tunable weights: (w-sovereignty w-trust w-capability w-confidence divisor).
; sovereignty and trust are the core values (weight 2); capability and confidence
; lift (weight 1). Change the body's behavior by changing this data, not the math.
(defn fcr-weights () (list 2 2 1 1 6))

; a backend is (name, sovereignty, trust, capability, confidence).
(defn fcr-backend (name sovereignty trust capability confidence)
    (list name sovereignty trust capability confidence))
(defn fcr-name        (b) (nth b 0))
(defn fcr-sovereignty (b) (nth b 1))
(defn fcr-trust       (b) (nth b 2))
(defn fcr-capability  (b) (nth b 3))
(defn fcr-confidence  (b) (nth b 4))

; build a backend whose confidence axis is COMPUTED from accumulated learning by
; the one confidence primitive — the same number form-cli-loop.fk's gate reads.
; This is the wire that makes the loop gate's input and the router fitness scalar
; literally the same scalar: pass (passes attempts) once, both consume it.
(defn fcr-backend-learned (name sovereignty trust capability passes attempts)
    (fcr-backend name sovereignty trust capability
                 (fcr-confidence-axis passes attempts)))

; THE one formula: a single fitness score from the four axes. Capability is a
; hard gate — a backend that cannot do this category at all scores 0, whatever
; its other axes. Among capable backends, the weighted sum decides.
(defn fcr-fitness (b)
    (if (eq (fcr-capability b) 0)
        0
        (div (add (add (mul (nth (fcr-weights) 0) (fcr-sovereignty b))
                       (mul (nth (fcr-weights) 1) (fcr-trust b)))
                  (add (mul (nth (fcr-weights) 2) (fcr-capability b))
                       (mul (nth (fcr-weights) 3) (fcr-confidence b))))
             (nth (fcr-weights) 4))))

; route to the fitter backend; a tie goes to form-native — prefer what is ours.
; Only two backends are ever weighed: form-native and the subscription agent CLI.
(defn fcr-route (form-native agent-cli)
    (if (ge (fcr-fitness form-native) (fcr-fitness agent-cli))
        (fcr-name form-native)
        (fcr-name agent-cli)))

; the flywheel made checkable: the SAME request, routed before vs after learning
; raised form-native's capability/confidence, flips agent-cli -> form-native.
(defn fcr-flips-local? (fn-before fn-after agent-cli)
    (if (and (str_eq (fcr-route fn-before agent-cli) "agent-cli")
             (str_eq (fcr-route fn-after  agent-cli) "form-native"))
        1 0))

; a route is sovereign when it landed on form-native (no external lane touched).
(defn fcr-sovereign? (winner-name) (if (str_eq winner-name "form-native") 1 0))
; form-cli-judge.fk — score the REASONING lane: how well a native answer covers
; the agent's, graded 0..100 by a judge.
;
; preludes: form-stdlib/core.fk
;
; Tool selection (form-cli-score / form-cli-predict) is a SET problem — exact,
; cheap, and the native model already wins it. Reasoning is the hard lane: the
; native answer must cover the SUBSTANCE of the agent's, which set-overlap can't
; measure. So a judge (a local oracle, the membrane crossing) rates each native
; answer 0..100 for how well it covers the agent's reference; this recipe is the
; rubric and the tally over those scores — the proven (four-way) logic, the judge
; is the carrier.
;
; A judged sample is one native score in 0..100. The recipe grades it, counts
; passes at a threshold, sums for the average, and reports whether the native
; reaches a majority — the same champion-challenger shape, on a graded lane.
;
; Proven by: form-stdlib/tests/form-cli-judge-band.fk

; grade a score: 0 poor (<=25) / 1 weak (<=50) / 2 partial (<=75) / 3 strong
(defn fcj-grade (score)
    (if (le score 25) 0
        (if (le score 50) 1
            (if (le score 75) 2 3))))
(defn fcj-grade-poor () 0)
(defn fcj-grade-weak () 1)
(defn fcj-grade-partial () 2)
(defn fcj-grade-strong () 3)

; does a score clear the bar?
(defn fcj-pass? (score threshold) (if (ge score threshold) 1 0))

; tallies over a list of scores
(defn fcj-passed (scores threshold)
    (if (eq (len scores) 0) 0
        (add (fcj-pass? (head scores) threshold) (fcj-passed (tail scores) threshold))))
(defn fcj-count-grade (scores g)
    (if (eq (len scores) 0) 0
        (add (if (eq (fcj-grade (head scores)) g) 1 0) (fcj-count-grade (tail scores) g))))
(defn fcj-total (scores) (len scores))
(defn fcj-sum (scores)
    (if (eq (len scores) 0) 0 (add (head scores) (fcj-sum (tail scores)))))
; (the average is sum/total — computed by the carrier; div is kept off the
;  four-way path so the tally stays integer-identical on every arm.)

; native reaches the lane when a majority of samples pass the threshold
(defn fcj-native-reaches? (scores threshold)
    (if (ge (add (fcj-passed scores threshold) (fcj-passed scores threshold)) (len scores)) 1 0))

0
; form-cli-sufficiency.fk — was the LOCAL answer ENOUGH, or escalate to the remote oracle?
;
; preludes: form-stdlib/core.fk form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk
;
; form-cli-router.fk picks where to START (a soft weighted fitness over sovereignty /
; trust / capability / confidence — an a-priori choice). This is its POSTERIOR partner:
; after the local lane actually answers, read THIS RUN's signals and decide accept / retry
; / escalate. A hard "remote = last resort, only on total failure" rule does not serve a
; daily driver — to reach claude-code quality you must escalate for the REAL answer whenever
; local was not enough (empty, malformed, weak content, low confidence, low trust), not only
; when it crashed. So this is a SOFT multi-signal blend with tunable policy DATA, and it
; records WHY it escalated so the crossing (form-cli-membrane.fk) teaches the local lane.
;
; Signals — each a run-time read of the local oracle's actual answer this turn:
;   has-output   1 if non-empty                            (the lane produced something)
;   shape-ok     1 if it parses / fits the expected output shape
;   content      0..100 judge coverage of the answer's substance (the fcj rubric's score)
;   confidence   0..100 accumulated pass-rate of this lane (fcr-confidence-axis)
;   trust        0..100 accumulated success rate of this lane
;   retries-left how many local re-tries remain
;
; Verdict: 0 accept (local stands) / 1 retry (transient — re-run local) / 2 escalate (remote).
; Reason : 0 ok / 1 empty / 2 bad-shape / 3 weak-content / 4 low-confidence / 5 low-trust.
;
; Proven by: form-stdlib/tests/form-cli-sufficiency-band.fk

(defn fsuf-signals (has-output shape-ok content confidence trust retries-left)
    (list has-output shape-ok content confidence trust retries-left))
(defn fsuf-has-output (s) (nth s 0))
(defn fsuf-shape-ok   (s) (nth s 1))
(defn fsuf-content    (s) (nth s 2))
(defn fsuf-confidence (s) (nth s 3))
(defn fsuf-trust      (s) (nth s 4))
(defn fsuf-retries    (s) (nth s 5))

; tunable policy DATA (like fcr-weights): (w-content w-confidence w-trust accept-threshold floor).
; quality is a weighted blend of the three soft axes; floor is a per-axis hard minimum below
; which a present, parseable answer still can't stand (a strong-on-paper lane that has never
; been proven — confidence/trust under the floor — does not get to answer alone). Change the
; body's behavior by changing this cell, not the math.
(defn fsuf-policy () (list 2 1 1 60 25))
(defn fsuf-w-content  () (nth (fsuf-policy) 0))
(defn fsuf-w-conf     () (nth (fsuf-policy) 1))
(defn fsuf-w-trust    () (nth (fsuf-policy) 2))
(defn fsuf-accept-thr () (nth (fsuf-policy) 3))
(defn fsuf-floor      () (nth (fsuf-policy) 4))

; the soft quality blend (0..100) — no single axis is a hard gate; they lift together.
(defn fsuf-quality (s)
    (div (add (add (mul (fsuf-w-content) (fsuf-content s))
                   (mul (fsuf-w-conf) (fsuf-confidence s)))
              (mul (fsuf-w-trust) (fsuf-trust s)))
         (add (add (fsuf-w-content) (fsuf-w-conf)) (fsuf-w-trust))))

; every soft axis at or above the floor — a present answer that no axis disqualifies.
(defn fsuf-above-floor? (s)
    (if (and (ge (fsuf-content s) (fsuf-floor))
             (and (ge (fsuf-confidence s) (fsuf-floor)) (ge (fsuf-trust s) (fsuf-floor)))) 1 0))

; which soft axis dragged below the floor (the escalation reason / the learning signal)
(defn fsuf-weak-reason (s)
    (if (lt (fsuf-content s) (fsuf-floor)) 3
        (if (lt (fsuf-confidence s) (fsuf-floor)) 4
            (if (lt (fsuf-trust s) (fsuf-floor)) 5 3))))

; THE verdict — soft, multi-signal:
;   garbled (no output OR bad shape) -> retry if a re-try remains, else escalate (transient recovery)
;   quality clears accept-threshold AND no axis under the floor -> accept (local stands)
;   otherwise -> escalate for the real answer (a quality gap; re-running a weak lane won't lift it)
(defn fsuf-verdict (s)
    (if (eq (mul (fsuf-has-output s) (fsuf-shape-ok s)) 0)
        (if (gt (fsuf-retries s) 0) 1 2)
        (if (and (ge (fsuf-quality s) (fsuf-accept-thr)) (eq (fsuf-above-floor? s) 1)) 0 2)))

; the reason behind the verdict — what the crossing should teach
(defn fsuf-reason (s)
    (if (eq (fsuf-has-output s) 0) 1
        (if (eq (fsuf-shape-ok s) 0) 2
            (if (eq (fsuf-verdict s) 0) 0 (fsuf-weak-reason s)))))

; the carrier's gate: 1 = escalate to the remote oracle, 0 = local stands or re-tries
(defn fsuf-escalate? (s) (if (eq (fsuf-verdict s) 2) 1 0))
0
; form-cli-ask.fk — the form-cli ASK flow as a PURE FORM recipe the kernel runs (no Python body).
;
; preludes: form-stdlib/core.fk form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk
;
; Local-first ask, IN THE KERNEL: call the local oracle (host-exec), judge its answer (host-exec),
; let the four-way-proven form-cli-sufficiency.fk decide accept / escalate, and on escalate call the
; subscription oracle (host-exec `claude -p`) for the real answer — recording the crossing (host-exec
; append) so the gap teaches the local lane. The body is Form; the kernel is the runtime; host-io is
; the only carrier. Modeled on form-native-run.fk. Witness: scripts/form_cli_ask.sh (bin/form-cli ask+).

; call an oracle: write the prompt to a file, exec `oracle < file`, return its stdout
(defn fca-oracle (oracle prompt)
    (do (host-write "/tmp/fca_prompt.txt" prompt)
        (host-exec (str_concat oracle " < /tmp/fca_prompt.txt 2>/dev/null"))))

; the first integer embedded in a string (so a chatty judge "the score is 84" still reads 84)
(defn fca-isdigit (c) (if (ge c 48) (if (le c 57) 1 0) 0))
; end of the digit run starting at i (str_to_int rejects trailing non-digits, so we slice exactly)
(defn fca-numend (s i)
    (if (ge i (str_len s)) i
        (if (eq (fca-isdigit (ord (char_at s i))) 1) (fca-numend s (add i 1)) i)))
; the LAST integer in a string — robust for a rating, since chatty judges ("0 issues, so 95")
; put the verdict last; taking the first would grab a leaked leading 0.
(defn fca-scan-nums (s i last)
    (if (ge i (str_len s)) last
        (if (eq (fca-isdigit (ord (char_at s i))) 1)
            (fca-scan-nums s (fca-numend s i) (str_to_int (substring s i (fca-numend s i))))
            (fca-scan-nums s (add i 1) last))))
(defn fca-clamp100 (n) (if (gt n 100) 100 n))
(defn fca-lastnum (s) (fca-clamp100 (fca-scan-nums s 0 0)))

; judge the answer's coverage of the question, 0..100 (the fcj content axis), via the local judge.
(defn fca-judge (judge question answer)
    (fca-lastnum (fca-oracle judge
        (str_concat "How fully does the ANSWER address the QUESTION? Reply with ONLY a single integer percent (higher means more complete), nothing else.\nQUESTION: "
            (str_concat question (str_concat "\nANSWER: " answer))))))

; did the local lane punt? -> shape-ok 0
(defn fca-refused? (ans)
    (if (ge (str_find ans "do not answer" 0) 0) 1
        (if (ge (str_find ans "cannot answer" 0) 0) 1
            (if (ge (str_find ans "not enough" 0) 0) 1
                (if (ge (str_find ans "don't have" 0) 0) 1 0)))))

; record the crossing (reason code) for learning — host-io append, the gap teaches the local lane
(defn fca-record (reason)
    (host-exec (str_concat "printf '%d\\n' " (str_concat (int_to_str reason)
        " >> $HOME/.coherence-network/form-cli-escalations.log"))))

; THE ask: local -> judge -> sufficiency verdict -> accept locally, or escalate for the real answer.
; trust is the lane's accumulated confidence (0..100), passed in; retries the re-try budget.
(defn fca-ask (question model judge remote trust retries)
    (do
        (let local (fca-oracle (str_concat "ollama run " model) question))
        (let hasout (if (gt (str_len local) 0) 1 0))
        (let shape (if (eq (fca-refused? local) 1) 0 1))
        (let content (if (eq hasout 1) (fca-judge judge question local) 0))
        (let sig (fsuf-signals hasout shape content trust trust retries))
        (let v (fsuf-verdict sig))
        (let r (fsuf-reason sig))
        (if (eq v 0)
            (str_concat "[local · sufficient · 0 subscription tokens]\n" local)
            (do
                (fca-record r)
                (str_concat "[escalated -> remote · reason " (str_concat (int_to_str r)
                    (str_concat "]\n" (fca-oracle remote question))))))))
; form-cli-repl.fk — the form-cli's interactive / non-interactive CONTROL logic, as recipes.
;
; preludes: form-stdlib/core.fk
;
; Every agent CLI (claude, codex, cursor, gemini, grok) has the same two modes: a one-shot
; print mode for scripts/pipes, and an interactive REPL when launched bare at a terminal. The
; SHELL of a REPL (reading lines, history, rendering) is carrier; the two decisions that govern
; it are logic, so they live here and are four-way proven — the carrier only gathers the reads
; and obeys the verdict.
;
; LAUNCH MODE — from three reads the carrier makes:
;   print-flag  1 if -p / --print was passed
;   tty         1 if stdin is a terminal
;   has-input   1 if a question arg or piped text is present
; ->  0 interactive (a REPL)   1 one-shot (answer once, exit)   2 help (no input, no terminal)
;
; PER-LINE KIND — inside the REPL, from three reads of the typed line:
;   is-empty    1 if blank
;   starts-paren 1 if it begins with '(' (a Form expression -> eval on the kernel, 0 tokens)
;   starts-slash 1 if it begins with '/' (a meta-command -> /help /model /local /exit ...)
; ->  0 form-expr   1 meta-command   2 question (the local-first ask+ loop)   3 empty (ignore)
;
; Proven by: form-stdlib/tests/form-cli-repl-band.fk

; the launch decision: an explicit -p or any given input is one-shot; a bare terminal is
; interactive; bare with no terminal (e.g. an empty pipe) falls to help.
(defn frepl-mode (print-flag tty has-input)
    (if (eq print-flag 1) 1
        (if (eq has-input 1) 1
            (if (eq tty 1) 0 2))))

; the per-line decision inside the REPL.
(defn frepl-classify (is-empty starts-paren starts-slash)
    (if (eq is-empty 1) 3
        (if (eq starts-slash 1) 1
            (if (eq starts-paren 1) 0 2))))

(defn frepl-interactive? (m) (if (eq m 0) 1 0))
(defn frepl-oneshot?     (m) (if (eq m 1) 1 0))
(defn frepl-help?        (m) (if (eq m 2) 1 0))
(defn frepl-is-question? (k) (if (eq k 2) 1 0))
(defn frepl-is-formexpr? (k) (if (eq k 0) 1 0))
(defn frepl-is-meta?     (k) (if (eq k 1) 1 0))
0
; form-native-run.fk — the form-cli agent runner as a PURE FORM recipe.
;
; preludes: form-stdlib/core.fk
;
; This is the runner the kernel runs — NOT hand-written emitted C. It composes the
; kernel's own primitives: host-io builtins (host-exec / host-read / host-write, the
; host-kernel.form driver layer) for the oracle call and tools, and the string
; builtins (str_find / substring / str_len) to parse the oracle's Hermes tool-call.
; The loop is Form recursion. No C, no Python — the body is Form, the kernel is the
; native runtime. Supersedes the emitted-C runner (form-cli-run.fk fcrun-emit).
;
; The oracle is a host command (ollama run qwen2.5:72b — local, sovereign; or
; claude -p). Tools: bash / read_file / write_file / search, each a tool-channel
; host:exec / host:file family. The reply is parsed tolerantly (tagged or bare JSON).
;
; Witness: scripts/form_native_run.sh (the kernel runs this recipe end to end).

; ── Hermes tool-call field extractor: "key":"value" -> value ("" if missing) ──
(defn fnr-jf (json key)
    (do
        (let patt (str_concat "\"" (str_concat key "\"")))
        (let ki (str_find json patt 0))
        (if (lt ki 0)
            ""
            (do
                (let colon (str_find json ":" (add ki (str_len patt))))
                (let q1 (str_find json "\"" (add colon 1)))
                (let q2 (str_find json "\"" (add q1 1)))
                (if (lt q2 0) "" (substring json (add q1 1) q2))))))

; ── the system prompt (Hermes tool protocol) ──
(defn fnr-sys ()
    "You are form-cli, a coding agent. Tools (reply with ONE line of JSON to use one): {\"name\":\"bash\",\"arguments\":{\"cmd\":\"...\"}} | {\"name\":\"read_file\",\"arguments\":{\"path\":\"...\"}} | {\"name\":\"write_file\",\"arguments\":{\"path\":\"...\",\"content\":\"...\"}} | {\"name\":\"edit\",\"arguments\":{\"path\":\"...\",\"find\":\"...\",\"replace\":\"...\"}} | {\"name\":\"search\",\"arguments\":{\"pattern\":\"...\"}} | {\"name\":\"glob\",\"arguments\":{\"pattern\":\"*.fk\"}}. After each tool you receive an OBSERVATION. When the task is done, reply with your final answer as plain text (no JSON).\n\n")

; ── call the oracle: write the prompt to a file, exec `oracle < file` ──
(defn fnr-oracle (oracle prompt)
    (do
        (host-write "/tmp/fnr_prompt.txt" prompt)
        (host-exec (str_concat oracle " < /tmp/fnr_prompt.txt 2>/dev/null"))))

; ── structured edit: replace the FIRST occurrence of `find` with `repl` in s (pure Form, four-way) ──
(defn fnr-replace (s find repl)
    (do
        (let i (str_find s find 0))
        (if (lt i 0) s
            (str_concat (substring s 0 i)
                (str_concat repl (substring s (add i (str_len find)) (str_len s)))))))

; ── execute a parsed tool-call (tc is the reply text carrying the JSON) ──
(defn fnr-exec (name tc)
    (if (str_eq name "bash")
        (host-exec (fnr-jf tc "cmd"))
        (if (str_eq name "read_file")
            (host-read (fnr-jf tc "path"))
            (if (str_eq name "write_file")
                (do (host-write (fnr-jf tc "path") (fnr-jf tc "content"))
                    (str_concat "wrote " (fnr-jf tc "path")))
                (if (str_eq name "search")
                    (host-exec (str_concat "grep -rn -- '" (str_concat (fnr-jf tc "pattern") "' . 2>/dev/null | head -40")))
                    (if (str_eq name "edit")
                        (do (host-write (fnr-jf tc "path")
                                (fnr-replace (host-read (fnr-jf tc "path")) (fnr-jf tc "find") (fnr-jf tc "replace")))
                            (str_concat "edited " (fnr-jf tc "path")))
                        (if (str_eq name "glob")
                            (host-exec (str_concat "find . -name '" (str_concat (fnr-jf tc "pattern") "' 2>/dev/null | head -40")))
                            "(unknown tool)")))))))

; ── is this reply a tool-call? (carries both "name" and "arguments") ──
(defn fnr-toolcall? (reply)
    (if (and (ge (str_find reply "\"name\"" 0) 0) (ge (str_find reply "\"arguments\"" 0) 0)) 1 0))

; ── the loop: recurse over (transcript, step) until a final answer or max. The
;    `guide` is the runner's self-guidance — the corpus-trained tool predictor's
;    likely-tools hint for this task (form-cli-predict.fk, computed by the
;    carrier), prepended to the system prompt so the local model stops omitting
;    tools it learned to need (e.g. Bash). Empty guide = the unguided runner. ──
(defn fnr-step (oracle guide transcript step max)
    (if (ge step max)
        (str_concat "(reached max-steps)\n" transcript)
        (do
            (let prompt (str_concat (fnr-sys) (str_concat guide (str_concat transcript "\nYour reply:"))))
            (let reply (fnr-oracle oracle prompt))
            (if (eq (fnr-toolcall? reply) 0)
                reply
                (do
                    (let nm (fnr-jf reply "name"))
                    (let obs (fnr-exec nm reply))
                    (fnr-step oracle guide
                        (str_concat transcript
                            (str_concat "\nACTION " (str_concat (int_to_str step)
                                (str_concat ": " (str_concat reply (str_concat "\nOBSERVATION: " obs))))))
                        (add step 1) max))))))

; ── the entry: run a task. returns the final answer (or the capped transcript). ──
(defn fnr-run (task oracle max)
    (fnr-step oracle "" (str_concat "TASK: " task) 1 max))
; ── self-guided entry: the runner runs with the predictor's likely-tools hint. ──
(defn fnr-run-guided (task oracle max guide)
    (fnr-step oracle guide (str_concat "TASK: " task) 1 max))

; ── FRONTIER-IN-THE-LOOP: a step's reply is usable if it is a tool-call OR a substantive final
;    answer; a garbled/empty local reply (the weak-model failure we saw) is not. ──
(defn fnr-usable? (reply)
    (if (eq (fnr-toolcall? reply) 1) 1 (if (gt (str_len reply) 40) 1 0)))

; tiered step: try the LOCAL oracle; if its reply is not usable, escalate THIS step to the REMOTE
; (frontier) oracle — local-first quality, frontier when local can't, learning toward sovereignty.
(defn fnr-step-tiered (local remote guide transcript step max)
    (if (ge step max)
        (str_concat "(reached max-steps)\n" transcript)
        (do
            (let prompt (str_concat (fnr-sys) (str_concat guide (str_concat transcript "\nYour reply:"))))
            (let lr (fnr-oracle local prompt))
            (let reply (if (eq (fnr-usable? lr) 1) lr (fnr-oracle remote prompt)))
            (if (eq (fnr-toolcall? reply) 0)
                reply
                (do
                    (let nm (fnr-jf reply "name"))
                    (let obs (fnr-exec nm reply))
                    (fnr-step-tiered local remote guide
                        (str_concat transcript
                            (str_concat "\nACTION " (str_concat (int_to_str step)
                                (str_concat ": " (str_concat reply (str_concat "\nOBSERVATION: " obs))))))
                        (add step 1) max))))))

; ── SESSION MEMORY (logs now, substrate later): read recent session context, persist this run. ──
(defn fnr-recent ()
    (host-exec "tail -c 1500 $HOME/.coherence-network/form-cli-sessions.log 2>/dev/null"))
(defn fnr-persist (transcript)
    (do (host-write "/tmp/fnr_session.txt" transcript)
        (host-exec "cat /tmp/fnr_session.txt >> $HOME/.coherence-network/form-cli-sessions.log; printf '\\n=== /turn ===\\n' >> $HOME/.coherence-network/form-cli-sessions.log")))

; tiered entry WITH memory: prepend recent session context, run local-first+escalating, persist the run
; (the persisted transcript is both cross-turn memory AND a training corpus of real agent work).
(defn fnr-run-tiered (task local remote max)
    (do
        (let mem (fnr-recent))
        (let guide (if (gt (str_len mem) 0) (str_concat "RECENT SESSION (memory):\n" (str_concat mem "\n\n")) ""))
        (let result (fnr-step-tiered local remote guide (str_concat "TASK: " task) 1 max))
        (do (fnr-persist result) result)))
