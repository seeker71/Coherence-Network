; higher.fk — exercises higher-order patterns + list shape transforms.
; Returns an integer that aggregates several expected results; both
; kernels must agree.
;
; Components:
;   (sum (reverse [1 2 3 4 5]))           → 15
;   (sum (append [1 2 3] [4 5 6]))        → 21
;   (sum (take 3 [1 2 3 4 5]))            → 6
;   (sum (drop 3 [1 2 3 4 5]))            → 9
;   (if (any? even? [1 3 4]) 1 0)         → 1
;   (if (all? even? [2 4 6]) 1 0)         → 1
;   (if (any? even? [1 3 5]) 1 0)         → 0
;   (if (all? even? [1 2 4]) 1 0)         → 0
;   Total                                  → 53

(do
    (defn b->i (b) (if b 1 0))
    (add (sum (reverse (list 1 2 3 4 5)))
    (add (sum (append (list 1 2 3) (list 4 5 6)))
    (add (sum (take 3 (list 1 2 3 4 5)))
    (add (sum (drop 3 (list 1 2 3 4 5)))
    (add (b->i (any? even? (list 1 3 4)))
    (add (b->i (all? even? (list 2 4 6)))
    (add (b->i (any? even? (list 1 3 5)))
         (b->i (all? even? (list 1 2 4))))))))))
)
