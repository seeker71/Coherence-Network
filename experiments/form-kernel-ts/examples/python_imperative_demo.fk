(do (defn sum_to (n) (do (let total 0) (let i 1) (do (defn _while_0 (total i) (if (le i n) (_while_0 (add total i) (add i 1)) (list total i))) (let _while_1_result (_while_0 total i)) (let total (nth _while_1_result 0)) (let i (nth _while_1_result 1))) total)) (defn fact_loop (n) (do (let result 1) (let i 1) (do (defn _while_1 (result i) (if (le i n) (_while_1 (mul result i) (add i 1)) (list result i))) (let _while_2_result (_while_1 result i)) (let result (nth _while_2_result 0)) (let i (nth _while_2_result 1))) result)) (add (sum_to 100) (fact_loop 8)))
