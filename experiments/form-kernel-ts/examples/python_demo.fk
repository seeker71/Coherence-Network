(do (defn fact (n) (if (lt n 2) 1 (mul n (fact (sub n 1))))) (defn fib (n) (if (lt n 2) n (add (fib (sub n 1)) (fib (sub n 2))))) (defn ackermann (m n) (if (eq m 0) (add n 1) (if (eq n 0) (ackermann (sub m 1) 1) (ackermann (sub m 1) (ackermann m (sub n 1)))))) (defn is_prime_helper (n i) (if (gt (mul i i) n) true (if (eq (mod n i) 0) false (is_prime_helper n (add i 1))))) (defn is_prime (n) (if (lt n 2) false (is_prime_helper n 2))) (defn count_primes_helper (n limit count) (if (ge n limit) count (count_primes_helper (add n 1) limit (add count (if (is_prime n) 1 0))))) (defn count_primes (limit) (count_primes_helper 2 limit 0)) (add (add (add (count_primes 30) (fact 8)) (fib 15)) (ackermann 2 3)))
