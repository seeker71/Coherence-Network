# Discord bot token (bot permissions: channels, messages, reactions, threads)
DISCORD_TOKEN=

# Target Discord server (guild) ID
DISCORD_GUILD_ID=

# Category names for channel organization
DISCORD_ACTIVE_CATEGORY=Active Ideas
DISCORD_ARCHIVE_CATEGORY=Archived Ideas

# Named channel slugs
DISCORD_SUBMISSIONS_CHANNEL=idea-submissions
DISCORD_PIPELINE_CHANNEL=pipeline-feed
DISCORD_COMMANDS_CHANNEL=bot-commands

# Coherence Network REST API base URL
COHERENCE_API_BASE=https://api.coherencycoin.com

# Polling intervals
POLL_INTERVAL_SEC=60
SYNC_INTERVAL_MIN=5

# Logging
LOG_LEVEL=info

# Data directory for SQLite databases
DATA_DIR=./data
