{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mfb-html-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "8765"
      ],
      "port": 8765,
      "cwd": "experiments/memory-as-framebuffer-v0"
    },
    {
      "name": "api",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "port": 8000,
      "cwd": "api"
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 3000,
      "autoPort": true,
      "cwd": "web",
      "env": {
        "API_URL": "http://localhost:8000"
      }
    },
    {
      "name": "pulse",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "PULSE_API_BASE=https://api.coherencycoin.com",
        "PULSE_WEB_BASE=https://coherencycoin.com",
        "PULSE_DB_PATH=./data/pulse.db",
        "PULSE_INTERVAL_SECONDS=15",
        "PULSE_CORS_ORIGINS=*",
        ".venv/bin/uvicorn",
        "pulse_app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8100"
      ],
      "port": 8100,
      "cwd": "/Users/ursmuff/source/Coherence-Network/.claude/worktrees/silence-3d/pulse"
    }
  ]
}
