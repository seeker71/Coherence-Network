{
  "edge_types": [
    {
      "type": "inspires",
      "description": "A gave rise to or motivated B without directly implementing it — soft causal origin",
      "symmetric": false,
      "direction_label": "A → B",
      "example": "idea:resonance-nav → inspires → idea:fractal-primitives"
    },
    {
      "type": "depends-on",
      "description": "A requires B to function correctly or to be implemented first — hard dependency",
      "symmetric": false,
      "direction_label": "A → B",
      "example": "spec:169 → depends-on → spec:166"
    },
    {
      "type": "implements",
      "description": "A puts B into practice — code realises a spec, a spec realises an idea",
      "symmetric": false,
      "direction_label": "A → B",
      "example": "impl:graph-router → implements → spec:166"
    },
    {
      "type": "contradicts",
      "description": "A and B are in tension or mutually exclusive — logically symmetric",
      "symmetric": true,
      "direction_label": "A ↔ B",
      "example": "idea:centralise-auth ↔ contradicts ↔ idea:federated-identity"
    },
    {
      "type": "extends",
      "description": "A adds to or refines B, building on its foundation without replacing it",
      "symmetric": false,
      "direction_label": "A → B",
      "example": "spec:169 → extends → spec:166"
    },
    {
      "type": "analogous-to",
      "description": "A and B are structurally isomorphic or conceptually parallel — cross-domain isomorphism",
      "symmetric": true,
      "direction_label": "A ↔ B",
      "example": "concept:ice-water-gas ↔ analogous-to ↔ concept:breath-states"
    },
    {
      "type": "parent-of",
      "description": "A hierarchically contains B — A is the container, B is the sub-unit",
      "symmetric": false,
      "direction_label": "A → B",
      "example": "domain:graph-theory → parent-of → concept:edge-types"
    }
  ]
}
