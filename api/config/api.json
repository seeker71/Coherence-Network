{
  "_doc": "API server configuration. Phase 1: core runtime (database, auth, telegram, CORS).",

  "database": {
    "_doc": "Primary database. Used by graph_nodes, graph_edges, specs, ideas, etc.",
    "url": "sqlite:///data/coherence.db",
    "_url_doc": "SQLite for dev, PostgreSQL for production: postgresql://user:pass@host/db"
  },

  "database_overrides": {
    "_doc": "Per-service database URLs. null = use database.url as fallback.",
    "agent_tasks": null,
    "agent_runner_registry": null,
    "agent_run_state": null,
    "commit_evidence": null,
    "runtime": null,
    "telemetry": null,
    "runtime_events": null,
    "_doc2": "Set these only if a service needs its own database (e.g., separate PostgreSQL instance)."
  },

  "auth": {
    "_doc": "API authentication keys.",
    "api_key": "dev-key",
    "admin_key": "dev-admin",
    "_warning": "Change these in production. dev-key is rejected when COHERENCE_ENV=production."
  },

  "cors": {
    "_doc": "Allowed CORS origins for web frontend.",
    "allowed_origins": [
      "https://coherencycoin.com",
      "https://www.coherencycoin.com",
      "http://localhost:3000",
      "http://localhost:3001"
    ]
  },

  "telegram": {
    "_doc": "Telegram bot for alerts on failed/needs_decision tasks.",
    "bot_token": null,
    "chat_ids": [],
    "allowed_user_ids": [],
    "failed_alert_max_per_window": 5,
    "failed_alert_window_seconds": 3600
  },

  "translator": {
    "_doc": "View attunement backend selection. Secrets belong in ~/.coherence-network/config.json or keys.json.",
    "backend": "libretranslate",
    "libretranslate_url": "https://libretranslate.com",
    "libretranslate_key": null,
    "anthropic_api_key": null,
    "anthropic_api_url": "https://api.anthropic.com/v1/messages",
    "anthropic_model": "claude-haiku-4-5-20251001",
    "timeout_seconds": 120
  },

  "news": {
    "_doc": "News ingestion source list and fetch behavior.",
    "sources_path": "config/news-sources.json",
    "cache_ttl_seconds": 900,
    "fetch_timeout_seconds": 15.0,
    "user_agent": "CoherenceNetwork/1.0"
  },

  "storage": {
    "_doc": "File paths for local storage (dev mode). Production uses database.url.",
    "graph_store_path": null,
    "idea_portfolio_path": null,
    "value_lineage_path": null,
    "_doc2": "null = use database. Set paths only for file-based dev mode."
  },

  "server": {
    "_doc": "Server behavior.",
    "environment": "development",
    "enable_hsts": false,
    "_environment_doc": "development or production. Production enforces real API keys."
  },

  "agent_tasks": {
    "_doc": "Task store configuration.",
    "persist": true,
    "use_db": true,
    "path": null,
    "db_reload_ttl_seconds": 1800,
    "output_max_chars": 50000,
    "task_output_max_chars": 4000,
    "retry_max": 3,
    "runtime_fallback_mode": "disabled",
    "runtime_fallback_limit": 100,
    "runtime_fallback_in_tests": false,
    "route_side_effects_in_tests": false,
    "hollow_completion_guard_in_tests": false,
    "task_log_dir": "data/task_logs",
    "smart_reap_max_age_minutes": 15
  },

  "agent_executor": {
    "_doc": "How tasks are executed by the API-side executor (not the local runner).",
    "default": "federation",
    "cheap_default": "federation",
    "repo_default": "federation",
    "open_question_default": "federation",
    "escalate_to": null,
    "policy_enabled": true,
    "allow_unavailable_explicit": false,
    "disable_codex_executor": true,
    "auto_execute": false,
    "executors": [],
    "execute_token": null,
    "execute_token_allow_unauth": false,
    "escalate_failure_threshold": 1,
    "escalate_retry_threshold": 2,
    "_doc2": "default=federation means tasks go to node runners, not API-side execution."
  },

  "agent_cost": {
    "_doc": "Cost tracking and budget controls.",
    "max_cost_usd": 2.0,
    "estimated_cost_usd": 0.5,
    "cost_slack_ratio": 1.5,
    "runtime_cost_per_second": 0.002,
    "external_input_cost_per_1k": 0.003,
    "external_output_cost_per_1k": 0.015,
    "allow_paid_providers": true,
    "block_on_soft_quota_threshold": false,
    "paid_tool_8h_limit": null,
    "paid_tool_week_limit": null,
    "paid_tool_window_budget_fraction": 0.333
  },

  "automation_usage": {
    "_doc": "Automation usage service configuration.",
    "endpoint_cache_max_workers": 4,
    "quality_awareness_ttl_seconds": 300.0,
    "snapshots_path": null,
    "use_db": true,
    "purge_imported_files": true,
    "max_snapshots": 800
  },

  "persistence_contract": {
    "_doc": "Global persistence enforcement. true/false force behavior; auto enforces only when a non-SQLite primary database is configured.",
    "required": "auto"
  },

  "route_registry": {
    "_doc": "Route registry configuration.",
    "canonical_routes_path": null
  },

  "agent_lifecycle": {
    "_doc": "Task lifecycle event logging.",
    "jsonl_enabled": false,
    "jsonl_path": null,
    "jsonl_max_lines": 10000,
    "telemetry_enabled": false,
    "subscribers": []
  },

  "metrics": {
    "_doc": "Metrics collection and aggregation settings.",
    "file_path": null,
    "use_db": null,
    "purge_legacy_file": true,
    "max_rows": 50000
  },

  "agent_providers": {
    "_doc": "Provider-specific API config for the executor.",
    "codex_home": null,
    "codex_oauth_session_file": null,
    "orchestration_policy_path": null,
    "retry_openai_model_override": null,
    "auto_retry_openai_override": false,
    "api_base_url": "https://api.coherencycoin.com",
    "web_ui_base_url": "https://coherencycoin.com",
    "openrouter_chat_url": null,
    "openrouter_http_referer": null,
    "openrouter_x_title": null,
    "openrouter_temperature": 0.2,
    "openrouter_disable_stream": "1"
  },

  "pipeline": {
    "_doc": "Pipeline monitoring and threshold settings.",
    "orphan_running_seconds": 1800,
    "stale_running_seconds": 1800,
    "monitor_max_age_seconds": 900,
    "status_report_max_age_seconds": 900,
    "pending_actionable_window_seconds": 86400,
    "poll_interval_seconds": 60,
    "concurrency": 1
  },

  "inventory": {
    "_doc": "Inventory service configuration.",
    "cache_ttl_seconds": 30.0,
    "timing_log_ms": 750.0,
    "timing_enabled": false,
    "project_root": null,
    "tracking_repository": null,
    "tracking_repository_ref": null
  },

  "ideas": {
    "_doc": "Idea service configuration.",
    "internal_idea_id_prefixes": null,
    "internal_idea_id_exact": null,
    "internal_idea_interface_tags": null,
    "sync_enable_domain_discovery": null,
    "sync_runtime_window_seconds": 86400,
    "sync_runtime_event_limit": 2000,
    "sync_contribution_limit": 3000
  },

  "runtime": {
    "_doc": "Runtime events configuration.",
    "events_path": null,
    "idea_map_path": null,
    "agent_tasks_path": null,
    "tool_success_streak_target": 3,
    "endpoint_cache_ttl_seconds": 120.0,
    "endpoint_cache_max_workers": 4,
    "telemetry_enabled": true
  },

  "api": {
    "_doc": "API process settings.",
    "slow_request_ms": 1500.0,
    "testing": false,
    "test_context_id": null,
    "log_all_requests": false
  },

  "audit_ledger": {
    "_doc": "Transparent audit ledger diagnostics.",
    "debug": false
  },

  "web": {
    "_doc": "Shared web settings consumed by the Next.js app.",
    "api_base_url": "https://api.coherencycoin.com",
    "local_api_base_url": "http://localhost:8000",
    "deployed_sha": null,
    "updated_at": null
  },

  "live_updates": {
    "_doc": "Client-side live refresh controls.",
    "poll_ms": 120000,
    "router_refresh_every_ticks": 8,
    "global": false,
    "active_route_prefixes": [
      "/tasks",
      "/remote-ops",
      "/api-health",
      "/gates"
    ],
    "router_refresh_skip_prefixes": [
      "/automation"
    ]
  },

  "runtime_beacon": {
    "_doc": "Client runtime beacon sampling and proxy behavior.",
    "sample_rate": 0.2,
    "upstream_timeout_ms": 5000,
    "failure_threshold": 3,
    "cooldown_ms": 30000
  },

  "health_proxy": {
    "_doc": "Health proxy failure/cooldown behavior for the web app.",
    "failure_threshold": 2,
    "cooldown_ms": 30000
  },

  "cli": {
    "_doc": "Shared CLI defaults stored in config.json.",
    "provider": "cli",
    "active_task_id": null
  },

  "commit_evidence": {
    "_doc": "Commit evidence configuration.",
    "directory": null
  },

  "route_evidence": {
    "_doc": "Route evidence configuration.",
    "probe_directory": null
  },

  "friction": {
    "_doc": "Friction ledger service configuration.",
    "events_path": null,
    "use_db": null,
    "purge_imported_files": "1"
  },

  "monitor": {
    "_doc": "Monitor issues configuration.",
    "issues_path": null
  },

  "github_actions": {
    "_doc": "GitHub Actions health configuration.",
    "health_path": null
  },

  "data_retention": {
    "_doc": "Data retention service configuration.",
    "hot_days": 7,
    "warm_days": 30,
    "cold_days": 90,
    "backup_dir": "data/retention-backups"
  },

  "contributor_hygiene": {
    "_doc": "Contributor hygiene configuration.",
    "test_email_domains": null,
    "plus_alias_domains": null,
    "email_alias_map": null,
    "internal_email_prefixes": null
  },

  "smart_reap": {
    "_doc": "Smart reap service configuration.",
    "runner_liveness_seconds": 270,
    "human_attention_threshold": 3
  },

  "governance": {
    "_doc": "Governance service configuration.",
    "min_approvals": 1
  },

  "federation": {
    "_doc": "Federation service configuration.",
    "stats_window_days": 7,
    "bridge_token": null
  },

  "github": {
    "_doc": "GitHub integration settings.",
    "token": null,
    "api_token": null
  },

  "release_gates": {
    "_doc": "Release gate configuration.",
    "verification_jobs_path": null,
    "verification_max_attempts": 8,
    "verification_retry_seconds": 60,
    "branch_head_sha_timeout_seconds": 6.0,
    "branch_head_sha_cache_ttl_seconds": 45.0,
    "require_telegram_alerts": false,
    "require_provider_readiness": false,
    "require_api_health_sha": false,
    "require_web_health_proxy_sha": false
  },

  "deploy_logs_url": null,

  "deployed_sha": null,

  "github_token": null
}
