+  if (!response || typeof response !== "object" || Array.isArray(response)) return null;
+  const raw = response as Record<string, unknown>;
+  if (!Object.prototype.hasOwnProperty.call(raw, "pending")
+    && !Object.prototype.hasOwnProperty.call(raw, "running")
+    && !Object.prototype.hasOwnProperty.call(raw, "completed")) {
+    return null;
+  }
+  return {
+    pending: parseStatusCount(raw.pending),
+    running: parseStatusCount(raw.running),
+    completed: parseStatusCount(raw.completed),
+  };
