(do (defn slen (s) (str_len s)) (defn chr (s i) (substring s i (add i 1))) (defn find_ch (s c i) (if (lt i (slen s)) (if (str_eq (chr s i) c) i (find_ch s c (add i 1))) -1)) (defn field_end (line) (do (let colon (find_ch line ":" 0)) (do (let semi (find_ch line ";" 0)) (if (lt colon 0) -1 (if (lt semi 0) colon (if (lt semi colon) semi colon)))))) (defn starts (line name) (do (let e (field_end line)) (if (lt e 0) 0 (if (str_eq (substring line 0 e) name) 1 0)))) (defn ical_field (line name) (if (eq (starts line name) 0) "" (do (let colon (find_ch line ":" 0)) (if (lt colon 0) "" (substring line (add colon 1) (slen line)))))) (let line "DTSTART;VALUE=DATE:20260615") (let name "DTSTART") (ical_field line name))
