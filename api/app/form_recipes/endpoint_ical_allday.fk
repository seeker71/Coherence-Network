(do (defn slen (s) (str_len s)) (defn has_char (s c i) (if (lt i (slen s)) (if (str_eq (substring s i (add i 1)) c) 1 (has_char s c (add i 1))) 0)) (defn has_str (s sub i) (if (gt (add i (slen sub)) (slen s)) 0 (if (str_eq (substring s i (add i (slen sub))) sub) 1 (has_str s sub (add i 1))))) (defn is_allday (value params) (if (eq (has_str params "VALUE=DATE" 0) 1) 1 (if (eq (slen value) 8) (if (eq (has_char value "T" 0) 0) 1 0) 0))) (let value "20260615") (let params "") (is_allday value params))
