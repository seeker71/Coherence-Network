    {
      "kind": "manual",
      "id": "practice:contact-improv",
      "type": "practice",
      "name": "Contact Improv",
      "description": "Contact Improvisation — a post-modern dance practice of shared weight, spontaneous duets, listening through skin. Global tradition (founded in 1972 by Steve Paxton) with deep local embodiments — in Boulder, Ecstatic Movement Tribe holds regular jams that open awareness to an entire community of moving bodies learning each other's weight.",
      "properties": {
        "claimed": false,
        "scope": "global-and-local"
      }
    },
    {
      "kind": "manual",
      "id": "practice:cacao-ceremony",
      "type": "practice",
      "name": "Cacao Ceremony",
      "description": "Cacao Ceremony — an indigenous-rooted container where cacao is held as medicine and teacher, opening the heart, grounding the body, preparing the room for deeper presence. The practice travels globally; each ceremonialist holds it in their own voice (Bruna Bortolato's lineage runs through Mayan Guatemala with Mose).",
      "properties": {
        "claimed": false,
        "scope": "global-and-local"
      }
    },
