            meaning: "the kernel-router reads ideas/INDEX.md and emits an IdeaPortfolioResponse-shaped curated portfolio without CPython",
            boundary: "source-backed curated portfolio is native; mutable DB-backed /api/ideas still fans out until a live graph storage carrier lands",
        },
        {
            path: "/api/ideas/graph-projection",
            route_source: "deploy/kernel-router/production-routes.fk::route_ideas_graph_projection",
            status: "kernel-first capable",
