    ],
    ["resolve contributor", "honor dry-run as no-write preview", "execute or inspect stake", "return value trace"],
    ["api/tests/test_investments.py", "api/tests/test_portfolio_governance.py"]
);

defn rollup_super_idea_recipe() = idea_route_recipe(
    "rollup",
    "Let super-ideas read and validate their child completion condition.",
    [
        idea_route("get_idea_rollup", "GET", "/ideas/{idea_id}/rollup", "read rollup", "idea_service.get_rollup_progress", "RollupProgress", ["super-idea-rollup-criteria"]),
        idea_route("validate_super_idea_rollup", "POST", "/ideas/{idea_id}/validate-rollup", "validate rollup", "idea_service.validate_super_idea", "RollupProgress", ["require_api_key", "super-idea-rollup-criteria"]),
    ],
    ["read super-idea", "count validated children", "apply rollup condition", "return progress or exact blocker"],
    ["api/tests/test_idea_lifecycle_closure.py"]
);

defn inspect_idea_recipe() = idea_route_recipe(
    "inspect",
    "Return one idea and its local resonance surfaces.",
    [
        idea_route("get_idea", "GET", "/ideas/{idea_id}", "inspect idea", "idea_service.get_idea", "IdeaWithScore", ["question votes heard", "language projection"]),
        idea_route("get_idea_concept_resonance", "GET", "/ideas/{idea_id}/concept-resonance", "inspect concepts", "idea_service.get_concept_resonance_matches", "IdeaConceptResonanceResponse", ["cross-domain concept resonance"]),
        idea_route("get_idea_resonance", "GET", "/ideas/{idea_id}/resonance", "inspect resonant ideas", "idea_resonance_service.find_resonant_ideas", "list[dict]", ["coherence score"]),
        idea_route("get_idea_breath", "GET", "/ideas/{idea_id}/breath", "inspect phase", "breath_service.compute_idea_breath", "dict", ["gas/water/ice"]),
        idea_route("get_idea_lifecycle", "GET", "/ideas/{idea_id}/lifecycle", "inspect closure", "idea_service.get_idea_lifecycle", "dict", ["closure blockers"]),
    ],
    ["resolve idea", "attach local evidence", "project requested view", "return exact not-found when absent"],
    ["api/tests/test_discord_votes_heard.py", "api/tests/test_idea_lifecycle_closure.py"]
);

# ---------------------------------------------------------------------
# Part 3 -- the whole router as one structure
# ---------------------------------------------------------------------

