            status: "kernel-first capable",
            meaning: "the high-level ideas router structure is dispatchable by the kernel-router without CPython",
            boundary: "mutable portfolio data routes still fan out to FastAPI until storage-backed ideas recipes lift",
        },
        {
            path: "/api/ideas/source-index",
            route_source: "deploy/kernel-router/production-routes.fk::route_ideas_source_index",
