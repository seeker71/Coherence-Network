        "claim boundary",
    ],
    "routing claims are strong when live machine receipts carry them",
    [
        "decision can cite receipt",
        "freshness boundary visible",
        "numeric gaps remain visible",
    ],
    "yield > spend",
    "cite the receipt and rerun when freshness expires",
    [
        "API status became resonance evidence",
        "machine receipt bounded language",
        "claim strength followed observed fields",
    ]
);

defn skipped_form_flow = observable_resonance_flow(
    "visitor lingers on page and skips one field",
    "witness-trace page interaction",
    "event-class trace with privacy budget and retention window",
    ["behavioral", "relational", "lexical"],
    [
        "field label",
        "prompt text",
        "page copy",
    ],
    [
        "privacy budget",
        "event retention",
        "interpretation attention",
    ],
    "the page resonates while the field asks too soon",
    [
        "move ask later",
        "reduce form pressure",
        "watch completion improve",
    ],
    "yield ~= spend",
    "shift timing before adding explanation",
    [
        "linger marked resonance",
        "skipped field marked timing pressure",
        "language change follows behavioral spectrum",
    ]
);

defn observable_resonance_examples() = [
    hati_suci_image_flow,
    awen_audio_flow,
    readiness_api_flow,
    skipped_form_flow,
];

# ---------------------------------------------------------------------
# Part 4 -- operating rule
# ---------------------------------------------------------------------

defn resonance_yield_rule(flow) =
    [
        "record spectrum before adding language",
        "record language spend before adding explanation",
        "record observer spend before widening the look",
        "name the shared pattern",
        "measure yield after contact",
        "route the next carrier by yield",
    ];
