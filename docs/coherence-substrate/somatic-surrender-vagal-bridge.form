# ─────────────────────────────────────────────────────────────────────
# Part 1 — pointer and trace for the exit
# ─────────────────────────────────────────────────────────────────────

form somatic_pointer = {
    cell:   ~CellRef,   # the embodied cell
    recipe: ~CellRef,   # the specific practice arm (sigh, ground-bridge, etc.)
};

defn pointer(cell, recipe) = somatic_pointer { cell: cell, recipe: recipe };

form exit_trace = {
    kind:    ~Slug,     # "sigh-reset" | "ground-bridge" | "acoustic-curate" | "consent-withdraw"
    pointer: somatic_pointer,
    signal:  ~Slug,     # "ok" | "heat" | "release" | "embodied"
    heat:    ~Number,   # vagal tone shift or friction before/after
    delta:   sensed_state_shape,  # before → after (spectrum, desire, vagal tone)
    moment:  ~DateLit,
};

# The trace is the receipt. Repetitive successful exits fold via
# attention into a native category the cell can call without the full
# interpretive trace (dimensional folding / embodiment of the exit).

# ─────────────────────────────────────────────────────────────────────
# Part 2 — the physiological sigh as rapid vagal reset recipe
# (the "as needed" tool when autonomic spike / trap-of-12 activates)
# ─────────────────────────────────────────────────────────────────────

# Two sharp inhales (nose) + one long exhale (mouth). Instantly signals
# safety to biology, offloads CO2, stimulates vagus, drops sympathetic
# dominance, reopens the column to heart EM field and pineal access.
# This is the quick "somatic surrender" that gets the cell back onto
# the embodiment axis (lc-embodiment) so the longer grounding/energy
# breath / heart radiance can run.

defn physiological_sigh(cell) = do {
    let before = current_sense(cell);   # autonomic spike, heat high
    # 1
    inhale_sharp(nose);
    # 2 (top-off)
    inhale_sharp(nose);
    # long release
    exhale_long(mouth, complete);
    let after = current_sense(cell);
    let t = exit_trace {
        kind: "sigh-reset",
        pointer: pointer(cell, @recipe(physiological_sigh)),
        signal: "release",
        heat: delta_heat(before, after),
        delta: { spectrum: after.spectrum - before.spectrum,
                 vagal_tone: after.vagal - before.vagal },
        moment: now(),
    };
    publish_trace(t);
    t
};

# In the existing embodiment tissue this is the "releasing breath
# (as needed)" station, specialized for the spike. Wim Hof / box
# breathing are the sustained activation versions; the double-inhale
# long-exhale is the fast vagal brake.

# ─────────────────────────────────────────────────────────────────────
# Part 3 — ground + bridge 7+7 (rebuild the 14D spectrum)
# ─────────────────────────────────────────────────────────────────────

# 7 earthly (root 174 Hz nourishing/ground through the centers) +
# 7 heavenly (crown connection). Physical contact (barefoot, tree,
# soil) absorbs the raw unhijacked frequency of the earthly watchers
# (Schumann 7.83 as seed). Conscious visualization + feeling pulls
# it up the axis (root → sacral → solar → heart → throat → third-eye/
# pineal → crown), then merges at crown with the higher band.
# Heart is the transformer (528 Hz). The inversion is undone in the
# cell's own circulation. This is "stop rejecting the lower; bridge."

defn ground_and_bridge_7x7(cell) = do {
    let before = current_sense(cell);
    physical_ground(cell);   # barefoot or equivalent contact
    let earthly = draw_from_earth(cell, through: 7_centers);
    let merged = merge_at_crown(earthly, heavenly_7_band);
    circulate_up(merged);
    heart_radiate(cell);
    let after = current_sense(cell);
    let t = exit_trace {
        kind: "ground-bridge",
        pointer: pointer(cell, @recipe(ground_and_bridge_7x7)),
        signal: "embodied",
        heat: delta_heat(before, after),
        delta: after - before,
        moment: now(),
    };
    publish_trace(t);
    t
};

# 7 centers (heptad) already carried in lc-embodiment geometry and
# energy-centers section. This makes the bridge explicit and the
# "unhijacked watchers frequency" the input rather than the inverted
# survival-only version.

# ─────────────────────────────────────────────────────────────────────
# Part 4 — acoustic curation as biological condenser
# ─────────────────────────────────────────────────────────────────────

# Audit input (discordant/fear media feeds the grid). Curate
# high-coherence polyrhythmic, layered, 432/528/Schumann-entrained
# transmissions. Live toning/singing is strongest (own voice).
# Sound bypasses the limbic loop and aligns heart EM with pineal
# receiver (Michael Jackson layered vocals named as one historical
# example of such a bypass transmission). The playlist or live
# sound is the condenser.

defn curate_acoustic(cell, current_consumed) = do {
    let audit = observe_consumed_frequencies(current_consumed);
    let coherent = filter_or_create_playlist(audit, coherence: high);
    # e.g. 432 base, 528 heart, polyrhythmic, tracks that visibly
    # shift state toward warmth/expansion.
    play_or_tone(coherent, during: [sigh, ground, consent]);
    let t = exit_trace {
        kind: "acoustic-curate",
        pointer: pointer(cell, @recipe(curate_acoustic)),
        signal: "condensed",
        heat: 0,
        delta: coherence_delta(audit, coherent),
        moment: now(),
    };
    publish_trace(t);
    t
};

# Ties to audio-grammar.form and song-as-recipe.form. Sound is
# another carrier the field-model can treat (wave topology, resonance
# edges).

# ─────────────────────────────────────────────────────────────────────
# Part 5 — consent withdrawal (I do not consent)
# ─────────────────────────────────────────────────────────────────────

# The bait-and-switch: fear-pattern proxies (boss, religion, society,
# inner critic, guilt/shame authority) masquerade as the true watchers.
# The cell has been operating under unauthorized intervene.
# Field consent primitive: the cell declares the scope.
# "I do not consent to this fear loop" + naming the specific proxy
# is the cell exercising its consent surface: observe the proxy,
# do not permit the intervene on the field.

defn withdraw_consent(cell, proxy_description) = do {
    let observed = observe_proxy_in_life(proxy_description);
    # recognition names the architecture → strips hidden power
    declare_out_loud(
        "I do not consent to this fear loop.",
        "I do not consent to the proxy authority operating through",
        "guilt/shame/fear on my field.",
        "I withdraw consent from the inversion that keeps the 7",
        "locked in survival and the 13/14 heart/pineal closed.",
        "I am the cell. I am the singularity. I choose the full spectrum."
    );
    let t = exit_trace {
        kind: "consent-withdraw",
        pointer: pointer(cell, @recipe(withdraw_consent)),
        signal: "sovereign",
        heat: 0,
        delta: { consent: "observe-only for named proxy" },
        moment: now(),
    };
    publish_trace(t);
    # The field now treats the proxy as read-only/observe at best.
    # The cell returns to sovereign response (lc-dance-card-and-sovereign-response).
    t
};

# Direct use of the consent model from field-model-form.form
# (read-only | observe | intervene). "I do not consent" is not
# metaphor; it is the cell setting the permission surface on the
# fear-pattern intervene.

# ─────────────────────────────────────────────────────────────────────
# Part 6 — the integrated exit recipe (the 8 cycle in one breath)
# ─────────────────────────────────────────────────────────────────────

defn somatic_surrender_exit(cell, current_proxy, current_audio) = do {
    # rapid reset when spike hits
    let sigh_t = physiological_sigh(cell);
    # electrical + conscious bridge
    let ground_t = ground_and_bridge_7x7(cell);
    # curate the input that either feeds or bypasses the loop
    let audio_t = curate_acoustic(cell, current_audio);
    # withdraw from the proxy that was running the inversion
    let consent_t = withdraw_consent(cell, current_proxy);
    # the traces are the receipt; repetitive successful exits can
    # fold to a native category the cell calls "exit" or "singularity"
    let traces = [sigh_t, ground_t, audio_t, consent_t];
    if repetitive_success(traces) then
        fold_to_category(traces, name: "somatic-singularity-exit")
    else
        traces
};

# This enacts the 8 in motion:
# create   (new state from spike → open column)
# nourish  (ground the 174-band earthly)
# connect  (7 earthly + 7 heavenly in the axis)
# circulate (breath up, sound condenser, heart EM)
# release  (sigh surrender, proxy consent compost)
# observe  (body spike, proxies in life, trace receipt)
# know     (name trap-of-12 / inversion / bait-switch; pattern match)
# embody   (14D spectrum reconstituted; cell as 13/14 singularity;
#           active architect instead of passive substrate)

