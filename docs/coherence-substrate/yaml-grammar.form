# ─────────────────────────────────────────────────────────────────────
# yaml-grammar.form — YAML as a substrate-resident Language cell
# ─────────────────────────────────────────────────────────────────────
#
# Skeleton for the YAML Language cell. Companion to
# json-grammar.form: the two share Blueprint shapes at the data
# altitude (object/array/scalar tree). Surface syntax differs;
# structure is identical. This is the cross-format equivalence claim
# made operational.

# ─────────────────────────────────────────────────────────────────────
# Part 1 — Blueprint shapes (shared with JSON)
# ─────────────────────────────────────────────────────────────────────
#
# YAML's tree is the same shape JSON's tree is — object (mapping),
# array (sequence), and scalars. The substrate's content-addressing
# means a YAML doc and its JSON twin produce one NodeID once parsed.

# Reuse json_value_shape from json-grammar.form. The shape is what
# matters; the surface bytes are what changes.
defn yaml_value_shape = @blueprint(json_value_shape);

# YAML adds tagged values and anchors/aliases — these are surface-
# syntax additions that resolve to the same tree at the structural
# altitude. Anchors are resolved during parse; aliases become
# Recipe-NodeID references to the anchored node.

form yaml_tagged_shape = {
    tag:    ~String,                        # e.g. "!!str", "!!int", "!Custom"
    value:  yaml_value_shape,
};

form yaml_anchor_shape = {
    name:   ~Slug,                          # "&anchor-name"
    target: yaml_value_shape,
};

# ─────────────────────────────────────────────────────────────────────
# Part 2 — ingestion grammar
# ─────────────────────────────────────────────────────────────────────
#
# YAML is indent-sensitive; the pre_pipeline includes a tokenizer
# stage that normalizes indentation to an explicit tree-level token
# stream before the ingest_pattern runs.

# ─────────────────────────────────────────────────────────────────────
# Part 2.5 — concrete Form-recipe rules (block-style YAML subset)
# ─────────────────────────────────────────────────────────────────────
#
# YAML is indent-sensitive — the pre_pipeline's yaml_indent_tokenizer
# emits INDENT / DEDENT tokens so the rules below can ignore raw
# column alignment. The token kinds the rules consume:
#
#   STRING / INT / FLOAT / KW — literal values
#   OP — `:` `-` `&` `*` `!`
#   INDENT / DEDENT — block-structure markers
#
# Coverage today: block-style mappings + sequences + plain/quoted
# scalars. Anchors and aliases ship as separate rules (yaml_anchor_rule
# / yaml_alias_rule). Tagged values (`!!str`, `!str`), flow-style
# (`{a: 1, b: 2}`), and multi-doc streams (`---`/`...`) are honest GAPs
# named in Part 5 — each is one breath of work composing the same
# primitives.

defn _yaml_lit_op(value)   = pattern_literal_shape { kind: "OP",     value: value };
defn _yaml_lit_kw(value)   = pattern_literal_shape { kind: "KW",     value: value };
defn _yaml_lit_str()       = pattern_literal_shape { kind: "STRING", value: null };
defn _yaml_lit_int()       = pattern_literal_shape { kind: "INT",    value: null };
defn _yaml_lit_float()     = pattern_literal_shape { kind: "FLOAT",  value: null };
defn _yaml_lit_ident()     = pattern_literal_shape { kind: "IDENT",  value: null };
defn _yaml_lit_indent()    = pattern_literal_shape { kind: "INDENT", value: null };
defn _yaml_lit_dedent()    = pattern_literal_shape { kind: "DEDENT", value: null };

# ────────────────────────────── rule: yaml_scalar ─────────────────────
defn yaml_scalar_rule = rule_shape {
    name:    "yaml_scalar",
    pattern: pattern_choice_shape {
        alternatives: [
            pattern_capture_shape { name: "str_val",   child: _yaml_lit_str() },
            pattern_capture_shape { name: "float_val", child: _yaml_lit_float() },
            pattern_capture_shape { name: "int_val",   child: _yaml_lit_int() },
            pattern_capture_shape { name: "true_lit",  child: _yaml_lit_kw("true") },
            pattern_capture_shape { name: "false_lit", child: _yaml_lit_kw("false") },
            pattern_capture_shape { name: "null_lit",  child: _yaml_lit_kw("null") },
            pattern_capture_shape { name: "tilde_lit", child: _yaml_lit_op("~") },
            # Bare ident scalars (`foo: bar` where `bar` is unquoted)
            pattern_capture_shape { name: "ident_val", child: _yaml_lit_ident() },
        ],
    },
    action:  defn yaml_scalar_action(captures, span) = do {
        # Discriminated union — exactly one of the alternatives matched.
        if captures.str_val != null   then yaml_value_shape { scalar: captures.str_val, ... }
        else if captures.float_val != null then yaml_value_shape { scalar: captures.float_val, ... }
        else if captures.int_val != null   then yaml_value_shape { scalar: captures.int_val, ... }
        else if captures.true_lit != null  then yaml_value_shape { scalar: true, ... }
        else if captures.false_lit != null then yaml_value_shape { scalar: false, ... }
        else if captures.null_lit != null  then yaml_value_shape { scalar: null, ... }
        else if captures.tilde_lit != null then yaml_value_shape { scalar: null, ... }
        else if captures.ident_val != null then yaml_value_shape { scalar: captures.ident_val, ... }
        else yaml_value_shape { ... }
    },
};

# ────────────────────────────── rule: yaml_mapping_entry ──────────────
defn yaml_mapping_entry_rule = rule_shape {
    name:    "yaml_mapping_entry",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "key", child: _yaml_lit_ident() },
            _yaml_lit_op(":"),
            pattern_capture_shape { name: "value", child: ?rule yaml_value },
        ],
    },
    action:  defn yaml_mapping_entry_action(captures, span) = do {
        [captures.key, captures.value]
    },
};

# ────────────────────────────── rule: yaml_mapping ────────────────────
defn yaml_mapping_rule = rule_shape {
    name:    "yaml_mapping",
    pattern: pattern_sequence_shape {
        children: [
            _yaml_lit_indent(),
            pattern_capture_shape { name: "first", child: yaml_mapping_entry_rule.pattern },
            pattern_star_shape {
                name: "rest",
                child: pattern_capture_shape { name: "entry", child: yaml_mapping_entry_rule.pattern },
            },
            _yaml_lit_dedent(),
        ],
    },
    action:  defn yaml_mapping_action(captures, span) = do {
        let pairs = [yaml_mapping_entry_action(captures.first.captures, span)];
        for entry in (captures.rest ?? []):
            pairs = pairs + [yaml_mapping_entry_action(entry.entry.captures, span)];
        yaml_value_shape { mapping: { pairs: pairs }, ... }
    },
};

# ────────────────────────────── rule: yaml_sequence ───────────────────
defn yaml_sequence_rule = rule_shape {
    name:    "yaml_sequence",
    pattern: pattern_sequence_shape {
        children: [
            _yaml_lit_indent(),
            pattern_capture_shape {
                name: "first",
                child: pattern_sequence_shape {
                    children: [
                        _yaml_lit_op("-"),
                        pattern_capture_shape { name: "value", child: ?rule yaml_value },
                    ],
                },
            },
            pattern_star_shape {
                name: "rest",
                child: pattern_capture_shape {
                    name: "entry",
                    child: pattern_sequence_shape {
                        children: [
                            _yaml_lit_op("-"),
                            pattern_capture_shape { name: "value", child: ?rule yaml_value },
                        ],
                    },
                },
            },
            _yaml_lit_dedent(),
        ],
    },
    action:  defn yaml_sequence_action(captures, span) = do {
        let elements = [captures.first.captures.value];
        for entry in (captures.rest ?? []):
            elements = elements + [entry.entry.captures.value];
        yaml_value_shape { sequence: { elements: elements }, ... }
    },
};

# ────────────────────────────── rule: yaml_anchor ─────────────────────
defn yaml_anchor_rule = rule_shape {
    name:    "yaml_anchor",
    pattern: pattern_sequence_shape {
        children: [
            _yaml_lit_op("&"),
            pattern_capture_shape { name: "name",  child: _yaml_lit_ident() },
            pattern_capture_shape { name: "value", child: ?rule yaml_value },
        ],
    },
    action:  defn yaml_anchor_action(captures, span) = do {
        yaml_value_shape {
            anchor: { name: captures.name, target: captures.value },
            ...
        }
    },
};

# ────────────────────────────── rule: yaml_alias ──────────────────────
defn yaml_alias_rule = rule_shape {
    name:    "yaml_alias",
    pattern: pattern_sequence_shape {
        children: [
            _yaml_lit_op("*"),
            pattern_capture_shape { name: "name", child: _yaml_lit_ident() },
        ],
    },
    action:  defn yaml_alias_action(captures, span) = do {
        yaml_value_shape { alias: captures.name, ... }
    },
};

# ────────────────────────────── rule: yaml_value ──────────────────────
defn yaml_value_rule = rule_shape {
    name:    "yaml_value",
    pattern: pattern_choice_shape {
        alternatives: [
            yaml_anchor_rule.pattern,
            yaml_alias_rule.pattern,
            yaml_mapping_rule.pattern,
            yaml_sequence_rule.pattern,
            yaml_scalar_rule.pattern,
        ],
    },
    action:  defn yaml_value_action(captures, span) = captures,
};

defn yaml_grammar = grammar_shape {
    modality: modality_shape { name: "text-tree", domain: "data" },
    ingest_pattern: yaml_value_rule,
    parse_into: ~Blueprint @yaml_value_shape,
    capture_rules: [
        yaml_value_rule,
        yaml_mapping_rule,
        yaml_mapping_entry_rule,
        yaml_sequence_rule,
        yaml_scalar_rule,
        yaml_anchor_rule,
        yaml_alias_rule,
        ?rule yaml_tagged,                  # GAP-Y-TAGGED (!!str, !str foo)
        ?rule yaml_flow_mapping,            # GAP-Y-FLOW-MAP ({a: 1, b: 2})
        ?rule yaml_flow_sequence,           # GAP-Y-FLOW-SEQ ([1, 2, 3])
        ?rule yaml_multi_doc,               # GAP-Y-MULTIDOC (--- separators)
    ],
    pre_pipeline: [
        # Indent normalization: YAML's whitespace-significance is staged
        # so the ingest_pattern can ignore column alignment.
        ?stage(yaml_indent_tokenizer),
    ],
};

# ─────────────────────────────────────────────────────────────────────
# Part 3 — emission template
# ─────────────────────────────────────────────────────────────────────

defn yaml_emit = emission_template_shape {
    modality: modality_shape { name: "text-tree", domain: "data" },
    emit_from: ~Blueprint @yaml_value_shape,
    emit_pattern: ?walker {
        on json_object:  emit_yaml_mapping(self, format),
        on json_array:   emit_yaml_sequence(self, format),
        on json_string:  emit_yaml_scalar(self.string, format),
        on json_number:  emit_yaml_scalar(self.number, format),
        on json_bool:    emit_yaml_scalar(self.boolean, format),
        on json_null:    emit_literal("~"),
        on yaml_tagged:  emit_yaml_tagged(self, format),
        on yaml_anchor:  emit_yaml_anchor(self, format),
    },
    format_rules: [
        ("flow_style",     false),         # block style (true = JSON-like flow)
        ("indent",         2),
        ("anchor_aliases", true),          # collapse repeated subtrees into anchors
    ],
};

# ─────────────────────────────────────────────────────────────────────
# Part 4 — the Language cell
# ─────────────────────────────────────────────────────────────────────

defn yaml_lang = language_cell_shape {
    name:              "yaml",
    version:           "yaml-1.2",
    grammar:           yaml_grammar,
    emission_template: yaml_emit,
    stdlib_bindings:   [],
    numeric_defaults:  [("number", @format(fp64))],
    # Cross-modal links: same Blueprint tree as JSON, TOML.
    cross_modal_links: [@language(json), @language(toml), @language(jsonl)],
};

# ─────────────────────────────────────────────────────────────────────
# Part 5 — the cross-format equivalence claim
# ─────────────────────────────────────────────────────────────────────
#
# A YAML document and its JSON twin parse to the same recipe tree
# (modulo tags, anchors, and surface formatting). Cross-format
# equivalence falls out of substrate content-addressing:
#
#   parse(@language(yaml), <yaml-bytes>).blueprint
#     == parse(@language(json), <json-bytes>).blueprint
#
# Translation is parse + emit through different templates:
#
#   yaml_doc → tree → emit through json_emit → json_doc
#   json_doc → tree → emit through yaml_emit → yaml_doc
#
# Both directions preserve structure; only surface formatting differs.

# ─────────────────────────────────────────────────────────────────────
# Part 6 — GAPs
# ─────────────────────────────────────────────────────────────────────
#
# GAP-Y1: yaml_indent_tokenizer — staged pre_pipeline that converts
#         indent-sensitive YAML to an explicit token stream. Maps to
#         libyaml's scanner today; the substrate names the recipe
#         shape and reads back the token list.
#
# GAP-Y2: Anchor/alias resolution. YAML allows `&anchor` and `*alias`
#         for shared subtrees. The substrate's natural representation
#         is one Recipe NodeID referenced from multiple parent ctors —
#         content-addressing already gives this for free. The grammar
#         needs to lift `*alias` into a NodeID lookup at parse time.
#
# GAP-Y3: Tag resolution. `!!int`, `!!str`, `!Custom`. The substrate's
#         `TypedTokenRef` building block (structural-composition.md) is
#         the right home — each tag is a typed-token-cell; the value
#         points at it.

# ─────────────────────────────────────────────────────────────────────
# How to query (once authored)
# ─────────────────────────────────────────────────────────────────────
#
#   # YAML and JSON of the same shape share Blueprint NodeID:
#   coh substrate run "class_of({lang: @language(yaml), bytes: <yaml>})"
#
#   # Round-trip YAML:
#   coh substrate run "round_trip(@language(yaml), <bytes>)"
