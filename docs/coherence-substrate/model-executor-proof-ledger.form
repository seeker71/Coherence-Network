# model-executor-proof-ledger.form -- native proof-run ledger shape
#
# The committed JSONL proof record is useful as an exchange/cache format, but
# it is a poor coordination surface because every agent appends to the same
# line-oriented file. This Form-native ledger shape gives each proof run a
# stable record cell that can be validated and exported back to JSONL.

form model_executor_proof_run = {
    run_id:         ~String,
    thread_branch:  ~String,
    model_used:     ~String,
    input_tokens:   ~Int,
    output_tokens:  ~Int,
    attempts:       ~Int,
    commands_run:   [~String],
    pass_fail:      ~String,
    failure_reason: ~String,
    source: {
        kind:       ~String,
        path:       ~String,
    },
    validation: {
        status:     ~String,
        commands:   [~String],
    },
};

defn mepl_run(run-id thread-branch model-used input-tokens output-tokens attempts commands-run pass-fail failure-reason source validation) =
    model_executor_proof_run {
        run_id:         run-id,
        thread_branch:  thread-branch,
        model_used:     model-used,
        input_tokens:   input-tokens,
        output_tokens:  output-tokens,
        attempts:       attempts,
        commands_run:   commands-run,
        pass_fail:      pass-fail,
        failure_reason: failure-reason,
        source:         source,
        validation:     validation,
    };

defn model_executor_proof_ledger_contract() = {
    north_star: "Executor proof runs are native substrate records; JSONL is an export/cache shape, not the coordination source.",
    record_home: "docs/system_audit/model_executor_run_ledger/*.json",
    legacy_cache: "docs/system_audit/model_executor_runs.jsonl",
    import_rule: "Each run has a stable run_id and its own record file, so unrelated agents do not contend on one append-only file.",
    export_rule: "form/form-stdlib/model-executor-proof-ledger.fk validates native records and their legacy JSONL projection shape; JSONL refresh is a compatibility export, not the authority.",
    sister_node_rule: "Evidence, PR text, and floor manifests should cite the native ledger record first; JSONL rows stay aligned as compatibility exports.",
    required_fields: [
        "run_id",
        "thread_branch",
        "model_used",
        "input_tokens",
        "output_tokens",
        "attempts",
        "commands_run",
        "pass_fail",
        "failure_reason",
        "source",
        "validation"
    ],
};
