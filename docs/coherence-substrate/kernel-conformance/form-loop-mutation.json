{
  "version": 1,
  "surface": "form-loop-mutation",
  "description": "Pure Form local iteration and mutation over JSON-safe values. Kernels conform by returning the same JSON-safe values with no host events.",
  "harness": {
    "command": "python3 scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-loop-mutation.json --kernel python --kernel rust --kernel go --kernel typescript",
    "target_command": null
  },
  "cases": [
    {
      "name": "for_list_returns_body_values",
      "form": "for x in [1, 2, 3] { x * 2 }",
      "expected_value": [2, 4, 6],
      "expected_events": []
    },
    {
      "name": "for_accumulates_with_set",
      "form": "do { let total = 0; for x in [1, 2, 3, 4, 5] { set total = total + x }; total }",
      "expected_value": 15,
      "expected_events": []
    },
    {
      "name": "for_appends_with_set_and_concat",
      "form": "do { let xs = []; for x in [10, 20, 30] { set xs = concat(xs, [x * 2]) }; xs }",
      "expected_value": [20, 40, 60],
      "expected_events": []
    },
    {
      "name": "for_string_iterates_characters",
      "form": "for c in \"abc\" { c }",
      "expected_value": ["a", "b", "c"],
      "expected_events": []
    },
    {
      "name": "while_counts_with_set",
      "form": "do { let i = 0; while i < 5 { set i = i + 1 }; i }",
      "expected_value": 5,
      "expected_events": []
    },
    {
      "name": "while_returns_last_body_value",
      "form": "do { let i = 0; while i < 3 { set i = i + 1; i * 10 } }",
      "expected_value": 30,
      "expected_events": []
    },
    {
      "name": "while_unentered_returns_null",
      "form": "while false { 42 }",
      "expected_value": null,
      "expected_events": []
    },
    {
      "name": "set_walks_to_outer_frame",
      "form": "do { let x = 1; do { set x = 99 }; x }",
      "expected_value": 99,
      "expected_events": []
    }
  ],
  "kernels": {
    "python": {
      "status": "implemented",
      "entrypoint": "app.services.substrate.form_runtime.form_execute_text",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-loop-mutation.json --kernel python"
    },
    "rust": {
      "status": "implemented",
      "entrypoint": "seedbank/form-question-kernels/rust/src/main.rs",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-loop-mutation.json --kernel rust",
      "runner": [
        "cargo",
        "run",
        "--quiet",
        "--manifest-path",
        "seedbank/form-question-kernels/rust/Cargo.toml",
        "--",
        "{vector}"
      ]
    },
    "go": {
      "status": "implemented",
      "entrypoint": "seedbank/form-question-kernels/go/question_kernel.go",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-loop-mutation.json --kernel go",
      "runner": [
        "go",
        "run",
        "seedbank/form-question-kernels/go/question_kernel.go",
        "{vector}"
      ]
    },
    "typescript": {
      "status": "implemented",
      "entrypoint": "form/form-kernel-ts/src/conformance.ts",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-loop-mutation.json --kernel typescript",
      "runner": [
        "npx",
        "--yes",
        "tsx",
        "form/form-kernel-ts/src/conformance.ts",
        "{vector}"
      ]
    }
  }
}
