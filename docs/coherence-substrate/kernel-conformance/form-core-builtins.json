{
  "version": 1,
  "surface": "form-core-builtins",
  "description": "Pure Form built-ins over literals and lists. Kernels conform by returning the same JSON-safe values with no host events.",
  "harness": {
    "command": "python3 scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-core-builtins.json --kernel python --kernel rust --kernel go",
    "target_command": null
  },
  "cases": [
    {
      "name": "len_counts_list",
      "form": "len([1, 2, 3])",
      "expected_value": 3,
      "expected_events": []
    },
    {
      "name": "head_returns_first_item",
      "form": "head([1, 2, 3])",
      "expected_value": 1,
      "expected_events": []
    },
    {
      "name": "tail_returns_remaining_items",
      "form": "tail([1, 2, 3])",
      "expected_value": [2, 3],
      "expected_events": []
    },
    {
      "name": "sum_reduces_integer_list",
      "form": "sum([1, 2, 3, 4])",
      "expected_value": 10,
      "expected_events": []
    },
    {
      "name": "concat_merges_lists",
      "form": "concat([1], [2, 3])",
      "expected_value": [1, 2, 3],
      "expected_events": []
    },
    {
      "name": "concat_merges_strings",
      "form": "concat(\"co\", \"here\")",
      "expected_value": "cohere",
      "expected_events": []
    },
    {
      "name": "reverse_flips_list",
      "form": "reverse([1, 2, 3])",
      "expected_value": [3, 2, 1],
      "expected_events": []
    }
  ],
  "kernels": {
    "python": {
      "status": "implemented",
      "entrypoint": "app.services.substrate.form_runtime.form_execute_text",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-core-builtins.json --kernel python"
    },
    "rust": {
      "status": "implemented",
      "entrypoint": "experiments/form-question-kernels/rust/src/main.rs",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-core-builtins.json --kernel rust",
      "runner": [
        "cargo",
        "run",
        "--quiet",
        "--manifest-path",
        "experiments/form-question-kernels/rust/Cargo.toml",
        "--",
        "{vector}"
      ]
    },
    "go": {
      "status": "implemented",
      "entrypoint": "experiments/form-question-kernels/go/question_kernel.go",
      "proof": "api/tests/test_kernel_conformance_harness.py",
      "harness": "scripts/verify_kernel_conformance.py --vector docs/coherence-substrate/kernel-conformance/form-core-builtins.json --kernel go",
      "runner": [
        "go",
        "run",
        "experiments/form-question-kernels/go/question_kernel.go",
        "{vector}"
      ]
    }
  }
}
