# native-mutation-side-effect-ledger.form -- source-classified mutation effects
#
# This ledger answers a narrow question: which mutable companions are Python
# parity, which are reversible gate receipts, and which are not carried yet?
# It is not a proof that side effects should exist. It is a keep/delete map
# for moving ideas and specs toward Form-native execution without smuggling in
# behavior that Python did not already carry.

form native_mutation_side_effect_entry = {
    effect_id:          ~String,
    classification:     ~String,
    python_source:      [~String],
    python_observation: ~String,
    form_native_carrier:[~String],
    evidence:           [~String],
    decision:           ~String,
    deletion_rule:      ~String,
    boundary:           ~String,
};

defn nmsl_entry(effect-id classification python-source python-observation form-native-carrier evidence decision deletion-rule boundary) =
    native_mutation_side_effect_entry {
        effect_id:           effect-id,
        classification:      classification,
        python_source:       python-source,
        python_observation:  python-observation,
        form_native_carrier: form-native-carrier,
        evidence:            evidence,
        decision:            decision,
        deletion_rule:       deletion-rule,
        boundary:            boundary,
    };

