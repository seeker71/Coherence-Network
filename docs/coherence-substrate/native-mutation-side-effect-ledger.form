defn native_mutation_side_effect_recipe_shift() = {
    shifted: [
        "side-effect proof -> source-classified side-effect ledger",
        "rollback receipt as proof -> rollback receipt as reversible gate safety",
        "prediction residual ignored -> residual held with 0/1/silence/protocol/fail/stop/BMA markers in the gate, not used to smuggle effects",
        "unknown companion effects -> missing parity or not-carried rows",
        "idea valuation audit-ledger missing parity -> hash-chained Form-native audit ledger carrier",
    ],
    move_next: [
        "observe deployed X-Form-Native-Public-Gate canary",
        "then consider ordinary no-header mutation movement",
    ],
};
