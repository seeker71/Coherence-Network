# once — vertical (consciousness) and horizontal (embedded place).
defn pair_awareness_as_self_land = dyad_pair_shape {
    cell_a:      @concept(lc-awareness-as-self),
    cell_b:      @concept(lc-land),
    kind:        kind_scale_paired,
    axis:        "ground-axis",
    discernment: "two grounds the cell rests on — awareness-as-self is the inner ground (the space inside which identities arise); land is the outer ground (the field within which the local field lives); both required for embodied sovereignty",
    noticed_at:  "2026-05-24",
    noticed_by:  "refined-scan-pr-current",
};

