    discernment:      "mycelium, blood, Mondragon's circulation — substance flowing to where vitality needs it; received because nourishing-as-flow is older than any kitchen; the substance face of the same distributed-circulation teaching circulation names as flow",
};

defn column_received_circulating__mycorrhizal = column_identity_shape {
    cell:             @concept(lc-w-mycorrhizal),
    column_kind:      "received-circulating-mycelial-body",
