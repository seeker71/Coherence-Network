    axis_b_c:            "phase-what-falls-vs-what-remains",
    axis_a_c:            "reference-what-was-vs-what-IS",
    kind:                kind_transmission_triad,
    discernment:         "three facets of the dissolution-and-recognition arc from one April-2026 transmission — echo of what was, dissolution of who-you-were, awareness as what remains; the source IS the binding, not any single pairwise axis",
    noticed_at:          "2026-05-24",
    noticed_by:          "transmission-cluster-walk",
};

