# opposite directions.
defn pair_inner_travel_mirrors = dyad_pair_shape {
    cell_a:      @concept(lc-inner-travel),
    cell_b:      @concept(lc-relationships-as-mirrors),
    kind:        kind_membrane_crossing,
    axis:        "topology",
    discernment: "self-knowing through two doors — inner-travel crosses the membrane from inside (interior landscape); mirrors crosses it from outside (other's reflection); both at the consciousness band, neither alone catches the full self-encounter teaching",
