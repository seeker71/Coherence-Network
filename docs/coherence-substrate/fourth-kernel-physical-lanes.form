# fourth-kernel-physical-lanes.form - local Hati-OS resource lane proof

(fourth-kernel-physical-lanes
  (lineage
    (rests-on fourth-kernel.form tool-channel.form host-kernel.form hati-os-targets.form)
    (probe scripts/hati_os_physical_lanes_probe.sh)
    (assembly-probe scripts/bml_form_jit_metal_planes_audit.sh)
    (carrier form/form-stdlib/hati-os-kernel.fk)
    (emitter form/form-stdlib/hati-os-kernel-emit.fk)
    (matcher form/form-stdlib/hati-os-match.fk))

  (jit-hardware-lane-contract
    (oracle clang-and-host-driver-samples)
    (runtime form-native-recipes)
    (choice measured-oracle-learning-samples)
    (hardware-classes cpu gpu ml)
    (proof form/form-stdlib/tests/jit-metal-lanes-band.fk -> 4095)
    (learning-proof form/form-stdlib/tests/jit-oracle-learning-band.fk -> 1023))

  (claim
    "The tool/channel surface is more than catalog data when a lane is backed by a Hati-emitted binary."
    "The probe emits C from Form, compiles native Hati binaries with clang, and runs those binaries against local host resources.")

  (floor
    "The local proof emits native Hati binaries and records real host/resource stdout or artifacts for the currently available physical lanes.")

  (north-star
    "Every resource and channel row has a locally inspectable physical receipt, with the most native available codec first and third-party carriers kept explicit until a kernel-native codec replaces them.")
    "Host process and utilization lanes walk from host:exec carrier receipts toward direct host OS calls such as process table APIs, task counters, memory statistics, load counters, and device pressure signals."
    "Third-party compilers, GPU drivers, MLK kernels, and hosted models stay in the mesh as oracles until Form-native recipes beat them on measured correctness, latency, cost, and trust, with continuing exploration after promotion.")

  (native-binaries
    (fkdump  "driver binary: fork/exec/pipe host stdout into fk_src, then PUTC captured bytes")
    (fkcount "driver binary: count captured fk_src bytes")
    (fkmatch-host "driver binary: parse captured fk_src for a fixed host-exec marker")
    (fkserver "server binary: socket/bind/listen/accept/fork, stage request into fk_src, respond with PUTC bytes"))

  (resource-lanes
    (host-exec     host:exec    "printf/date through the Hati driver")
    (http-request  http:request "curl over external REST through the Hati driver")
    (kernel-route  kernel:route "local Hati server binary answered curl")
    (store-query   store:query  "sqlite3 query through the Hati driver")
    (host-process  host:process "process table rows are constructible as a native host OS call lane; current physical floor may use ps/top carriers")
    (host-usage    host:usage   "CPU, memory, load, disk, network, and energy counters are constructible as native host OS call lanes; current physical floor may use host counter carriers")
    (shell-applets stream:read  "grep/find/awk/xmllint over local files through the Hati driver")
    (agent-model   kernel:call  "ollama model choice through the Hati driver")
    (audio-mic     host:file    "rec captures a local WAV when the OS grants mic access")
    (audio-speaker host:exec    "say renders audio and afplay pushes it to the output device")
    (screen        host:file    "osascript writes a notification and screencapture reads a PNG frame")
    (camera        host:file    "ffmpeg avfoundation attempts a real camera frame")
    (sensors       stream:read  "AVFoundation/audio/display inventory plus physical GPS absence on this Mac host"))

  (evidence
    (output-dir .cache/hati-os-physical-lanes)
    (summary summary.json)
    (lane-artifacts "stdout captures, WAV/AIFF/PNG/JPG/sqlite files when granted by the host OS"))

  (host-target-proof-lanes
    (macos-arm64
      (clang-triple arm64-apple-macosx)
      (binary-format mach-o)
      (assembly-surface mach-o-relocatable+arm64-asm)
      (jit-oracle clang)
      (jit-runtime form-native-arm64-assembler)
      (distribution https://hati.earth/downloads/hati-os/macos/arm64/hati-os-macos-arm64.tar.zst)
      (resource-implementations libproc+sysctl+proc_pidinfo host_statistics64+task_info+getifaddrs+IOKit CoreAudio+AVFoundation ScreenCaptureKit+AVFoundation CoreMotion+CoreLocation-when-present)
      (floor "current physical receipts are captured on this Mac host"))
    (android-arm64
      (clang-triple aarch64-linux-android)
      (binary-format elf)
      (assembly-surface elf-relocatable+aarch64-asm)
      (jit-oracle clang)
      (jit-runtime form-native-arm64-assembler)
      (distribution https://hati.earth/downloads/hati-os/android/arm64/hati-os-android-arm64.apk)
      (resource-implementations procfs+ActivityManager-permission-gated procfs+BatteryManager+Debug+SensorManager AAudio+AudioRecord+AudioTrack Camera2+MediaProjection-permission-gated SensorManager+LocationManager+GNSS-permission-gated)
      (floor "Android receipts require an Android device or emulator with granted permissions")))

  (missing-physical-samples
    (tts-stt-loopback
      (floor "mic WAV and speaker AIFF are proven separately")
      (missing "one receipt that renders text to audio, transcribes that audio back to text, and records transcript-match"))
    (stt-tts-loopback
      (floor "local model Q/A and speaker output are proven separately")
      (missing "one receipt that takes captured speech tokens, renders speech, and records spoken-render-match"))
    (video-gen-classifier-loopback
      (floor "camera JPEG frame is proven")
      (missing "one generated video/frame sequence plus classifier feature receipt for shape, distance, texture, obstruction, occlusion, composition, transparency, frequency, and spectrum"))
    (video-classifier-gen-loopback
      (floor "video feature rows are planned")
      (missing "one feature-to-render receipt that regenerates frames and checks rendered-feature-match"))
    (screen-interaction
      (floor "notification write plus screenshot read is proven")
      (missing "gesture/event input receipt tied to the pixel receipt"))
    (gps-sensor
      (floor "this Mac host physically reports no GPS provider")
      (missing "GPS coordinate receipt from a device that exposes a location provider"))
    (multi-model-learning
      (floor "local Ollama model choice is proven, and jit-oracle-learning-band names the measurable oracle/native choice contract")
      (missing "two or more native/third-party model receipts over the same channel sample with explicit model choice, comparison fidelity, and continuing exploration cadence"))
    (host-process-usage
      (floor "process and utilization channels now plan through host:process and host:usage; the present receipt floor may still use host:exec carriers")
      (missing "one Hati-emitted physical receipt for direct host OS process and utilization calls, with ps/top/vm_stat/iostat-style carriers only as fallback receipts")))

  (missing-target-distribution-samples
    (macos-arm64
      (floor "target row, clang oracle assembly/object proof, Form-native JIT runtime row, and hati.earth URL are proven")
      (missing "published tarball, sha256, source map, and physical-lane summary JSON at the catalog URL"))
    (android-arm64
      (floor "target row, clang oracle assembly/object proof, Form-native JIT runtime row, and hati.earth URL are proven")
      (missing "published APK, sha256, source map, and Android device/emulator physical-lane summary JSON at the catalog URL")))

  (invariant
    (no-mock-data)
    (no-python-runtime-carrier-for-lanes)
    (python-only-serializes-summary-json)
    (os-refusal-is-recorded-as-physical-lane-data)
    (every-lane-runs-through-a-Hati-native-binary)))
