# fourth-kernel-physical-lanes.form - local Hati-OS resource lane proof

(fourth-kernel-physical-lanes
  (lineage
    (rests-on fourth-kernel.form tool-channel.form host-kernel.form hati-os-targets.form)
    (probe scripts/hati_os_physical_lanes_probe.sh)
    (assembly-probe scripts/bml_form_jit_metal_planes_audit.sh)
    (carrier form/form-stdlib/hati-os-kernel.fk)
    (emitter form/form-stdlib/hati-os-kernel-emit.fk)
    (matcher form/form-stdlib/hati-os-match.fk))

  (jit-hardware-lane-contract
    (oracle clang-and-host-driver-samples)
    (runtime form-native-recipes)
    (object-floor form-native-macho-and-elf-recipes)
    (executable-floor form-native-elf-exec-recipe)
    (choice measured-oracle-learning-samples)
    (hardware-classes cpu gpu ml)
    (proof form/form-stdlib/tests/jit-metal-lanes-band.fk -> 8191 four-way-fkwu)
    (learning-proof form/form-stdlib/tests/jit-oracle-learning-band.fk -> 1023 four-way-fkwu))

  (claim
    "The tool/channel surface is more than catalog data when a lane is backed by a Hati-emitted binary."
    "The probe emits C from Form, compiles native Hati binaries with clang, and runs those binaries against local host resources.")

  (floor
    "The local proof emits native Hati binaries, runs the Form-native JIT, Form-native Mach-O/PE-COFF/ELF object proofs, and Form-native Android ELF executable shape through fkwu as a fourth sibling, records real host/resource stdout or artifacts for the currently available physical lanes, carries a Mac+Android native receipt channel over adb-forward TCP, keeps Windows ARM64 on the shared ARM64 assembler lane, and gives Windows x86_64 its separate Intel/AMD x64 native DLL load/swap receipt.")

  (north-star
    "Every resource and channel row has a locally inspectable physical receipt, with the most native available codec first and third-party carriers kept explicit until a kernel-native codec replaces them.")
    "Host process and utilization lanes walk from host:exec carrier receipts toward direct host OS calls such as process table APIs, task counters, memory statistics, load counters, and device pressure signals."
    "Third-party compilers, GPU drivers, MLK kernels, and hosted models stay in the mesh as oracles until Form-native recipes beat them on measured correctness, latency, cost, and trust, with continuing exploration after promotion.")

  (native-binaries
    (fkdump  "driver binary: fork/exec/pipe host stdout into fk_src, then PUTC captured bytes")
    (fkcount "driver binary: count captured fk_src bytes")
    (fkmatch-host "driver binary: parse captured fk_src for a fixed host-exec marker")
    (fkserver "server binary: socket/bind/listen/accept/fork, stage request into fk_src, respond with PUTC bytes"))

  (resource-lanes
    (host-exec     host:exec    "printf/date through the Hati driver")
    (http-request  http:request "curl over external REST through the Hati driver")
    (kernel-route  kernel:route "local Hati server binary answered curl")
    (store-query   store:query  "sqlite3 query through the Hati driver")
    (host-process  host:process "process table rows are constructible as a native host OS call lane; current physical floor may use ps/top carriers")
    (host-usage    host:usage   "CPU, memory, load, disk, network, and energy counters are constructible as native host OS call lanes; current physical floor may use host counter carriers")
    (gpu-compute   gpu:compute  "GPU lanes are constructible as native accelerator calls; current floor is catalog and dashboard visibility without active dispatch receipt")
    (dsp-signal    dsp:signal   "DSP/NPU lanes are constructible as native signal/NN accelerator calls; current floor is catalog visibility without active dispatch receipt")
    (mlx-array     mlx:array    "MLX lanes are constructible on Apple hosts; Android and Windows record explicit unsupported rows and map equivalent semantics to GPU/NNAPI or DirectML/Vulkan")
    (shell-applets stream:read  "grep/find/awk/xmllint over local files through the Hati driver")
    (agent-model   kernel:call  "ollama model choice through the Hati driver")
    (audio-mic     host:file    "rec captures a local WAV when the OS grants mic access")
    (audio-speaker host:exec    "say renders audio and afplay pushes it to the output device")
    (screen        host:file    "osascript writes a notification and screencapture reads a PNG frame")
    (camera        host:file    "ffmpeg avfoundation attempts a real camera frame")
    (sensors       stream:read  "AVFoundation/audio/display inventory plus physical GPS absence on this Mac host"))

  (evidence
    (output-dir .cache/hati-os-physical-lanes)
    (summary summary.json)
    (lane-artifacts "stdout captures, WAV/AIFF/PNG/JPG/sqlite files when granted by the host OS"))

  (host-target-proof-lanes
    (macos-arm64
      (clang-triple arm64-apple-macosx)
      (binary-format mach-o)
      (assembly-surface mach-o-relocatable+arm64-asm)
      (form-native-object form-macho)
      (core-axiom-channel core-axiom-native-receipt)
      (jit-oracle clang)
      (jit-runtime form-native-arm64-assembler)
      (distribution https://hati.earth/downloads/hati-os/macos/arm64/hati-os-macos-arm64.tar.zst)
      (resource-implementations libproc+sysctl+proc_pidinfo host_statistics64+task_info+getifaddrs+IOKit CoreAudio+AVFoundation ScreenCaptureKit+AVFoundation CoreMotion+CoreLocation-when-present Metal+IOReport+powermetrics Accelerate+AudioToolbox MLX+Metal)
      (floor "current physical receipts are captured on this Mac host"))
    (android-arm64
      (clang-triple aarch64-linux-android)
      (binary-format elf)
      (assembly-surface elf-relocatable+aarch64-asm)
      (form-native-object form-elf)
      (form-native-executable form-elf-exec)
      (core-axiom-channel core-axiom-native-receipt)
      (jit-oracle clang)
      (jit-runtime form-native-arm64-assembler)
      (distribution https://hati.earth/downloads/hati-os/android/arm64/hati-os-android-arm64.tar.zst)
      (resource-implementations procfs+ActivityManager-permission-gated procfs+BatteryManager+Debug+SensorManager AAudio+AudioRecord+AudioTrack Camera2+MediaProjection-permission-gated SensorManager+LocationManager+GNSS-permission-gated Vulkan+OpenGL-ES NNAPI+vendor-DSP-delegates unsupported-MLX)
      (floor "Android executable shape is Form-native and inspectable; Docker Linux/arm64 executes the image for stdout/stderr/exit; an authorized Android arm64 device executes the same image through adb with stdout/stderr/exit receipt; the phone also runs a generated native receipt binary that exchanges a bounded verifier receipt with a generated Mac binary over adb-forward TCP"))
    (windows-arm64
      (clang-triple aarch64-pc-windows-msvc)
      (binary-format pe-coff)
      (assembly-surface pe-coff+arm64-asm)
      (instruction-lane arm64-shared-with-macos-linux-android)
      (host-image-surface windows-pe-coff)
      (form-native-object form-pe-coff-arm64-pending)
      (form-native-executable form-pe-arm64-exec-pending)
      (jit-oracle clang)
      (jit-runtime form-native-arm64-assembler)
      (distribution https://hati.earth/downloads/hati-os/windows/arm64/hati-os-windows-arm64.zip)
      (resource-implementations PowerShell+CIM+Get-Process CIM+PerformanceCounter+DirectML WASAPI+MediaFoundation Windows.Graphics.Capture+MediaFoundation Windows.Devices.Sensors+Location-when-present DirectML+D3D12+Vulkan DirectML+WASAPI-DSP unsupported-MLX)
      (floor "Windows ARM64 shares the ARM64 assembler/JIT lane with macOS, Linux, and Android; the distinct work is the Windows PE/COFF object, executable, import, relocation, and loader/linker image surface"))
    (windows-x86_64
      (clang-triple x86_64-pc-windows-msvc)
      (binary-format pe-coff)
      (assembly-surface pe-coff+x64-asm)
      (instruction-lane x64-intel-amd)
      (host-image-surface windows-pe-coff)
      (form-native-object form-pe-coff)
      (form-native-executable form-pe-coff+dll-bootstrap-exe)
      (bootstrap-host form/native/bootstrap/form_bootstrap_host.c)
      (jit-oracle optional-clang-llvm-build-witness)
      (jit-runtime fkwu-self-jit-no-runtime-toolchain)
      (distribution https://hati.earth/downloads/hati-os/windows/x86_64/hati-os-windows-x86_64.zip)
      (resource-implementations PowerShell+CIM+Get-Process CIM+PerformanceCounter+nvidia-smi WASAPI+MediaFoundation Windows.Graphics.Capture+MediaFoundation Windows.Devices.Sensors+Location-when-present NVIDIA-CUDA-driver+DirectML+Vulkan DirectML+WASAPI-DSP unsupported-MLX)
      (floor "Windows x86_64 is the Intel/AMD x64 instruction lane; it is proven today by the Windows fkwu self-JIT runtime verifier without Go, clang, or LLVM on the runtime PATH, plus a Form-emitted PE/COFF object that lld-link turns into loadable DLLs swapped through LoadLibrary/GetProcAddress behind the same recipe symbol, and a cross-platform minimal bootstrap exe source that loads dynamic libraries on Windows/macOS/Linux/Android while measuring load/resolve/call boundary crossings")))

  (missing-physical-samples
    (tts-stt-loopback
      (floor "mic WAV and speaker AIFF are proven separately")
      (missing "one receipt that renders text to audio, transcribes that audio back to text, and records transcript-match"))
    (stt-tts-loopback
      (floor "local model Q/A and speaker output are proven separately")
      (missing "one receipt that takes captured speech tokens, renders speech, and records spoken-render-match"))
    (video-gen-classifier-loopback
      (floor "camera JPEG frame is proven")
      (missing "one generated video/frame sequence plus classifier feature receipt for shape, distance, texture, obstruction, occlusion, composition, transparency, frequency, and spectrum"))
    (video-classifier-gen-loopback
      (floor "video feature rows are planned")
      (missing "one feature-to-render receipt that regenerates frames and checks rendered-feature-match"))
    (screen-interaction
      (floor "notification write plus screenshot read is proven")
      (missing "gesture/event input receipt tied to the pixel receipt"))
    (gps-sensor
      (floor "this Mac host physically reports no GPS provider")
      (missing "GPS coordinate receipt from a device that exposes a location provider"))
    (multi-model-learning
      (floor "local Ollama model choice is proven, and jit-oracle-learning-band names the measurable oracle/native choice contract with fkwu parity")
      (missing "two or more native/third-party model receipts over the same channel sample with explicit model choice, comparison fidelity, and continuing exploration cadence"))
    (host-process-usage
      (floor "process and utilization channels now plan through host:process and host:usage; the present receipt floor may still use host:exec carriers")
      (missing "one Hati-emitted physical receipt for direct host OS process and utilization calls, with ps/top/vm_stat/iostat-style carriers only as fallback receipts"))
    (gpu-dsp-mlx
      (floor "GPU, DSP, and MLX/equivalent lanes are cataloged and capability-gated for macOS and Android")
      (missing "one native accelerator dispatch receipt per supported lane: macOS Metal, macOS MLX, Android GPU, Android NNAPI/DSP; Android MLX remains explicit unsupported data"))
    (release-visual-review
      (floor "human-visible app/service changes require actual screenshots plus self and sister-agent review before release")
      (missing "automated screenshot/accessibility/review receipts attached to the release evidence, cadence-limited outside active refinement loops")))

  (missing-target-distribution-samples
    (macos-arm64
      (floor "target row, clang oracle assembly/object proof, four-way Form-native JIT runtime row, Form-native Mach-O object proof, and hati.earth URL are proven")
      (missing "published tarball, sha256, source map, and physical-lane summary JSON at the catalog URL"))
    (android-arm64
      (floor "target row, clang oracle assembly/object proof, four-way Form-native JIT runtime row, Form-native ELF/aarch64 object proof, Form-native ELF/aarch64 executable shape proof, Docker Linux/arm64 stdout/stderr/exit receipt, Android adb stdout/stderr/exit receipt, and hati.earth URL are proven")
      (missing "published Android native kernel package, sha256, source map, and Android device/emulator physical-lane summary JSON at the catalog URL; APK proof remains separate until the app shell announces to hati.mesh and carries organ channels"))
    (windows-arm64
      (floor "target row, clang oracle coordinate, PE/COFF ARM64 assembly surface, Form-native ARM64 assembler runtime row, Windows host implementation rows, and hati.earth URL are proven")
      (missing "Form-native PE/COFF ARM64 object/executable image emitter, published zip, sha256, source map, and Windows-on-ARM physical-lane summary JSON at the catalog URL"))
    (windows-x86_64
      (floor "target row, x64 PE/COFF assembly surface, Form-native PE/COFF x64 object proof, lld-link DLL load/swap receipt, fkwu self-JIT runtime verifier, Windows host implementation rows, and hati.earth URL are proven")
      (missing "broader Form-native PE/COFF x64 executable image emitter, published zip, sha256, source map, and Windows x86_64 physical-lane summary JSON at the catalog URL")))

  (invariant
    (no-mock-data)
    (no-python-runtime-carrier-for-lanes)
    (python-only-serializes-summary-json)
    (os-refusal-is-recorded-as-physical-lane-data)
    (every-lane-runs-through-a-Hati-native-binary)))
