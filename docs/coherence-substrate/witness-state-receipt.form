# witness-state-receipt.form - Form-native live witness counter receipts

(witness-state-receipt
  (lineage
    (rests-on android-mesh-learning.form llm-feature-channel-floor.form)
    (recipe form/form-stdlib/witness-state-receipt.fk)
    (proof form/form-stdlib/tests/witness-state-receipt-band.fk -> 16777215)
    (fourth-arm form/fourth-arm-bands.txt -> witness-state-receipt fks 16777215))

  (purpose
    "Turn live Mac witness /state counters into deterministic Form-native receipt rows."
    "Use the receipt rows to feed Android/Mac active sample learning without extending the Python JSON helper.")

  (floor
    "The live witness receipt row carries source, present flag, frame count, mic RMS summary, camera luma summary, camera sample count, GPU readback count, GPU latency summary, total sample count, active organs, and privacy mode."
    "The current observed values are represented with integer-scaled metrics: frames 141, mic_rms_ppm 7045, camera_luma_ppm 28054, camera_samples 2367, gpu_samples 99, gpu_latency_us 1412, and sample_count 5084."
    "The recipe validates live presence, summary-only privacy, active mic/camera/GPU organs, count floors, and Form-native exporter source."
    "The row lowers into android-mesh-learning active sample rows, then proves speech-transcribe, vision-describe, and multimodal-align route native-first when all three active lanes are present."
    "The receipt emits heldout learner rows for speech, vision, multimodal, and GPU readback lanes, scores challenger/champion trials, keeps too-few samples on the oracle teacher, and retires one narrow teacher only after enough native wins."
    "Native witness export rows and oracle-label rows form the source-backed teacher membrane: raw-media exports are rejected, fixture providers are rejected, and source-backed labels can create heldout rows that retire a narrow teacher only after a long enough native-win window."
    "Live oracle process rows and emission-cycle rows now express continuous source-backed teacher flow: STT, vision, multimodal, and GPU processes must be running, must cover each label by provider/protocol/feature, and must emit across increasing witness export cycles."
    "scripts/witness_oracle_emission_ledger.py reads the live Mac witness /state endpoint, refuses stale/non-live mic-camera-GPU state by default, and writes summary-only emission records under .cache/witness-oracle-emissions/records.")

  (north-star
    "The Mac witness exports native receipt cells continuously into the substrate/native recipe ledger."
    "Speech, vision, multimodal, GPU, and model learners consume those receipt cells as first-class samples."
    "Raw audio, frames, and GPU buffers stay out of durable receipt storage; only typed summaries, counters, and provenance are retained.")

  (receipt-row
    (source "form-native-witness-state")
    (privacy "summary-only/no-raw-audio-frame-buffer")
    (active-organs accelerometer camera gps gpu gyroscope light magnetometer mic network screen)
    (metrics frames mic_rms_ppm camera_luma_ppm camera_samples gpu_samples gpu_latency_us sample_count))

  (heldout-learning
    (rows speech-transcribe vision-describe multimodal-align gpu-readback-kernel)
    (trial "champion-correct/challenger-correct")
    (authority "third-party until min-samples and native reaches the oracle")
    (retirement "native only after a long enough heldout window"))

  (oracle-label-export
    (export-source "native-witness-export")
    (transport "substrate:receipt-cell")
    (teacher-protocols oracle:stt oracle:vision oracle:multimodal oracle:gpu)
    (rejects fixture raw-media)
    (retirement-gate "source-backed labels plus long-window native wins"))

  (oracle-process-emission
    (process-row feature provider protocol status confidence-floor privacy)
    (cycle-row seq export labels processes heldout-rows privacy)
    (requires "running processes cover every label; cycle seq matches export seq; next cycles increase seq and do not regress frames/sample_count")
    (rejects "fixture providers and raw-media process/cycle privacy"))

  (carrier-ledger
    (command "python3 scripts/witness_oracle_emission_ledger.py --cycles 2 --interval 1")
    (latest ".cache/witness-oracle-emissions/latest.json")
    (records ".cache/witness-oracle-emissions/records/*.json")
    (refusal "present=false or missing mic/camera/GPU counters writes a blocked receipt and exits non-zero"))

  (remaining-gaps
    (physical-teacher-runs "replace summary-label carriers with full model-backed STT and vision oracle calls while keeping the same process-row contract")
    (continuous-export "install the emission ledger carrier beside the macOS witness LaunchAgent so cycles write continuously")
    (accelerator-depth "extend EGL readback summaries to Vulkan/NNAPI/Metal parity receipts compared with CPU/oracle lanes")))
