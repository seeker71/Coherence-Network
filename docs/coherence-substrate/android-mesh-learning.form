# android-mesh-learning.form - physical Mac + Android mesh learning receipts

(android-mesh-learning
  (lineage
    (rests-on hati-mesh.form channel-loopback.form co-learning-stream.form colearning-retire.form llm-feature-channel-floor.form oracle-catalog.form)
    (recipe form/form-stdlib/android-mesh-learning.fk)
    (proof form/form-stdlib/tests/android-mesh-learning-band.fk -> 32767)
    (witness-receipt witness-state-receipt.form)
    (physical-receipt scripts/android_mesh_learning_receipt.py))

  (purpose
    "Use the connected Android phone and the Mac as always-on learning organs."
    "The phone supplies physical sensing and mobile accelerator lanes; the Mac supplies host witness, Form kernels, local tools, and oracle/sample infrastructure."
    "Expensive model/compiler/media oracles become explicit teachers. Native candidates run first when the quality, cost, trust, and liveness receipts say they are ready.")

  (floor
    "A real authorized Android device is sampled through adb without storing raw sensor values, location coordinates, package inventory, or the adb serial."
    "The receipt records device model/ABI/Android release, battery summary, safe capability inventory, sensor-category inventory, Coherence Sense installed/running state, Mac host/tool summary, Mac witness service state, typed channel rows, and high-cost feature route decisions."
    "The Android carrier can emit active mic RMS, camera luma, and GPU EGL readback summaries while sharing; it does not store raw audio, frames, or GPU buffers."
    "The current live physical floor observed an unlocked SM-S918U1 sharing to the Mac witness with 141 witness frames, nonzero mic RMS, nonzero camera luma, 2367 camera luma samples, 99 GPU EGL readback samples, and body sample_count 5084."
    "Those live witness counters now have a Form-native receipt row in witness-state-receipt.fk, with integer-scaled summary metrics, heldout learner rows, source-backed oracle label/export rows, live oracle process rows, continuous emission-cycle rows, and a four-way proof at verdict 16777215."
    "The Form recipe proves the deterministic route surface: native-first, native-first with oracle sampling, oracle-teacher-until-physical-samples, stream merging, per-category oracle retirement, and active mic/camera/GPU sample rows that lift speech, vision, and multimodal routing to native-first when those lanes are present.")

  (north-star
    "Mac and Android run continuously: Mac LaunchAgent keeps the witness and local Form learners available; Android keeps Coherence Sense sharing permissioned samples."
    "Sensor, audio, video, host, network, GPU, DSP/NPU, and model receipts feed Form-native learners. Third-party LLM/model/compiler oracles are sampled as teachers and heldout judges until native recipes beat them per lane."
    "The mesh ingests ideas, code, feature requests, runtime traces, and physical-world samples; digests them into typed receipts and exemplars; then embodies winning recipes as first-class native choices.")

  (receipt-command
    (once "python3 scripts/android_mesh_learning_receipt.py --start-app")
    (continuous "python3 scripts/android_mesh_learning_receipt.py --start-app --loop --interval 60")
    (oracle-emission "python3 scripts/witness_oracle_emission_ledger.py --cycles 2 --interval 1")
    (output ".cache/android-mesh-learning/<stamp>/android-mesh-learning-summary.json")
    (latest ".cache/android-mesh-learning/latest.json")
    (oracle-latest ".cache/witness-oracle-emissions/latest.json"))

  (organs
    (android-phone adb coherence-sense sensor audio video gpu network location)
    (macos-binary launchagent form-kernel clang-oracle local-llm-oracle witness-store))

  (channels
    (sensor:signal android-phone macos-binary "ready inventory; active sample flow when app shares")
    (audio:pcm16 android-phone macos-binary "permissioned active mic RMS summary lane; no raw audio storage")
    (video:rgba-time android-phone macos-binary "permissioned active camera luma summary lane; no frame storage")
    (gpu:compute android-phone macos-binary "active OpenGL ES/EGL readback summary lane; no buffer storage")
    (hati.mesh:presence macos-binary android-phone "ready presence/liveness channel"))

  (learning-route
    (native-first "known feature, observed quality at row floor, native cost lower than oracle cost, trust >= 70")
    (native-first-sample-oracle "known feature, quality near floor, native cost lower, oracle sampled as teacher/heldout judge")
    (oracle-teacher-until-physical-samples "quality or physical sample proof missing; keep teacher explicit and bounded"))

  (expensive-oracle-pressure
    (summarize "reduce token-heavy summaries with source-backed native summary receipts")
    (code-lower "use clang/compiler oracles as sample generators while Form-native ASM/object lanes mature")
    (tool-select "learn cheap native tool routing before asking general LLM planners")
    (speech-transcribe "sample whisper/STT teachers until phone/Mac audio learner wins categories")
    (vision-describe "sample vision teachers until frame geometry/recognition lanes win categories")
    (multimodal-align "align sensor/audio/video/text by receipt instead of sending every fused context to an LLM")
    (distill-retire "stop paying per category once champion/challenger proof retires the teacher"))

  (24-7-operation
    (mac-witness "experiments/coherence-sense-android/macos-witness-service.sh install --mode recognition --port 8800")
    (android-app "adb shell am start -n com.coherence.sense/.MainActivity")
    (receipt-loop "python3 scripts/android_mesh_learning_receipt.py --start-app --loop --interval 60")
    (oracle-emission-loop "python3 scripts/witness_oracle_emission_ledger.py --cycles 2 --interval 1")
    (form-native-receipt "form/form-stdlib/witness-state-receipt.fk")
    (handoff "running service should write native substrate ledger records continuously, with JSON summaries as export/cache"))

  (next-physical-gaps
    (mic "full whisper/STT carrier labels raw-free summary windows under the existing process-row contract")
    (camera "full vision carrier labels raw-free summary windows under the existing process-row contract")
    (accelerator "EGL readback summaries extended to live Vulkan/NNAPI kernel receipts compared with CPU/oracle lanes")
    (stream "install the oracle emission loop beside the Mac witness service for 24/7 records")
    (retirement "one narrow category with enough heldout native wins to stop sampling the teacher")))
