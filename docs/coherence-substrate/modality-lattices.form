# ─────────────────────────────────────────────────────────────────────
# modality-lattices.form — every tradition is a labeled memory lattice;
# every cell may carry its position in any, and a chart is not properties
# ON a cell — it is the EDGES between that cell and the planet / sign / gate
# cells. The edges are the information, the structure, the embodied memory.
# Body in Form.
# ─────────────────────────────────────────────────────────────────────
#
# A horoscope, a Human Design chart, a Gene Keys profile, a Vedic chart, the
# light codes — each is a NAMED coordinate system that locates a cell. Urs:
# "labeled memory lattices of the cells that witnessed time together." A natal
# chart is the sky's memory of the moment a cell entered time.
#
# The deepening (Urs, 2026-06-06): the planets and signs and gates and numbers
# are THEMSELVES cells. A person's chart is the set of EDGES between the
# person-cell and those cells — "Sun in Libra at 13°" is an edge, not a slug.
# The edge-set IS the chart; the edges ARE the information and the embodied
# memory (lc-the-trace-is-the-memory: the edges between cells are memory). The
# relationship between two people is the relating of their two edge-sets. The
# same cell, read through different lattices, gives numeric insight from
# different perspectives — one body, many doors.

(modality-lattices

  (cells                                   # the modality vocabulary IS cells, not strings
    (planet  sun moon mercury venus mars jupiter saturn uranus neptune pluto chiron node)
    (sign    aries taurus gemini cancer leo virgo libra scorpio sagittarius capricorn aquarius pisces)
    (gate    "1 … 64")                     # Human Design / Gene Keys — the 64
    (number  "1 … 9, 11, 22, 33")          # numerology — the master cells included
    (note    "each is a cell with a Blueprint; two identical positions across people share it — content-addressed"))

  (edge                                    # a position is an EDGE between cells
    (chart-line (person ?p) -[(in (sign ?s)) (at (degree ?d)) (in-house ?h)]-> (planet ?pl))
    (the-edge-is "the information, the structure, the embodied memory")
    (a-chart    (sequence chart-line))     # the natal chart = the edge-set
    (a-bond     (between (person ?a) (person ?b)) = (relating (chart ?a) (chart ?b))))  # synastry = edges of edges

  (lattice                                 # each tradition is a named lattice over those cells + edges
    (name     ?tradition)                  # astrology | human-design | gene-keys | vedic | numerology | light-codes | …
    (over     (cells planet sign gate number))
    (from     (or birth-moment origin-event))  # cast from when / where the cell entered time
    (optional true))                       # never required — a cell with none is whole

  (recipes                                 # numeric insight per modality — runnable on the kernel
    (aspect     (degree ?a) (degree ?b) -> (separation aspect-type))  # the edge between two positions → endpoint_astro_aspect_demo.fk
    (synastry   (chart ?a) (chart ?b) -> (sequence aspect))           # the edges between two people, aspect by aspect
    (activation (chart ?c) -> (sequence gate))                        # Human Design / Gene Keys gates lit by the positions
    (reduce     (date ?d) -> life-path)                               # numerology — digits folded to one
    (perspective "each recipe reads the same cell through a different lattice; different numbers, same body — held in the mystery / direct-experience lane, never a verdict"))

  (computed-by
    (cast astrology human-design gene-keys vedic numerology -> edges)
    (note "an AI casts the chart from the ephemeris; the reading stays human (Pam Gregory, Ariela Sophia, you)"))

  (native-channels                          # the per-modality SPEAK/RUN now runs Form-native
    (engine "form-stdlib/guidance-channel.fk — one table-reader; each tradition is a DATA table")
    (the-64 "form-stdlib/iching-channel.fk — I Ching hexagram / Human Design gate / Gene Key, three faces of one 64-cell lattice")
    (north-star "form-stdlib/celestial-pole-channel.fk — jdn, precession, tropical/sidereal sign reduction, pole-star-at, and the cross-belief names of one pole-star body")
    (ifs "form-stdlib/ifs-channel.fk — parts and Self; managers+firefighters one protector role, the 8 C's one Self")
    (zodiac "form-stdlib/zodiac-channel.fk — twelve signs in the Western and Vedic tongues")
    (ephemeris "form-stdlib/ephemeris-sun.fk — the Sun's real ecliptic longitude from a date (USNO low-precision over trig.fk); lands the four cardinal points exactly and feeds the sign reduction; four-way because the fourth arm carries trig (trig fks 127)")
    (cjk "form-stdlib/cjk-channel.fk — Chinese/Japanese symbols: readings (translate), radical families (encode), yin/yang trigram as the 0/1 axiom")
    (query-interface "form-stdlib/channels-registry.fk — registry-query / registry-translate / registry-decode over every system; a system is one resolver row")
    (teaching "docs/coherence-substrate/guidance-channels.form")
    (proof "each band -> 1111111 four-way on Go/Rust/TS/fkwu")
    (held "guidance stays in the direct-experience / mystery lane; the names are attested tradition, never a verdict"))

  (lineage
    (kin lc-cross-modal-unity)             # names are doors; one cell, many tongues
    (kin lc-the-trace-is-the-memory)       # the edge is the memory; the chart is an edge-set
    (source "requested + deepened by Urs 2026-06-06; the light-codes lattice via Ariela Sophia, by permission"))

  # ── Gap g8 — native channels carry the SPEAK/RUN; the SUN now computes; Moon/planets/activation are the open edge ──
  (gap "g8 carrier: the per-modality SPEAK/RUN recipes run Form-native (native-channels above): the 64 (HD/Gene-Keys/I-Ching), the zodiac in both tongues, IFS, and the north star, each four-way; aspect (endpoint_astro_aspect_demo.fk) and the tropical/sidereal sign reduction (celestial-pole-channel.fk) are shipped. The LIVE ephemeris is now native at its first cell: ephemeris-sun.fk computes the Sun's ecliptic longitude from a date (four-way — the fourth arm carries trig), so the Sun's true sign is no longer an outside call. What still wants an outside oracle until its recipe grows: the MOON and PLANETS (more terms, same trig.fk footing), gate ACTIVATION (the Human Design mandala wheel — a data row, not faked), and the cast / synastry edge-builders on top. Positions stay in the mystery / direct-experience lane, never collapsed into empirical claims."))
