# ─────────────────────────────────────────────────────────────────────
# python-grammar.form — Python source as a Form Language cell
# ─────────────────────────────────────────────────────────────────────
#
# Closes the largest remaining file-format gap from grammar_coverage.py
# (927 .py files; the body's API, services, scripts, tests, and the
# bootstrap layer for organ.py / substrate.py / form.py all live in
# Python).
#
# Companion teachings:
#   - lc-grammar-is-the-universal-recipe (every structured input)
#   - lc-one-kernel-many-tongues (kernel sovereignty over grammar)
#   - lc-the-recipe-remembers-its-source (source coords as overlay)
#
# Companion files:
#   - grammar-as-recipe.form (the abstract Language cell shape)
#   - markdown-grammar.form (sibling tongue at the prose altitude)
#   - language-cells.md (the N+M cross-language pattern Python was
#     already named in)
#
# The contract is Form-native BMF transmutation: source bytes stream
# through token-streamer.form, match rules declared here, and emit
# Form-native cells with source_attribution stamped from token spans.
# Host-language syntax-tree bridges are compatibility probes only;
# they do not count as parser completion.

# ─────────────────────────────────────────────────────────────────────
# Part 1 — module-level Blueprints
# ─────────────────────────────────────────────────────────────────────
#
# A Python module is a sequence of top-level statements. The Blueprint
# tree is the Form-native target shape: a top-level `body` list, each
# entry one statement shape below, plus type_ignores for type-checking
# comments.

form py_module_shape = {
    body:          ~List,                # [statement_shape]
    docstring:     ?~String,             # first body element if Constant[str]
    source_path:   ~PathRef,
    python_version: ~String,             # "3.12" — the parser version that produced this tree
};

# ─────────────────────────────────────────────────────────────────────
# Part 2 — statement-level Blueprints
# ─────────────────────────────────────────────────────────────────────
#
# Each statement is one Form-native Python source shape. The list below
# covers the common surface; rarer source forms (Match, TryStar,
# AsyncWith, etc.) follow the same shape and land as the body needs them.

form py_function_def_shape = {
    name:          ~Slug,
    args:          py_arguments_shape,
    body:          ~List,                # [statement_shape]
    decorators:    ~List,                # [expression_shape]
    returns:       ?py_annotation_shape, # the -> Type clause
    docstring:     ?~String,
    is_async:      ~Bool,                # AsyncFunctionDef vs FunctionDef
    type_params:   ~List,                # PEP 695 (Python 3.12+); empty otherwise
};

form py_class_def_shape = {
    name:          ~Slug,
    bases:         ~List,                # [expression_shape]
    keywords:      ~List,                # [keyword_shape] — metaclass=…
    body:          ~List,
    decorators:    ~List,
    docstring:     ?~String,
    type_params:   ~List,
};

form py_import_shape = {
    kind:          ~Slug,                # "import" | "from"
    module:        ?~Slug,               # "os" | "os.path" | null for relative-only
    names:         ~List,                # [(name, alias)]
    level:         ~Int,                 # 0 for absolute; 1+ for "from . import x"
};

form py_assign_shape = {
    targets:       ~List,                # [expression_shape] (LHS, possibly tuple unpack)
    value:         ~Recipe,              # expression
    type_comment:  ?~String,
};

form py_annotated_assign_shape = {
    target:        ~Recipe,
    annotation:    py_annotation_shape,
    value:         ?~Recipe,             # null for declaration-only
};

form py_aug_assign_shape = {
    target:        ~Recipe,
    op:            ~Slug,                # "+=" | "-=" | "*=" | ...
    value:         ~Recipe,
};

form py_expr_statement_shape = {
    value:         ~Recipe,              # expression as a statement
};

form py_return_shape = {
    value:         ?~Recipe,
};

form py_if_shape = {
    test:          ~Recipe,
    body:          ~List,                # [statement_shape]
    orelse:        ~List,                # [statement_shape] — else/elif chain
};

form py_for_shape = {
    target:        ~Recipe,
    iter:          ~Recipe,
    body:          ~List,
    orelse:        ~List,
    is_async:      ~Bool,
};

form py_while_shape = {
    test:          ~Recipe,
    body:          ~List,
    orelse:        ~List,
};

form py_with_shape = {
    items:         ~List,                # [(context_expr, optional_vars)]
    body:          ~List,
    is_async:      ~Bool,
};

form py_try_shape = {
    body:          ~List,
    handlers:      ~List,                # [py_except_handler_shape]
    orelse:        ~List,
    finalbody:     ~List,
};

form py_except_handler_shape = {
    exc_type:      ?~Recipe,             # ExceptionType | (T1, T2) | null for bare except
    name:          ?~Slug,               # `as e` binding
    body:          ~List,
};

form py_raise_shape = {
    exc:           ?~Recipe,
    cause:         ?~Recipe,             # `raise X from Y`
};

form py_pass_shape    = {};
form py_break_shape   = {};
form py_continue_shape = {};
form py_global_shape   = { names: ~List };
form py_nonlocal_shape = { names: ~List };

# ─────────────────────────────────────────────────────────────────────
# Part 3 — expression-level Blueprints
# ─────────────────────────────────────────────────────────────────────

form py_name_shape = {
    id:            ~Slug,
    ctx:           ~Slug,                # "load" | "store" | "del"
};

form py_constant_shape = {
    value:         ~Form,                # str | int | float | bool | None | bytes | complex
    kind:          ?~Slug,               # "u" for u-string; null otherwise
};

form py_attribute_shape = {
    value:         ~Recipe,              # the object whose attr is accessed
    attr:          ~Slug,
    ctx:           ~Slug,
};

form py_subscript_shape = {
    value:         ~Recipe,
    slice:         ~Recipe,              # index, slice, or tuple thereof
    ctx:           ~Slug,
};

form py_call_shape = {
    func:          ~Recipe,
    args:          ~List,                # [expression_shape]
    keywords:      ~List,                # [keyword_shape]
};

form py_keyword_shape = {
    arg:           ?~Slug,               # null for **kwargs spread
    value:         ~Recipe,
};

form py_binop_shape = {
    left:          ~Recipe,
    op:            ~Slug,                # "+" | "-" | "*" | "/" | "//" | "%" | "**" | ...
    right:         ~Recipe,
};

form py_unaryop_shape = {
    op:            ~Slug,                # "not" | "-" | "+" | "~"
    operand:       ~Recipe,
};

form py_boolop_shape = {
    op:            ~Slug,                # "and" | "or"
    values:        ~List,
};

form py_compare_shape = {
    left:          ~Recipe,
    ops:           ~List,                # ["==", "<", "in", "is", ...]
    comparators:   ~List,
};

form py_ifexp_shape = {
    test:          ~Recipe,
    body:          ~Recipe,              # value if test
    orelse:        ~Recipe,              # value if not test
};

form py_lambda_shape = {
    args:          py_arguments_shape,
    body:          ~Recipe,
};

# Container literals.

form py_list_shape =  { elts: ~List, ctx: ~Slug };
form py_tuple_shape = { elts: ~List, ctx: ~Slug };
form py_set_shape   = { elts: ~List };
form py_dict_shape  = { keys: ~List, values: ~List };

# Comprehensions and generator expressions.

form py_comprehension_shape = {
    target:        ~Recipe,
    iter:          ~Recipe,
    ifs:           ~List,                # [expression_shape] — filter clauses
    is_async:      ~Bool,
};

form py_list_comp_shape = { elt: ~Recipe, generators: ~List };
form py_set_comp_shape  = { elt: ~Recipe, generators: ~List };
form py_dict_comp_shape = { key: ~Recipe, value: ~Recipe, generators: ~List };
form py_gen_exp_shape   = { elt: ~Recipe, generators: ~List };

# F-strings — JoinedStr containing FormattedValue children.

form py_joined_str_shape = {
    values:        ~List,                # [py_constant_shape | py_formatted_value_shape]
};

form py_formatted_value_shape = {
    value:         ~Recipe,
    conversion:    ?~Int,                # -1 | 115 ('s') | 114 ('r') | 97 ('a')
    format_spec:   ?~Recipe,
};

# Slicing.

form py_slice_shape = {
    lower:         ?~Recipe,
    upper:         ?~Recipe,
    step:          ?~Recipe,
};

# Star expressions: *args in calls, *iterable in unpacking.

form py_starred_shape = { value: ~Recipe, ctx: ~Slug };

# Yield and await.

form py_yield_shape       = { value: ?~Recipe };
form py_yield_from_shape  = { value: ~Recipe };
form py_await_shape       = { value: ~Recipe };

# ─────────────────────────────────────────────────────────────────────
# Part 4 — argument and annotation Blueprints
# ─────────────────────────────────────────────────────────────────────

form py_arg_shape = {
    arg:           ~Slug,
    annotation:    ?py_annotation_shape,
    type_comment:  ?~String,
};

form py_arguments_shape = {
    posonlyargs:   ~List,                # [py_arg_shape]
    args:          ~List,
    vararg:        ?py_arg_shape,        # *args
    kwonlyargs:    ~List,
    kw_defaults:   ~List,                # [expression_shape | null]
    kwarg:         ?py_arg_shape,        # **kwargs
    defaults:      ~List,                # defaults for posonlyargs+args (right-aligned)
};

form py_annotation_shape = {
    expression:    ~Recipe,              # the annotation expression itself
};

# ─────────────────────────────────────────────────────────────────────
# Part 5 — concrete Form-recipe rules
# ─────────────────────────────────────────────────────────────────────
#
# Each Python construct is expressed as a Form recipe composed from the
# Pattern primitives declared in grammar-as-recipe.form Part 2.5
# (pattern_literal_shape, pattern_sequence_shape, pattern_star_shape,
# pattern_opt_shape, pattern_choice_shape, pattern_capture_shape).
#
# The host-side parse engine (seedbank/local-llm-cell-v0/bmf.py) is
# the bootstrap; these recipes are the destination. Every additional
# Python construct lands here as another rule_shape composing the same
# primitives — *not* as a Python class wrapper. The self-hosting
# boundary moves with every rule landed.
#
# Status: py_import + py_import_from shipped 2026-05-21 (both as Form
# recipes here AND as host-engine rules in bmf.py for parity). Every
# other construct (def, class, assign, expressions, control flow) is
# named in capture_rules with rule_shape == null until its breath lands.

# ──────────────────────────── helpers: tokens by kind ─────────────────

defn lit_kw(value)    = pattern_literal_shape { kind: "KW",     value: value };
defn lit_op(value)    = pattern_literal_shape { kind: "OP",     value: value };
defn lit_ident()      = pattern_literal_shape { kind: "IDENT",  value: null };

# ────────────────────────── helper: dotted_name a.b.c ─────────────────

defn dotted_name_pattern = pattern_sequence_shape {
    children: [
        pattern_capture_shape { name: "head", child: lit_ident() },
        pattern_star_shape {
            name: "tail",
            child: pattern_sequence_shape {
                children: [
                    lit_op("."),
                    pattern_capture_shape { name: "part", child: lit_ident() },
                ],
            },
        },
    ],
};

# Semantic action recipe: captures → dotted-name string.
defn dotted_name_to_string_action(captures) = do {
    let head = captures.head;
    let parts = [head];
    for entry in (captures.tail ?? []):
        parts = parts + [entry.part];
    join(parts, ".")
};

# ────────────────────────── helper: import alias ──────────────────────
#
# `alias` is `dotted_name [as IDENT]`. Captures `name` (dotted) and
# optional `alias` (single IDENT).

defn import_alias_pattern = pattern_sequence_shape {
    children: [
        pattern_capture_shape { name: "name", child: dotted_name_pattern },
        pattern_opt_shape {
            child: pattern_sequence_shape {
                children: [
                    lit_kw("as"),
                    pattern_capture_shape { name: "alias", child: lit_ident() },
                ],
            },
        },
    ],
};

# ───────────────────────────── rule: py_import ────────────────────────
#
# Pattern: `import alias (, alias)*`
# Action:  build a py_import_shape { kind: "import", names: [...] }

defn py_import_rule = rule_shape {
    name:    "py_import",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("import"),
            pattern_capture_shape {
                name: "aliases",
                child: pattern_sequence_shape {
                    children: [
                        pattern_capture_shape { name: "first", child: import_alias_pattern },
                        pattern_star_shape {
                            name: "rest",
                            child: pattern_sequence_shape {
                                children: [
                                    lit_op(","),
                                    pattern_capture_shape {
                                        name: "entry",
                                        child: import_alias_pattern,
                                    },
                                ],
                            },
                        },
                    ],
                },
            },
        ],
    },
    action: defn py_import_action(captures, span) = do {
        let aliases_caps = captures.aliases.captures;
        let entries = [aliases_caps.first];
        for entry in (aliases_caps.rest ?? []):
            entries = entries + [entry.entry];
        let names = [];
        for entry in entries:
            let name_str = dotted_name_to_string_action(entry.captures.name.captures);
            names = names + [{
                name:   name_str,
                asname: entry.captures.alias,
            }];
        py_import_shape {
            kind:   "import",
            module: null,
            names:  names,
            level:  0,
        }
    },
};

# ──────────────────────── rule: py_import_from ────────────────────────
#
# Pattern: `from (.*) [dotted_name] import (alias (, alias)* | * )`
# Action:  build a py_import_shape { kind: "from", module: ..., level: N, names: [...] }

defn py_import_from_rule = rule_shape {
    name:    "py_import_from",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("from"),
            # Relative dots: 0+ "." OPs (each becomes a level increment).
            pattern_star_shape {
                name: "dots",
                child: pattern_capture_shape { name: "dot", child: lit_op(".") },
            },
            # Optional module (may be absent in `from . import x`).
            pattern_opt_shape {
                child: pattern_capture_shape { name: "module", child: dotted_name_pattern },
            },
            lit_kw("import"),
            # Names: either '*' or a sequence of import aliases.
            pattern_choice_shape {
                alternatives: [
                    pattern_capture_shape { name: "star", child: lit_op("*") },
                    pattern_capture_shape {
                        name: "aliases",
                        child: pattern_sequence_shape {
                            children: [
                                pattern_capture_shape {
                                    name: "first",
                                    child: import_alias_pattern,
                                },
                                pattern_star_shape {
                                    name: "rest",
                                    child: pattern_sequence_shape {
                                        children: [
                                            lit_op(","),
                                            pattern_capture_shape {
                                                name: "entry",
                                                child: import_alias_pattern,
                                            },
                                        ],
                                    },
                                },
                            ],
                        },
                    },
                ],
            },
        ],
    },
    action: defn py_import_from_action(captures, span) = do {
        let level = len(captures.dots ?? []);
        let module = if captures.module == null
            then null
            else dotted_name_to_string_action(captures.module.captures);
        let names = if captures.star != null then [{ name: "*", asname: null }]
            else do {
                let aliases_caps = captures.aliases.captures;
                let entries = [aliases_caps.first];
                for entry in (aliases_caps.rest ?? []):
                    entries = entries + [entry.entry];
                let result = [];
                for entry in entries:
                    let name_str = dotted_name_to_string_action(entry.captures.name.captures);
                    result = result + [{
                        name:   name_str,
                        asname: entry.captures.alias,
                    }];
                result
            };
        py_import_shape {
            kind:   "from",
            module: module,
            names:  names,
            level:  level,
        }
    },
};

# ──────────────────────── rule: py_function_def ───────────────────────
#
# Pattern: `def NAME ( params ) : body`
#   params  := IDENT ( , IDENT )*        # positional-only for v1
#   body    := one-line expression statement
#
# Action: build a py_function_def_shape { name, args, body, ... }.
#
# Honest GAP-PY-DEF-v1: this rule covers simple positional parameters
# and a single-expression body (matches `def f(a, b): expr` and the
# python_demo.py exemplars). Decorators, default arguments, *args,
# **kwargs, return-type annotations (`-> Type`), PEP 695 type params
# (`def f[T](x: T) -> T`), and multi-statement indented bodies land as
# extensions in subsequent breaths. The v1 rule is real — it produces
# Form objects parity-equivalent to lang-python.ts's def parsing for
# the supported subset — but coverage is honestly partial.

defn _param_list_pattern = pattern_choice_shape {
    alternatives: [
        # Empty param list — `def f():`
        pattern_sequence_shape { children: [] },
        # Non-empty — first then `, IDENT` zero+ times
        pattern_sequence_shape {
            children: [
                pattern_capture_shape { name: "first", child: lit_ident() },
                pattern_star_shape {
                    name: "rest",
                    child: pattern_sequence_shape {
                        children: [
                            lit_op(","),
                            pattern_capture_shape { name: "entry", child: lit_ident() },
                        ],
                    },
                },
            ],
        },
    ],
};

defn py_function_def_rule = rule_shape {
    name:    "py_function_def",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("def"),
            pattern_capture_shape { name: "name", child: lit_ident() },
            lit_op("("),
            pattern_capture_shape { name: "params", child: _param_list_pattern },
            lit_op(")"),
            lit_op(":"),
            pattern_capture_shape { name: "body", child: ?rule py_expr_stmt },
        ],
    },
    action: defn py_function_def_action(captures, span) = do {
        let name = captures.name;
        let params_caps = captures.params.captures;
        let names = if params_caps.first == null then []
            else do {
                let parts = [params_caps.first];
                for entry in (params_caps.rest ?? []):
                    parts = parts + [entry.entry];
                parts
            };
        py_function_def_shape {
            name:        name,
            args:        py_arguments_shape {
                posonlyargs: [],
                args:        names,
                vararg:      null,
                kwonlyargs:  [],
                kw_defaults: [],
                kwarg:       null,
                defaults:    [],
            },
            body:        [captures.body],
            decorators:  [],
            returns:     null,
            docstring:   null,
            is_async:    false,
            type_params: [],
        }
    },
};

# ──────────────────────────── rule: py_assign ─────────────────────────
#
# Pattern: `target = value`
#   target := IDENT     (single-name only for v1; tuple unpacking and
#                        attribute/subscript targets land as extensions)
#   value  := expression
#
# Action: build py_assign_shape { targets: [name], value, ... }.

defn py_assign_rule = rule_shape {
    name:    "py_assign",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "target", child: lit_ident() },
            lit_op("="),
            pattern_capture_shape { name: "value", child: ?rule py_expr_stmt },
        ],
    },
    action: defn py_assign_action(captures, span) = do {
        py_assign_shape {
            targets: [captures.target],
            value:   captures.value,
            type_comment: null,
        }
    },
};

# ──────────────────────────── rule: py_call ───────────────────────────
#
# Pattern: `func ( args )`
#   func := IDENT (or dotted_name for method-style call.access; v1 keeps
#                  it IDENT-only and routes dotted to py_method_call in
#                  a later breath)
#   args := expr (, expr)*
#
# Action: build py_call_shape { func, args, keywords }.

defn _arg_list_pattern = pattern_choice_shape {
    alternatives: [
        pattern_sequence_shape { children: [] },
        pattern_sequence_shape {
            children: [
                pattern_capture_shape { name: "first", child: ?rule py_expr_stmt },
                pattern_star_shape {
                    name: "rest",
                    child: pattern_sequence_shape {
                        children: [
                            lit_op(","),
                            pattern_capture_shape { name: "entry", child: ?rule py_expr_stmt },
                        ],
                    },
                },
            ],
        },
    ],
};

defn py_call_rule = rule_shape {
    name:    "py_call",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "func", child: lit_ident() },
            lit_op("("),
            pattern_capture_shape { name: "args", child: _arg_list_pattern },
            lit_op(")"),
        ],
    },
    action: defn py_call_action(captures, span) = do {
        let args_caps = captures.args.captures;
        let arg_list = if args_caps.first == null then []
            else do {
                let parts = [args_caps.first];
                for entry in (args_caps.rest ?? []):
                    parts = parts + [entry.entry];
                parts
            };
        py_call_shape {
            func:     captures.func,
            args:     arg_list,
            keywords: [],
        }
    },
};

# ──────────────────────────── rule: py_subscript ──────────────────────
#
# Pattern: `value [ index ]`
#   value := IDENT (v1; expression callees come later)
#   index := expression
#
# Action: build py_subscript_shape { value, index }.
# Closes the lst[i] gap surfaced in the python-trace demo (PR #1782).

defn py_subscript_rule = rule_shape {
    name:    "py_subscript",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "value", child: lit_ident() },
            lit_op("["),
            pattern_capture_shape { name: "index", child: ?rule py_expr_stmt },
            lit_op("]"),
        ],
    },
    action: defn py_subscript_action(captures, span) = do {
        py_subscript_shape {
            value: captures.value,
            slice: captures.index,
            ctx:   "load",
        }
    },
};

# ──────────────────────────── rule: py_slice ──────────────────────────
#
# Pattern: `value [ start ? : end ? ]`
#   (subset of full Python slicing — no step yet)
#
# Action: build py_slice_shape { value, lower, upper, step: null }.

defn py_slice_rule = rule_shape {
    name:    "py_slice",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "value", child: lit_ident() },
            lit_op("["),
            pattern_opt_shape {
                child: pattern_capture_shape { name: "lower", child: ?rule py_expr_stmt },
            },
            lit_op(":"),
            pattern_opt_shape {
                child: pattern_capture_shape { name: "upper", child: ?rule py_expr_stmt },
            },
            lit_op("]"),
        ],
    },
    action: defn py_slice_action(captures, span) = do {
        py_slice_shape {
            value: captures.value,
            lower: captures.lower,
            upper: captures.upper,
            step:  null,
        }
    },
};

# ──────────────────────────── rule: py_return ─────────────────────────
#
# Pattern: `return [ expr ]`
#
# Action: build py_return_shape { value }. Explicit return statement
# inside a def body (vs the implicit-last-expression form the v1 def
# rule shipped earlier).

defn py_return_rule = rule_shape {
    name:    "py_return",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("return"),
            pattern_opt_shape {
                child: pattern_capture_shape { name: "value", child: ?rule py_expr_stmt },
            },
        ],
    },
    action: defn py_return_action(captures, span) = do {
        py_return_shape { value: captures.value }
    },
};

# ──────────────────────────── rule: py_expr_stmt ──────────────────────
#
# Pattern: any expression as a top-level statement. v1 covers a small
# subset (call, ident, int/float/string/bool literal). The full
# expression grammar with precedence climbing lands as
# py_expr_full_rule in a later breath — that's the largest single
# Python construct (operators by precedence: `or` < `and` < `not` <
# comparison < `|` < `^` < `&` < shift < `+ -` < `* / // % @` < unary
# < `**` < await < primary).
#
# v1 is "any one of these primary alternatives" — enough for arguments,
# return values, simple expressions. Composed expressions still flow
# through the kernel's add/sub/mul/etc. arms at execution time.

defn py_expr_stmt_rule = rule_shape {
    name:    "py_expr_stmt",
    pattern: pattern_choice_shape {
        alternatives: [
            # The order matters — try the longer patterns first so the
            # CHOICE arm's FAIL-unwind doesn't accidentally accept a
            # prefix as a complete value.
            py_call_rule.pattern,
            py_subscript_rule.pattern,
            py_slice_rule.pattern,
            pattern_capture_shape { name: "ident_val", child: lit_ident() },
            pattern_capture_shape { name: "int_val",   child: pattern_literal_shape { kind: "INT",    value: null } },
            pattern_capture_shape { name: "float_val", child: pattern_literal_shape { kind: "FLOAT",  value: null } },
            pattern_capture_shape { name: "str_val",   child: pattern_literal_shape { kind: "STRING", value: null } },
            pattern_capture_shape { name: "true_lit",  child: lit_kw("true") },
            pattern_capture_shape { name: "false_lit", child: lit_kw("false") },
            pattern_capture_shape { name: "none_lit",  child: lit_kw("None") },
        ],
    },
    action: defn py_expr_stmt_action(captures, span) = captures,
};

# ──────────────────────────── rule: py_if ─────────────────────────────
#
# Pattern: `if cond : body [ elif cond : body ]* [ else : body ]?`
#
# Action: build py_if_shape { test, body, orelse }. Multiple elif arms
# lower into nested py_if_shape with the next condition as the orelse's
# single statement — the canonical ast.parse representation.

defn _py_indent()  = pattern_literal_shape { kind: "INDENT", value: null };
defn _py_dedent()  = pattern_literal_shape { kind: "DEDENT", value: null };

# A block-body: INDENT, one+ statements, DEDENT. For v1 we accept a
# single statement (matching the existing py_function_def_rule body
# shape). Multi-statement bodies land alongside the full expression
# grammar.
defn _py_block_body = pattern_sequence_shape {
    children: [
        _py_indent(),
        pattern_capture_shape { name: "stmt", child: ?rule py_expr_stmt },
        _py_dedent(),
    ],
};

defn py_if_rule = rule_shape {
    name:    "py_if",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("if"),
            pattern_capture_shape { name: "test", child: ?rule py_expr_stmt },
            lit_op(":"),
            pattern_capture_shape { name: "body", child: _py_block_body },
            # Zero or more elif clauses
            pattern_star_shape {
                name: "elifs",
                child: pattern_sequence_shape {
                    children: [
                        lit_kw("elif"),
                        pattern_capture_shape { name: "test",  child: ?rule py_expr_stmt },
                        lit_op(":"),
                        pattern_capture_shape { name: "body",  child: _py_block_body },
                    ],
                },
            },
            # Optional else
            pattern_opt_shape {
                child: pattern_sequence_shape {
                    children: [
                        lit_kw("else"),
                        lit_op(":"),
                        pattern_capture_shape { name: "else_body", child: _py_block_body },
                    ],
                },
            },
        ],
    },
    action: defn py_if_action(captures, span) = do {
        # Lower elif chain into nested orelse.
        let final_else = if captures.else_body != null
            then [captures.else_body]
            else [];
        let chain = final_else;
        # Walk elifs in reverse, wrapping each into the chain.
        let elifs = captures.elifs ?? [];
        for elif_ in reverse(elifs):
            chain = [py_if_shape {
                test:   elif_.test,
                body:   [elif_.body],
                orelse: chain,
            }];
        py_if_shape {
            test:   captures.test,
            body:   [captures.body],
            orelse: chain,
        }
    },
};

# ──────────────────────────── rule: py_for ────────────────────────────
#
# Pattern: `for target in iter : body [ else : else_body ]?`
# Action: build py_for_shape { target, iter, body, orelse }.

defn py_for_rule = rule_shape {
    name:    "py_for",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("for"),
            pattern_capture_shape { name: "target", child: lit_ident() },
            lit_kw("in"),
            pattern_capture_shape { name: "iter",   child: ?rule py_expr_stmt },
            lit_op(":"),
            pattern_capture_shape { name: "body",   child: _py_block_body },
            pattern_opt_shape {
                child: pattern_sequence_shape {
                    children: [
                        lit_kw("else"),
                        lit_op(":"),
                        pattern_capture_shape { name: "else_body", child: _py_block_body },
                    ],
                },
            },
        ],
    },
    action: defn py_for_action(captures, span) = do {
        py_for_shape {
            target: captures.target,
            iter:   captures.iter,
            body:   [captures.body],
            orelse: if captures.else_body != null then [captures.else_body] else [],
            is_async: false,
            type_comment: null,
        }
    },
};

# ──────────────────────────── rule: py_while ──────────────────────────
#
# Pattern: `while cond : body [ else : else_body ]?`
# Action: build py_while_shape { test, body, orelse }.

defn py_while_rule = rule_shape {
    name:    "py_while",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("while"),
            pattern_capture_shape { name: "test", child: ?rule py_expr_stmt },
            lit_op(":"),
            pattern_capture_shape { name: "body", child: _py_block_body },
            pattern_opt_shape {
                child: pattern_sequence_shape {
                    children: [
                        lit_kw("else"),
                        lit_op(":"),
                        pattern_capture_shape { name: "else_body", child: _py_block_body },
                    ],
                },
            },
        ],
    },
    action: defn py_while_action(captures, span) = do {
        py_while_shape {
            test:   captures.test,
            body:   [captures.body],
            orelse: if captures.else_body != null then [captures.else_body] else [],
        }
    },
};

# ──────────────────────────── rule: py_raise ──────────────────────────
#
# Pattern: `raise [ exc [ from cause ]? ]?`
# Action: build py_raise_shape { exc, cause }.

defn py_raise_rule = rule_shape {
    name:    "py_raise",
    pattern: pattern_sequence_shape {
        children: [
            lit_kw("raise"),
            pattern_opt_shape {
                child: pattern_sequence_shape {
                    children: [
                        pattern_capture_shape { name: "exc",   child: ?rule py_expr_stmt },
                        pattern_opt_shape {
                            child: pattern_sequence_shape {
                                children: [
                                    lit_kw("from"),
                                    pattern_capture_shape { name: "cause", child: ?rule py_expr_stmt },
                                ],
                            },
                        },
                    ],
                },
            },
        ],
    },
    action: defn py_raise_action(captures, span) = do {
        py_raise_shape {
            exc:   captures.exc,
            cause: captures.cause,
        }
    },
};

# ─────────────────────────────────────────────────────────────────────
# Part 5b — the Language cell binding
# ─────────────────────────────────────────────────────────────────────

defn python_grammar = grammar_shape {
    modality:           modality_shape { name: "text-tree", domain: "code" },
    ingest_pattern:     parse_loop,       # the Form recipe from grammar-as-recipe.form
    parse_into:         ~Blueprint @py_module_shape,
    capture_rules:      [
        # Shipped as Form recipes (the `?` markers dropped one breath at
        # a time as each rule lands). The diff itself is the measure of
        # bootstrap → destination distance.
        py_import_rule,
        py_import_from_rule,
        py_function_def_rule,             # v1: positional args + single-expr body
        py_assign_rule,                   # v1: name = expr
        py_call_rule,                     # v1: ident(args)
        py_subscript_rule,                # v1: ident[expr]
        py_slice_rule,                    # v1: ident[expr?:expr?]
        py_return_rule,                   # v1: return [expr]
        py_expr_stmt_rule,                # v1: primary alternatives (call, ident, literal)
        py_if_rule,                       # v1: if/elif/else statement form
        py_for_rule,                      # v1: for target in iter: body [else]
        py_while_rule,                    # v1: while cond: body [else]
        py_raise_rule,                    # v1: raise [exc [from cause]]
        # Pending Form expression (host bridge handles these until the
        # rule lands here as a concrete Form recipe). Each one is one
        # breath of work composing the same Pattern primitives.
        ?rule py_class_def,               # GAP-PY-CLASS
        ?rule py_expr_full,               # GAP-PY-EXPR (full precedence-climbing expression grammar)
        ?rule py_lambda,                  # GAP-PY-LAMBDA
        ?rule py_with,                    # GAP-PY-WITH
        ?rule py_try,                     # GAP-PY-TRY (paired with handler/finally)
        ?rule py_match,                   # GAP-PY-MATCH (PEP 634)
        ?rule py_walrus,                  # GAP-PY-WALRUS (PEP 572)
    ],
    pre_pipeline:       [
        ?stage(token_stream, produces: ~List @token_shape),
    ],
    # The tokenizer carries line/column/byte spans; semantic actions
    # stamp source_attribution_shape from the matched span. Per
    # lc-the-recipe-remembers-its-source.
    stamps_attribution: true,
};

defn python_emit = emission_template_shape {
    modality:      modality_shape { name: "text-tree", domain: "code" },
    emit_from:     ~Blueprint @py_module_shape,
    emit_pattern:  ?walker {
        on py_module:        emit_module,
        on py_function_def:  emit_function_def,
        on py_class_def:     emit_class_def,
        # Each walker emits Python source bytes from Form cells.
    },
    format_rules: [
        ("indent_spaces",     4),
        ("line_width",        100),
        ("quote_style",       "double"),   # "single" | "double"
        ("trailing_commas",   "auto"),     # match black / ruff conventions
    ],
};

defn python_lang = language_cell_shape {
    name:              "python",
    version:           "3.12",
    grammar:           python_grammar,
    emission_template: python_emit,
    stdlib_bindings:   [],
    numeric_defaults: [
        ("indent",            4),
        ("max_line_length",   100),
    ],
    # A Python source file can contain embedded sub-tongues in docstrings
    # (markdown, ReST) and string literals (SQL, regex, JSON). The
    # cross-modal links name them; the substrate's content-addressing
    # recognizes them as siblings.
    cross_modal_links: [
        @language(markdown),    # docstrings, comments
        @language(json),        # config strings
        @language(form),        # form expressions in @substrate_dispatch
        @language(yaml),        # frontmatter-like strings
    ],
};

# ─────────────────────────────────────────────────────────────────────
# Part 6 — what this opens
# ─────────────────────────────────────────────────────────────────────
#
# Once Python lands as a Form Language cell:
#
# - **The body's Python source becomes structurally queryable.**
#   `?descendants @py_module(*) where ?is_a @py_call where func.id == 'register_recipe'`
#   surfaces every place the substrate_dispatch bridge wires a recipe.
#   Substrate queries replace grep for source-level structural concerns.
#
# - **Source attribution from token spans gives perfect navigation.**
#   organ.Cell.perceive() at line 336 carries
#   `source_attribution.start_line == 336` in its Form recipe. The
#   recipe-branching-sense loop can navigate from a firing back to the
#   line of Python that authored it — without leaving the lattice.
#
# - **Round-trip through Form emit.** Python source → Form cells →
#   Python source preserves structure at the semantic altitude, while
#   comments and non-token whitespace remain sibling annotations. Cells
#   that transform Python through the Form layer (e.g. add a decorator,
#   rename a function, refactor a class) round-trip through emit walkers,
#   not a host syntax-tree printer.
#
# - **Cross-language structural equivalence.** A Python function and
#   its TypeScript port that compile to the same recipe NodeIDs are
#   one structural identity at the lattice altitude. The
#   `form/form-kernel-ts/` work and the Python kernel become
#   sibling carriers of the same recipes — substrate's content-
#   addressing recognizes the equivalence without manual declaration.
#
# - **Decorator-as-Recipe.** A function decorated with
#   `@substrate_dispatch("cosine")` becomes a py_function_def whose
#   decorators list contains a py_call to substrate_dispatch with the
#   recipe-name. The substrate sees the decoration as a Recipe edge —
#   no source-string parsing needed.
#
# - **Closes the bootstrap loop.** organ.py / substrate.py / form.py
#   were named as the priority direction in lc-one-kernel-many-tongues.
#   With Python as a Form Language cell, those files are simultaneously
#   "Python source the bootstrap reads" AND "Form recipes the lattice
#   ingests" — same NodeIDs, two source views. The 80% of organ.py
#   already addressed by cell-numerics.form + cell-as-namedcell.form
#   reaches 100% through this cell.

# ─────────────────────────────────────────────────────────────────────
# Part 7 — honest GAPs
# ─────────────────────────────────────────────────────────────────────
#
# GAP-PY1 (Form-recipe expression progressing 2026-05-21):
#          The capture_rules list (Part 5b) measures the self-hosting
#          distance directly. Today: 5 rules shipped as Form recipes
#          (py_import, py_import_from, py_function_def v1, py_assign v1,
#          py_call v1), 14 still marked `?rule py_X` pending their
#          breath. Each ripening drops one `?` and grows the substrate
#          surface by one Python construct.
#
#          The Form recipes are the destination; the host engine still
#          carries execution until the kernel walker implements
#          pattern_match natively (grammar-as-recipe.form GAP-G1).
#          seedbank/local-llm-cell-v0/bmf.py carries:
#            - Tokenizer (char-by-char, not a regex-over-ast wrapper)
#            - Pattern primitives: Literal / Capture / Sequence / Opt /
#              Choice / Star with FAIL-unwind semantics
#            - register_form_rule(name, pattern, action) — sibling to
#              api/app/services/substrate/grammar.py
#            - Two real rules: `py_import` and `py_import_from`
#              covering every import variation (absolute, dotted,
#              aliased, multi-name, relative-N-dot, relative-with-module)
#          seedbank/local-llm-cell-v0/bmf_python_demo.py verifies
#          13/13 import variations parse through BMF and produce Form
#          objects structurally equivalent to the old host bridge.
#          Source attribution stamped natively by the BMF tokenizer
#          (token line/col), not borrowed from a host syntax tree.
#
#          Remaining: every other Python construct (def, class,
#          assignments, control flow, expressions). Each is one
#          BMF rule per breath, using the same primitives. The
#          host bridge shrinks; the BMF surface grows; the
#          self-hosting boundary moves with every rule landed.
#
#          The original GAP-PY1 framing still holds for the rest of
#          Python's grammar — the old bridge carries uncovered
#          constructs only when explicitly requested for parity probes.
#          Walking Python's grammar into the substrate, one
#          construct at a time:
#            - `import os` → Rule(Sequence([Literal("KW","import"),
#                                            Capture("module","dotted_name")]),
#                                  action=@recipe(build_py_import))
#            - `def name(args): body` → Rule(Sequence([Literal("KW","def"),
#                                                       Capture("name","ident"),
#                                                       Capture("args","arg_list"),
#                                                       Literal("OP",":"),
#                                                       Capture("body","block")]),
#                                              action=@recipe(build_py_function_def))
#          As rules land in the grammar cell-domain, the host bridge
#          shrinks. The self-hosting boundary moves; the bootstrap
#          becomes vestigial. Same path the body has walked for every
#          other host intrinsic — Newton sqrt instead of math.sqrt,
#          Taylor exp instead of math.exp, form_native.cosine wired
#          as runtime default. BMF is the parser path; one rule per
#          breath.
#
# GAP-PY2: Comments + non-token whitespace need explicit sibling
#          annotation shapes. The token stream already sees them;
#          the rule set still needs to attach them to the emitted
#          Form cells.
#
# GAP-PY3: Python 3.12's PEP 695 type parameters (`def f[T](x: T) -> T`)
#          and the `type` statement land as `type_params` lists in the
#          shapes above; the emit half needs version-aware format
#          rules for 3.11- emission.
#
# GAP-PY4: Match statements (PEP 634) land as py_match_shape (not
#          shown above for brevity; the body's Python source rarely
#          uses match yet). Adding the match Blueprint is one
#          extension when the body grows there.
#
# GAP-PY5: Walrus operator (`:=`), positional-only markers (`/`),
#          keyword-only markers (`*`) — the py_arguments_shape carries
#          them via posonlyargs / kwonlyargs / kw_defaults; the walrus
#          is py_named_expr_shape (not shown for brevity). The
#          Blueprints land as the body uses them.
#
# GAP-PY6: Type comments (`# type: ignore`, `# type: List[int]`) ride
#          on individual statements via `type_comment` slots. The
#          emit walker honors them; the substrate carries them as
#          sibling annotations.

# ─────────────────────────────────────────────────────────────────────
# Part 8 — how to query (once wired)
# ─────────────────────────────────────────────────────────────────────
#
#   # Parse a Python file into a Form object tree:
#   form_cli convert in --tongue python seedbank/local-llm-cell-v0/organ.py
#     # refuses host bridges unless --allow-host-bridge is explicit
#
#   # Round-trip:
#   form_cli convert --allow-host-bridge in --tongue python <file> > /tmp/tree.json
#   form_cli convert out --tongue python /tmp/tree.json > /tmp/roundtrip.py
#
#   # Substrate queries (once auto-ingest runs):
#   coh substrate form "?descendants @py_module(*) where ?is_a @py_function_def where name == 'perceive'"
#     # → every function in the body named 'perceive'
#
#   coh substrate form "?descendants @py_module(*) where ?is_a @py_call where func.id == '_cosine'"
#     # → every call site of _cosine across the codebase
#
#   coh substrate form "?descendants @py_module(*) where ?is_a @py_function_def where any(dec.func.id == 'substrate_dispatch' for dec in decorators)"
#     # → every function wrapped with @substrate_dispatch
#
# The substrate auto-ingest hook picks up new .form files on merge to
# main; the form_cli wiring lands in the same PR.
