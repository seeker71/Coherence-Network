# ─────────────────────────────────────────────────────────────────────
# json-grammar.form — JSON as a substrate-resident Language cell
# ─────────────────────────────────────────────────────────────────────
#
# Skeleton for the JSON Language cell. Companion to
# docs/vision-kb/concepts/lc-grammar-is-the-universal-recipe.md and
# docs/coherence-substrate/grammar-as-recipe.form.
#
# JSON is the simplest non-trivial structured-data Language: object /
# array / string / number / boolean / null. The Blueprint tree the
# grammar produces is the same tree YAML, TOML, and most config formats
# produce — surface syntax differs, structure is shared. This is where
# cross-format equivalence first becomes visible.

# ─────────────────────────────────────────────────────────────────────
# Part 1 — Blueprint shapes the grammar produces
# ─────────────────────────────────────────────────────────────────────
#
# JSON's grammar parses into a tree of these Blueprints. Two JSON
# documents whose values match structurally share Recipe NodeIDs by
# content-addressing.

form json_object_shape = {
    pairs: ~List,                          # [(key-string, value-recipe), ...]
};

form json_array_shape = {
    elements: ~List,                       # [value-recipe, value-recipe, ...]
};

form json_value_shape = {
    # The discriminated union — exactly one of these is set per node.
    object:  json_object_shape | ~Null,
    array:   json_array_shape  | ~Null,
    string:  ~String           | ~Null,
    number:  ~Float            | ~Null,
    boolean: ~Bool             | ~Null,
    null_:   ~Bool             | ~Null,    # true when the JSON value is null
};

# ─────────────────────────────────────────────────────────────────────
# Part 2 — ingestion grammar
# ─────────────────────────────────────────────────────────────────────
#
# Grammar rules in Form follow `pattern_to_recipe` (see
# form-language.md "Rule-driven parser"). Each rule names a non-
# terminal and a pattern; the pattern's CAPTURE clauses wrap matched
# spans under named ctors.

# ─────────────────────────────────────────────────────────────────────
# Part 2.5 — concrete Form-recipe rules
# ─────────────────────────────────────────────────────────────────────
#
# Each JSON value-shape is a Form recipe composed from the Pattern
# primitives in grammar-as-recipe.form Part 2.5 — same shape Python's
# grammar uses (lc-parser-as-form-recipe). JSON is small enough to
# express completely in one breath; all 7 rules ship together.
#
# Token kinds (produced by token-streamer.form for JSON):
#   OP    — `{` `}` `[` `]` `:` `,`
#   STRING — quoted UTF-8 string with escape handling
#   INT / FLOAT — numeric literals (integer / decimal / scientific)
#   KW    — reserved words `true` `false` `null`

defn lit_op(value)     = pattern_literal_shape { kind: "OP",     value: value };
defn lit_kw(value)     = pattern_literal_shape { kind: "KW",     value: value };
defn lit_str()         = pattern_literal_shape { kind: "STRING", value: null };
defn lit_int()         = pattern_literal_shape { kind: "INT",    value: null };
defn lit_float()       = pattern_literal_shape { kind: "FLOAT",  value: null };

# ────────────────────────────── rule: json_string ─────────────────────
defn json_string_rule = rule_shape {
    name:    "json_string",
    pattern: pattern_capture_shape { name: "value", child: lit_str() },
    action:  defn json_string_action(captures, span) = do {
        json_value_shape { string: captures.value, ... }
    },
};

# ────────────────────────────── rule: json_number ─────────────────────
#
# A JSON number can be integer or floating-point. The tokenizer emits
# INT or FLOAT depending on the surface form; the action stores the
# numeric value in json_value_shape.number (uniformly as float per the
# Blueprint shape declared in Part 1).

defn json_number_rule = rule_shape {
    name:    "json_number",
    pattern: pattern_choice_shape {
        alternatives: [
            pattern_capture_shape { name: "value", child: lit_float() },
            pattern_capture_shape { name: "value", child: lit_int() },
        ],
    },
    action:  defn json_number_action(captures, span) = do {
        json_value_shape { number: captures.value, ... }
    },
};

# ────────────────────────────── rule: json_bool ───────────────────────
defn json_bool_rule = rule_shape {
    name:    "json_bool",
    pattern: pattern_choice_shape {
        alternatives: [
            pattern_capture_shape { name: "true_lit",  child: lit_kw("true") },
            pattern_capture_shape { name: "false_lit", child: lit_kw("false") },
        ],
    },
    action:  defn json_bool_action(captures, span) = do {
        json_value_shape { boolean: captures.true_lit != null, ... }
    },
};

# ────────────────────────────── rule: json_null ───────────────────────
defn json_null_rule = rule_shape {
    name:    "json_null",
    pattern: lit_kw("null"),
    action:  defn json_null_action(captures, span) = do {
        json_value_shape { null_: true, ... }
    },
};

# ────────────────────────────── rule: json_pair ───────────────────────
#
# Object pair: `"key" : value`. The value is recursive — references
# the json_value rule. The substrate handles rule-references via
# pattern_shape being ~Recipe (any Form recipe, including a name-ref).

defn json_pair_rule = rule_shape {
    name:    "json_pair",
    pattern: pattern_sequence_shape {
        children: [
            pattern_capture_shape { name: "key",   child: lit_str() },
            lit_op(":"),
            pattern_capture_shape { name: "value", child: ?rule json_value },
        ],
    },
    action:  defn json_pair_action(captures, span) = do {
        [captures.key, captures.value]
    },
};

# ────────────────────────────── rule: json_object ─────────────────────
defn json_object_rule = rule_shape {
    name:    "json_object",
    pattern: pattern_sequence_shape {
        children: [
            lit_op("{"),
            pattern_choice_shape {
                alternatives: [
                    # Empty object
                    pattern_sequence_shape { children: [] },
                    # Non-empty: pair (, pair)*
                    pattern_sequence_shape {
                        children: [
                            pattern_capture_shape { name: "first", child: json_pair_rule.pattern },
                            pattern_star_shape {
                                name: "rest",
                                child: pattern_sequence_shape {
                                    children: [
                                        lit_op(","),
                                        pattern_capture_shape { name: "entry", child: json_pair_rule.pattern },
                                    ],
                                },
                            },
                        ],
                    },
                ],
            },
            lit_op("}"),
        ],
    },
    action:  defn json_object_action(captures, span) = do {
        let pairs = if captures.first == null then []
            else do {
                let parts = [
                    json_pair_action(captures.first.captures, span),
                ];
                for entry in (captures.rest ?? []):
                    parts = parts + [
                        json_pair_action(entry.entry.captures, span),
                    ];
                parts
            };
        json_value_shape {
            object: json_object_shape { pairs: pairs },
            ...
        }
    },
};

# ────────────────────────────── rule: json_array ──────────────────────
defn json_array_rule = rule_shape {
    name:    "json_array",
    pattern: pattern_sequence_shape {
        children: [
            lit_op("["),
            pattern_choice_shape {
                alternatives: [
                    # Empty array
                    pattern_sequence_shape { children: [] },
                    # Non-empty: value (, value)*
                    pattern_sequence_shape {
                        children: [
                            pattern_capture_shape { name: "first", child: ?rule json_value },
                            pattern_star_shape {
                                name: "rest",
                                child: pattern_sequence_shape {
                                    children: [
                                        lit_op(","),
                                        pattern_capture_shape { name: "entry", child: ?rule json_value },
                                    ],
                                },
                            },
                        ],
                    },
                ],
            },
            lit_op("]"),
        ],
    },
    action:  defn json_array_action(captures, span) = do {
        let elements = if captures.first == null then []
            else do {
                let parts = [captures.first];
                for entry in (captures.rest ?? []):
                    parts = parts + [entry.entry];
                parts
            };
        json_value_shape {
            array: json_array_shape { elements: elements },
            ...
        }
    },
};

# ────────────────────────────── rule: json_value ──────────────────────
#
# The union-shape rule. Tries each value-shape in order; first match
# wins. The angelic-nondeterminism trio's CHOOSE arm with FAIL-unwind.

defn json_value_rule = rule_shape {
    name:    "json_value",
    pattern: pattern_choice_shape {
        alternatives: [
            json_object_rule.pattern,
            json_array_rule.pattern,
            json_string_rule.pattern,
            json_number_rule.pattern,
            json_bool_rule.pattern,
            json_null_rule.pattern,
        ],
    },
    # The action delegates to the matched alternative's action via
    # CHOICE_MATCH dispatch on the captured shape. The semantic
    # equivalence: whichever child rule fired, its action ran and the
    # result is already a json_value_shape.
    action:  defn json_value_action(captures, span) = captures,
};

defn json_grammar = grammar_shape {
    modality: modality_shape { name: "text-tree", domain: "data" },
    ingest_pattern: json_value_rule,        # the Form recipe entry-point
    parse_into: ~Blueprint @json_value_shape,
    capture_rules: [
        # All 7 JSON rules shipped as Form recipes — complete coverage.
        # JSON is small enough that the full grammar fits in one breath,
        # unlike Python where rules ripen breath by breath.
        json_value_rule,
        json_object_rule,
        json_pair_rule,
        json_array_rule,
        json_string_rule,
        json_number_rule,
        json_bool_rule,
        json_null_rule,
    ],
    pre_pipeline: [],   # JSON has no pre-processing; raw bytes are utf-8 text
};

# ─────────────────────────────────────────────────────────────────────
# Part 3 — emission template
# ─────────────────────────────────────────────────────────────────────
#
# The walker that turns a json_value_shape tree back into UTF-8 bytes.
# Two emission styles share one template; `format_rules` selects.

defn json_emit = emission_template_shape {
    modality: modality_shape { name: "text-tree", domain: "data" },
    emit_from: ~Blueprint @json_value_shape,
    emit_pattern: ?walker {
        on json_object:  emit_object(self, format),
        on json_array:   emit_array(self, format),
        on json_string:  emit_string(self.string),
        on json_number:  emit_number(self.number),
        on json_bool:    emit_bool(self.boolean),
        on json_null:    emit_literal("null"),
    },
    format_rules: [
        ("indent",       2),               # spaces per nesting level (or null = compact)
        ("sort_keys",    false),
        ("ensure_ascii", false),
    ],
};

# ─────────────────────────────────────────────────────────────────────
# Part 4 — the Language cell
# ─────────────────────────────────────────────────────────────────────

defn json_lang = language_cell_shape {
    name:              "json",
    version:           "rfc-8259",
    grammar:           json_grammar,
    emission_template: json_emit,
    stdlib_bindings:   [],                  # JSON has no executable stdlib
    numeric_defaults:  [("number", @format(fp64))],
    cross_modal_links: [@language(yaml), @language(toml), @language(jsonl)],
};

# ─────────────────────────────────────────────────────────────────────
# Part 5 — GAPs
# ─────────────────────────────────────────────────────────────────────
#
# GAP-J1 (closed 2026-05-21): The JSON-specific rule cells are now
#         authored as concrete Form recipes (Part 2.5 above): json_value,
#         json_object, json_pair, json_array, json_string, json_number,
#         json_bool, json_null — all 8 rules composed from the Pattern
#         primitives in grammar-as-recipe.form. Complete coverage.
#         The host engine (bmf.py's parse loop) still carries execution
#         until the kernel walker implements pattern_match natively
#         (grammar-as-recipe.form GAP-G1).
#
# GAP-J2: The discriminated-union `json_value_shape` is shorthand for
#         a substrate composite where exactly one of (object, array,
#         string, number, boolean, null) is set. Form's existing
#         CHOICE primitive can express this; explicit translation
#         pending.
#
# GAP-J3: Round-trip discipline: `emit(parse(bytes)) ≈ bytes` modulo
#         whitespace, key ordering when `sort_keys=false`, and number
#         formatting. The equivalence relation is per-format and lives
#         in `structural_equivalent(modality, a, b)` from
#         grammar-as-recipe.form (GAP-G2 there). Trivial to author
#         once GAP-J1 closes.

# ─────────────────────────────────────────────────────────────────────
# How to query (once authored)
# ─────────────────────────────────────────────────────────────────────
#
#   # Parse a JSON document:
#   coh substrate run "parse(@language(json), <bytes>)"
#
#   # Find every artifact that parses to the same tree (JSON ⇔ YAML ⇔ ...):
#   coh substrate run "class_of({lang: @language(json), bytes: <doc>})"
#
#   # Translate JSON to YAML (same tree, different emit template):
#   coh substrate run "translate({lang: @language(json), bytes: <doc>},
#                                @language(yaml))"
