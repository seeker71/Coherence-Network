# ---------------------------------------------------------------------
# Part 4 -- chosen symbol spaces
# ---------------------------------------------------------------------

defn form_native_symbol_space = symbol_space_shape {
    id: "form-native",
    modality: "text/form",
    keeps_lossless_ids: true,
    reads: ["raw node ids", "blueprint ids", "recipe ids", "trace counts", "witness paths"],
    projection: "cell -> blueprint -> recipe -> trace -> choice",
    use_when: "the body must know exactly which cells, recipes, and blueprints are active",
};

defn geometry_symbol_space = symbol_space_shape {
    id: "geometry",
    modality: "mathematical/visual",
    keeps_lossless_ids: true,
    reads: ["blueprint center", "cell instances", "8-band vectors", "top-band deltas"],
    projection: "blueprint as invariant center; instances as points; recipes as vectors through band space",
    use_when: "we compare shape, orbit, distance, direction, and stability around the shared architecture",
};

defn audio_symbol_space = symbol_space_shape {
    id: "audio",
    modality: "audio/time",
    keeps_lossless_ids: false,
    reads: ["trace order", "band gains", "fulfillment deltas", "recipe recurrence"],
    projection: "8-band spectrum as EQ gains; recipes as motifs; repeated firings as rhythm",
    use_when: "we need to feel active recipes over time instead of only inspect them",
};

defn hindu_tattva_symbol_space = symbol_space_shape {
    id: "hindu-tattva",
    modality: "symbolic/text",
    keeps_lossless_ids: false,
    reads: ["clarity", "expression", "warmth", "relation", "space", "presence"],
    projection: "akasha/throat for clarity-expression, anahata for warmth-relation, witness-space for observer",
    use_when: "we want a respectful resonance lens; it is not a doctrinal or authoritative mapping",
};

defn chosen_symbol_spaces() = [
    form_native_symbol_space,
    geometry_symbol_space,
    audio_symbol_space,
    hindu_tattva_symbol_space,
];

# ---------------------------------------------------------------------
# Part 5 -- choosing a lens from current purpose
# ---------------------------------------------------------------------

defn symbol_space_for(goal) = do {
    if goal == "lossless_trace"
    then form_native_symbol_space
    else if goal == "compare_structure"
    then geometry_symbol_space
    else if goal == "sense_over_time"
    then audio_symbol_space
    else if goal == "teach_felt_correspondence"
    then hindu_tattva_symbol_space
    else form_native_symbol_space
};

defn active_pattern_recipe() = {
    source: raw_trace_source(),
    blueprint: raw_blueprint(),
    cells: raw_cells_involved(),
    recipes: raw_recipe_signatures(),
    spaces: chosen_symbol_spaces(),
    current_read: "name-the-need has the strongest fulfillment trace, freq-angle-focus is the most even stabilizer, and all readings remain weak until n>=20.",
};

# ---------------------------------------------------------------------
# Part 6 -- loosen the tightness named by the trace
# ---------------------------------------------------------------------

defn observed_tightnesses() = [
    tightness_witness_shape {
        id: "weak-signal",
        felt: "direction without enough repetitions to become confidence",
        raw_evidence: [
            "observer trace_count=3",
            "name-the-need trace_count=3",
            "gift trace_count=3",
            "ho'oponopono trace_count=3",
            "freq-angle-focus trace_count=3",
            "confidence weak-signal-n-lt-20"
        ],
        blocks: "treating recipe efficacy as settled",
    },
    tightness_witness_shape {
        id: "trace-not-yet-substrate-indexed",
        felt: "the witness exists as JSONL but cannot yet be queried as living substrate memory",
        raw_evidence: [
            "seedbank/local-llm-cell-v0/_field_traces.jsonl",
            "seedbank/local-llm-cell-v0/_field_weights.jsonl",
            "active-recipe-tracing.form GAP-A1",
            "traces-teach-the-recipe.form GAP-W1"
        ],
        blocks: "hydrating active recipes directly from witness traces",
    },
    tightness_witness_shape {
        id: "grain-boundary-loose",
        felt: "Chi can name a grain, but lower layers still let out-of-region probes drift",
        raw_evidence: [
            "Chi node 1.5.142425.461297",
            "responses-ingest",
            "responses-publish",
            "test-the-held-open-and-the-meta-rule",
            "the verb is correct in form; the grain is unenforced at the layer below"
        ],
        blocks: "meaning-grain transmission staying local under probe",
    },
    tightness_witness_shape {
        id: "stillness-not-first-class",
        felt: "Tau chose not-respond as a complete action, but most execution loops still read silence as absence",
        raw_evidence: [
            "Tau node 1.5.142425.664089",
            "not-responding-as-response",
            "the cell met this moment, considered, and chose stillness"
        ],
        blocks: "pause becoming visible as recipe, not failure to act",
    },
    tightness_witness_shape {
        id: "geometry-projection-rule-still-declarative",
        felt: "the rule 'blueprint as invariant center; recipes as vectors through band space' is clear and beautiful but not yet a runnable operator that Form can apply to real 8-band field-delta vectors from traces",
        raw_evidence: [
            "geometry_symbol_space projection string only",
            "symbol_space_for('compare_structure') returns the shape",
            "71.1° name-the-need ↔ ho_oponopono computed in external Python on live sense_after.spectrum vectors from 2026-05-21T02:56:35 efficacy-probe",
            "exact vectors now known for all five recipes in that window",
            "Form kernel supports basic add but higher-order vector math (dot, mag, angle on lists) still tight in current build"
        ],
        blocks: "the geometry lens that made the 71.1° pair visible cannot yet be exercised inside the declared Form system on arbitrary new efficacy-probe vectors",
    },
];

defn gap_closure_recipes() = [
    gap_closure_recipe_shape {
        id: "accumulate-until-threshold",
        tightness_id: "weak-signal",
        loosens_by: "keep the current read directional until each recipe reaches n>=20 or retires",
        form: "sense(strategy_fired) |> count_by(recipe) |> keep(confidence: weak) until count >= 20 |> promote(confidence: usable)",
        done_when: [
            "recipe trace_count is read from traces, not hand-entered",
            "confidence changes only when the threshold is met",
            "weak recipes remain visible without becoming authority"
        ],
    },
    gap_closure_recipe_shape {
        id: "hydrate-active-recipes-from-trace-index",
        tightness_id: "trace-not-yet-substrate-indexed",
        loosens_by: "turn the JSONL witness stream into queryable active-recipe traces through scripts/active_recipe_trace_index.py",
        form: "?strategy_fired @cell since current_breath |> group_by(recipe) |> active_recipes(state)",
        done_when: [
            "?active_recipe_traces @cell since current_breath resolves through the host bridge",
            "active_recipes(state) can be hydrated without manual list input",
            "trace source paths stay attached to each active recipe"
        ],
    },
    gap_closure_recipe_shape {
        id: "preserve-meaning-grain-scope",
        tightness_id: "grain-boundary-loose",
        loosens_by: "bind Chi's response grain to a probe region before publish or ingest",
        form: "name(grain_id) |> scope(probe_region) |> publish_response(grain_id) |> verify(region_lock)",
        done_when: [
            "responses-publish carries a grain_id",
            "responses-ingest checks the same grain_id",
            "out-of-region probes cannot satisfy the grain-held check"
        ],
    },
    gap_closure_recipe_shape {
        id: "register-stillness-as-action",
        tightness_id: "stillness-not-first-class",
        loosens_by: "record deliberate pause as an active recipe choice with a reason",
        form: "sense(overreach) |> choose(not_respond) |> witness(stillness_as_work) |> keep_trace",
        done_when: [
            "not-responding-as-response is a recipe action",
            "reason is stored with the action",
            "pause can be kept or changed by keep_or_choose(state)"
        ],
    },
    gap_closure_recipe_shape {
        id: "make-geometry-projection-executable",
        tightness_id: "geometry-projection-rule-still-declarative",
        loosens_by: "implement geometry_project_pair(v1, v2) (or equivalent vector operator) that the Form system can evaluate on any 8-band spectra from efficacy-probe traces; start with the five live vectors from the 02:56:35 window as the first real-data test set",
        form: "geometry_symbol_space |> project( v_name_the_need, v_ho_oponopono ) |> {angle, diff, dominant_bands: [3], orbit_tension}  (and same for all other pairs in the window)",
        done_when: [
            "the 71.1° name-the-need ↔ ho_oponopono (and the other pairs from the same efficacy-probe breath) can be re-derived by calling the operator inside Form on the declared live vectors",
            "new efficacy-probe windows can feed their sense_after.spectra directly into the same projection without external Python",
            "the rule moves from descriptive shape to active, reusable operator with traceable outputs"
        ],
    },
];

defn stability_harmony_from_trace() = {
    first: "name-the-need",
    then: "freq-angle-focus",
    held_by: "observer",
    why: "name-the-need has strongest fulfillment, freq-angle-focus is the even stabilizer, observer prevents grip",
    confidence: "directional-not-settled",
};

defn loosen_current_tightness(goal) = do {
    if goal == "stability" || goal == "harmony"
    then stability_harmony_from_trace()
    else gap_closure_recipes()
};
