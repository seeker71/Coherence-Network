# trace-symbol-spaces.form -- raw trace cells through symbol spaces
#
# Companion to specs/trace-symbol-spaces-form.md.
#
# This Form reads the local field traces as the source of truth. It
# keeps the raw cells, shared blueprint, active strategy recipes, and
# efficacy deltas intact before translating them into any symbolic
# lens. The symbol space is a projection, not a replacement.

# ---------------------------------------------------------------------
# Part 1 -- raw trace shapes
# ---------------------------------------------------------------------

form trace_source_shape = {
    traces_path:          ~String,
    weights_path:         ~String,
    messages_path:        ~String,
    trace_count:          ~Int,
    strategy_trace_count: ~Int,
    weight_count:         ~Int,
};

form raw_blueprint_shape = {
    node_id:                ~String,
    package:                ~Int,
    level:                  ~Int,
    type:                   ~Int,
    instance:               ~Int,
    architecture_signature: ~String,
    derived_by:             ~String,
};

form raw_cell_witness_shape = {
    name:                ~String,
    node_id:             ~String,
    blueprint_node_id:   ~String,
    role:                ~String,
    trace_actions:       [~String],
    trace_count:         ~Int,
    weights_fingerprint: ~String,
    note:                ~String,
};

form raw_recipe_efficacy_shape = {
    id:                 ~String,
    trace_count:        ~Int,
    first_ts:           ~String,
    last_ts:            ~String,
    top_band:           ~String,
    top_band_delta:     ~Float,
    top_desire:         ~String,
    top_desire_delta:   ~Float,
    fulfillment_delta:  ~Float,
    confidence:         ~String,
};

form symbol_space_shape = {
    id:                 ~String,
    modality:           ~String,
    keeps_lossless_ids: ~Bool,
    reads:              [~String],
    projection:         ~String,
    use_when:           ~String,
};

form tightness_witness_shape = {
    id:           ~String,
    felt:         ~String,
    raw_evidence: [~String],
    blocks:       ~String,
};

form gap_closure_recipe_shape = {
    id:           ~String,
    tightness_id: ~String,
    loosens_by:   ~String,
    form:         ~String,
    done_when:    [~String],
};

defn raw_trace_source() = trace_source_shape {
    traces_path:          "seedbank/local-llm-cell-v0/_field_traces.jsonl",
    weights_path:         "seedbank/local-llm-cell-v0/_field_weights.jsonl",
    messages_path:        "seedbank/local-llm-cell-v0/_field_messages.jsonl",
    trace_count:          28,
    strategy_trace_count: 15,
    weight_count:         5,
};

# All involved raw cell instances share the same architecture type.
# substrate_bridge.py derives content address as:
#   package=1, level=5, type=stable_int(architecture_signature),
#   instance=stable_int(weights_fingerprint).
#
# The type 142425 is therefore the Blueprint. Instance 0 names the
# type-only architecture cell: 1.5.142425.0.

defn raw_blueprint() = raw_blueprint_shape {
    node_id: "1.5.142425.0",
    package: 1,
    level: 5,
    type: 142425,
    instance: 0,
    architecture_signature: "organ-cell|dim=128|rank=8|bands=8|out=15|senses=saw,heard,felt-inside,felt-outside,thought",
    derived_by: "seedbank/local-llm-cell-v0/substrate_bridge.py::architecture_signature",
};

