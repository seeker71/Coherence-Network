# hati-mesh.form - organ identity, presence, and communication channels

(hati-mesh
  (lineage
    (rests-on tool-channel.form channel-interface-consent.form kernel-offer-protocol.form hati-os-targets.form)
    (recipe form/form-stdlib/hati-mesh.fk)
    (proof form/form-stdlib/tests/hati-mesh-band.fk -> 255)
    (api api/app/routers/hati_mesh.py)
    (android experiments/coherence-sense-android))

  (purpose
    "A phone, Mac binary, agent, camera, microphone, speaker, screen, or hardware device can identify itself as a sensing/acting organ in hati.mesh."
    "The organ announces who it is, which steward/cell it serves, which capabilities it offers, and which communication channels are open or offered.")

  (floor
    "The public API accepts organ announcements, organ heartbeats, and channel offers, records runtime receipts, and lists recent organs/channels."
    "The Android app now creates a stable install-scoped organ id, can explicitly bind a user-entered cell/email label, announces to the public API, heartbeats while listening, polls for other mesh organs, offers a sensor channel, and displays local sensor flow rates plus recent channel rows.")

  (north-star
    "Each organ carries a signed self-sovereign identity, explicit steward/cell relation, revocable capabilities, nearby-cell discovery, negotiated offer/ack interfaces, typed media codecs, and measured information flow rates.")
    "Screen, mic, speaker, camera, sensors, agents, host binaries, and local hardware all communicate through the same offer-channel surface instead of app-specific hidden links.")

  (identity
    (organ-id stable-install-or-device-cell-id)
    (organ-kind android-phone macos-binary camera microphone speaker agent hardware-device)
    (steward-cell-id unbound-or-cell-ref)
    (floor stable-install-id)
    (human-binding explicit-user-entered-cell-or-email-label)
    (no-silent-phone-or-email-extraction)
    (north-star signed-self-sovereign-organ-id-with-revocable-cell-binding))

  (capabilities
    (cap.mesh.presence hati.mesh:presence json)
    (cap.sensor.read sensor:signal json)
    (cap.video.frame video:rgba-time rgba/video)
    (cap.audio.sample audio:pcm16 pcm16)
    (cap.screen.write screen:write native-ui)
    (cap.compute.gpu gpu:compute tensor/buffer)
    (cap.compute.dsp dsp:signal signal-buffer)
    (cap.compute.mlx mlx:array mlx-array))

  (resource-dashboard
    (floor "active samples are displayed separately from offered/not-granted/unavailable lanes")
    (north-star "all OS host resources become signed typed channel receipts with pressure, codec, permission, and flow-rate metadata")
    (lanes
      (motion sensor:signal "accelerometer/gyroscope samples")
      (gps sensor:signal "permission state and last-known location when granted")
      (mic audio:pcm16 "permission state, offered-not-sampling")
      (speaker audio:pcm16 "offered output channel")
      (camera video:rgba-time "permission state, offered-not-sampling")
      (screen screen:write "dashboard plus QR identity offer")
      (disk host:usage "StatFs free/total sample")
      (network host:usage "TrafficStats byte counters")
      (cpu host:usage "processor-count floor")
      (ram host:usage "Runtime memory sample")
      (gpu gpu:compute "cataloged-no-active-sample")
      (dsp dsp:signal "cataloged-no-active-sample")
      (mlx mlx:array "cataloged-no-active-sample; unsupported on Android")
      (inner-cells kernel:call "created/updated/freed app counters")))

  (accelerator-awareness
    (floor "GPU, DSP, and MLX/equivalent lanes are visible on the mesh surface even before active compute samples exist")
    (macos "GPU=Metal floor; DSP=Accelerate/AudioToolbox signal floor; MLX=MLX+Metal target row")
    (android "GPU=Vulkan/OpenGL ES floor; DSP/NPU=NNAPI/vendor delegate floor; MLX=explicit unsupported row with Android equivalent routed to GPU/NNAPI")
    (north-star "accelerator lanes carry native dispatch receipts, pressure counters, input/output codec hashes, and refusal data when unavailable"))

  (channel-offers
    (shape from-organ to-organ protocol interface capability codec status sample-rate-hz bytes-per-second)
    (statuses offered accepted open paused closed refused)
    (interfaces offer:observe-sensor-field offer:listen-speak offer:see-be-seen offer:show-channel-state))

  (heartbeat
    (route POST-/api/hati/mesh/organs/heartbeat)
    (shape organ-id listening active-channels sample-rate-hz bytes-per-second)
    (listening-window fresh-runtime-events)
    (purpose "cells can see who is currently listening, coming, going, and what information is flowing"))

  (android-floor
    (identity stable-install-id)
    (presence POST-/api/hati/mesh/organs/announce)
    (heartbeat POST-/api/hati/mesh/organs/heartbeat)
    (nearby-discovery GET-/api/hati/mesh/organs)
    (channel-offer POST-/api/hati/mesh/channels/offer)
    (channel-list GET-/api/hati/mesh/channels)
    (active-flow sensor:signal)
    (offerable-flow screen:write audio:pcm16 video:rgba-time)
    (visualization identity-receipt channel-list sensor-samples-per-second bytes-per-second)
    (dashboard gps motion mic camera disk network cpu ram gpu dsp mlx inner-cells qr-offer)
    (install-signing-floor "release APK is signed by the Hati mesh app key and verified before publish")
    (install-signing-north-star "same identity key also signs mesh announcements, channel offers, sensor receipts, and update manifests")
    (public-asset https://hati.earth/downloads/hati-os/android/arm64/coherence-sense-hati-mesh-release.apk))

  (visual-release-review
    (floor "macOS/web and Android app/service changes are checked with actual screenshots before release")
    (reviewers self sister-agent)
    (cadence "before release; no more often than every couple of hours unless actively refining the same app surface")
    (north-star "screenshot, accessibility, flow-rate, and reviewer receipts are first-class release evidence"))

  (missing-physical-samples
    (audio:pcm16 "permissioned mic capture and speaker playback samples from the Android app")
    (video:rgba-time "permissioned camera frame samples from the Android app")
    (nearby-local-discovery "LAN/Bluetooth/Nearby discovery receipts, beyond public mesh recent-presence polling")
    (signed-identity "public-key signature verification over announcements and channel offers")
    (accelerator-dispatch "GPU, DSP/NPU, and MLX/equivalent active compute sample receipts from real devices")
    (visual-review-automation "automated screenshot and sister-review receipts wired into the release gate")
    (channel-ack "accepted/open/refused acknowledgements from the receiving organ")))
