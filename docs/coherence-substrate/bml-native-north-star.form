# bml-native-north-star.form - BML/BMF/Form native compiler orientation

(bml-native-compiler
  (north-star
    (sentence "The original BML, BMF, and Form compiler sources compile themselves into versioned .fkb images and Hati fourth-kernel native binaries.")
    (must-carry full-class-support full-template-support full-generic-support method-dispatch state exception-and-backtracking typed-values physical-lanes clang-target-assembly form-native-jit-runtime lowered-jit-residual-tags value-native-jit-span clang-oracle-sampling oracle-learning-choice gpu-kernel-emission ml-kernel-emission)
    (artifact-contract source -> compiler-image -> loadable-table -> native-binary -> target-assembly -> oracle-sample -> form-native-jit-bytes -> lowered-jit-table -> value-native-jit-table -> measured-native-choice -> measured-run)
    (proof-shape same-source-same-image same-table-same-value stdout-stderr-timing binary-size loadable-artifact-roundtrip clang-target-assembly target-object-format form-native-byte-conviction lowered-jit-four-way value-native-jit-four-way oracle-learning-choice))

  (floor
    (sentence "A native compiler claim is allowed only when the supported subset emits a loadable Hati table with parity proof, target assembly receipts exist for the supported metal planes, third-party compilers/drivers/models are treated as oracle/sample sources, Form-native JIT runtime rows, lowered residual JIT rows, value-native JIT span rows, and measured oracle-learning choice samples run four-way on fkwu for the supported lanes, and unsupported BML shapes are named before table emission.")
    (no-silent-zero unsupported-lowering-must-not-be-a-valid-table)
    (current-supported int float string char add const lexical-const-binding bound-name-return bound-name-add return method-body one-argument-method-parameter known-method-call block-sequence simple-choose/fail table-image string-stdout clang-target-assembly clang-oracle-samples form-native-jit-runtime lowered-jit-tags-70-79 value-native-jit-tags-81-86 jit-logic-lower jit-folded-literal jit-unbox-carrier jit-closure-lift jit-bmf-output-lower jit-lowered-emit jit-value-native-span oracle-learning-choice gpu-kernel-emitter ml-kernel-emitter macos-arm64 android-arm64)
    (current-unsupported class interface field package import unresolved-names mutable-locals arrays general-calls overload-resolution multi-argument-methods break continue try throw while standalone-fail cut save restore discard android-runtime-clang-required-for-jit))

  (next-step
    (sentence "Close one missing semantic family at a time with a source-level proof and native binary probe.")
    (walked-now unsupported-lowering-audit lexical-const-and-bound-name-lowering macos/android-clang-assembly-proof form-native-jit-lane-proof lowered-jit-residual-proof value-native-jit-span-proof gpu/ml-kernel-emitter-proof oracle-learning-choice-floor one-argument-method-parameter-and-known-call-lowering)
    (next-semantic-candidate field-access-and-class-method-scope)
    (why "bound names and one-argument known calls give method bodies a real floor; target assembly receipts keep the metal-plane claim honest; Form-native JIT rows, the lowered residual cluster, and the Value-ABI float/vector/string-name/JIT-offer span now run through the fourth arm so Android is not coupled to a clang runtime dependency; a clang-like compiler binary may ship inside the Android APK as an optional oracle/accelerator, but the minimum supported Android JIT floor is the Form-native lowered recipe/table path; oracle-learning choice samples let native recipes earn runtime selection without losing the third-party teacher; field access and class method scope are the next gate before templates and generics can become native without pretending the whole model is solved at once")))
