# bml-native-north-star.form - BML/BMF/Form native compiler orientation

(bml-native-compiler
  (north-star
    (sentence "The original BML, BMF, and Form compiler sources compile themselves into versioned .fkb images and Hati fourth-kernel native binaries.")
    (must-carry full-class-support full-template-support full-generic-support method-dispatch state exception-and-backtracking typed-values physical-lanes)
    (artifact-contract source -> compiler-image -> loadable-table -> native-binary -> measured-run)
    (proof-shape same-source-same-image same-table-same-value stdout-stderr-timing binary-size loadable-artifact-roundtrip))

  (floor
    (sentence "A native compiler claim is allowed only when the supported subset emits a loadable Hati table with parity proof, and unsupported BML shapes are named before table emission.")
    (no-silent-zero unsupported-lowering-must-not-be-a-valid-table)
    (current-supported int float string char add const return method-body block-sequence simple-choose/fail table-image string-stdout)
    (current-unsupported class interface field package import names locals arrays calls break continue try throw while standalone-fail cut save restore discard))

  (next-step
    (sentence "Make unsupported BML-to-Hati lowering observable, then close one missing semantic family at a time with a source-level proof and native binary probe.")
    (walked-now unsupported-lowering-audit)
    (next-semantic-candidate locals-and-name-binding)
    (why "locals and names unlock method bodies, calls, fields, classes, templates, and generics without pretending the whole model is native at once")))
