# spec-registry-router.form -- spec_registry.py as high-level route recipes
#
# Companion to api/app/routers/spec_registry.py and
# specs/spec-registry-source-native.md. The public FastAPI routes still carry
# live mutable transport; Form now carries the source-backed read route and the
# graph-node mutation carrier that create/update/delete will use when the live
# front door moves.

form spec_route_shape = {
    name:             ~String,
    method:           ~String,
    path:             ~String,
    movement:         ~String,
    carrier:          ~String,
    service_recipe:   ~String,
    response_shape:   ~String,
    evidence:         [~String],
};

form spec_route_recipe_shape = {
    family:           ~String,
    intent:           ~String,
    routes:           [spec_route_shape],
    route_trace:      [~String],
    proof:            [~String],
};

defn spec_route(name, method, path, movement, service_recipe, response_shape, evidence) =
    spec_route_shape {
        name:           name,
        method:         method,
        path:           path,
        movement:       movement,
        carrier:        "api/app/routers/spec_registry.py",
        service_recipe: service_recipe,
        response_shape: response_shape,
        evidence:       evidence,
    };

defn spec_route_recipe(family, intent, routes, route_trace, proof) =
    spec_route_recipe_shape {
        family:      family,
        intent:      intent,
        routes:      routes,
        route_trace: route_trace,
        proof:       proof,
    };

defn browse_specs_recipe() = spec_route_recipe(
    "browse",
    "Read specs as source-backed rows or graph-backed registry entries.",
    [
        spec_route("list_specs", "GET", "/spec-registry", "browse live specs", "spec_registry_service.list_specs", "list[SpecRegistryEntry]", ["graph node type=spec"]),
        spec_route("list_spec_cards", "GET", "/spec-registry/cards", "browse spec cards", "spec_registry_service.build_spec_cards_feed", "dict", ["inventory cards"]),
        spec_route("get_spec", "GET", "/spec-registry/{spec_id}", "inspect spec", "spec_registry_service.get_spec", "SpecRegistryEntry", ["graph node id lookup"]),
        spec_route("source_list_specs", "GET", "/spec-registry/source-list", "browse source specs", "route_specs_source_list", "list[SpecRegistryEntry]", ["specs/INDEX.md"]),
    ],
    ["read query filters", "resolve graph/source carrier", "project optional language view", "return spec entries"],
    ["api/app/routers/spec_registry.py::list_specs", "deploy/kernel-router/production-routes.fk::route_specs_source_list"]
);

defn mutate_specs_recipe() = spec_route_recipe(
    "mutate",
    "Create, replace, or delete spec graph nodes while preserving source and workspace fields.",
    [
        spec_route("create_spec", "POST", "/spec-registry", "create spec", "spec_registry_service.create_spec + gn-create-node", "SpecRegistryEntry", ["workspace validation", "graph node type=spec"]),
        spec_route("update_spec", "PATCH", "/spec-registry/{spec_id}", "update spec", "spec_registry_service.update_spec + gn-replace-node", "SpecRegistryEntry", ["field allow-list", "graph node revision"]),
        spec_route("delete_spec", "DELETE", "/spec-registry/{spec_id}", "delete spec", "spec_registry_service.delete_spec + gn-delete-node", "204", ["API key", "edge cleanup boundary"]),
    ],
    ["validate request", "shape graph-node mutation", "emit header-gated native SQL preview when invited", "call live service carrier until execution parity lands", "return entry or exact not-found/duplicate result"],
    ["api/app/routers/spec_registry.py::create_spec", "api/app/routers/spec_registry.py::update_spec", "api/app/routers/spec_registry.py::delete_spec", "form/form-stdlib/graph-node-port.fk::gn-create-node", "form/form-stdlib/graph-node-port.fk::gn-replace-node", "form/form-stdlib/graph-node-port.fk::gn-delete-node", "deploy/kernel-router/production-routes.fk::route_specs_create_native_preview", "deploy/kernel-router/production-routes.fk::route_specs_update_native_preview", "deploy/kernel-router/production-routes.fk::route_specs_delete_native_preview"]
);

