# anything-arrives-trace.form -- translation as traceable contact
#
# Companion to docs/vision-kb/concepts/lc-anything-arrives-room.md.
#
# The point of this file is intentionally small: describe the trace
# shape that lets an arbitrary stream become knowable without forcing a
# fixed symbol at the doorway. A stream arrives; an observer pays to
# look; recipes make contact; cells change; refinement keeps the next
# question alive.

# ---------------------------------------------------------------------
# Part 1 -- trace shape
# ---------------------------------------------------------------------

form anything_arrives_trace_shape = {
    input_stream:       ~String,
    carrier:            ~String,       # audio | code | prose | csv | gesture | silence | ...
    observer_pressure:  [~String],     # what became noticeable before a label settled
    recipes:            [~String],     # provisional contact recipes
    cells_affected:     [~String],     # where the stream touched the body
    observer_cost:      ~String,       # attention / compute / risk / exposure
    trace:              [~String],     # path of contact becoming visible
    refinement:         ~String,       # next smaller question
    output:             ~String,       # not verdict; current lantern
};

defn anything_arrives_trace(
    input_stream,
    carrier,
    observer_pressure,
    recipes,
    cells_affected,
    observer_cost,
    trace,
    refinement,
    output
) =
    anything_arrives_trace_shape {
        input_stream:      input_stream,
        carrier:           carrier,
        observer_pressure: observer_pressure,
        recipes:           recipes,
        cells_affected:    cells_affected,
        observer_cost:     observer_cost,
        trace:             trace,
        refinement:        refinement,
        output:            output,
    };

# ---------------------------------------------------------------------
# Part 2 -- example traces
# ---------------------------------------------------------------------

defn georgian_song_trace = anything_arrives_trace(
    "livestreamed song in Georgian, untranslated",
    "audio",
    [
        "phrase returns every eighteen seconds",
        "vocal strain rises on the return",
        "breath breaks in the same place",
    ],
    [
        "lament-pattern",
        "recurrence-before-lexicon",
        "prosody-as-pressure",
    ],
    ["return", "breath", "threshold", "loss"],
    "low compute, medium interpretive risk; lexical translation deferred",
    [
        "audio moved from unknown-language to repeated-return",
        "return moved from timing feature to grief-shaped pressure",
        "words remain unopened while recurrence carries the first contact",
    ],
    "ask what recurrence is doing before translating the words",
    "this stream is making grief-shaped recurrence available"
);

defn code_diff_trace = anything_arrives_trace(
    "three config settings and one retry-loop change",
    "code",
    [
        "small file surface",
        "retry behavior touches paid provider path",
        "failure mode changes under uncertainty",
    ],
    [
        "resilience",
        "cost-control",
        "routing-pressure",
    ],
    ["failure-recovery", "provider-routing", "attention-budget"],
    "medium review cost; money-path risk requires exact proof",
    [
        "diff moved from config update to pressure valve",
        "retry moved from local behavior to spending behavior",
        "provider route became the affected cell",
    ],
    "prove one cheap route and one escalation route before claiming routing behavior",
    "this diff changes how uncertainty behaves when it gets expensive"
);

