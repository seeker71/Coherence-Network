# ---------------------------------------------------------------------
# Part 4 -- operating rule
# ---------------------------------------------------------------------

defn translation_rule(trace) =
    [
        "do not ask first what the stream means",
        "ask what it touched",
        "ask which recipe made contact",
        "ask which cells changed",
        "ask what the observer paid",
        "leave the next question smaller",
    ];

defn play_deck_traces() = [
    georgian_song_trace,
    code_diff_trace,
    door_city_trace,
    failed_payment_trace,
    publish_hesitation_trace,
    silence_trace,
    unnamed_color_trace,
    skipped_field_trace,
    laptop_fan_trace,
    ladder_without_rungs_trace,
];

defn io_carrier_traces() = [
    program_wellness_trace,
    story_api_trace,
    visual_frame_trace,
    audio_prosody_trace,
    api_usage_readiness_trace,
    local_archive_io_trace,
];

defn physical_io_care_traces() = [
    camera_legibility_trace,
    microphone_pause_trace,
    speaker_gentle_return_trace,
    wearable_kind_schedule_trace,
    power_network_care_trace,
];
