# ---------------------------------------------------------------------
# Part 3 -- local resource transaction shape
# ---------------------------------------------------------------------

form local_resource_transaction_shape = {
    resource:            ~String,      # file | command | api | audio | image | db-row | ...
    carrier:             ~String,
    access_mode:         ~String,      # sense | influence | both
    permission_boundary: ~String,      # allowed surface and privacy boundary
    sense:               [~String],    # what was observed
    influence:           [~String],    # what was changed, if anything
    before_state:        [~String],
    after_state:         [~String],
    observer_cost:       ~String,
    cells_affected:      [~String],
    trace:               [~String],
    output:              ~String,
};

defn local_resource_transaction(
    resource,
    carrier,
    access_mode,
    permission_boundary,
    sense,
    influence,
    before_state,
    after_state,
    observer_cost,
    cells_affected,
    trace,
    output
) =
    local_resource_transaction_shape {
        resource:            resource,
        carrier:             carrier,
        access_mode:         access_mode,
        permission_boundary: permission_boundary,
        sense:               sense,
        influence:           influence,
        before_state:        before_state,
        after_state:         after_state,
        observer_cost:       observer_cost,
        cells_affected:      cells_affected,
        trace:               trace,
        output:              output,
    };

defn program_wellness_trace = local_resource_transaction(
    "python3 scripts/wellness_check.py",
    "program-run",
    "sense",
    "repo-local read of body state; no artifact mutation",
    [
        "stdout names strained circulation",
        "silent organ count is zero",
        "exit code reports whether sensing completed",
    ],
    [],
    ["body state unknown to this observer"],
    ["body state cached as wellness reading"],
    "low compute, medium attention; interpretation follows the machine reading",
    ["proprioception", "circulation", "source-map", "witness-trace"],
    [
        "command moved from utility to sense organ",
        "stdout moved from text to body-state carrier",
        "exit code bounded the claim",
    ],
    "the body is breathing everywhere, but some organs are carrying heat"
);

