# Coherence Web — copy to .env.local
# API base URL (no trailing slash)
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional compatibility alias used by scripts (kept equal to NEXT_PUBLIC_API_URL):
API_URL=http://localhost:8000
# Production (use your public API domain):
# NEXT_PUBLIC_API_URL=https://api.coherencycoin.com
