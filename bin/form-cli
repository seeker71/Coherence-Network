#!/usr/bin/env bash
# form-cli — the one door into the Form-native organism.
#
# Everything routes through here: ask a question (answered local-first, grounded
# in the body's recipes/specs/concepts and any local docs you index), see your own
# open gaps, close one offline with a local oracle, review your own thinking
# against an oracle, run the self-guided agent loop, or evaluate a Form expression
# directly on the kernel. Local-first by design — a remote oracle (incl. Claude via
# `claude -p`) is consulted only to review, never required to answer.
set -euo pipefail
# resolve through symlinks — the installer links this onto PATH (~/.local/bin),
# so BASH_SOURCE is the symlink; follow it to the real file in the cloned repo.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  d="$(cd -P "$(dirname "$src")" && pwd)"; src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$d/$src";; esac
done
ROOT="$(cd -P "$(dirname "$src")/.." && pwd)"
RAG="$ROOT/scripts/form_cli_rag.py"

python_bridge() {
  if [ -x "$ROOT/api/.venv/bin/python" ]; then
    printf '%s\n' "$ROOT/api/.venv/bin/python"
  elif [ -x "$ROOT/api/.venv/Scripts/python.exe" ]; then
    printf '%s\n' "$ROOT/api/.venv/Scripts/python.exe"
  else
    command -v python3
  fi
}

ensure_native_cli() {
  if ! native_cli="$(bash "$ROOT/scripts/ensure_form_cli_native.sh" --print-path 2>/dev/null)"; then
    echo "form-cli: native carrier refresh/verification failed" >&2
    return 3
  fi
  if [ ! -x "$native_cli" ]; then
    echo "form-cli: native binary unavailable; run scripts/ensure_form_cli_native.sh" >&2
    return 3
  fi
  printf '%s\n' "$native_cli"
}

native_send() {
  b="$(ensure_native_cli)" || exit "$?"
  # One command followed by EOF has no synthetic quit result. Callers that need
  # byte-exact answer payloads use native_send_file, never command substitution.
  (cd "${HOME:-$ROOT}" && printf '%s\n' "$1" | "$b")
}

native_send_file() {
  command="$1"
  destination="$2"
  b="$(ensure_native_cli)" || return "$?"
  (cd "${HOME:-$ROOT}" && printf '%s\n' "$command" | "$b" >"$destination")
}

usage() {
  cat <<'EOF'
form-cli — the one door (local-first, Form-native)

  form-cli                          show this help; default requests use form-cli ask
  form-cli -p "<question>"          one-shot print mode, same Form-native carrier as ask
  form-cli repl                     native fkwu form-cli REPL

  form-cli ask "<question>"
        default ask path: Form-native local-only staged RAG through the c-bootstrapped
        fkwu binary; no hidden HTTP/Ollama/subscription fallback
  form-cli ask+ "<question>" [-m LOCAL] [-j JUDGE] [--remote "claude -p"] [--judge-gate] [--timeout N]
        explicit escalating ask: local-first, then the four-way-proven sufficiency gate
        (form-cli-sufficiency.fk via form-cli-ask-gate.fk) escalates to the
        subscription oracle when local is not enough. Sovereignty-first by default
        (a usable local answer stands; a local failure escalates); --judge-gate adds
        the judge model as the content scorer — claude-code quality at its latency.
        Prints a live trust row per query to stderr (path / grounded / freq / suffic —
        native vs rented); pipe the answer with 2>/dev/null to drop the row
  form-cli stats
        dashboard: learning · models · tools · tool->native · local/remote oracle
        (counts read from the body's records; stats by form-cli-stats.fk, four-way)
  form-cli train [hid epochs lr]
        train the native tool-use predictor on the real agent corpus (M4 Max GPU),
        caching its held-out scores for `form-cli stats` tool->native
  form-cli learn [hid epochs lr]
        ONE motion (the continuous-learning step): grow the corpus from this machine's
        Claude Code sessions, then retrain the predictor on the GROWN corpus — always
        re-featurizes, so "more samples" actually reach the model (no stale cache)
  form-cli shadow [N] [model]
        SHADOW MODE: replay N real captured agent turns through the native lane and
        score its tool-prediction against what the agent actually did (vs baseline)
        — watch how form-cli would have handled real work, without it being live
  form-cli index [INDEX_PATH]
        resolve the full corpus into substrate REF+CTOR identities, then heal
        the typed searchable index; refuses to replace it if resolution fails
  form-cli search "<query>"
        Form-native grounded retrieval through the native form-cli grounded verb
  form-cli rag-ask "<question>" [-k N] [-m MODEL]
        retiring Python bridge for the old vector RAG lane; explicit only
  form-cli rag-status
        native receipt for the healed index/query staging lane
  form-cli synthesis-status
        receipt for the fkwu+Metal model lane: grounded decoded answer binding,
        what is still missing, and why full real GGUF generation remains pending
  form-cli final-observations
        one wide model-lane convergence receipt: every observed component, every
        remaining bridge, and the strict blocker for full real GGUF generation
  form-cli ask-staged-model-call "<question>" [RECEIPT_JSON]
        local fkwu+Metal model-call witness used by ask after a native RAG miss;
        no HTTP/Ollama, decoded grounded answer bound without full GGUF token generation
  form-cli land [--merge] [--settle-deploy]
        land the current worktree branch through the Form-owned current-branch
        landing plan (current-branch-landing.fk); git/GitHub/deploy effects are
        explicit host passthrough while fsh host-effect coverage grows
  form-cli model-gap-receipt [OUT_DIR_OR_JSON] [GGUF_PATH]
        observed receipt for tokenizer, full GGUF map, autoregressive loop,
        sampler, final-observations, and ask-staged model-call binding; proves
        what is local and names the one wide blocker
  form-cli gguf-tensor-slice-math <MANIFEST>
        native fkwu receipt: read one content-addressed real GGUF tensor byte
        slice through form-cli and run Q6_K Form math over it
  form-cli gguf-tensor-set-cell <MANIFEST>
        native fkwu receipt: read a required real GGUF tensor-set byte-window
        manifest through form-cli and verify every row's content hash in Form
  form-cli gguf-semantic-token-cell <MANIFEST>
        native fkwu receipt: read one real GGUF tokenizer string row through
        form-cli, select it with Form argmax over receipt logits, and emit the
        decoded token text without claiming full model logits
  form-cli gguf-fullwidth-logits-cell <MANIFEST>
        native fkwu receipt: walk every real GGUF token-embedding row through
        Form Q6_K dot4 projection, select the full-width argmax, and decode it
  form-cli roadmap
        list the floor->north-star steps (roadmap.fk) and the next one to build
  form-cli asm "<C>" [--ir|--opt|--x86|--passes]
        ask LLVM offline how it lowers/optimizes — clang emits the arm64 asm, IR,
        opt-delta, other targets, or per-pass pipeline (the lowering teacher)
  form-cli gaps
        walk the body's open gaps (ideas/specs/capabilities), offline-closable tally
  form-cli close "<name>" "<spec>" "<assert>" "<expected>" [oracle]
        let a LOCAL oracle draft the missing recipe; the kernel validates it
  form-cli review [N] [native] [inner-judge] [oracle] [tol]
        the body answers; an inner judge + an oracle review it; the gap is measured
  form-cli run "<task>" [oracle] [max-steps]
        the self-guided agent loop (tool prediction + body memory in the prompt)
  form-cli eval "<form-expression>"
        evaluate a Form expression on the kernel, e.g. form-cli eval '(add 20 22)'
  form-cli ensure [--install]
        check (and with --install, fetch) the oracles form-cli needs — decided by
        oracle-ensure.fk on the kernel, installed via host-exec
  form-cli preflight
        air-gap readiness check (kernel, oracles, body on disk, offline loop, memory)

Models are local (ollama): coder, qwen2.5:72b, deepseek-r1:32b, llama3.2:3b.
EOF
}

run_native_cli() {
  out="$(native_send "$1")"
  if [ -z "$out" ]; then
    echo "form-cli: native grounded lookup returned no result; run form-cli index after T_flat is available" >&2
    exit 4
  fi
  printf '%s\n' "$out"
}

model_status() {
  out="$(native_send "synthesis-status")"
  receipt="${HOME:-$ROOT}/.coherence-network/ask-staged-model-call/current-receipt.json"
  printf '%s\n' "$out"
  printf '%s\n' "ask-staged-model-call-receipt:$receipt"
}

ask_native_local() {
  source_query_file=""
  if [ "${1:-}" = "--query-file" ]; then
    source_query_file="${2:-}"
    [ -f "$source_query_file" ] && [ -s "$source_query_file" ] || {
      echo "form-cli ask: staged query file is missing or empty" >&2
      exit 2
    }
    shift 2
  else
    q="$*"
    [ -n "$q" ] || { echo "usage: form-cli ask '<question>'" >&2; exit 2; }
  fi
  home="${HOME:-$ROOT}"
  request_dir="$home/.coherence-network/rag-requests"
  if [ -L "$request_dir" ] || ! mkdir -p "$request_dir" || \
     ! chmod 700 "$request_dir"; then
    echo "form-cli ask: cannot create $request_dir" >&2
    exit 3
  fi
  capture_dir="$(mktemp -d)" || {
    echo "form-cli ask: cannot create byte-exact capture directory" >&2
    exit 3
  }
  query_reservation="$(mktemp "$request_dir/req_XXXXXXXX")" || {
    echo "form-cli ask: cannot reserve invocation-owned request" >&2
    exit 3
  }
  query_file="${query_reservation}.query"
  if [ -e "$query_file" ] || ! mv "$query_reservation" "$query_file"; then
    rm -f "$query_reservation"
    echo "form-cli ask: cannot name invocation-owned request" >&2
    exit 3
  fi
  request_id="$(basename "$query_file" .query)"
  receipt_file="$request_dir/$request_id.receipt"
  cleanup_ask_native_local() {
    rm -rf "$capture_dir"
    rm -f "$query_file" "$receipt_file" "$receipt_file.consuming"
  }
  trap cleanup_ask_native_local EXIT
  trap 'exit 129' HUP
  trap 'exit 130' INT
  trap 'exit 143' TERM
  if [ -n "$source_query_file" ]; then
    cp "$source_query_file" "$query_file"
  else
    printf '%s' "$q" >"$query_file"
  fi || {
    echo "form-cli ask: cannot stage invocation-owned RAG query" >&2
    exit 3
  }
  py="$(python_bridge)"
  native_source="$(ensure_native_cli)" || exit "$?"
  native_source_digest="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$native_source")"
  index="$home/.coherence-network/rag-index/index.jsonl"
  run_offline_setup() {
    setup_log="$capture_dir/offline-setup.log"
    if ! "$ROOT/scripts/form_first_offline_setup.sh" >"$setup_log" 2>&1; then
      echo "form-cli ask: grounded substrate/index bootstrap failed" >&2
      sed 's/^/  /' "$setup_log" >&2
      return 1
    fi
  }
  if ! "$py" "$RAG" validate-current --index "$index" >/dev/null 2>&1; then
    run_offline_setup || exit 3
  fi
  native_capture="$capture_dir/form-cli"
  cp "$native_source" "$native_capture" || {
    echo "form-cli ask: cannot capture immutable native carrier" >&2
    exit 3
  }
  chmod 500 "$native_capture"
  captured_digest="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$native_capture")"
  source_digest_after="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$native_source")"
  if [ "$native_source_digest" != "$captured_digest" ] || \
     [ "$native_source_digest" != "$source_digest_after" ] || \
     ! "$py" "$RAG" validate-current --index "$index" >/dev/null 2>&1; then
    echo "form-cli ask: native carrier/index identity changed during capture" >&2
    exit 3
  fi
  ask_native_send_file() {
    captured_command="$1"
    captured_destination="$2"
    if ! (cd "$home" && printf '%s\n' "$captured_command" | \
      "$native_capture" >"$captured_destination"); then
      return 1
    fi
    digest_now="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$native_capture")"
    [ "$digest_now" = "$captured_digest" ]
  }
  ask_out="$capture_dir/ask-staged.out"
  trace_out="$capture_dir/ask-staged-trace.out"
  query_key="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$query_file")" || {
    echo "form-cli ask: query digest failed" >&2
    exit 3
  }
  receipt="none|none|none|none|none|none|$query_key|0|0|none|none|none|none|none|0|0|none|none"
  attempt=1
  while [ "$attempt" -le 2 ]; do
    ask_native_send_file "ask-request $request_id" "$ask_out" || {
      echo "form-cli: native staged ask failed" >&2
      exit 4
    }
    if [ ! -s "$ask_out" ]; then
      echo "form-cli: native staged ask returned no result" >&2
      exit 4
    fi
    IFS= read -r first_line <"$ask_out" || true
    first_line="${first_line%$'\r'}"
    node_id=""
    if [[ "$first_line" =~ ^grounded:(@[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
      node_id="${BASH_REMATCH[1]}"
    fi
    if [ -z "$node_id" ]; then
      break
    fi
    if "$py" "$RAG" trace-receipt "$node_id" --index "$index" \
        --query-file "$query_file" --request-id "$request_id" \
        >"$receipt_file" 2>/dev/null; then
      IFS= read -r verified_receipt <"$receipt_file" || true
      if [ -n "${verified_receipt:-}" ]; then
        receipt="$verified_receipt"
        break
      fi
    fi
    if [ "$attempt" -eq 1 ]; then
      run_offline_setup || exit 3
      source_digest_retry="$("$py" -c 'import hashlib,sys; print(hashlib.sha256(open(sys.argv[1], "rb").read()).hexdigest())' "$native_source")"
      if [ "$source_digest_retry" != "$captured_digest" ] || \
         ! "$py" "$RAG" validate-current --index "$index" >/dev/null 2>&1; then
        echo "form-cli ask: retry reconciliation changed carrier identity" >&2
        exit 3
      fi
      attempt=2
      continue
    fi
    echo "form-cli ask: exact persisted grounding could not be reconciled" >&2
    exit 5
  done
  printf '%s\n' "$receipt" >"$receipt_file" || {
    echo "form-cli ask: cannot stage invocation-owned grounding receipt" >&2
    exit 3
  }
  ask_native_send_file "ask-request-trace $request_id" "$trace_out" || {
    echo "form-cli ask: native trust gate failed" >&2
    exit 5
  }
  IFS= read -r trust_line <"$trace_out" || true
  trust_line="${trust_line%$'\r'}"
  if [ -z "${trust_line:-}" ] || [[ "$trust_line" != trust\ \ * ]]; then
    echo "form-cli ask: native trust gate returned no valid trace" >&2
    exit 5
  fi
  if [ -n "$node_id" ]; then
    # A cryptographically grounded local hit is useful even when frequency or
    # sufficiency correctly keeps the overall decision at partial/escalate.
    # Observed callers enforce the stronger all-four-axis row explicitly.
    if [[ "$trust_line" != trust\ \ path:native\ \ grounded:yes\ \ * ]]; then
      echo "form-cli ask: native grounding attestation failed" >&2
      exit 5
    fi
  elif [[ "$trust_line" != trust\ \ path:rented\ \ grounded:no\ \ * ]]; then
    echo "form-cli ask: native miss trust shape is inconsistent" >&2
    exit 5
  fi
  printf '%s\n' "$trust_line" >&2
  tail -n +2 "$trace_out"
}

cmd="${1:-}"; shift 2>/dev/null || true
case "$cmd" in
  "")        usage ;;
  help|-h|--help) usage ;;
  repl)      b="$(ensure_native_cli)" || exit "$?"; cd "${HOME:-$ROOT}" && exec "$b" ;;
  -p|--print) ask_native_local "$@" ;;  # one-shot print mode uses the local fkwu staged ask carrier
  -*)        exec bash "$ROOT/scripts/form_cli_ask.sh" "$cmd" "$@" ;; # ask flags (-m/-j/--remote/...) -> Form-native ask carrier
  ask)       ask_native_local "$@" ;;  # default ask is local fkwu staged RAG only
  ask-file)  ask_native_local --query-file "${1:-}" ;;
  ask-staged-model-call) exec bash "$ROOT/scripts/form_cli_ask_staged_model_call.sh" "$@" ;;
  ask+)      exec bash "$ROOT/scripts/form_cli_ask.sh" "$@" ;;  # body is form-cli-ask.fk, run by the kernel
  grounded)  run_native_cli "grounded $*" ;;
  rag-status) run_native_cli "rag-status" ;;
  synthesis-status|model-status) model_status ;;
  final-observations|model-convergence) run_native_cli "final-observations" ;;
  gguf-tensor-slice-math)
    [ -n "${1:-}" ] || { echo "usage: form-cli gguf-tensor-slice-math <manifest-path>" >&2; exit 2; }
    run_native_cli "gguf-tensor-slice-math $1" ;;
  gguf-tensor-set-cell)
    [ -n "${1:-}" ] || { echo "usage: form-cli gguf-tensor-set-cell <manifest-path>" >&2; exit 2; }
    run_native_cli "gguf-tensor-set-cell $1" ;;
  gguf-semantic-token-cell)
    [ -n "${1:-}" ] || { echo "usage: form-cli gguf-semantic-token-cell <manifest-path>" >&2; exit 2; }
    run_native_cli "gguf-semantic-token-cell $1" ;;
  gguf-fullwidth-logits-cell)
    [ -n "${1:-}" ] || { echo "usage: form-cli gguf-fullwidth-logits-cell <manifest-path>" >&2; exit 2; }
    run_native_cli "gguf-fullwidth-logits-cell $1" ;;
  model-gap-receipt) exec bash "$ROOT/scripts/validate_form_cli_model_lane_gap_receipts.sh" "$@" ;;
  land)      exec bash "$ROOT/scripts/land_current_branch.sh" "$@" ;;
  rag-ask)   ask_native_local "$@" ;;
  do)        exec bash "$ROOT/scripts/form_cli_agent.sh" "$@" ;;  # tiered agent loop (local-first, escalate)
  stats)     exec python3 "$ROOT/scripts/form_cli_stats.py" "$@" ;;
  train)     exec bash "$ROOT/scripts/agent_tooluse_train.sh" "$@" ;;
  learn)     exec bash "$ROOT/scripts/form_cli_learn.sh" "$@" ;;
  gold)      exec bash "$ROOT/scripts/form_cli_gold.sh" "$@" ;;  # record a human freq-reading (verdict + named boundary) into the gold catalog
  shadow)    exec env FORM_CLI_CORPUS="${FORM_CLI_CORPUS:-$HOME/.coherence-network/form-cli-corpus/corpus.jsonl}" \
                  bash "$ROOT/scripts/form_cli_replay.sh" "$@" ;;
  search)    run_native_cli "grounded $*" ;;
  index)
    py="$(python_bridge 2>/dev/null || true)"
    [ -n "$py" ] || {
      echo "form-cli index: verified substrate resolver unavailable (python3 missing)" >&2
      exit 3
    }
    "$py" "$ROOT/scripts/coh_substrate.py" bootstrap || exit "$?"
    ensure_native_cli >/dev/null || exit "$?"
    if [ "$#" -gt 0 ]; then
      exec "$py" "$RAG" heal --index "$1"
    fi
    exec "$py" "$RAG" heal ;;
  roadmap)   exec bash "$ROOT/scripts/form_cli_roadmap.sh" "$@" ;;
  asm)       exec bash "$ROOT/scripts/form_cli_asm.sh" "$@" ;;
  gaps)      exec bash "$ROOT/scripts/form_cli_gaps.sh" "$@" ;;
  close)     exec bash "$ROOT/scripts/form_cli_close_gap.sh" "$@" ;;
  close-next) exec bash "$ROOT/scripts/form_cli_close_next.sh" "$@" ;;
  review)    exec bash "$ROOT/scripts/form_cli_self_review.sh" "$@" ;;
  run)       exec bash "$ROOT/scripts/form_native_run.sh" "$@" ;;
  ensure)    exec bash "$ROOT/scripts/form_cli_ensure.sh" "$@" ;;
  preflight) exec bash "$ROOT/scripts/form_cli_preflight.sh" "$@" ;;
  eval)
    [ -n "${1:-}" ] || { echo "usage: form-cli eval '<form-expression>'" >&2; exit 2; }
    tf="$(mktemp "${TMPDIR:-/tmp}/form-cli-eval.XXXXXXXX")"
    printf '%s\n' "$1" > "$tf"
    out="$(bash "$ROOT/scripts/fkwu_run.sh" --src "$tf")"
    rc=$?
    rm -f "$tf"
    printf '%s\n' "$out" | sed '/^null$/d' | tail -1
    exit "$rc" ;;
  *) usage ;;
esac
